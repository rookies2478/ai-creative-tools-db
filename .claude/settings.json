{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "effortLevel": "low",
  "includeGitInstructions": false,
  "respectGitignore": true,
  "permissions": {
    "deny": [
      "Read(./node_modules/**)",
      "Read(./dist/**)",
      "Read(./.astro/**)",
      "Read(./coverage/**)",
      "Read(./.git/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./package-lock.json)",
      "Read(./pnpm-lock.yaml)",
      "Read(./yarn.lock)",
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ]
  }
}
