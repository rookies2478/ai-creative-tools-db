  .tdp-x .tdp-sample-img{display:block;width:100%;height:auto;object-fit:cover;}
  .tdp-x .tdp-sample-cap{padding:14px 18px;display:flex;flex-direction:column;gap:6px;}
  .tdp-x .tdp-sample-label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--brand-ink);background:var(--brand-tint);padding:2px 8px;border-radius:999px;width:fit-content;}
  .tdp-x .tdp-sample-note{font-size:11.5px;line-height:1.75;color:var(--muted);margin:0;}
</style>

<script>
  // JSは [data-tdp] 配下のみ操作（既存サイトに干渉しない）
  (function () {
    document.querySelectorAll('[data-tdp]').forEach(function (root) {
      // FAQ 開閉（1つ開くと他は閉じる）
      var faq = root.querySelector('.tdp-faq');
      if (faq) {
        faq.addEventListener('click', function (e) {
          var btn = (e.target as HTMLElement).closest('.tdp-faqq'); if (!btn) return;
          var item = btn.closest('.tdp-faqitem'); if (!item) return;
          var open = item.getAttribute('aria-expanded') === 'true';
          faq.querySelectorAll('.tdp-faqitem').forEach(function (it) {
            it.setAttribute('aria-expanded', 'false');
            var a = it.querySelector('.tdp-faqa') as HTMLElement | null; if (a) a.style.maxHeight = '';
          });
          if (!open) {
            item.setAttribute('aria-expanded', 'true');
            var a = item.querySelector('.tdp-faqa') as HTMLElement | null; if (a) a.style.maxHeight = a.scrollHeight + 'px';
          }
        });
      }
      // スクロールで表示アニメ（prefers-reduced-motion 尊重・8秒フェイルセーフ）
      var reveals = Array.prototype.slice.call(root.querySelectorAll('.reveal'));
      if (!reveals.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) { reveals.forEach(function (el) { el.classList.add('in'); }); return; }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) { if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); } });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach(function (el) { io.observe(el); });
      setTimeout(function () { reveals.forEach(function (el) { el.classList.add('in'); }); }, 8000);
    });
  })();
</script>
