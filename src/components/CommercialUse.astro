  { q:'YouTubeサムネや広告バナーに使う場合の注意点は？', a:'収益化を伴うYouTubeチャンネルのサムネイルや広告バナーは、商用利用と判断される場合があります。プランごとの商用利用条件・透かし条件・クレジット表記義務を各ツールの公式規約で事前に確認することを推奨します。透かしなしツールは<a href="/conditions/no-watermark/">透かしなしツール</a>ページで確認できます。本記事は法的助言ではありません。' },
  { q:'商用利用前に確認すべき公式情報は何ですか？', a:'主に以下の3点を確認することを推奨します：①利用規約（Terms of Service）における商用利用の定義と許可範囲、②プランごとの料金ページにおける商用利用の記載、③コンテンツポリシー（禁止コンテンツ・用途）。各ツールの<a href="/tools/">詳細ページ</a>には公式情報へのリンクを掲載しています。本記事は法的助言ではありません。' },
  { q:'「条件あり」と表示されていれば商用利用できますか？', a:'利用できる場合がありますが、プラン・用途・生成コンテンツの内容・利用規約によって条件が変わります。実際に使う前に、必ず各ツールの最新公式情報をご確認ください。' },
];

const {
  headingHtml = '商用利用条件を確認しやすい<span class="hl">AIツール</span>比較',
  lead = 'AI画像・動画生成ツールを仕事や副業で使う場合は、商用利用条件を事前に確認することが重要です。このページでは公式情報をもとに商用利用ステータスを整理しています。用途・プラン・生成内容によって条件は異なる場合があり、規約はツール側の判断で随時変更されることがあります。',
  notice = '商用利用の可否は、プラン・生成内容・利用目的・各ツールの規約によって変わる場合があります。掲載情報は調査時点の内容であり、公式情報をもとにした一般的な整理です。実務利用前には必ず各ツールの公式サイト・最新の利用規約をご確認ください。本サイトの内容は法的助言ではありません。',
  toolsBase = '/tools/',
  stats = [
    { n:'24', label:'対象ツール' },
    { n:'5',  label:'ステータス段階' },
    { n:'7',  label:'よくある質問' },
  ],
  points = DEFAULT_POINTS,
  tools = DEFAULT_TOOLS,
  faqs = DEFAULT_FAQS,
  related = [
    { label:'無料で使えるツール', href:'/conditions/free/' },
    { label:'日本語対応ツール', href:'/conditions/japanese/' },
    { label:'透かしなしツール', href:'/conditions/no-watermark/' },
    { label:'商用利用・著作権ガイド', href:'/guides/commercial-use-copyright/' },
    { label:'AI動画生成ツール一覧', href:'/categories/video-generation/' },
    { label:'全ツール比較表', href:'/comparisons/', solid:true },
    { label:'すべてのツールを見る', href:'/tools/', solid:true },
    { label:'AI画像生成ツール一覧', href:'/categories/image-generation/', solid:true },
  ] as RelatedLink[],
} = Astro.props;

const relStd = related.filter((r) => !r.solid);
const relSolid = related.filter((r) => r.solid);

/* ○/△/× の判定（列ごとの意味づけ） */
function mark(field: 'free' | 'ja' | 'wm', val: string) {
  let cls = 'cond', ch = '△';
  if (field === 'free') { if (val === 'あり') { cls = 'yes'; ch = '○'; } else if (val === 'なし') { cls = 'no'; ch = '×'; } }
  else if (field === 'ja') { if (val === '対応') { cls = 'yes'; ch = '○'; } else if (val === '非対応') { cls = 'no'; ch = '×'; } }
  else if (field === 'wm') { if (val === 'なし') { cls = 'yes'; ch = '○'; } else if (val === 'あり') { cls = 'no'; ch = '×'; } }
  return { cls, ch };
}
const ini = (t: Tool) => t.initial ?? t.name.charAt(0);
const presentStatuses = Array.from(new Set(tools.map((t) => t.commercial)));
const filterChips: { st: Status | 'all'; label: string }[] = [
  { st: 'all', label: 'すべて' },
  ...(['ok','paid','limited','no','unknown'] as Status[]).filter((s) => presentStatuses.includes(s)).map((s) => ({ st: s, label: STATUS[s].label })),
];
---

<div class="cu-x" data-cu>

  <!-- ===== 見出し ===== -->
  <header class="cu-head">
    <span class="eyebrow">Commercial Use</span>
    <h1 set:html={headingHtml}></h1>
    <p class="lead">{lead}</p>
    {stats.length > 0 && (
      <div class="stats">
        {stats.map((s) => (<div class="stat"><span class="n">{s.n}</span><span class="t">{s.label}</span></div>))}
      </div>
    )}
  </header>

  <!-- ===== 注意 ===== -->
  {notice && (
    <div class="notice">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p><b>ご利用前の注意：</b>{notice}</p>
    </div>
  )}

  <!-- ===== ステータスの見方 ===== -->
  <section class="cu-sec">
    <div class="sec-head">
      <span class="eyebrow">Status legend</span>
      <h2>商用利用ステータスの見方</h2>
      <p>各ツールの商用利用欄は、確認時点の公式情報をもとに以下の5段階で整理しています。「公式案内あり」であっても、用途・プラン・生成内容によって条件が変わる場合があります。商用利用を前提にする場合は、最新の公式規約をご確認ください。</p>
    </div>
    <div class="status-grid">
      <div class="status-card ok"><span class="st ok"><span class="d"></span>公式案内あり <small>ok</small></span><p>公式規約で商用利用が案内されています。ただしプラン・用途・生成内容によって条件が変わる場合があります。</p></div>
      <div class="status-card paid"><span class="st paid"><span class="d"></span>有料プラン向け <small>paid-only</small></span><p>有料プランで商用利用が案内されています。無料プランでは商用利用に制限がある場合があります。</p></div>
      <div class="status-card limited"><span class="st limited"><span class="d"></span>条件あり <small>limited</small></span><p>一定の条件のもとで商用利用が案内されています。用途・生成内容・プランによって異なります。</p></div>
      <div class="status-card no"><span class="st no"><span class="d"></span>非対応 <small>no</small></span><p>公式規約で商用利用が禁止または制限されている、または非対応の可能性があるツールです。</p></div>
      <div class="status-card unknown"><span class="st unknown"><span class="d"></span>要確認 <small>unknown</small></span><p>公式情報から商用利用条件を確認できていません。利用前に必ず公式規約をご確認ください。</p></div>
    </div>
  </section>

  <!-- ===== 選ぶ際のポイント ===== -->
  <section class="cu-sec band">
    <div class="sec-head">
      <span class="eyebrow">Checkpoints</span>
      <h2>商用利用ツールを選ぶ際のポイント</h2>
      <p>「商用利用OK」と案内されていても、生成内容やプランによって条件は変わります。実務で使う前に確認しておきたい観点を整理しました。</p>
    </div>
    <ol class="points">
      {points.map((p, i) => (
        <li><span class="pn">{String(i + 1).padStart(2, '0')}</span><span class="pt"><b>{p.title}：</b><span set:html={p.body}></span></span></li>
      ))}
    </ol>
  </section>

  <!-- ===== 対象ツール一覧 ===== -->
  <section class="cu-sec">
    <div class="sec-head">
      <span class="eyebrow">Tool index</span>
      <h2>対象ツール一覧</h2>
      <p>確認時点で{tools.length}件。「条件あり」はプラン・用途・生成内容によって条件が変わる場合があります。ステータスで絞り込み、各ツールの詳細ページで注意事項を確認してください。</p>
    </div>

    <div class="statusbar">
      <span class="sb-label">Status</span>
      <div class="sfilter">
        {filterChips.map((c) => (
          <button class="schip" data-st={c.st} aria-pressed={c.st === 'all' ? 'true' : 'false'}>
            {c.st !== 'all' && (<span class="d" data-tone={c.st}></span>)}{c.label}
          </button>
        ))}
      </div>
      <div class="statusbar-right">
        <label class="cu-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20.5 20.5-4-4"/></svg>
          <input type="search" data-search placeholder="ツール名で検索" aria-label="ツール名で検索" />
        </label>
        <span class="cu-count" data-count><b>{tools.length}</b> 件</span>
      </div>
    </div>

    <div class="cu-table-wrap">
      <table class="cu">
        <thead>
          <tr><th class="col-tool">ツール</th><th>無料枠</th><th>日本語</th><th>商用利用</th><th>透かしなし</th><th>詳細</th></tr>
        </thead>
        <tbody>
          {tools.map((t) => {
            const f = mark('free', t.free), j = mark('ja', t.ja), w = mark('wm', t.wm);
            return (
              <tr data-name={t.name.toLowerCase()} data-st={t.commercial}>
                <td><div class="cu-tool"><span class="b">{ini(t)}</span><span class="nm">{t.name}</span></div></td>
                <td><span class={`mk ${f.cls}`} title={t.free}>{f.ch}</span></td>
                <td><span class={`mk ${j.cls}`} title={t.ja}>{j.ch}</span></td>
                <td><span class={`st ${STATUS[t.commercial].code === 'paid-only' ? 'paid' : t.commercial}`}><span class="d"></span>{STATUS[t.commercial].label}</span></td>
                <td><span class={`mk ${w.cls}`} title={t.wm}>{w.ch}</span></td>
                <td><a class="cu-detail" href={`${toolsBase}${t.slug}/`}>詳細 →</a></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    <div class="cu-legend">
      <span class="li"><span class="mk yes">○</span>あり / 対応 / 透かしなし</span>
      <span class="li"><span class="mk cond">△</span>要確認</span>
      <span class="li"><span class="mk no">×</span>なし / 透かしあり</span>
      <span class="cu-legend-sp">商用利用列はステータス（ok / paid-only / limited）で表示</span>
    </div>
    <p class="note">※ 値は確認日時点の参考値です。無料枠・商用利用・対応状況はプランや用途により異なる場合があります。透かしなし列は「透かしなし＝○」で評価しています。最新情報は必ず公式サイトでご確認ください。</p>
  </section>

  <!-- ===== 各ツールの注意点 ===== -->
  <section class="cu-sec band">
    <div class="sec-head">
      <span class="eyebrow">Per-tool notes</span>
      <h2>各ツールの商用利用に関する注意点</h2>
      <p>確認時点の公式情報をもとにした整理です。条件・規約は変更される可能性があります。上の絞り込みは表とこのカードの両方に反映されます。実務利用前に必ず公式情報をご確認ください。</p>
    </div>
    <div class="note-grid">
      {tools.map((t) => (
        <article class="note-card" data-name={t.name.toLowerCase()} data-st={t.commercial}>
          <div class="nc-head">
            <span class="nc-b">{ini(t)}</span>
            <a class="nc-name" href={`${toolsBase}${t.slug}/`}>{t.name}</a>
            <span class={`st ${t.commercial}`}><span class="d"></span>{STATUS[t.commercial].label}</span>
          </div>
          <p>{t.note}</p>
        </article>
      ))}
      <div class="cu-empty" hidden>条件に一致するツールはありません。</div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="cu-sec">
    <div class="sec-head">
      <span class="eyebrow">FAQ</span>
      <h2>よくある質問</h2>
      <p>商用利用できるツールの選び方や、プラン・著作権・用途ごとの確認ポイントについてお答えします。</p>
    </div>
    <div class="faq-list">
      {faqs.map((f) => (
        <div class="faq-item" aria-expanded="false">
          <button class="faq-q"><span class="qm">Q</span>{f.q}<span class="ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner" set:html={f.a}></div></div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 関連ページ ===== -->
  <section class="cu-sec">
    <div class="finder">
      <h2>関連ページ</h2>
      <p class="finder-lead">他の条件や比較表・ガイドからも、商用利用に適したツールを探せます。</p>
      <div class="taglinks">{relStd.map((r) => (<a class="taglink" href={r.href}><span class="ld"></span>{r.label}</a>))}</div>
      <div class="taglinks row">{relSolid.map((r) => (<a class="taglink solid" href={r.href}>{r.label}</a>))}</div>
    </div>
  </section>

</div>

<style>
  .cu-x{
    --paper:#F4F4EE; --surface:#FFFFFF; --surface-2:#FAFAF6;
    --ink:#16181D; --ink-soft:#3A3E47; --muted:#6A7180; --faint:#98A0AD;
    --line:#E3E2D9; --line-strong:#D2D1C6;
    --brand:#4B3FE4; --on-brand:#FFFFFF; --brand-tint:#ECEBFB; --brand-ink:#2E25A6;
    --video:#E1543A; --video-tint:#FCEDE9; --image:#15897F; --image-tint:#E2F1EF;
    --ok:#1E8A4C; --ok-tint:#E6F3EC; --warn:#A06A09; --warn-tint:#F8EFD9; --na:#6A7180; --na-tint:#EFEFEA;
    --radius:14px; --radius-lg:22px;
    --shadow-sm:0 1px 2px rgba(20,22,28,.04),0 1px 3px rgba(20,22,28,.05);
    --f-jp:"Zen Kaku Gothic New","Noto Sans JP",system-ui,sans-serif;
    --f-latin:"Space Grotesk",system-ui,sans-serif;
    --f-mono:"Space Mono",ui-monospace,monospace;
    --ease:cubic-bezier(.22,.61,.36,1);
    display:block; color:var(--ink); font-family:"Noto Sans JP",system-ui,sans-serif; line-height:1.7;
  }
  .cu-x .eyebrow{font-family:var(--f-latin);font-size:12px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--muted);display:inline-flex;align-items:center;gap:10px;}
  .cu-x .eyebrow::before{content:"";width:22px;height:2px;border-radius:2px;background:var(--brand);}
  .cu-x h1,.cu-x h2,.cu-x h3,.cu-x h4{font-family:var(--f-jp);font-weight:700;line-height:1.32;color:var(--ink);}

  /* 見出し */
  .cu-x .cu-head h1{font-size:clamp(27px,3.6vw,42px);font-weight:900;letter-spacing:-.01em;line-height:1.24;margin:16px 0;max-width:820px;text-wrap:balance;}
  .cu-x .cu-head h1 .hl{color:var(--brand-ink);position:relative;}
  .cu-x .cu-head h1 .hl::after{content:"";position:absolute;left:0;right:0;bottom:.08em;height:.26em;background:color-mix(in srgb,var(--brand) 18%,transparent);z-index:-1;border-radius:2px;}
  .cu-x .lead{font-size:15.5px;color:var(--ink-soft);max-width:680px;}
  .cu-x .stats{display:flex;flex-wrap:wrap;gap:10px 26px;margin-top:24px;}
  .cu-x .stat{display:flex;align-items:baseline;gap:8px;}
  .cu-x .stat + .stat{padding-left:26px;border-left:1px solid var(--line);}
  .cu-x .stat .n{font-family:var(--f-latin);font-weight:700;font-size:24px;color:var(--ink);line-height:1;}
  .cu-x .stat .t{font-size:12.5px;color:var(--muted);white-space:nowrap;}

  /* 注意バナー */
  .cu-x .notice{display:flex;align-items:flex-start;gap:12px;background:var(--warn-tint);border:1px solid color-mix(in srgb,var(--warn) 28%,var(--line));border-radius:var(--radius);padding:16px 20px;margin-top:26px;}
  .cu-x .notice svg{width:18px;height:18px;color:var(--warn);flex:none;margin-top:2px;}
  .cu-x .notice p{font-size:13px;color:var(--ink-soft);line-height:1.7;}
  .cu-x .notice b{color:var(--warn);font-weight:700;}

  /* セクション */
  .cu-x .cu-sec{padding:60px 0;}
  .cu-x .cu-sec.band{background:var(--surface-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);
    /* 全幅バンド化したい場合は有効化（最大幅1200px前提・違えば数値調整）:
    margin-left:calc(50% - 50vw); margin-right:calc(50% - 50vw); padding-left:max(28px,calc(50vw - 600px)); padding-right:max(28px,calc(50vw - 600px)); */
  }
  .cu-x .sec-head{max-width:720px;margin-bottom:36px;}
  .cu-x .sec-head h2{font-size:clamp(24px,3vw,34px);font-weight:900;letter-spacing:-.005em;margin:16px 0 12px;}
  .cu-x .sec-head p{color:var(--muted);font-size:15px;}

  /* ステータスバッジ */
  .cu-x .st{display:inline-flex;align-items:center;gap:6px;flex:none;font-family:var(--f-jp);font-weight:700;font-size:12px;line-height:1.2;padding:5px 11px;border-radius:999px;white-space:nowrap;}
  .cu-x .st .d{width:6px;height:6px;border-radius:50%;background:currentColor;}
  .cu-x .st small{opacity:.7;font-weight:600;}
  .cu-x .st.ok{color:var(--ok);background:var(--ok-tint);}
  .cu-x .st.paid{color:var(--brand-ink);background:var(--brand-tint);}
  .cu-x .st.limited{color:var(--warn);background:var(--warn-tint);}
  .cu-x .st.no{color:var(--video);background:var(--video-tint);}
  .cu-x .st.unknown{color:var(--na);background:var(--na-tint);}

  /* ステータス凡例 */
  .cu-x .status-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;}
  .cu-x .status-card{border:1px solid var(--line);border-radius:var(--radius);background:var(--surface);padding:20px 20px 18px;display:flex;flex-direction:column;gap:10px;}
  .cu-x .status-card .st{align-self:flex-start;}
  .cu-x .status-card p{font-size:12.5px;color:var(--muted);line-height:1.7;}
  .cu-x .status-card.ok{border-top:3px solid var(--ok);}
  .cu-x .status-card.paid{border-top:3px solid var(--brand);}
  .cu-x .status-card.limited{border-top:3px solid var(--warn);}
  .cu-x .status-card.no{border-top:3px solid var(--video);}
  .cu-x .status-card.unknown{border-top:3px solid var(--na);}

  /* 選び方ポイント */
  .cu-x .points{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius-lg);padding:30px 32px;list-style:none;display:flex;flex-direction:column;gap:20px;margin:0;}
  .cu-x .points li{display:grid;grid-template-columns:auto 1fr;gap:14px;align-items:start;}
  .cu-x .points .pn{font-family:var(--f-latin);font-weight:700;font-size:13px;color:var(--brand);background:var(--brand-tint);width:28px;height:28px;border-radius:8px;display:grid;place-items:center;flex:none;}
  .cu-x .points .pt{font-size:14px;color:var(--ink-soft);line-height:1.7;}
  .cu-x .points .pt b{color:var(--ink);font-weight:700;}
  .cu-x .points .pt a{color:var(--brand-ink);font-weight:600;}

  /* フィルタ */
  .cu-x .statusbar{display:flex;align-items:center;gap:16px 22px;flex-wrap:wrap;margin-bottom:22px;}
  .cu-x .sb-label{font-family:var(--f-latin);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--faint);flex:none;}
  .cu-x .sfilter{display:flex;flex-wrap:wrap;gap:8px;}
  .cu-x .schip{font-family:var(--f-jp);font-weight:600;font-size:13px;padding:8px 15px;border-radius:999px;background:var(--surface);border:1px solid var(--line-strong);color:var(--ink-soft);cursor:pointer;display:inline-flex;align-items:center;gap:8px;white-space:nowrap;transition:transform .16s var(--ease),background .16s,border-color .16s,color .16s;}
  .cu-x .schip:hover{border-color:var(--brand);color:var(--brand-ink);}
  .cu-x .schip .d{width:8px;height:8px;border-radius:50%;background:currentColor;opacity:.8;}
  .cu-x .schip .d[data-tone="ok"]{color:var(--ok);}
  .cu-x .schip .d[data-tone="paid"]{color:var(--brand);}
  .cu-x .schip .d[data-tone="limited"]{color:var(--warn);}
  .cu-x .schip .d[data-tone="no"]{color:var(--video);}
  .cu-x .schip .d[data-tone="unknown"]{color:var(--na);}
  .cu-x .schip[aria-pressed="true"]{background:var(--ink);color:var(--surface);border-color:var(--ink);}
  .cu-x .schip[data-st="ok"][aria-pressed="true"]{background:var(--ok);border-color:var(--ok);color:#fff;}
  .cu-x .schip[data-st="paid"][aria-pressed="true"]{background:var(--brand);border-color:var(--brand);color:#fff;}
  .cu-x .schip[data-st="limited"][aria-pressed="true"]{background:var(--warn);border-color:var(--warn);color:#fff;}
  .cu-x .schip[aria-pressed="true"] .d{color:#fff;}
  .cu-x .statusbar-right{margin-left:auto;display:flex;align-items:center;gap:14px;}
  .cu-x .cu-search{display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--line-strong);border-radius:999px;padding:8px 15px;transition:border-color .15s,box-shadow .15s;}
  .cu-x .cu-search:focus-within{border-color:var(--brand);box-shadow:0 0 0 3px color-mix(in srgb,var(--brand) 14%,transparent);}
  .cu-x .cu-search svg{width:15px;height:15px;color:var(--muted);flex:none;}
  .cu-x .cu-search input{border:none;background:none;outline:none;font-family:var(--f-jp);font-size:14px;color:var(--ink);width:150px;}
  .cu-x .cu-search input::placeholder{color:var(--faint);}
  .cu-x .cu-count{font-family:var(--f-mono);font-size:12.5px;color:var(--muted);white-space:nowrap;}
  .cu-x .cu-count b{color:var(--ink);font-weight:700;}

  /* 表 */
  .cu-x .cu-table-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:var(--radius);background:var(--surface);box-shadow:var(--shadow-sm);}
  .cu-x table.cu{width:100%;border-collapse:collapse;min-width:720px;}
  .cu-x table.cu thead th{font-family:var(--f-jp);font-weight:700;font-size:12.5px;color:var(--ink-soft);background:var(--surface-2);padding:15px 16px;text-align:center;border-bottom:1px solid var(--line);white-space:nowrap;}
  .cu-x table.cu thead th.col-tool{text-align:left;}
  .cu-x table.cu tbody td{padding:13px 16px;text-align:center;border-bottom:1px solid var(--line);vertical-align:middle;}
  .cu-x table.cu tbody tr:last-child td{border-bottom:none;}
  .cu-x table.cu tbody tr{transition:background .12s,opacity .18s;}
  .cu-x table.cu tbody tr:hover{background:var(--surface-2);}
  .cu-x table.cu tbody tr.hide{display:none;}
  .cu-x .cu-tool{display:flex;align-items:center;gap:11px;text-align:left;}
  .cu-x .cu-tool .b{width:30px;height:30px;border-radius:8px;display:grid;place-items:center;background:var(--brand-tint);color:var(--brand-ink);font-family:var(--f-latin);font-weight:700;font-size:13px;flex:none;}
  .cu-x .cu-tool .nm{font-family:var(--f-jp);font-weight:700;font-size:14.5px;color:var(--ink);white-space:nowrap;}
  .cu-x .cu-tool .st{justify-self:center;}
  .cu-x .mk{display:inline-flex;width:24px;height:24px;border-radius:50%;align-items:center;justify-content:center;font-size:13px;font-weight:700;}
  .cu-x .mk.yes{background:var(--ok-tint);color:var(--ok);}
  .cu-x .mk.cond{background:var(--warn-tint);color:var(--warn);}
  .cu-x .mk.no{background:var(--na-tint);color:var(--na);}
  .cu-x table.cu td .st{margin:0 auto;}
  .cu-x .cu-detail{font-family:var(--f-jp);font-weight:700;font-size:12.5px;color:var(--brand-ink);text-decoration:none;white-space:nowrap;}
  .cu-x .cu-detail:hover{text-decoration:underline;text-underline-offset:3px;}
  .cu-x .cu-legend{display:flex;gap:18px;flex-wrap:wrap;margin-top:14px;font-size:12.5px;color:var(--muted);align-items:center;}
  .cu-x .cu-legend .li{display:inline-flex;align-items:center;gap:7px;}
  .cu-x .cu-legend .mk{width:20px;height:20px;font-size:11px;}
  .cu-x .cu-legend-sp{margin-left:auto;font-family:var(--f-mono);font-size:11px;}
  .cu-x .note{margin-top:18px;font-size:12.5px;color:var(--faint);line-height:1.7;}

  /* 注意点カード */
  .cu-x .note-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;}
  .cu-x .note-card{border:1px solid var(--line);border-radius:var(--radius);background:var(--surface);padding:22px 24px;display:flex;flex-direction:column;gap:12px;}
  .cu-x .note-card.hide{display:none;}
  .cu-x .note-card .nc-head{display:flex;align-items:center;gap:12px;}
  .cu-x .note-card .nc-b{width:34px;height:34px;border-radius:9px;display:grid;place-items:center;background:var(--brand-tint);color:var(--brand-ink);font-family:var(--f-latin);font-weight:700;font-size:15px;flex:none;}
  .cu-x .note-card .nc-name{font-family:var(--f-jp);font-weight:700;font-size:15.5px;color:var(--ink);line-height:1.25;text-decoration:none;}
  .cu-x .note-card .nc-name:hover{color:var(--brand-ink);}
  .cu-x .note-card .st{margin-left:auto;}
  .cu-x .note-card p{font-size:13px;color:var(--ink-soft);line-height:1.78;}
  .cu-x .cu-empty{grid-column:1 / -1;padding:40px;text-align:center;color:var(--muted);font-size:14px;border:1px dashed var(--line-strong);border-radius:var(--radius);background:var(--surface-2);}

  /* FAQ */
  .cu-x .faq-list{max-width:860px;}
  .cu-x .faq-item{border-bottom:1px solid var(--line);}
  .cu-x .faq-item:first-child{border-top:1px solid var(--line);}
  .cu-x .faq-q{width:100%;text-align:left;background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:16px;padding:24px 6px;font-family:var(--f-jp);font-weight:700;font-size:16.5px;color:var(--ink);}
  .cu-x .faq-q .qm{font-family:var(--f-latin);color:var(--brand);font-size:16px;flex:none;}
  .cu-x .faq-q .ind{margin-left:auto;flex:none;width:24px;height:24px;display:grid;place-items:center;transition:transform .3s var(--ease);color:var(--muted);}
  .cu-x .faq-q .ind svg{width:18px;height:18px;}
  .cu-x .faq-item[aria-expanded="true"] .faq-q .ind{transform:rotate(45deg);color:var(--brand);}
  .cu-x .faq-a{max-height:0;overflow:hidden;transition:max-height .35s var(--ease);}
  .cu-x .faq-a-inner{padding:0 6px 26px 46px;color:var(--ink-soft);font-size:14.5px;line-height:1.8;}
  .cu-x .faq-a-inner a{color:var(--brand-ink);font-weight:600;}

  /* 関連ページ */
  .cu-x .finder{background:var(--surface-2);border:1px solid var(--line);border-radius:var(--radius-lg);padding:34px 34px 30px;}
  .cu-x .finder h2{font-size:clamp(20px,2.4vw,26px);margin-bottom:6px;}
  .cu-x .finder-lead{color:var(--muted);font-size:14px;margin-bottom:22px;}
  .cu-x .taglinks{display:flex;flex-wrap:wrap;gap:10px;}
  .cu-x .taglink{font-family:var(--f-jp);font-weight:600;font-size:13.5px;padding:9px 16px;border-radius:999px;background:var(--surface);border:1px solid var(--line-strong);color:var(--ink-soft);text-decoration:none;display:inline-flex;align-items:center;gap:7px;white-space:nowrap;transition:transform .16s var(--ease),background .16s,border-color .16s,color .16s;}
  .cu-x .taglink:hover{border-color:var(--brand);color:var(--brand-ink);background:var(--brand-tint);transform:translateY(-1px);}
  .cu-x .taglink .ld{width:7px;height:7px;border-radius:50%;background:var(--brand);flex:none;}
  .cu-x .taglinks.row{margin-top:16px;padding-top:18px;border-top:1px dashed var(--line-strong);}
  .cu-x .taglink.solid{background:var(--ink);color:var(--surface);border-color:var(--ink);}
  .cu-x .taglink.solid:hover{background:var(--brand);border-color:var(--brand);color:var(--on-brand);}

  /* reveal（任意・JSが付与） */
  @media (prefers-reduced-motion: no-preference){
    .cu-x .reveal{opacity:0;transform:translateY(18px);transition:opacity .6s var(--ease),transform .6s var(--ease);}
    .cu-x .reveal.in{opacity:1;transform:none;}
  }

  @media (max-width:980px){
    .cu-x .status-grid{grid-template-columns:repeat(2,1fr);}
    .cu-x .note-grid{grid-template-columns:1fr;}
  }
  @media (max-width:720px){
    .cu-x .status-grid{grid-template-columns:1fr;}
    .cu-x .statusbar-right{margin-left:0;width:100%;}
    .cu-x .cu-search{flex:1;}
    .cu-x .cu-search input{width:100%;}
    .cu-x .stat + .stat{padding-left:0;border-left:none;}
  }
  @media (prefers-reduced-motion: reduce){
    .cu-x *{animation-duration:.001ms !important;transition-duration:.001ms !important;}
    .cu-x .reveal{opacity:1 !important;transform:none !important;}
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-cu]').forEach((root) => {
    const tbody = root.querySelector<HTMLElement>('table.cu tbody')!;
    const rows = Array.from(tbody.querySelectorAll<HTMLElement>('tr'));
    const cards = Array.from(root.querySelectorAll<HTMLElement>('.note-card'));
    const chips = Array.from(root.querySelectorAll<HTMLElement>('.schip'));
    const search = root.querySelector<HTMLInputElement>('[data-search]')!;
    const countEl = root.querySelector<HTMLElement>('[data-count]')!;
    const empty = root.querySelector<HTMLElement>('.cu-empty')!;
    let activeSt = 'all';

    const matches = (name: string, st: string) => {
      const q = (search.value || '').trim().toLowerCase();
      if (q && name.indexOf(q) === -1) return false;
      if (activeSt !== 'all' && st !== activeSt) return false;
      return true;
    };

    const apply = () => {
      let n = 0;
      rows.forEach((r) => {
        const ok = matches(r.getAttribute('data-name') || '', r.getAttribute('data-st') || '');
        r.classList.toggle('hide', !ok);
        if (ok) n++;
      });
      cards.forEach((c) => {
        const ok = matches(c.getAttribute('data-name') || '', c.getAttribute('data-st') || '');
        c.classList.toggle('hide', !ok);
      });
      empty.hidden = n !== 0;
      countEl.innerHTML = '<b>' + n + '</b> 件';
    };

    chips.forEach((chip) => chip.addEventListener('click', () => {
      activeSt = chip.getAttribute('data-st') || 'all';
      chips.forEach((c) => c.setAttribute('aria-pressed', c === chip ? 'true' : 'false'));
      apply();
    }));
    search.addEventListener('input', apply);
    apply();

    /* FAQ アコーディオン */
    const items = Array.from(root.querySelectorAll<HTMLElement>('.faq-item'));
    items.forEach((item) => {
      const q = item.querySelector<HTMLElement>('.faq-q')!;
      const a = item.querySelector<HTMLElement>('.faq-a')!;
      q.addEventListener('click', () => {
        const open = item.getAttribute('aria-expanded') === 'true';
        items.forEach((o) => { o.setAttribute('aria-expanded', 'false'); o.querySelector<HTMLElement>('.faq-a')!.style.maxHeight = ''; });
        if (!open) { item.setAttribute('aria-expanded', 'true'); a.style.maxHeight = a.scrollHeight + 'px'; }
      });
    });

    /* スクロール表示アニメーション */
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const targets = Array.from(root.querySelectorAll<HTMLElement>('.sec-head, .status-grid, .points, .cu-table-wrap, .note-grid, .faq-list, .finder'));
    targets.forEach((el) => el.classList.add('reveal'));
    if (reduce || !('IntersectionObserver' in window)) {
      targets.forEach((el) => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.06, rootMargin: '0px 0px -4% 0px' });
      targets.forEach((el) => io.observe(el));
      window.setTimeout(() => targets.forEach((el) => el.classList.add('in')), 8000);
    }
  });
</script>
