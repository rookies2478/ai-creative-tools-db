---
/**
 * CommercialUse.astro
 * 「商用利用条件を確認しやすいAIツール比較」条件ページ本文
 *  — ステータス凡例 ＋ 選び方ポイント ＋ 対象ツール表（○/△/× ＋ ステータスバッジ）
 *    ＋ ステータス絞り込み＋検索 ＋ 各ツールの注意点カード ＋ FAQ ＋ 関連ページ
 *
 * 安全性（Tailwind / 既存ページを壊さない）:
 *  - スタイルは Astro scoped <style>。全セレクタを .cu-x 配下に限定 → 漏れない。
 *  - CSS変数は :root でなく .cu-x 上に定義 → 既存トークンと非衝突。
 *  - 素のリセット（* / body / table 等の global 指定）なし → Tailwind preflight 非干渉。
 *  - 表・カードは SSR で描画。JS は [data-cu] 配下のみ操作（絞り込み/検索/FAQ/表示アニメ）。
 *
 * ヘッダー / フッター / パンくず は既存 Layout 側のものを使う想定。
 */
export type Status = 'ok' | 'paid' | 'limited' | 'no' | 'unknown';
export interface Tool {
  name: string;
  slug: string;            // /tools/{slug}/ へのリンクに使用
  initial?: string;        // バッジの頭文字（省略時は name の先頭）
  free: string;            // 'あり' | 'なし' | '要確認'
  ja: string;              // '対応' | '非対応' | '要確認'
  wm: string;              // 透かし: 'なし' | 'あり' | '要確認'（列は「透かしなし＝○」評価）
  commercial: Status;      // 商用利用ステータス
  note: string;            // 各ツールの注意点（プレーンテキスト）
}
export interface Faq { q: string; a: string; } // a は HTML 文字列可
export interface RelatedLink { label: string; href: string; solid?: boolean; }
export interface Point { title: string; body: string; } // body は HTML 文字列可

export interface Props {
  headingHtml?: string;
  lead?: string;
  notice?: string;
  toolsBase?: string;          // 詳細リンクのベース（既定 '/tools/'）
  stats?: { n: string; label: string }[];
  points?: Point[];
  tools?: Tool[];
  faqs?: Faq[];
  related?: RelatedLink[];
}

const STATUS: Record<Status, { label: string; code: string }> = {
  ok:      { label: '公式案内あり',  code: 'ok' },
  paid:    { label: '有料プラン向け', code: 'paid-only' },
  limited: { label: '条件あり',      code: 'limited' },
  no:      { label: '非対応',        code: 'no' },
  unknown: { label: '要確認',        code: 'unknown' },
};

