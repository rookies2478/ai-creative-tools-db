const DEFAULT_FAQS: Faq[] = [
  { q:'商用利用できるAI画像生成ツールはどう選べばいいですか？', a:'まず公式規約で商用利用がどう案内されているかを確認し、次にプラン（無料・有料）、透かしの有無、用途ごとの制限を確認するのが基本の流れです。用途やプランによって条件が異なる可能性があるため、実務利用前には必ず最新の公式規約をご確認ください。本記事は法的助言ではありません。' },
