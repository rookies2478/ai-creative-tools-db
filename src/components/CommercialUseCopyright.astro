/* =========================================================
   CommercialUseCopyright.astro
   ガイド：/guides/commercial-use-copyright/ の記事本文
   （結論 ＋ 免責 ＋ 確認ポイント ＋ ツール別条件表 ＋ 無料プラン注意表
    ＋ 透かし表 ＋ チェックリスト ＋ FAQ ＋ 注意事項/鮮度 ＋ 関連）

   既存サイト（Tailwind）を壊さない設計:
   - すべてのセレクタを .cuc-x 配下に限定（スタイル漏れなし）
   - CSS変数は :root ではなく .cuc-x 上に定義（既存トークン非衝突）
   - 素のリセット（*{} / body{} / table{} 等）を含めない（preflight非干渉）
   - SSRで描画。JSは [data-cuc] 配下のみ操作（FAQ開閉・表示アニメ）

   ヘッダー・フッター・パンくずは既存 Layout 側のものを使用してください。
   このコンポーネントは記事本文だけを描画します。
   ========================================================= */

export type CondStatus = 'cond' | 'plan';

export interface Stat { n: string; label: string; }
export interface Point { title: string; body: string; }      // body はプレーンテキスト
export interface ToolRow {
  name: string;
  slug?: string;
  initial?: string;
  status?: CondStatus;     // 条件表のみ使用
  statusLabel?: string;    // 例: '〇 条件あり' / '△ プランによる'
  note: string;            // 主な注意点 / 制限 / 透かし条件
  date?: string;           // 確認日（条件表のみ）
}
export interface CheckItem { html: string; }                  // html可（<b> 等）
export interface Faq { q: string; a: string; }                // a はHTML可
export interface RelatedLink { label: string; href: string; solid?: boolean; }
export interface ToolLink { name: string; slug: string; initial?: string; }

export interface Props {
  headingHtml?: string;
  lead?: string;
  checkedDate?: string;
  nextCheckDate?: string;
  stats?: Stat[];
  conclusionHtml?: string;       // <p> を含むHTML可
  disclaimer?: string;
  points?: Point[];
  imageTools?: ToolRow[];
  videoTools?: ToolRow[];
  freePlan?: ToolRow[];
  watermark?: ToolRow[];
  checklist?: CheckItem[];
  faqs?: Faq[];
  notes?: string[];
  freshnessHtml?: string;
  footnote?: string;
  related?: RelatedLink[];
  relatedSolid?: RelatedLink[];
  toolLinks?: ToolLink[];
  toolsBase?: string;            // 既定 /tools/ → /tools/{slug}/
}

