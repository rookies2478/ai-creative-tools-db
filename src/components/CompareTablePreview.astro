---
import type { CollectionEntry } from 'astro:content';

interface Props {
  tools: CollectionEntry<'tools'>[];
  limit?: number;
}

type FreePlan = boolean | 'limited' | 'unknown';
type FourState = 'yes' | 'no' | 'limited' | 'unknown';
type CommercialUse = 'ok' | 'paid-only' | 'limited' | 'no' | 'unknown';
type TriState = boolean | 'partial' | 'unknown';

const { tools, limit = 5 } = Astro.props;
const preview = tools.slice(0, limit);

function freeBadge(val: FreePlan) {
  if (val === true)  return { text: 'あり',   cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === false) return { text: 'なし',   cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
                     return { text: '要確認', cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
}

function cuBadge(val: CommercialUse) {
  if (val === 'ok') return { text: '案内あり', cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === 'no') return { text: '非対応',   cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
                    return { text: '要確認',   cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
}

function jpBadge(ui: TriState, prompt: TriState) {
  if (ui === true)                     return { text: '対応',   cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (ui === false && prompt === false) return { text: '非対応', cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
                                        return { text: '要確認', cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
}

function wmBadge(val: FourState) {
  if (val === 'no')  return { text: 'なし',   cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === 'yes') return { text: 'あり',   cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
                     return { text: '要確認', cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
}
---

<div class="overflow-x-auto">
  <table class="w-full min-w-[560px] border-collapse text-sm">
    <thead>
      <tr class="bg-blue-50/60 text-left text-[11px] font-bold uppercase tracking-wide text-slate-500 border-b border-slate-200">
        <th class="px-4 py-3 min-w-[120px]">ツール名</th>
        <th class="px-3 py-3">無料枠</th>
        <th class="px-3 py-3">日本語対応</th>
        <th class="px-3 py-3">商用利用条件</th>
        <th class="px-3 py-3">透かし</th>
        <th class="px-3 py-3 text-right">詳細</th>
      </tr>
    </thead>
    <tbody>
      {preview.map((tool, i) => {
        const fp = freeBadge(tool.data.freePlan);
        const cu = cuBadge(tool.data.commercialUse);
        const jp = jpBadge(tool.data.japaneseUi, tool.data.japanesePrompt);
        const wm = wmBadge(tool.data.watermark);
        return (
          <tr class={`border-b border-slate-100 transition hover:bg-slate-50 ${i % 2 === 1 ? 'bg-slate-50/50' : 'bg-white'}`}>
            <td class="px-4 py-3.5 font-semibold text-slate-900 text-sm">{tool.data.name}</td>
            <td class="px-3 py-3.5">
              <span class={`inline-flex rounded-full px-2 py-0.5 text-[11px] font-semibold ${fp.cls}`}>{fp.text}</span>
            </td>
            <td class="px-3 py-3.5">
              <span class={`inline-flex rounded-full px-2 py-0.5 text-[11px] font-semibold ${jp.cls}`}>{jp.text}</span>
            </td>
            <td class="px-3 py-3.5">
              <span class={`inline-flex rounded-full px-2 py-0.5 text-[11px] font-semibold ${cu.cls}`}>{cu.text}</span>
            </td>
            <td class="px-3 py-3.5">
              <span class={`inline-flex rounded-full px-2 py-0.5 text-[11px] font-semibold ${wm.cls}`}>{wm.text}</span>
            </td>
            <td class="px-3 py-3.5 text-right">
              <a href={`/tools/${tool.slug}/`} class="text-xs font-semibold text-blue-600 hover:underline">
                詳細 →
              </a>
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
  <div class="ctp-legend">
    <span class="ctp-li ctp-ok"><span class="ctp-ic">○</span>あり / 対応</span>
    <span class="ctp-li ctp-warn"><span class="ctp-ic">△</span>要確認</span>
    <span class="ctp-li ctp-na"><span class="ctp-ic">×</span>なし / 非対応</span>
  </div>
  <p class="ctp-note">※ 値は確認日時点の参考値です。無料枠・商用利用・対応状況はプランや用途により異なる場合があります。最新情報は必ず公式サイトでご確認ください。</p>
</div>

<style>
  .ctp-legend {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin: 14px 0 0;
    font-size: 11.5px;
    color: #6a7180;
    align-items: center;
  }
  .ctp-li {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .ctp-ic {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 10px;
    font-weight: 700;
  }
  .ctp-ok .ctp-ic   { background: #e6f3ec; color: #1e8a4c; }
  .ctp-warn .ctp-ic { background: #f8efd9; color: #a06a09; }
  .ctp-na .ctp-ic   { background: #efefea; color: #6a7180; }
  .ctp-note {
    margin: 8px 0 0;
    font-size: 11px;
    color: #98a0ad;
    line-height: 1.7;
  }
</style>
