  .cig-x .gtable thead th.h-image{color:var(--image);}
  .cig-x .gtable thead th.h-video{color:var(--video);}
  .cig-x .gtable thead th .hdot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:9px;vertical-align:middle;}
