  .cig-x .gtable-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:var(--radius);background:var(--surface);box-shadow:var(--shadow-sm);}
  .cig-x .gtable{width:100%;border-collapse:collapse;min-width:680px;}
  .cig-x .gtable th,.cig-x .gtable td{text-align:left;padding:18px 22px;border-bottom:1px solid var(--line);vertical-align:top;}
