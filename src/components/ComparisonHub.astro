---
/**
 * ComparisonHub.astro
 * 「AIツール比較記事一覧」ハブページ本文
 *  — 注意バナー ＋ どの比較記事を読む？（ルーター）＋ 比較記事カード（フラッグシップ＋一覧）＋ FAQ ＋ あわせて見る
 *
 * 安全性（Tailwind / 既存ページを壊さない）:
 *  - スタイルは Astro scoped <style>。全セレクタを .chub-x 配下に限定 → 漏れない。
 *  - CSS変数は :root でなく .chub-x 上に定義 → 既存トークンと非衝突。
 *  - 素のリセット（* / body / table 等の global 指定）なし → Tailwind preflight 非干渉。
 *  - JS は [data-chub] 配下のみ操作。複数設置も可。
 *
 * ヘッダー / フッター / パンくず は既存 Layout 側のものを使う想定。
 * このコンポーネントは <main> の中身（記事本文）だけを描画します。
 */
export interface Stat { n: string; label: string; tone?: 'image' | 'video'; }
export interface RouterLink { label: string; href: string; ghost?: boolean; }
export interface RouterRow { goal: string; links: RouterLink[]; }
export interface Featured { catLabel: string; title: string; desc: string; axes: string[]; href: string; }
export type CatTone = 'brand' | 'free' | 'video' | 'image';
export interface Article { tone: CatTone; catLabel: string; title: string; desc: string; href: string; }
export interface Faq { q: string; a: string; } // a は HTML 文字列可
export interface RelatedLink { label: string; href: string; solid?: boolean; }

export interface Props {
  headingHtml?: string;
  lead?: string;
  notice?: string;
  stats?: Stat[];
  router?: RouterRow[];
  featured?: Featured;
  articles?: Article[];
  faqs?: Faq[];
  related?: RelatedLink[];
}

const {
  headingHtml = 'AIツール<br><span class="hl">比較・選び方</span>ガイド',
  lead = 'AI画像生成・AI動画生成ツールを無料枠・商用利用条件・透かし・日本語対応などの観点で比較したページです。ツール選びに迷ったとき、まずここから目的に合った比較記事や比較表を探してみてください。',
  notice = '商用利用条件や著作権はツール・プラン・用途によって異なる場合があります。比較記事はあくまで参考情報です。掲載内容は確認時点のもので、最新情報や具体的な利用可否は必ず各公式サイトでご確認ください。本サイトは商用利用・著作権について断定せず、本記事群は法的助言ではありません。',
  stats = [
    { n:'12', label:'比較記事' },
    { n:'6', label:'画像生成ツール', tone:'image' },
    { n:'4', label:'動画生成ツール', tone:'video' },
    { n:'6', label:'比較観点' },
  ] as Stat[],
  router = [
    { goal:'AI画像生成とAI動画生成をまとめて比較したい', links:[{ label:'AI画像・動画生成ツール比較表', href:'/comparisons/ai-image-video-tools/' }] },
    { goal:'無料で使えるAI画像生成ツールを条件別に比較したい', links:[{ label:'無料AI画像生成ツール比較', href:'/comparisons/free-ai-image-generators/' }, { label:'無料で試せるツール一覧', href:'/conditions/free/', ghost:true }] },
    { goal:'AI動画生成でRunwayとKling AIを比較したい', links:[{ label:'Runway vs Kling AI', href:'/comparisons/runway-vs-kling-ai/' }] },
    { goal:'AI動画生成でRunwayとPikaを比較したい', links:[{ label:'Runway vs Pika', href:'/comparisons/runway-vs-pika/' }] },
    { goal:'InVideo AIとCapCut AIを比較したい', links:[{ label:'InVideo AI vs CapCut AI', href:'/comparisons/invideo-ai-vs-capcut-ai/' }] },
    { goal:'MidjourneyとLeonardo AIを比較したい', links:[{ label:'Midjourney vs Leonardo AI', href:'/comparisons/midjourney-vs-leonardo-ai/' }] },
    { goal:'MidjourneyとAdobe Fireflyを比較したい', links:[{ label:'Midjourney vs Adobe Firefly', href:'/comparisons/midjourney-vs-adobe-firefly/' }] },
    { goal:'Canva AIとAdobe Fireflyを比較したい', links:[{ label:'Canva AI vs Adobe Firefly', href:'/comparisons/canva-ai-vs-adobe-firefly/' }] },
    { goal:'EC・商品画像向けのAI画像生成ツールを比較したい', links:[{ label:'商品画像生成AIおすすめ比較', href:'/comparisons/ec-product-image-ai-tools/' }] },
  ] as RouterRow[],
  featured = {
    catLabel:'比較表 / 横断',
    title:'AI画像・動画生成ツール比較表',
    desc:'商用利用・無料枠・日本語対応・透かし・料金目安で、主要ツールを横並びで比較できます。まず全体像をつかみたいときの出発点です。',
    axes:['商用利用','無料枠','日本語対応','透かし','料金目安'],
    href:'/comparisons/ai-image-video-tools/',
  } as Featured,
  articles = [
    { tone:'free',  catLabel:'無料枠',   title:'無料AI画像生成ツール比較', desc:'無料枠・透かし・商用利用条件をまとめて確認できます。', href:'/comparisons/free-ai-image-generators/' },
    { tone:'video', catLabel:'動画生成', title:'Runway vs Kling AI', desc:'映像制作向け多機能かリアル寄り動画か、無料枠と商用条件を比較。', href:'/comparisons/runway-vs-kling-ai/' },
    { tone:'video', catLabel:'動画生成', title:'Runway vs Pika', desc:'料金・無料枠・商用利用・用途別の選び方を比較（動画生成）。', href:'/comparisons/runway-vs-pika/' },
    { tone:'video', catLabel:'動画生成', title:'InVideo AI vs CapCut AI', desc:'台本型動画自動生成かSNS動画編集かで選び方が異なる。', href:'/comparisons/invideo-ai-vs-capcut-ai/' },
    { tone:'image', catLabel:'画像生成', title:'Midjourney vs Leonardo AI', desc:'アート調ビジュアルかゲーム・イラスト特化か、無料枠と商用条件を比較。', href:'/comparisons/midjourney-vs-leonardo-ai/' },
    { tone:'image', catLabel:'画像生成', title:'Midjourney vs Adobe Firefly', desc:'商用利用・料金・日本語対応・用途の違いを比較。', href:'/comparisons/midjourney-vs-adobe-firefly/' },
    { tone:'image', catLabel:'画像生成', title:'DALL·E vs Midjourney', desc:'ChatGPT連携・画質・商用利用・用途の違いを比較。', href:'/comparisons/dalle-vs-midjourney/' },
    { tone:'image', catLabel:'画像生成', title:'Stable Diffusion vs Midjourney', desc:'無料利用・画質・商用利用・自由度の違いを比較。', href:'/comparisons/stable-diffusion-vs-midjourney/' },
    { tone:'image', catLabel:'画像生成', title:'Canva AI vs Adobe Firefly', desc:'デザイン制作に使いやすいAI画像生成ツールはどちらか比較。', href:'/comparisons/canva-ai-vs-adobe-firefly/' },
    { tone:'image', catLabel:'画像生成', title:'Adobe Firefly vs Microsoft Designer', desc:'商用利用・デザイン制作で選ぶAI画像生成ツールを比較。', href:'/comparisons/adobe-firefly-vs-microsoft-designer/' },
    { tone:'image', catLabel:'EC向け', title:'商品画像生成AIおすすめ比較', desc:'EC向けの商品画像生成AIを、背景差し替え型・テンプレート合成型・生成型で比較します。', href:'/comparisons/ec-product-image-ai-tools/' },
  ] as Article[],
  faqs = [
    { q:'どの比較記事から読めばよいですか？',
      a:'AI画像生成と<a href="/categories/video-generation/">AI動画生成</a>をまとめて見たい場合は<a href="/comparisons/ai-image-video-tools/">全ツール横断比較</a>が出発点になります。動画生成ならRunwayとPikaの比較、画像生成ならMidjourneyやAdobe Fireflyなどのツール別比較記事が参考になります。上の「どの比較記事を読む？」セクションも参照してください。' },
    { q:'無料ツールだけを比較したい場合はどこを見ればよいですか？',
      a:'無料枠のあるツールを条件別に探す場合は<a href="/conditions/free/">無料で試せるツール一覧</a>が参考になります。AI画像生成ツールに絞って詳しく比較したい場合は<a href="/comparisons/free-ai-image-generators/">無料AI画像生成ツール比較</a>も参照してください。' },
    { q:'比較記事の商用利用情報だけで判断できますか？',
      a:'商用利用条件はツール・プラン・用途によって異なる場合があります。比較記事はあくまで参考情報であり、判断の根拠には公式規約をご確認ください。本サイトは商用利用・著作権について断定しません。詳しくは<a href="/guides/commercial-use-copyright/">商用利用・著作権ガイド</a>もあわせて参照してください。' },
    { q:'比較表の○△×はどのように読めばよいですか？',
      a:'○は対応あり、△は条件付きまたは要確認、×は非対応の目安を示しています。ただしいずれもプランや用途・確認時点によって変わる場合があります。最終的な判断は各公式サイトの最新情報をご確認ください。' },
    { q:'無料枠はどの程度使えますか？',
      a:'無料枠の内容（クレジット数・生成可能枚数・有効期限）はツールやプランによって大きく異なります。また無料プランでは透かしが入る場合や、商用利用が制限される場合があります。詳しくは<a href="/comparisons/free-ai-image-generators/">無料AI画像生成ツール比較</a>や<a href="/conditions/free/">無料で試せるツール一覧</a>をご確認ください。' },
    { q:'商用利用条件はどこで確認すればよいですか？',
      a:'本サイトの比較情報は参考にとどめ、実際の商用利用前には必ず各公式の利用規約をご確認ください。プラン・用途・生成物の種類によって条件が異なる場合があります。<a href="/guides/commercial-use-copyright/">商用利用・著作権ガイド</a>も参照してください。' },
    { q:'AI動画生成とAI画像生成、どちらを選べばよいですか？',
      a:'静止画・イラスト・デザイン素材が目的であればAI画像生成ツール、映像や動きのあるコンテンツが目的であればAI動画生成ツールが向いています。まず<a href="/comparisons/ai-image-video-tools/">AI画像・動画生成ツール比較表</a>で全体像を確認するのが近道です。' },
  ] as Faq[],
  related = [
    { label:'無料で試せる', href:'/conditions/free/' },
    { label:'商用利用を確認', href:'/conditions/commercial-use/' },
    { label:'商用利用・著作権ガイド', href:'/guides/commercial-use-copyright/' },
    { label:'用途別記事一覧', href:'/use-cases/' },
    { label:'すべてのツール', href:'/tools/', solid:true },
    { label:'AI画像生成ツール一覧', href:'/categories/image-generation/', solid:true },
    { label:'AI動画生成ツール一覧', href:'/categories/video-generation/', solid:true },
  ] as RelatedLink[],
} = Astro.props;

const relStd = related.filter((r) => !r.solid);
const relSolid = related.filter((r) => r.solid);
const pad2 = (i: number) => String(i + 1).padStart(2, '0');
---

<div class="chub-x" data-chub>

  <!-- ===== 見出し ===== -->
  <header class="chub-head">
    <span class="eyebrow">Comparisons</span>
    <h1 set:html={headingHtml}></h1>
    <p class="lead">{lead}</p>
    {stats.length > 0 && (
      <div class="stats">
        {stats.map((s) => (
          <div class="stat"><span class={`n${s.tone ? ' ' + s.tone : ''}`}>{s.n}</span><span class="t">{s.label}</span></div>
        ))}
      </div>
    )}
  </header>

  <!-- ===== 注意 ===== -->
  {notice && (
    <div class="notice">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p><b>ご利用前に：</b>{notice}</p>
    </div>
  )}

  <!-- ===== このページで比較できること ===== -->
  <section class="chub-sec can-compare">
    <div class="sec-head">
      <span class="eyebrow">What you can compare</span>
      <h2>このページで比較できること</h2>
      <p>比較記事・比較表でカバーしている主なカテゴリと観点です。</p>
    </div>
    <div class="compare-chips-grid">
      <div class="compare-chip video">
        <span class="chip-icon">🎬</span>
        <div>
          <strong>AI動画生成ツール</strong>
          <p>Runway・Kling AI・Pika・InVideo AIなど主要ツールの料金・無料枠・商用条件を比較</p>
        </div>
      </div>
      <div class="compare-chip image">
        <span class="chip-icon">🖼</span>
        <div>
          <strong>AI画像生成ツール</strong>
          <p>Midjourney・DALL·E・Stable Diffusion・Adobe Fireflyなどを複数観点で比較</p>
        </div>
      </div>
      <div class="compare-chip free">
        <span class="chip-icon">🆓</span>
        <div>
          <strong>無料枠</strong>
          <p>クレジット数・期間制限・無料プランの制約（透かし・商用利用不可等）を確認</p>
        </div>
      </div>
      <div class="compare-chip neutral">
        <span class="chip-icon">💧</span>
        <div>
          <strong>透かし</strong>
          <p>無料プラン・有料プランそれぞれで透かしが入るかどうかの目安を確認</p>
        </div>
      </div>
      <div class="compare-chip neutral">
        <span class="chip-icon">🗾</span>
        <div>
          <strong>日本語対応</strong>
          <p>UI・プロンプト・サポートの日本語対応状況（プランや機能によって異なる場合あり）</p>
        </div>
      </div>
      <div class="compare-chip warn">
        <span class="chip-icon">📋</span>
        <div>
          <strong>商用利用条件の確認ポイント</strong>
          <p>プラン・用途ごとの条件の違いを整理。断定はせず、公式規約確認を推奨</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== どの比較記事を読む？ ===== -->
  <section class="chub-sec band">
    <div class="sec-head">
      <span class="eyebrow">Where to start</span>
      <h2>どの比較記事を読む？</h2>
      <p>「やりたいこと」から、最初に読むと近道になる比較記事を選びました。迷ったら上から順に確認してください。</p>
    </div>
    <div class="router">
      {router.map((row, i) => (
        <div class="router-row">
          <span class="goal"><span class="qn">{pad2(i)}</span>{row.goal}</span>
          <span class="links">
            {row.links.map((l) => (<a class={`go${l.ghost ? ' ghost' : ''}`} href={l.href}>{l.label} <span class="arr">→</span></a>))}
          </span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 比較記事 ===== -->
  <section class="chub-sec">
    <div class="sec-head">
      <span class="eyebrow">All articles</span>
      <h2>比較記事</h2>
      <p>テーマ別の比較記事一覧です。各記事は商用利用・料金・無料枠などの観点で、要確認ベースで整理しています。</p>
    </div>
    <div class="cmp-grid">
      <a class="feature-card" href={featured.href}>
        <div class="fc-body">
          <span class="cat-badge brand"><span class="d"></span>{featured.catLabel}</span>
          <h3>{featured.title}</h3>
          <p>{featured.desc}</p>
          <div class="fc-axes">{featured.axes.map((a) => (<span>{a}</span>))}</div>
          <span class="fc-cta">比較表を見る <span class="arr">→</span></span>
        </div>
        <div class="fc-visual">
          <div class="mhead"><span></span><span><span class="dot di"></span>画像</span><span><span class="dot dv"></span>動画</span></div>
          <div class="mr"><span class="lbl">無料プラン</span><span class="m ok">○</span><span class="m cond">△</span></div>
          <div class="mr"><span class="lbl">透かしなし</span><span class="m cond">△</span><span class="m cond">△</span></div>
          <div class="mr"><span class="lbl">日本語対応</span><span class="m ok">○</span><span class="m cond">△</span></div>
        </div>
      </a>
      {articles.map((a) => (
        <a class="cmp-card" href={a.href}>
          <span class={`cat-badge ${a.tone}`}><span class="d"></span>{a.catLabel}</span>
          <h3>{a.title}</h3>
          <p>{a.desc}</p>
          <span class="more">読む <span class="arr">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="chub-sec band">
    <div class="sec-head">
      <span class="eyebrow">FAQ</span>
      <h2>よくある質問</h2>
      <p>比較記事の読み方や、比較情報をどう判断に使うかについてお答えします。</p>
    </div>
    <div class="faq-list">
      {faqs.map((f) => (
        <div class="faq-item" aria-expanded="false">
          <button class="faq-q"><span class="qm">Q</span>{f.q}<span class="ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14"/></svg></span></button>
          <div class="faq-a"><div class="faq-a-inner" set:html={f.a}></div></div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== あわせて見る ===== -->
  <section class="chub-sec">
    <div class="finder">
      <h2>あわせて見る</h2>
      <p class="finder-lead">カテゴリ・条件・ガイドのページからも、目的に合うAIツールを探せます。</p>
      <div class="taglinks">{relStd.map((r) => (<a class="taglink" href={r.href}><span class="ld"></span>{r.label}</a>))}</div>
      <div class="taglinks row">{relSolid.map((r) => (<a class="taglink solid" href={r.href}>{r.label}</a>))}</div>
    </div>
  </section>

</div>

<style>
  .chub-x{
    --paper:#F4F4EE; --surface:#FFFFFF; --surface-2:#FAFAF6;
    --ink:#16181D; --ink-soft:#3A3E47; --muted:#6A7180; --faint:#98A0AD;
    --line:#E3E2D9; --line-strong:#D2D1C6;
    --brand:#4B3FE4; --on-brand:#FFFFFF; --brand-tint:#ECEBFB; --brand-ink:#2E25A6;
    --video:#E1543A; --video-tint:#FCEDE9; --image:#15897F; --image-tint:#E2F1EF;
    --ok:#1E8A4C; --ok-tint:#E6F3EC; --warn:#A06A09; --warn-tint:#F8EFD9;
    --radius:14px; --radius-lg:22px;
    --shadow-sm:0 1px 2px rgba(20,22,28,.04),0 1px 3px rgba(20,22,28,.05);
    --shadow-md:0 4px 14px rgba(20,22,28,.06),0 2px 6px rgba(20,22,28,.04);
    --shadow-lg:0 18px 50px -16px rgba(28,24,80,.22);
    --f-jp:"Zen Kaku Gothic New","Noto Sans JP",system-ui,sans-serif;
    --f-latin:"Space Grotesk",system-ui,sans-serif;
    --f-mono:"Space Mono",ui-monospace,monospace;
    --ease:cubic-bezier(.22,.61,.36,1);
    display:block; color:var(--ink); font-family:"Noto Sans JP",system-ui,sans-serif; line-height:1.7;
  }
  .chub-x .eyebrow{font-family:var(--f-latin);font-size:12px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--muted);display:inline-flex;align-items:center;gap:10px;}
  .chub-x .eyebrow::before{content:"";width:22px;height:2px;border-radius:2px;background:var(--brand);}
  .chub-x h1,.chub-x h2,.chub-x h3,.chub-x h4{font-family:var(--f-jp);font-weight:700;line-height:1.32;color:var(--ink);}

  /* 見出し */
  .chub-x .chub-head{margin-bottom:8px;}
  .chub-x .chub-head h1{font-size:clamp(27px,3.6vw,42px);font-weight:900;letter-spacing:-.01em;line-height:1.24;margin:16px 0;}
  .chub-x .chub-head h1 .hl{color:var(--brand-ink);position:relative;}
  .chub-x .chub-head h1 .hl::after{content:"";position:absolute;left:0;right:0;bottom:.08em;height:.26em;background:color-mix(in srgb,var(--brand) 18%,transparent);z-index:-1;border-radius:2px;}
  .chub-x .lead{font-size:15.5px;color:var(--ink-soft);max-width:660px;}
  .chub-x .stats{display:flex;flex-wrap:wrap;gap:10px 26px;margin-top:24px;}
  .chub-x .stat{display:flex;align-items:baseline;gap:8px;}
  .chub-x .stat + .stat{padding-left:26px;border-left:1px solid var(--line);}
  .chub-x .stat .n{font-family:var(--f-latin);font-weight:700;font-size:24px;color:var(--ink);line-height:1;}
  .chub-x .stat .n.image{color:var(--image);}
  .chub-x .stat .n.video{color:var(--video);}
  .chub-x .stat .t{font-size:12.5px;color:var(--muted);white-space:nowrap;}

  /* 注意バナー */
  .chub-x .notice{display:flex;align-items:flex-start;gap:12px;background:var(--warn-tint);border:1px solid color-mix(in srgb,var(--warn) 28%,var(--line));border-radius:var(--radius);padding:16px 20px;margin-top:26px;}
  .chub-x .notice svg{width:18px;height:18px;color:var(--warn);flex:none;margin-top:2px;}
  .chub-x .notice p{font-size:13px;color:var(--ink-soft);line-height:1.7;}
