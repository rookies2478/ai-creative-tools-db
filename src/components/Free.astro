---
/**
 * Free.astro
 * 「無料で使えるAIクリエイティブツール」条件ページ本文
 *  — 見出し ＋ 選び方カテゴリ ＋ 確認ポイント ＋ 用途別の選び分け
 *    ＋ 無料枠ツール一覧（無料プラン絞り込み＋検索） ＋ 商用利用前の注意点
 *    ＋ 関連ページ ＋ FAQ ＋ 免責事項
 *
 * 安全性（Tailwind / 既存ページを壊さない）:
 *  - スタイルは Astro scoped <style>。全セレクタを .fp-x 配下に限定 → 漏れない。
 *  - CSS変数は :root でなく .fp-x 上に定義 → 既存トークンと非衝突。
 *  - 素のリセット（* / body / table 等の global 指定）なし → Tailwind preflight 非干渉。
 *  - 表は SSR で描画。JS は [data-fp] 配下のみ操作（絞り込み/検索/FAQ/表示アニメ）。
 *
 * ヘッダー / フッター / パンくず / 条件ナビ は既存 Layout 側のものを使う想定。
 */
export type FreePlan = 'あり' | 'limited';        // 'あり'＝無料プランあり / 'limited'＝制限あり
export type CatVariant = 'image' | 'video' | 'edit' | 'avatar';

export interface Tool {
  name: string;
  slug: string;            // /tools/{slug}/ へのリンクに使用
  initial?: string;        // バッジ頭文字（省略時は name の先頭）
  freePlan: FreePlan;      // 無料プランの状態
  ja?: string;             // 日本語対応: '対応' | '部分対応' | '非対応' | '要確認'
  commercial?: string;     // 商用利用条件: '公式案内あり' | '有料プラン向け' | '条件あり' | '非対応' | '要確認'
  watermark?: string;      // 透かし: 'なし' | 'あり' | '要確認'
}
export interface Category { variant: CatVariant; title: string; body: string; linkLabel: string; href: string; icon?: string; }
export interface Point { title: string; body: string; icon?: string; } // body は HTML 文字列可
export interface UseCase { use: string; kinds: string[]; refLabel: string; refHref: string; }
export interface Faq { q: string; a: string; }      // a は HTML 文字列可
export interface RelatedLink { label: string; href: string; solid?: boolean; }

export interface Props {
  headingHtml?: string;
  lead?: string;
  toolsBase?: string;          // 詳細リンクのベース（既定 '/tools/'）
  stats?: { n: string; label: string }[];
  categories?: Category[];
  points?: Point[];
  useCases?: UseCase[];
  tools?: Tool[];
  cautionTitle?: string;
  cautionItems?: string[];
  cautionNote?: string;        // HTML 可
  faqs?: Faq[];
  related?: RelatedLink[];
  relatedSolid?: RelatedLink[];
  disclaimer?: string;
}

/* ---- アイコン（カテゴリ／ポイント既定） ---- */
const IC = {
  image: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.6"/><path d="m21 15-5-5L5 21"/></svg>',
  video: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"/></svg>',
  edit:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h10M4 17h7"/><circle cx="18" cy="15" r="3"/></svg>',
  avatar:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-7 8-7s8 3 8 7"/></svg>',
  credit:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 6h18M3 12h18M3 18h18"/></svg>',
  drop:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22c4-3 7-7 7-12a7 7 0 0 0-14 0c0 5 3 9 7 12Z"/></svg>',
  bag:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>',
  expand:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>',
  grid:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>',
  globe: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/></svg>',
};

const DEFAULT_CATEGORIES: Category[] = [
  { variant:'image',  title:'AI画像生成を無料で試す', body:'ブログ画像・SNS投稿・サムネイルなど静止画コンテンツ作成に向いています。無料プランでも比較的多くの枚数を生成できるツールが多く、初めての方に適しています。', linkLabel:'AI画像生成ツール一覧', href:'/categories/image-generation/' },
  { variant:'video',  title:'AI動画生成を無料で試す', body:'SNS動画・YouTube Shorts・プロモーション動画の制作に向いています。画像生成より処理コストが高く、無料枠の上限が厳しいツールも多い傾向があります。', linkLabel:'AI動画生成ツール一覧', href:'/categories/video-generation/' },
  { variant:'edit',   title:'AI動画編集を無料で試す', body:'既存の動画素材をAIで編集・加工したい場合に向いています。字幕生成・背景除去・カット編集などの機能を無料枠で試せるツールがあります。', linkLabel:'AI動画編集ツール一覧', href:'/categories/video-editing/' },
  { variant:'avatar', title:'AIアバター動画を無料で試す', body:'顔出しなし動画や、AIアバターを使った解説・プレゼン動画に向いています。無料プランでは利用できるアバターや出力時間が制限されるケースが多いです。', linkLabel:'AIアバター動画ツール一覧', href:'/categories/avatar-video/' },
];

const DEFAULT_POINTS: Point[] = [
  { title:'生成回数・クレジット', icon:IC.credit, body:'月あたりの生成回数やクレジット数に上限があるツールがほとんどです。上限に達すると追加購入や有料プランへの移行が必要になる場合があります。' },
  { title:'透かし（ウォーターマーク）', icon:IC.drop, body:'無料プランでは生成画像・動画に透かしが付与されるツールがあります。透かしなしで使うには有料プランへの移行が必要なケースがほとんどです。<a href="/conditions/no-watermark/">透かしなしツール</a>もご参照ください。' },
  { title:'商用利用条件', icon:IC.bag, body:'無料プランでの商用利用可否はツールによって異なります。SNS投稿や広告・ブログへの使用が商用と判断される場合があります。<a href="/conditions/commercial-use/">商用利用条件を確認</a>でご確認ください。' },
  { title:'出力解像度・動画長', icon:IC.expand, body:'無料プランでは出力できる画像解像度や動画の最大長さが制限される場合があります。実務に必要な品質・長さが無料枠に含まれるかを事前に確認しましょう。' },
  { title:'利用できる機能の範囲', icon:IC.grid, body:'無料プランでは一部のモデルや機能（高解像度出力・優先処理・API利用など）が有料プラン専用の場合があります。必要な機能が無料枠に含まれるか公式サイトで確認してください。' },
  { title:'日本語対応', icon:IC.globe, body:'日本語UIやプロンプトへの対応状況はツールによって異なります。<a href="/conditions/japanese/">日本語対応ツール</a>でも対応状況を確認できます。' },
];

const DEFAULT_USECASES: UseCase[] = [
  { use:'SNS投稿・ブログ画像', kinds:['AI画像生成'], refLabel:'AI画像生成ツール一覧', refHref:'/categories/image-generation/' },
  { use:'YouTubeサムネイル', kinds:['AI画像生成'], refLabel:'サムネイル向けツール', refHref:'/use-cases/youtube-thumbnail/' },
  { use:'YouTube動画', kinds:['AI動画生成','AI動画編集'], refLabel:'YouTube向けツール', refHref:'/use-cases/youtube/' },
