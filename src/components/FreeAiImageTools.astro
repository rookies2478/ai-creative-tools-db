---
/* =========================================================
   FreeAiImageTools.astro
   ガイド：/guides/free-ai-image-tools/ の記事本文
   （結論 ＋ 免責 ＋ 選ぶポイント ＋ 無料枠で比較すべき項目
    ＋ 無料プランの種類表 ＋ 透かし解説 ＋ 商用利用パターン
    ＋ 無料プランがあるツール一覧表 ＋ 用途別おすすめ表
    ＋ 無料プラン利用時の注意 ＋ チェックリスト ＋ FAQ
    ＋ 注意事項/鮮度 ＋ 関連ページ）

   既存サイト（Tailwind）を壊さない設計:
   - すべてのセレクタを .fai-x 配下に限定（スタイル漏れなし）
   - CSS変数は :root ではなく .fai-x 上に定義（既存トークン非衝突）
   - 素のリセット（*{} / body{} / table{} 等）を含めない（preflight非干渉）
   - SSRで描画。JSは [data-fai] 配下のみ操作（FAQ開閉・表示アニメ）

   ヘッダー・フッター・パンくずは既存 Layout 側のものを使用してください。
   このコンポーネントは記事本文だけを描画します。
   ========================================================= */

export type Mark = 'ok' | 'cond' | 'no' | 'na';

export interface Stat { n: string; label: string; }
export interface Point { title: string; sub: string; }
export interface Badge { s: Mark; label: string; }
export interface ToolRow {
  name: string;
  slug?: string;
  initial?: string;
  freePlan?: Badge;        // 無料プラン列
  commercial?: Badge;      // 商用利用列
  watermark?: Badge;       // 透かし列
  date?: string;           // 最終確認日
}
export interface PlanType { en: string; ja: string; body: string; }
export interface Pattern { lead: string; body: string; tag?: string; tagStyle?: 'ok' | 'cond' | 'note' | 'alt'; }
export interface UseCase { situation: string; toolHtml: string; reason: string; }
export interface NoteItem { lead: string; body: string; }
export interface CheckItem { html: string; }
export interface Faq { q: string; a: string; }
export interface RelatedLink { label: string; href: string; solid?: boolean; }

export interface Props {
  headingHtml?: string;
  lead?: string;
  checkedDate?: string;
  nextCheckDate?: string;
  stats?: Stat[];
  conclusionHtml?: string;
  disclaimer?: string;
  points?: Point[];
  planTypes?: PlanType[];
  watermarkHtml?: string;
  patterns?: Pattern[];
  tools?: ToolRow[];
  toolsAsOf?: string;
  useCases?: UseCase[];
  cautions?: NoteItem[];
  checklist?: CheckItem[];
  faqs?: Faq[];
  notes?: string[];
  footnote?: string;
  related?: RelatedLink[];
  toolsBase?: string;          // 既定 /tools/ → /tools/{slug}/
}

const {
  headingHtml = '無料で試せる<span class="hl"><span class="phrase-nowrap">AI画像</span>生成ツール比較</span>',
