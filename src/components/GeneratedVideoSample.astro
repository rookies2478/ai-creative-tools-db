---
import type { GeneratedVideo } from '../data/generatedVideos';

interface Props {
  video: GeneratedVideo;
}

const { video } = Astro.props;
---

<figure class="gvs-fig">
  <div class="gvs-player">
    <video
      src={video.file}
      poster={video.poster}
      muted
      loop
      playsinline
      preload="none"
      controls
      class="gvs-video"
      aria-label={video.alt}
    ></video>
  </div>
  <figcaption class="gvs-cap">
    <span class="gvs-label">{video.caption}</span>
    <dl class="gvs-meta">
      <div>
        <dt>モデル：</dt>
        <dd>
          {video.modelUrl
            ? <a href={video.modelUrl} target="_blank" rel="noopener noreferrer">{video.model}</a>
            : video.model}
        </dd>
      </div>
      <div>
        <dt>尺：</dt>
        <dd>{video.durationSec}秒</dd>
      </div>
      <div>
        <dt>プロンプト：</dt>
        <dd class="gvs-prompt">{video.prompt}</dd>
      </div>
      {video.negativePrompt && (
        <div>
          <dt>ネガティブ：</dt>
          <dd class="gvs-prompt">{video.negativePrompt}</dd>
        </div>
      )}
      <div>
        <dt>生成日：</dt>
        <dd>{video.generatedAt}</dd>
      </div>
    </dl>
    <p class="gvs-note">
      ※ {video.usageNote}
    </p>
  </figcaption>
</figure>

<style>
.gvs-fig {
  margin: 0;
  border: 1px solid var(--line, #e3e2d9);
  border-radius: 12px;
  overflow: hidden;
  background: var(--surface, #fff);
}
.gvs-player {
  background: #111;
  aspect-ratio: 16 / 9;
  display: flex;
  align-items: center;
  justify-content: center;
}
.gvs-video {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
}
.gvs-cap {
  padding: 14px 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.gvs-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--brand-ink, #4B3FE4);
  background: var(--brand-tint, #EDEAFF);
  padding: 2px 8px;
  border-radius: 999px;
  width: fit-content;
}
.gvs-meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin: 0;
  font-size: 12px;
  color: var(--muted, #6A7180);
}
.gvs-meta > div { display: flex; flex-wrap: wrap; gap: 4px; }
.gvs-meta dt { font-weight: 600; color: var(--ink-soft, #3A3E47); white-space: nowrap; }
.gvs-meta dd { margin: 0; }
.gvs-meta a { color: var(--brand-ink, #4B3FE4); text-decoration: none; }
.gvs-meta a:hover { text-decoration: underline; }
.gvs-prompt { word-break: break-all; font-size: 11px; }
.gvs-note {
  font-size: 11.5px;
  line-height: 1.75;
  color: var(--muted, #6A7180);
  margin: 0;
}
</style>
