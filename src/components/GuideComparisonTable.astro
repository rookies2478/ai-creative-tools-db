---
interface TableCell {
  text: string;
  href?: string;
  muted?: boolean;
}

interface Props {
  caption: string;
  headers: string[];
  rows: TableCell[][];
  /** single badge column (legacy, ignored if statusColIndexes is set) */
  statusColIndex?: number;
  /** multiple badge columns – overrides statusColIndex */
  statusColIndexes?: number[];
}

const { caption, headers, rows, statusColIndex = 1, statusColIndexes } = Astro.props;

// Normalise to a Set for O(1) lookup
const badgeCols: Set<number> =
  statusColIndexes != null
    ? new Set(statusColIndexes.filter((i) => i >= 0))
    : statusColIndex >= 0
      ? new Set([statusColIndex])
      : new Set();

function getStatusBadge(text: string): string {
  if (text.startsWith('〇')) return 'bg-emerald-100 text-emerald-800';
  if (text.startsWith('△')) return 'bg-amber-100 text-amber-800';
  if (text.startsWith('×')) return 'bg-red-100 text-red-800';
  if (text.includes('不可') && !text.includes('場合')) return 'bg-red-100 text-red-800';
  return '';
}
---

<!-- Desktop: full table (md and up) -->
<div class="my-6 hidden overflow-x-auto rounded-xl border border-slate-200 md:block">
  <table class="w-full text-sm" aria-label={caption}>
    <caption class="sr-only">{caption}</caption>
    <thead>
      <tr class="border-b border-slate-200 bg-slate-50">
        {headers.map((h, i) => (
          <th
            scope="col"
            class={`px-4 py-3 text-left text-xs font-semibold text-slate-600 whitespace-nowrap ${i === 0 ? 'min-w-[140px]' : ''}`}
          >
            {h}
          </th>
        ))}
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {rows.map((row) => (
        <tr class="hover:bg-slate-50/60 transition-colors">
          {row.map((cell, ci) => {
            const badgeClass = badgeCols.has(ci) ? getStatusBadge(cell.text) : '';
            return (
              <td
                class={`px-4 py-3 align-top leading-relaxed ${cell.muted ? 'text-slate-400' : 'text-slate-700'}`}
              >
                {cell.href ? (
                  <a
                    href={cell.href}
                    class="text-blue-600 hover:underline focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-sm"
                  >
                    {cell.text}
                  </a>
                ) : badgeClass ? (
                  <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${badgeClass}`}>
                    {cell.text}
                  </span>
                ) : (
                  cell.text
                )}
              </td>
            );
          })}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<!-- Mobile: card stack (below md) -->
<div class="my-6 space-y-3 md:hidden">
  <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">{caption}</p>
  {rows.map((row) => {
    // Collect all badge-column values for the header area of the card
    const topBadges = [...badgeCols]
      .filter((ci) => ci > 0 && ci < row.length)
      .map((ci) => ({ header: headers[ci], cell: row[ci], badge: getStatusBadge(row[ci].text) }))
      .filter((b) => b.badge !== '');

    return (
      <div class="rounded-xl border border-slate-200 bg-white p-4">
        <div class="mb-3 flex items-start justify-between gap-2 flex-wrap">
          <p class="font-semibold text-slate-900 text-sm">{row[0].href ? (
            <a href={row[0].href} class="text-blue-600 hover:underline">{row[0].text}</a>
          ) : row[0].text}</p>
          {topBadges.length > 0 && (
            <div class="flex flex-wrap gap-1 shrink-0">
              {topBadges.map((b) => (
                <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${b.badge}`}>
                  {b.cell.text}
                </span>
              ))}
            </div>
          )}
        </div>
        <dl class="space-y-2">
          {headers.slice(1).map((header, i) => {
            const ci = i + 1;
            if (badgeCols.has(ci)) return null; // already shown as badge above
            const cell = row[ci];
            if (!cell) return null;
            return (
              <div class="flex gap-2 text-xs">
                <dt class="w-20 shrink-0 text-slate-400 pt-0.5">{header}</dt>
                <dd class={cell.muted ? 'text-slate-400' : 'text-slate-700'}>
                  {cell.href ? (
                    <a href={cell.href} class="text-blue-600 hover:underline">
                      {cell.text}
                    </a>
                  ) : (
                    cell.text
                  )}
                </dd>
              </div>
            );
          })}
        </dl>
      </div>
    );
  })}
</div>
