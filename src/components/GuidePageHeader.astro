---
interface Props {
  title: string;
  description: string;
  lastReviewed: string;
  breadcrumbLabel?: string;
}
const { title, description, lastReviewed, breadcrumbLabel = 'ガイド' } = Astro.props;
---

<nav class="mb-6 text-sm text-slate-400" aria-label="パンくずリスト">
  <ol class="flex items-center gap-1">
    <li><a href="/" class="hover:text-slate-700 hover:underline focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-sm">トップ</a></li>
    <li aria-hidden="true"><span class="mx-1 text-slate-300">/</span></li>
    <li><span class="text-slate-600" aria-current="page">{title}</span></li>
  </ol>
</nav>

<header class="mb-8 border-b border-slate-100 pb-8">
  <div class="mb-3 flex flex-wrap items-center gap-2">
    <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700">{breadcrumbLabel}</span>
    <span class="text-xs text-slate-400">最終確認: {lastReviewed}</span>
  </div>
  <h1 class="text-2xl font-bold leading-snug text-slate-900 sm:text-3xl">{title}</h1>
  <p class="mt-3 text-base leading-relaxed text-slate-500">{description}</p>
</header>
