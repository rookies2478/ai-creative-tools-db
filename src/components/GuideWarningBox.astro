---
interface Props {
  variant?: 'warning' | 'info' | 'danger';
  title?: string;
}
const { variant = 'warning', title } = Astro.props;

const config = {
  warning: {
    wrapper: 'border-amber-200 bg-amber-50',
    icon: 'text-amber-500',
    titleClass: 'text-amber-900',
    bodyClass: 'text-amber-800',
    path: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z',
  },
  info: {
    wrapper: 'border-blue-200 bg-blue-50',
    icon: 'text-blue-500',
    titleClass: 'text-blue-900',
    bodyClass: 'text-blue-800',
    path: 'm11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z',
  },
  danger: {
    wrapper: 'border-red-200 bg-red-50',
    icon: 'text-red-500',
    titleClass: 'text-red-900',
    bodyClass: 'text-red-800',
    path: 'M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z',
  },
}[variant];
---

<div class={`rounded-xl border ${config.wrapper} px-5 py-4 my-6`} role="note">
  <div class="flex gap-3">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class={`mt-0.5 h-5 w-5 shrink-0 ${config.icon}`}
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d={config.path} />
    </svg>
    <div>
      {title && <p class={`mb-1 text-sm font-semibold ${config.titleClass}`}>{title}</p>}
      <div class={`text-sm leading-relaxed ${config.bodyClass}`}>
        <slot />
      </div>
    </div>
  </div>
</div>
