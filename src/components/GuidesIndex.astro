---
/* =========================================================
   GuidesIndex.astro
   ガイド一覧ページ本文：/guides/
   （ページヘッダー ＋ ガイド記事カード一覧 ＋ 関連する補助ページ）

   既存サイト（Tailwind）を壊さない設計:
   - すべてのセレクタを .gix-x 配下に限定（スタイル漏れなし）
   - CSS変数は :root ではなく .gix-x 上に定義（既存トークン非衝突）
   - 素のリセット（*{} / body{} 等）を含めない（preflight非干渉）
   - SSRで描画。JSは [data-gix] 配下のみ操作（表示アニメ）

   ヘッダー・フッター・パンくずは既存 Layout 側のものを使用してください。
   このコンポーネントはページ本文だけを描画します。
   `WatermarkCreditGuide` / `CommercialUseCopyright` / `FreeAiImageTools` と
   同じデザインシステムです。
   ========================================================= */

export interface GuideCard {
  title: string;
  desc: string;
  tags: string[];       // カテゴリ／観点（例：['AI画像生成', '商用利用']）
  href: string;
  cta?: string;         // 既定「読む」
}
export interface HelperCard {
  label: string;        // 例「プロンプト」
  title: string;
  desc: string;
  href: string;
  cta?: string;         // 既定「見る」
}

export interface Props {
  eyebrow?: string;
  headingHtml?: string;
  lead?: string;
  guides?: GuideCard[];
  helperHeading?: string;
  helpers?: HelperCard[];
}

const {
  eyebrow = 'Guides',
  headingHtml = 'AIツールの使い方・<span class="hl">選び方ガイド</span>',
  lead = 'AI画像生成・AI動画生成を中心に、AIツールを選ぶ前に確認したい条件や使い方のポイントをまとめています。商用利用や著作権に関する内容は、公式情報の確認を前提に整理しています。',
  guides = [
    { title: 'AI画像生成の商用利用・著作権ガイド', desc: '商用利用の可否はツールとプランの組み合わせによって異なります。透かし条件・クレジット表記・利用規約の見方を整理しています。プランや用途によって条件が異なる場合があります。', tags: ['AI画像生成', '商用利用'], href: '/guides/commercial-use-copyright/' },
    { title: '無料で使えるAI画像生成ツール比較｜無料枠・透かし・商用利用の注意点', desc: '無料枠・クレジット制限・透かし・商用利用・日本語対応の観点で比較。実務利用前に確認すべき注意点も整理しています。', tags: ['AI画像生成', '無料プラン'], href: '/guides/free-ai-image-tools/' },
    { title: '日本語対応AI画像生成ツール比較｜日本語UI・プロンプト・使いやすさ', desc: '日本語UI・日本語プロンプト・対応環境・無料枠の観点で比較。初心者や日本語中心で使いたい方向けに選び方を整理しています。', tags: ['AI画像生成', '日本語対応'], href: '/guides/japanese-ai-image-tools/' },
    { title: '透かしなしAI画像生成ツール比較｜無料プラン・商用利用・注意点まとめ', desc: '無料プラン条件・透かしルール・商用利用可否を比較。ツールや条件によって異なるため、公式情報の確認を前提に整理しています。', tags: ['AI画像生成', '透かし・クレジット'], href: '/guides/watermark-credit-guide/' },
    { title: 'AI画像・AI動画を商用利用する前に確認したいチェックリスト', desc: 'SNS投稿・広告・YouTube・サムネイル・EC商品画像等で使う前に確認したい実務チェックリスト。規約・プラン・権利・肖像権・商標・透かし・用途別の注意点を整理。本記事は法的助言ではありません。', tags: ['AI画像・AI動画', '商用利用'], href: '/guides/ai-image-commercial-use-checklist/' },
    { title: 'AI動画生成ツールの料金・クレジット消費比較ガイド', desc: 'Runway・Pika・Kling AI・Luma AIなど主要ツールの料金体系とクレジット消費の目安を比較。無料枠の違いや有料プランへの移行タイミングの検討に役立てることができます。', tags: ['AI動画生成', '料金・クレジット'], href: '/guides/video-generation-credit-cost-comparison/' },
    { title: 'AI画像・動画生成ツールの商用利用条件と実質コスト比較ガイド', desc: '商用利用を前提にする場合に確認すべきプラン条件と実質的なコストを整理しています。無料プランの制約・有料プランの商用可否・コスト感の比較に役立てることができます。', tags: ['AI画像・AI動画', '商用利用・コスト'], href: '/guides/commercial-use-cost-comparison/' },
    { title: 'AI画像・動画生成ツールの料金表の見方｜日本円・ドル請求・税・アプリ課金の違い', desc: '日本円表示、ドル請求、税込・税別、Web版とアプリ版の違いなど、料金表を見るときに確認したいポイントを整理しています。日本から課金する前に確認したい内容です。', tags: ['AI画像・AI動画', '料金表の見方'], href: '/guides/ai-tool-pricing-currency-japan/' },
    { title: 'AI画像・動画生成ツールのクレジット制とは？無料枠・消費量・料金の見方', desc: 'クレジット制の仕組み、無料クレジットと有料クレジットの違い、動画生成で消費量が増えやすい理由を整理しています。', tags: ['AI画像・AI動画', 'クレジット制'], href: '/guides/ai-generation-credits-guide/' },
    { title: 'AIツールの日本語対応とは？日本語UI・日本語プロンプト・日本語文字生成の違い', desc: '「日本語対応」は日本語UI・日本語プロンプト・日本語文字生成の3つに分解できます。それぞれの意味と確認方法、混同しやすい誤解を整理しています。', tags: ['AI画像・AI動画', '日本語対応'], href: '/guides/japanese-support-three-types/' },
  ],
  helperHeading = '関連する補助ページ',
  helpers = [
    { label: 'プロンプト', title: 'プロンプト活用ガイド', desc: 'AI画像生成・AI動画生成で使うプロンプトの考え方を用途別に整理しています。', href: '/prompts/' },
    { label: 'テンプレート', title: '実務テンプレート集', desc: 'AI制作で使う構成案・制作指示・チェックリストのテンプレートを用途別に整理しています。', href: '/templates/' },
  ],
} = Astro.props as Props;
---

<div class="gix-x" data-gix>
  <!-- ===== ページヘッダー ===== -->
  <header class="gix-head reveal">
    <span class="gix-eyebrow">{eyebrow}</span>
    <h1 class="gix-h1" set:html={headingHtml}></h1>
    <p class="gix-lead">{lead}</p>
  </header>

  <!-- ===== ガイド記事カード一覧 ===== -->
  <section class="gix-sec">
    <ul class="gix-grid reveal" data-stagger>
      {guides.map((g) => (
        <li class="gix-card">
          <a class="gix-cardlink" href={g.href} aria-label={g.title}>
            <div class="gix-cardtop">
              <span class="gix-pill">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 5h16M4 12h16M4 19h10"/></svg>
                ガイド
              </span>
              <span class="gix-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </span>
            </div>
            <h2 class="gix-cardttl">{g.title}</h2>
            <p class="gix-carddesc">{g.desc}</p>
            <div class="gix-cardfoot">
              <span class="gix-tags">
                {g.tags.map((t) => (<span class="gix-tag">{t}</span>))}
              </span>
              <span class="gix-read">{g.cta ?? '読む'}<span class="ar">→</span></span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ===== 関連する補助ページ ===== -->
  <section class="gix-sec band">
    <div class="gix-sechead reveal">
      <span class="gix-eyebrow">Related</span>
      <h2>{helperHeading}</h2>
    </div>
    <ul class="gix-helpers reveal" data-stagger>
      {helpers.map((h) => (
        <li class="gix-helper">
          <a class="gix-cardlink" href={h.href} aria-label={h.title}>
            <span class="gix-htag">{h.label}</span>
            <div class="gix-htext">
              <h3>{h.title}</h3>
              <p>{h.desc}</p>
            </div>
            <span class="gix-hread">見る<span class="ar">→</span></span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</div>

<style>
  /* すべて .gix-x 配下に限定。CSS変数も .gix-x 上に定義（:root非使用）。 */
  .gix-x {
    --paper:#F4F4EE; --surface:#FFFFFF; --surface-2:#FAFAF6;
    --ink:#16181D; --ink-soft:#3A3E47; --muted:#6A7180; --faint:#98A0AD;
    --line:#E3E2D9; --line-strong:#D2D1C6;
    --brand:#4B3FE4; --brand-ink:#2E25A6; --brand-tint:#ECEBFB;
    --f-jp:"Zen Kaku Gothic New","Noto Sans JP",system-ui,sans-serif;
    --f-body:"Noto Sans JP",system-ui,sans-serif;
    --f-latin:"Space Grotesk",system-ui,sans-serif;
    --f-mono:"Space Mono",ui-monospace,monospace;
    --radius:14px; --radius-lg:22px;
    --shadow-sm:0 1px 2px rgba(20,22,28,.04),0 1px 3px rgba(20,22,28,.05);
    --shadow-md:0 4px 14px rgba(20,22,28,.06),0 2px 6px rgba(20,22,28,.04);
    --shadow-lg:0 18px 40px -18px rgba(20,22,28,.22),0 6px 16px rgba(20,22,28,.06);
    --ease:cubic-bezier(.22,.61,.36,1);

    font-family: var(--f-body);
    color: var(--ink);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }
  .gix-x :where(h1,h2,h3) { font-family: var(--f-jp); font-weight: 700; line-height: 1.32; letter-spacing: .01em; margin: 0; }
  .gix-x :where(p) { margin: 0; }
  .gix-x a { color: inherit; text-decoration: none; }

  .gix-eyebrow { font-family: var(--f-latin); font-size: 12px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: var(--muted); display: inline-flex; align-items: center; gap: 10px; }
  .gix-eyebrow::before { content: ""; width: 22px; height: 2px; border-radius: 2px; background: var(--brand); }

  /* ページヘッダー */
  .gix-head { padding: 30px 0 0; max-width: 760px; }
  .gix-h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 900; letter-spacing: -.012em; line-height: 1.18; margin: 16px 0 18px; max-width: min(960px, 100%); text-wrap: balance; }
  .gix-h1 .hl { color: var(--brand-ink); position: relative; }
  .gix-h1 .hl::after { content: ""; position: absolute; left: 0; right: 0; bottom: .08em; height: .26em; background: color-mix(in srgb, var(--brand) 18%, transparent); z-index: -1; border-radius: 2px; }
  .gix-h1 .gix-nowrap { white-space: nowrap; }
  .gix-lead { font-size: 15.5px; color: var(--ink-soft); max-width: 680px; }

  /* セクション */
  .gix-sec { padding: 44px 0 64px; }
  .gix-sec.band { background: var(--surface-2); border-top: 1px solid var(--line); padding: 56px 0 64px; }
  .gix-sechead { max-width: 760px; margin-bottom: 28px; }
  .gix-sechead h2 { font-size: clamp(21px, 2.6vw, 30px); font-weight: 900; letter-spacing: -.005em; margin-top: 14px; }

  /* ガイドカードグリッド */
  .gix-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .gix-card { display: flex; }
  .gix-cardlink { position: relative; display: flex; flex-direction: column; width: 100%; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 24px 26px 22px; box-shadow: var(--shadow-sm); transition: transform .22s var(--ease), box-shadow .22s, border-color .22s; overflow: hidden; }
  .gix-cardlink::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; background: var(--brand); transform: scaleX(0); transform-origin: left; transition: transform .3s var(--ease); }
  .gix-card:hover .gix-cardlink { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: color-mix(in srgb, var(--brand) 30%, var(--line)); }
  .gix-card:hover .gix-cardlink::before { transform: scaleX(1); }

  .gix-cardtop { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .gix-pill { font-family: var(--f-jp); font-weight: 700; font-size: 11.5px; letter-spacing: .04em; color: var(--brand-ink); background: var(--brand-tint); padding: 5px 12px; border-radius: 999px; display: inline-flex; align-items: center; gap: 7px; }
  .gix-pill svg { width: 12px; height: 12px; }
  .gix-arrow { width: 30px; height: 30px; border-radius: 50%; border: 1px solid var(--line-strong); display: grid; place-items: center; color: var(--muted); transition: transform .22s var(--ease), background .22s, color .22s, border-color .22s; flex: none; }
  .gix-arrow svg { width: 15px; height: 15px; }
  .gix-card:hover .gix-arrow { background: var(--brand); border-color: var(--brand); color: #fff; transform: translateX(3px); }

  .gix-cardttl { font-size: 17px; font-weight: 700; line-height: 1.42; color: var(--ink); margin-bottom: 11px; text-wrap: pretty; }
  .gix-card:hover .gix-cardttl { color: var(--brand-ink); }
  .gix-carddesc { font-size: 13px; color: var(--muted); line-height: 1.78; flex: 1; }

  .gix-cardfoot { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--line); }
  .gix-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .gix-tag { font-family: var(--f-jp); font-weight: 600; font-size: 11px; color: var(--ink-soft); background: var(--surface-2); border: 1px solid var(--line); border-radius: 7px; padding: 3px 9px; line-height: 1.5; white-space: nowrap; }
  .gix-read { font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; color: var(--brand-ink); display: inline-flex; align-items: center; gap: 5px; white-space: nowrap; flex: none; }
  .gix-read .ar { transition: transform .2s var(--ease); }
  .gix-card:hover .gix-read .ar { transform: translateX(3px); }

  /* 補助ページ */
  .gix-helpers { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .gix-helper .gix-cardlink { flex-direction: row; align-items: center; gap: 20px; padding: 24px 26px; border-radius: var(--radius-lg); }
  .gix-htag { font-family: var(--f-jp); font-weight: 700; font-size: 12px; color: var(--brand-ink); background: var(--brand-tint); padding: 7px 14px; border-radius: 10px; flex: none; align-self: flex-start; }
  .gix-htext { min-width: 0; flex: 1; }
  .gix-htext h3 { font-size: 16px; font-weight: 700; color: var(--ink); margin-bottom: 6px; }
  .gix-helper:hover .gix-htext h3 { color: var(--brand-ink); }
  .gix-htext p { font-size: 12.5px; color: var(--muted); line-height: 1.72; }
  .gix-hread { font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; color: var(--brand-ink); display: inline-flex; align-items: center; gap: 5px; white-space: nowrap; flex: none; align-self: center; }
  .gix-hread .ar { transition: transform .2s var(--ease); }
  .gix-helper:hover .gix-hread .ar { transform: translateX(3px); }

  /* スクロール表示アニメ */
  @media (prefers-reduced-motion: no-preference) {
    .gix-x .reveal { opacity: 0; transform: translateY(18px); transition: opacity .6s var(--ease), transform .6s var(--ease); }
    .gix-x .reveal.in { opacity: 1; transform: none; }
    .gix-x .reveal[data-stagger] > * { opacity: 0; transform: translateY(16px); transition: opacity .5s var(--ease), transform .5s var(--ease); }
    .gix-x .reveal[data-stagger].in > * { opacity: 1; transform: none; }
    .gix-x .reveal[data-stagger].in > *:nth-child(1) { transition-delay: .03s; }
    .gix-x .reveal[data-stagger].in > *:nth-child(2) { transition-delay: .07s; }
    .gix-x .reveal[data-stagger].in > *:nth-child(3) { transition-delay: .11s; }
    .gix-x .reveal[data-stagger].in > *:nth-child(4) { transition-delay: .15s; }
    .gix-x .reveal[data-stagger].in > *:nth-child(5) { transition-delay: .19s; }
    .gix-x .reveal[data-stagger].in > *:nth-child(6) { transition-delay: .23s; }
    .gix-x .reveal[data-stagger].in > *:nth-child(7) { transition-delay: .27s; }
    .gix-x .reveal[data-stagger].in > *:nth-child(8) { transition-delay: .31s; }
    .gix-x .reveal[data-stagger].in > *:nth-child(9) { transition-delay: .35s; }
  }
  @media (prefers-reduced-motion: reduce) {
    .gix-x .reveal, .gix-x .reveal[data-stagger] > * { opacity: 1 !important; transform: none !important; }
  }

  /* レスポンシブ */
  @media (max-width: 980px) {
    .gix-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 720px) {
    .gix-sec { padding: 36px 0 48px; }
    .gix-sec.band { padding: 44px 0 48px; }
    .gix-grid { grid-template-columns: 1fr; }
    .gix-helpers { grid-template-columns: 1fr; }
    .gix-helper .gix-cardlink { gap: 16px; }
  }
  @media (max-width: 640px) {
    .gix-x .gix-h1 .gix-nowrap { white-space: normal; }
  }
</style>

<script>
  // JSは [data-gix] 配下のみ操作（既存サイトに干渉しない）
  (function () {
    document.querySelectorAll('[data-gix]').forEach(function (root) {
      var reveals = Array.prototype.slice.call(root.querySelectorAll('.reveal'));
      if (!reveals.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach(function (el) { io.observe(el); });
      setTimeout(function () { reveals.forEach(function (el) { el.classList.add('in'); }); }, 8000);
    });
  })();
</script>
