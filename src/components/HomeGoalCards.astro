---
// HomeGoalCards.astro
// コンテンツ正本: src/pages/index.astro 既存「目的から選ぶ」セクション（USE CASES 8枚）
---

<section id="use-cases" class="hg-section scroll-mt-24">
  <div class="wrap">

    <div class="section-head">
      <span class="eyebrow">用途から探す</span>
      <h2>目的から選ぶ</h2>
      <p>制作したいアウトプットから、関連カテゴリの比較・ガイド記事に案内します。</p>
    </div>

    <div class="uc-grid">

      <a href="/use-cases/youtube-thumbnail/" class="uc-card">
        <span class="uc-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </span>
        <h3>YouTubeサムネイル</h3>
        <p>クリックされるサムネ画像</p>
        <span class="textlink uc-more">見る <span class="arr">→</span></span>
      </a>

      <a href="/use-cases/sns-post-image/" class="uc-card">
        <span class="uc-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </span>
        <h3>SNS投稿</h3>
        <p>画像・動画投稿</p>
        <span class="textlink uc-more">見る <span class="arr">→</span></span>
      </a>

      <a href="/use-cases/ad-banner/" class="uc-card">
        <span class="uc-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="7" width="20" height="14" rx="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
        </span>
        <h3>広告クリエイティブ</h3>
        <p>バナー・動画広告</p>
        <span class="textlink uc-more">見る <span class="arr">→</span></span>
      </a>

      <a href="/use-cases/blog-eyecatch/" class="uc-card">
        <span class="uc-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </span>
        <h3>ブログ・アイキャッチ</h3>
        <p>記事・メディア用画像</p>
        <span class="textlink uc-more">見る <span class="arr">→</span></span>
      </a>

      <a href="/use-cases/ec-product-image/" class="uc-card">
        <span class="uc-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
        </span>
        <h3>EC商品画像</h3>
        <p>商品写真・背景合成</p>
        <span class="textlink uc-more">見る <span class="arr">→</span></span>
      </a>

      <a href="/use-cases/faceless-video/" class="uc-card">
        <span class="uc-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </span>
        <h3>顔出しなし動画</h3>
        <p>アバター・読み上げ</p>
        <span class="textlink uc-more">見る <span class="arr">→</span></span>
      </a>

      <a href="/use-cases/youtube/" class="uc-card">
        <span class="uc-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="23 7 16 12 23 17 23 7"/>
            <rect x="1" y="5" width="15" height="14" rx="2"/>
          </svg>
        </span>
        <h3>YouTube動画</h3>
        <p>長尺・横型動画</p>
        <span class="textlink uc-more">見る <span class="arr">→</span></span>
      </a>

      <a href="/use-cases/shorts/" class="uc-card">
        <span class="uc-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="5" y="2" width="14" height="20" rx="2"/>
            <line x1="12" y1="18" x2="12.01" y2="18"/>
          </svg>
        </span>
        <h3>Shorts・縦型動画</h3>
        <p>短尺・縦型動画</p>
        <span class="textlink uc-more">見る <span class="arr">→</span></span>
      </a>

    </div>

    <div class="hg-footer">
      <a href="/use-cases/" class="textlink">用途別ページを一覧で見る <span class="arr">→</span></a>
    </div>

  </div>
</section>

<style>
  .hg-section {
    padding: 88px 0 72px;
    background: var(--surface);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .uc-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  .uc-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: transform .2s var(--ease), box-shadow .2s, border-color .2s;
    min-height: 100%;
  }
  .uc-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--brand) 35%, var(--line));
  }
  .uc-ico {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    background: var(--brand-tint);
    color: var(--brand-ink);
    display: grid;
    place-items: center;
    margin-bottom: 6px;
    transition: transform .2s var(--ease), background .2s;
    flex-shrink: 0;
  }
  .uc-card:hover .uc-ico {
    transform: scale(1.06) rotate(-3deg);
  }
  .uc-ico svg { width: 21px; height: 21px; }
  .uc-card h3 {
    font-family: var(--f-jp);
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
  }
  .uc-card p {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }
  .uc-more {
    margin-top: auto;
    padding-top: 10px;
    font-size: 13px;
  }
  .hg-footer {
    margin-top: 26px;
  }

  @media (max-width: 980px) {
    .uc-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .hg-section { padding: 60px 0 48px; }
    .uc-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
