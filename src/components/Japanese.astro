---
/**
 * Japanese.astro
 * 「日本語対応AIツール比較」条件ページ本文
 *  — 見出し ＋ 日本語対応の種類（凡例）＋ 選び方ポイント
 *    ＋ 対象ツール表（無料枠/日本語対応/商用利用/透かし）＋ 日本語対応ステータス絞り込み＋検索
 *    ＋ 日本語対応の詳細マトリクス（UI/プロンプト/ドキュメント）＋ FAQ ＋ 関連ページ
 *
 * 安全性（Tailwind / 既存ページを壊さない）:
 *  - スタイルは Astro scoped <style>。全セレクタを .ja-x 配下に限定 → 漏れない。
 *  - CSS変数は :root でなく .ja-x 上に定義 → 既存トークンと非衝突。
 *  - 素のリセット（* / body / table 等の global 指定）なし → Tailwind preflight 非干渉。
 *  - 表は SSR で描画。JS は [data-ja] 配下のみ操作（絞り込み/検索/FAQ/表示アニメ）。
 *
 * ヘッダー / フッター / パンくず / 条件ナビ は既存 Layout 側のものを使う想定。
 */
export type JaStatus = 'ok' | 'partial' | 'unknown';   // 対応 / 一部対応 / 要確認
export type Mark = '○' | '△' | '×' | '?';              // 詳細マトリクスの評価

export interface Tool {
  name: string;
  slug: string;            // /tools/{slug}/ へのリンクに使用
  initial?: string;        // バッジ頭文字（省略時は name の先頭）
  ja: JaStatus;            // 日本語対応ステータス（バッジ＋絞り込み）
  ui: Mark;                // 日本語UI
  prompt: Mark;            // 日本語プロンプト
  docs: Mark;              // 日本語ドキュメント
  free: string;            // 無料枠: 'あり' | 'なし' | '要確認'
  commercial: string;      // 商用利用: '案内あり' | '要確認' など（参考列・○/△で表示）
  wm: string;              // 透かし: 'なし' | 'あり' | '要確認'（列は「透かしなし＝○」評価）
}
export interface TypeCard { variant: 'ui' | 'prompt' | 'docs'; title: string; body: string; }
export interface Point { title: string; body: string; }   // body は HTML 文字列可
export interface Faq { q: string; a: string; }             // a は HTML 文字列可
export interface RelatedLink { label: string; href: string; solid?: boolean; }

export interface Props {
  headingHtml?: string;
  lead?: string;
  notice?: string;
  toolsBase?: string;          // 詳細リンクのベース（既定 '/tools/'）
  stats?: { n: string; label: string }[];
  types?: TypeCard[];
  points?: Point[];
  tools?: Tool[];
  faqs?: Faq[];
  related?: RelatedLink[];
}

const STATUS: Record<JaStatus, { label: string; cls: string }> = {
  ok:      { label: '対応',     cls: 'ok' },
  partial: { label: '一部対応', cls: 'partial' },
  unknown: { label: '要確認',   cls: 'unknown' },
};

/* ---- アイコン（種類カード） ---- */
