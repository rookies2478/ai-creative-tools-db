const {
  headingHtml = '日本語対応の<br><span class="hl">AIツール</span>比較',
  lead = '日本語UIや日本語プロンプトに対応しているAI画像・動画生成ツールを整理しています。英語が苦手な方や、国内向けの制作・SNS運用でAIツールを使いたい方が対象です。日本語対応の範囲はツールごとに異なるため、最新情報は各ツールの公式サイトでご確認ください。',
  notice = '掲載情報は調査時点の内容です。料金・商用利用条件・著作権に関する規約は変更される場合があります。実務利用前には必ず各ツールの公式サイト・利用規約をご確認ください。本サイトの内容は法的助言ではありません。',
  toolsBase = '/tools/',
  stats = [
    { n:'21', label:'対象ツール' },
    { n:'3',  label:'対応の種類' },
    { n:'6',  label:'よくある質問' },
  ],
  types = DEFAULT_TYPES,
  points = DEFAULT_POINTS,
  tools = DEFAULT_TOOLS,
  faqs = DEFAULT_FAQS,
  related = [
    { label:'無料で使えるツール', href:'/conditions/free/' },
    { label:'商用利用を確認しやすいツール', href:'/conditions/commercial-use/' },
    { label:'透かしなしツール', href:'/conditions/no-watermark/' },
    { label:'日本語対応ツールの選び方', href:'/guides/japanese-ai-image-tools/' },
    { label:'AI動画生成ツール一覧', href:'/categories/video-generation/' },
    { label:'全ツール比較表', href:'/comparisons/', solid:true },
    { label:'すべてのツールを見る', href:'/tools/', solid:true },
    { label:'AI画像生成ツール一覧', href:'/categories/image-generation/', solid:true },
  ] as RelatedLink[],
} = Astro.props;

const relStd = related.filter((r) => !r.solid);
const relSolid = related.filter((r) => r.solid);

/* ○/△/× の判定（参考列ごとの意味づけ） */
function mark(field: 'free' | 'commercial' | 'wm', val: string) {
  let cls = 'cond', ch = '△';
  if (field === 'free') { if (val === 'あり') { cls = 'yes'; ch = '○'; } else if (val === 'なし') { cls = 'no'; ch = '×'; } }
  else if (field === 'commercial') { if (val === '案内あり' || val === 'あり') { cls = 'yes'; ch = '○'; } else if (val === '不可' || val === 'なし') { cls = 'no'; ch = '×'; } }
  else if (field === 'wm') { if (val === 'なし') { cls = 'yes'; ch = '○'; } else if (val === 'あり') { cls = 'no'; ch = '×'; } }
  return { cls, ch };
}
/* 詳細マトリクスの ○/△/×/? → クラス */
function matrixCls(m: Mark) {
  if (m === '○') return 'yes';
  if (m === '△') return 'cond';
  if (m === '×') return 'no';
  return 'q';
}
const ini = (t: Tool) => t.initial ?? t.name.charAt(0);
const presentStatuses = Array.from(new Set(tools.map((t) => t.ja)));
const filterChips: { st: JaStatus | 'all'; label: string }[] = [
  { st: 'all', label: 'すべて' },
  ...(['ok','partial','unknown'] as JaStatus[]).filter((s) => presentStatuses.includes(s)).map((s) => ({ st: s, label: STATUS[s].label })),
];
---

<div class="ja-x" data-ja>

  <!-- ===== 見出し ===== -->
  <header class="ja-head">
    <span class="eyebrow">Japanese support</span>
    <h1 set:html={headingHtml}></h1>
    <p class="lead">{lead}</p>
    {stats.length > 0 && (
      <div class="stats">
        {stats.map((s) => (<div class="stat"><span class="n">{s.n}</span><span class="t">{s.label}</span></div>))}
      </div>
    )}
  </header>

  <!-- ===== 注意 ===== -->
  {notice && (
    <div class="notice">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p><b>ご利用前の注意：</b>{notice}</p>
    </div>
  )}

  <!-- ===== 日本語対応の種類（見方） ===== -->
  <section class="ja-sec">
    <div class="sec-head">
      <span class="eyebrow">Three types</span>
      <h2>「日本語対応」の3つの種類</h2>
      <p>ひと口に「日本語対応」といっても範囲はさまざまです。操作画面が日本語でも、プロンプトは英語の方が精度が高い場合があります。下記3つの観点で対応状況を整理しています。詳細マトリクスの評価は <b>○対応</b> / <b>△一部対応</b> / <b>×非対応</b> / <b>?不明</b> の4段階です。</p>
    </div>
    <div class="type-grid">
      {types.map((t) => (
        <div class={`type-card ${t.variant}`}>
          <span class="ico" set:html={IC[t.variant]}></span>
          <h3>{t.title}</h3>
          <p>{t.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 選ぶ際のポイント ===== -->
  <section class="ja-sec band">
    <div class="sec-head">
      <span class="eyebrow">Checkpoints</span>
      <h2>日本語対応ツールを選ぶ際のポイント</h2>
      <p>「日本語対応」と表示されていても、対応する範囲はツールごとに異なります。実務で使う前に確認しておきたい観点を整理しました。</p>
    </div>
    <ol class="points">
      {points.map((p, i) => (
        <li><span class="pn">{String(i + 1).padStart(2, '0')}</span><span class="pt"><b>{p.title}：</b><span set:html={p.body}></span></span></li>
      ))}
    </ol>
  </section>

  <!-- ===== 対象ツール一覧 ===== -->
  <section class="ja-sec">
    <div class="sec-head">
      <span class="eyebrow">Tool index</span>
      <h2>対象ツール一覧</h2>
      <p>確認時点で{tools.length}件。日本語対応ステータスで絞り込み、各ツールの詳細ページで対応範囲を確認してください。絞り込み・検索は下の「日本語対応の詳細」表にも反映されます。</p>
    </div>

    <div class="statusbar">
      <span class="sb-label">日本語対応</span>
      <div class="sfilter">
        {filterChips.map((c) => (
          <button class="schip" data-st={c.st} aria-pressed={c.st === 'all' ? 'true' : 'false'}>
            {c.st !== 'all' && (<span class="d" data-tone={c.st}></span>)}{c.label}
          </button>
        ))}
      </div>
      <div class="statusbar-right">
        <label class="ja-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20.5 20.5-4-4"/></svg>
          <input type="search" data-search placeholder="ツール名で検索" aria-label="ツール名で検索" />
        </label>
        <span class="ja-count" data-count><b>{tools.length}</b> 件</span>
      </div>
    </div>

    <div class="ja-table-wrap">
      <table class="ja-tbl">
        <thead>
          <tr><th class="col-tool">ツール</th><th>無料枠</th><th>日本語対応</th><th>商用利用</th><th>透かしなし</th><th>詳細</th></tr>
        </thead>
        <tbody>
          {tools.map((t) => {
            const f = mark('free', t.free), c = mark('commercial', t.commercial), w = mark('wm', t.wm);
            return (
              <tr data-name={t.name.toLowerCase()} data-st={t.ja}>
                <td><div class="ja-tool"><span class="b">{ini(t)}</span><span class="nm">{t.name}</span></div></td>
                <td><span class={`mk ${f.cls}`} title={t.free}>{f.ch}</span></td>
                <td><span class={`st ${STATUS[t.ja].cls}`}><span class="d"></span>{STATUS[t.ja].label}</span></td>
                <td><span class={`mk ${c.cls}`} title={t.commercial}>{c.ch}</span></td>
                <td><span class={`mk ${w.cls}`} title={t.wm}>{w.ch}</span></td>
                <td><a class="ja-detail" href={`${toolsBase}${t.slug}/`}>詳細 →</a></td>
              </tr>
            );
          })}
          <tr class="ja-empty-row" hidden><td colspan="6">条件に一致するツールはありません。</td></tr>
        </tbody>
      </table>
    </div>
    <div class="ja-legend">
      <span class="li"><span class="st ok"><span class="d"></span>対応</span></span>
      <span class="li"><span class="st unknown"><span class="d"></span>要確認</span></span>
      <span class="li"><span class="mk yes">○</span>あり / 対応 / 透かしなし</span>
      <span class="li"><span class="mk cond">△</span>要確認</span>
      <span class="li"><span class="mk no">×</span>なし / 非対応</span>
      <span class="ja-legend-sp">透かしなし列は「透かしなし＝○」で評価</span>
    </div>
