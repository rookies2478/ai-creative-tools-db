---
/* =========================================================
   JapaneseAiToolsGuide.astro
   ガイド：/guides/japanese-ai-image-tools/ の記事本文
   （まとめ ＋ 免責 ＋ はじめに ＋ 日本語UIと日本語プロンプトの違い
    ＋ 日本語対応ツールを選ぶときの確認ポイント
    ＋ 海外AIツールを日本語で使うときの注意点
    ＋ 日本語対応ツール一覧（確認時点）
    ＋ FAQ ＋ 注意事項/鮮度 ＋ 関連ページ）

   既存サイト（Tailwind）を壊さない設計:
   - すべてのセレクタを .jag-x 配下に限定（スタイル漏れなし）
   - CSS変数は :root ではなく .jag-x 上に定義（既存トークン非衝突）
   - 素のリセット（*{} / body{} / table{} 等）を含めない（preflight非干渉）
   - SSRで描画。JSは [data-jag] 配下のみ操作（FAQ開閉・表示アニメ）

   ヘッダー・フッター・パンくず・条件ナビは既存 Layout 側のものを使用してください。
   このコンポーネントは記事本文だけを描画します。
   `透かし・クレジット表記ガイド`（WatermarkCreditGuide）と同じデザインシステムです。
   ========================================================= */

export type Mark = 'ok' | 'cond' | 'no' | 'na';

export interface Stat { n: string; label: string; }
export interface Badge { s: Mark; label: string; }
export interface KeyPoint { html: string; }               // まとめの箇条書き（HTML可）
export interface DiffCard { title: string; body: string; note?: string; }
export interface ConfirmStep { title: string; bodyHtml: string; }
export interface CautionItem { title: string; body: string; }
export interface JpToolRow {
  name: string;
  slug?: string;
  initial?: string;
  jpUI?: Badge;          // 日本語UI
  jpPrompt?: Badge;      // 日本語プロンプト
  freePlan?: Badge;      // 無料プラン
  commercial?: Badge;    // 商用利用
  date?: string;
}
export interface Faq { q: string; a: string; }
export interface RelatedLink { label: string; href: string; }

export interface Props {
  headingHtml?: string;
  lead?: string;
  checkedDate?: string;
  nextCheckDate?: string;
  stats?: Stat[];
  keyPoints?: KeyPoint[];
  disclaimer?: string;
  introHtml?: string;
  diffCards?: DiffCard[];
  diffNote?: string;
  confirmSteps?: ConfirmStep[];
  cautions?: CautionItem[];
  statusTools?: JpToolRow[];
  statusAsOf?: string;
  faqs?: Faq[];
  notes?: string[];
  footnote?: string;
  related?: RelatedLink[];
  toolsBase?: string;          // 既定 /tools/ → /tools/{slug}/
}

