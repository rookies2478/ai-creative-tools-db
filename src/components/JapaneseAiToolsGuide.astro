  .jag-legend .li .jag-st { flex: none; padding: 3px 8px; }
  .jag-foot { margin-top: 12px; font-size: 12px; color: var(--faint); line-height: 1.7; }

  /* FAQ */
  .jag-faq { max-width: 860px; }
  .jag-faqitem { border-bottom: 1px solid var(--line); }
  .jag-faqitem:first-child { border-top: 1px solid var(--line); }
