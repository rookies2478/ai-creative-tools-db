---

<article class="jag-x" data-jag>
  <!-- ===== 記事ヘッダー ===== -->
  <header class="jag-head">
    <div class="jag-meta">
      <span class="jag-pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 5h16M4 12h16M4 19h10"/></svg>
        ガイド
      </span>
      <span class="jag-checked">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        記事内容の最終確認 <b>{checkedDate}</b>
      </span>
    </div>
    <h1 class="jag-h1" set:html={headingHtml}></h1>
    <p class="jag-lead">{lead}</p>
    <div class="jag-stats">
      {stats.map((s) => (
        <div class="jag-stat"><span class="n">{s.n}</span><span class="t">{s.label}</span></div>
      ))}
    </div>
  </header>

  <!-- ===== まとめ + 免責 ===== -->
  <section class="jag-sec reveal">
    <div class="jag-conclusion">
      <div class="ttl"><span class="k">Summary</span></div>
      <h2>このガイドのまとめ</h2>
      <ul class="jag-keylist">
        {keyPoints.map((k) => (<li><span class="kc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span><span class="kt" set:html={k.html}></span></li>))}
      </ul>
    </div>
    <div class="jag-disclaimer">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p><b>免責事項：</b>{disclaimer}</p>
    </div>
  </section>

  <!-- ===== はじめに ===== -->
  <section class="jag-sec">
    <div class="jag-sechead reveal">
      <span class="jag-eyebrow">Introduction</span>
      <h2>はじめに</h2>
    </div>
    <div class="jag-prose reveal" set:html={introHtml}></div>
  </section>

  <!-- ===== 日本語UIと日本語プロンプトの違い ===== -->
  <section class="jag-sec band">
    <div class="jag-sechead reveal">
      <span class="jag-eyebrow">Two meanings</span>
      <h2>日本語UIと日本語プロンプトの違い</h2>
      <p>「日本語対応」には大きく2つの意味があります。混同されがちですが、確認すべき点が異なります。</p>
    </div>
    <div class="jag-cards reveal" data-stagger>
      {diffCards.map((d) => (
        <article class="jag-card">
          <h3>{d.title}</h3>
          <p>{d.body}</p>
          {d.note ? <p class="note"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>{d.note}</p> : null}
        </article>
      ))}
    </div>
    <div class="jag-inlinenote reveal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p>{diffNote}</p>
    </div>
  </section>

  <!-- ===== 日本語対応ツールを選ぶときの確認ポイント ===== -->
  <section class="jag-sec">
    <div class="jag-sechead reveal">
      <span class="jag-eyebrow">How to choose</span>
      <h2>日本語対応ツールを選ぶときの確認ポイント</h2>
      <p>日本語で使いやすいツールを選ぶために、利用前に次の5点を順に確認しておきましょう。</p>
