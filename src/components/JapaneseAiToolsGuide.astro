    <ol class="jag-checks reveal" data-stagger>
      {confirmSteps.map((c, i) => (
        <li class="jag-check">
          <span class="cn">{i + 1}</span>
          <div class="cb">
            <h3 class="jag-h3">{c.title}</h3>
            <div class="jag-richtext" set:html={c.bodyHtml}></div>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ===== 海外AIツールを日本語で使うときの注意点 ===== -->
  <section class="jag-sec band">
    <div class="jag-sechead reveal">
      <span class="jag-eyebrow">Caveats</span>
      <h2>海外AIツールを日本語で使うときの注意点</h2>
      <p>日本語プロンプトに対応していても、海外発のツールならではの注意点があります。</p>
    </div>
    <div class="jag-cards reveal" data-stagger>
      {cautions.map((c) => (
        <article class="jag-card">
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ===== 日本語対応ツール一覧（確認時点） ===== -->
  <section class="jag-sec">
    <div class="jag-sechead reveal">
      <span class="jag-eyebrow">Status index</span>
      <h2>日本語対応ツール一覧（確認時点）</h2>
      <p>以下は <b>{statusAsOf}</b> 時点の調査に基づく目安です。日本語対応状況はアップデートによって変更される可能性があります。詳細は各ツールの詳細ページおよび公式サイトでご確認ください。</p>
    </div>
    <div class="reveal">
      <p class="jag-gtcap">各行の確認日と公式サイトをご確認ください。</p>
      <div class="jag-tablewrap">
        <table class="jag-gt tools">
          <thead><tr><th>ツール</th><th>日本語UI</th><th>日本語プロンプト</th><th>無料プラン</th><th>商用利用条件</th><th>情報確認日</th><th>詳細</th></tr></thead>
          <tbody>
            {statusTools.map((t) => (
              <tr>
                <td><div class="jag-tool"><span class="b">{t.initial}</span><span class="nm">{t.name}</span></div></td>
                <td>{t.jpUI ? <span class={`jag-st ${t.jpUI.s}`}><span class="d"></span>{t.jpUI.label}</span> : <span class="jag-dash">—</span>}</td>
                <td>{t.jpPrompt ? <span class={`jag-st ${t.jpPrompt.s}`}><span class="d"></span>{t.jpPrompt.label}</span> : <span class="jag-dash">—</span>}</td>
                <td>{t.freePlan ? <span class={`jag-st ${t.freePlan.s}`}><span class="d"></span>{t.freePlan.label}</span> : <span class="jag-dash">—</span>}</td>
                <td>{t.commercial ? <span class={`jag-st ${t.commercial.s}`}><span class="d"></span>{t.commercial.label}</span> : <span class="jag-dash">—</span>}</td>
                <td class="jag-date">{t.date}</td>
                <td>{toolUrl(t.slug) ? <a class="jag-detail" href={toolUrl(t.slug)}>詳細 →</a> : null}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="jag-legend">
        <span class="li"><span class="jag-st ok"><span class="d"></span>〇</span> 対応・可能・あり</span>
        <span class="li"><span class="jag-st cond"><span class="d"></span>△</span> 一部対応・条件付き・制限付き</span>
        <span class="li"><span class="jag-st no"><span class="d"></span>×</span> 非対応・なし</span>
        <span class="li"><span class="jag-dash">—</span> 公式情報で確認できていない項目</span>
      </div>
      <p class="jag-foot">※ この表は法的判断の根拠ではありません。日本語対応状況・商用利用可否は、必ず各ツールの最新公式情報をご確認ください。</p>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="jag-sec band">
    <div class="jag-sechead reveal">
      <span class="jag-eyebrow">FAQ</span>
      <h2>よくある質問</h2>
      <p>日本語UI・日本語プロンプト・商用利用について、確認のポイントをお答えします。</p>
    </div>
    <div class="jag-faq reveal">
      {faqs.map((f) => (
        <div class="jag-faqitem" aria-expanded="false">
          <button class="jag-faqq" type="button"><span class="qm">Q</span>{f.q}<span class="ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg></span></button>
          <div class="jag-faqa"><div class="jag-faqa-in" set:html={f.a}></div></div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 注意事項 + 鮮度 ===== -->
  <section class="jag-sec">
    <div class="jag-sechead reveal"><span class="jag-eyebrow">Notes</span><h2>注意事項</h2></div>
    <ul class="jag-notes reveal">
      {notes.map((n) => (<li><span class="dot"></span>{n}</li>))}
    </ul>
    <div class="jag-freshness reveal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
      <span><b>情報の鮮度：</b>記事内容の最終確認日 <span class="mono">{checkedDate}</span>（次回確認予定 <span class="mono">{nextCheckDate}</span>）</span>
    </div>
    <div class="jag-disclaimer reveal" style="margin-top:18px;max-width:820px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p>{footnote}</p>
    </div>
  </section>

  <!-- ===== 関連ページ ===== -->
  <section class="jag-sec" style="padding-bottom:0;">
    <div class="jag-finder reveal">
      <h2>関連ページ</h2>
      <p class="lead">他のガイド・条件ページからも、日本語対応・無料・商用利用の条件を確認できます。</p>
      <div class="jag-taglinks">
        {related.map((r) => (<a class="jag-taglink" href={r.href}><span class="ld"></span>{r.label}</a>))}
      </div>
    </div>
  </section>
</article>

<style>
  /* すべて .jag-x 配下に限定。CSS変数も .jag-x 上に定義（:root非使用）。 */
  .jag-x {
    --paper:#F4F4EE; --surface:#FFFFFF; --surface-2:#FAFAF6;
    --ink:#16181D; --ink-soft:#3A3E47; --muted:#6A7180; --faint:#98A0AD;
    --line:#E3E2D9; --line-strong:#D2D1C6;
    --brand:#4B3FE4; --brand-ink:#2E25A6; --brand-tint:#ECEBFB;
    --video:#E1543A; --video-tint:#FCEDE9; --image:#15897F; --image-tint:#E2F1EF;
    --ok:#1E8A4C; --ok-tint:#E6F3EC; --warn:#A06A09; --warn-tint:#F8EFD9;
    --na:#6A7180; --na-tint:#EFEFEA;
    --f-jp:"Zen Kaku Gothic New","Noto Sans JP",system-ui,sans-serif;
    --f-body:"Noto Sans JP",system-ui,sans-serif;
    --f-latin:"Space Grotesk",system-ui,sans-serif;
    --f-mono:"Space Mono",ui-monospace,monospace;
    --radius:14px; --radius-lg:22px;
    --shadow-sm:0 1px 2px rgba(20,22,28,.04),0 1px 3px rgba(20,22,28,.05);
    --shadow-md:0 4px 14px rgba(20,22,28,.06),0 2px 6px rgba(20,22,28,.04);
    --ease:cubic-bezier(.22,.61,.36,1);

    font-family: var(--f-body);
    color: var(--ink);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }
  .jag-x :where(h1,h2,h3) { font-family: var(--f-jp); font-weight: 700; line-height: 1.32; letter-spacing: .01em; margin: 0; }
  .jag-x :where(p) { margin: 0; }
  .jag-x a { color: inherit; text-decoration: none; }

  /* セクション */
  .jag-sec { padding: 64px 0; }
  .jag-sec.band { background: var(--surface-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .jag-sechead { max-width: 760px; margin-bottom: 32px; }
  .jag-sechead h2 { font-size: clamp(24px, 3vw, 36px); font-weight: 900; letter-spacing: -.005em; margin: 16px 0 12px; }
  .jag-sechead p { color: var(--muted); font-size: 15px; }
  .jag-sechead p b { color: var(--ink-soft); font-weight: 700; }
  .jag-eyebrow { font-family: var(--f-latin); font-size: 12px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: var(--muted); display: inline-flex; align-items: center; gap: 10px; }
  .jag-eyebrow::before { content: ""; width: 22px; height: 2px; border-radius: 2px; background: var(--brand); }

  /* 記事ヘッダー */
  .jag-head { padding-bottom: 8px; }
  .jag-meta { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 16px; }
  .jag-pill { font-family: var(--f-jp); font-weight: 700; font-size: 12px; letter-spacing: .04em; color: var(--brand-ink); background: var(--brand-tint); padding: 5px 13px; border-radius: 999px; display: inline-flex; align-items: center; gap: 7px; }
  .jag-pill svg { width: 13px; height: 13px; }
  .jag-checked { font-family: var(--f-mono); font-size: 12px; color: var(--muted); display: inline-flex; align-items: center; gap: 7px; }
  .jag-checked svg { width: 14px; height: 14px; }
  .jag-checked b { color: var(--ink-soft); font-weight: 700; }
  .jag-h1 { font-size: clamp(27px, 3.6vw, 42px); font-weight: 900; letter-spacing: -.01em; line-height: 1.24; margin: 14px 0 16px; text-wrap: balance; }
  .jag-h1 .hl { color: var(--brand-ink); position: relative; }
  .jag-h1 .hl::after { content: ""; position: absolute; left: 0; right: 0; bottom: .08em; height: .26em; background: color-mix(in srgb, var(--brand) 18%, transparent); z-index: -1; border-radius: 2px; }
  .jag-lead { font-size: 15.5px; color: var(--ink-soft); max-width: 680px; }
  .jag-stats { display: flex; flex-wrap: wrap; gap: 10px 26px; margin-top: 24px; }
  .jag-stat { display: flex; align-items: baseline; gap: 8px; }
  .jag-stat + .jag-stat { padding-left: 26px; border-left: 1px solid var(--line); }
  .jag-stat .n { font-family: var(--f-latin); font-weight: 700; font-size: 24px; color: var(--ink); line-height: 1; }
  .jag-stat .t { font-size: 12.5px; color: var(--muted); white-space: nowrap; }

  /* まとめ + 免責 */
  .jag-conclusion { position: relative; background: var(--brand-tint); border: 1px solid color-mix(in srgb, var(--brand) 24%, var(--line)); border-radius: var(--radius-lg); padding: 30px 34px 28px; overflow: hidden; }
  .jag-conclusion::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 5px; background: var(--brand); }
  .jag-conclusion .ttl { margin-bottom: 8px; }
  .jag-conclusion .ttl .k { font-family: var(--f-latin); font-size: 11px; font-weight: 600; letter-spacing: .2em; text-transform: uppercase; color: var(--brand); }
  .jag-conclusion h2 { font-size: 21px; font-weight: 900; color: var(--brand-ink); line-height: 1.3; margin-bottom: 16px; }
  .jag-keylist { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 12px; }
  .jag-keylist li { display: grid; grid-template-columns: auto 1fr; gap: 12px; align-items: start; }
  .jag-keylist .kc { width: 24px; height: 24px; border-radius: 7px; background: color-mix(in srgb, var(--brand) 14%, transparent); display: grid; place-items: center; flex: none; margin-top: 1px; }
  .jag-keylist .kc svg { width: 14px; height: 14px; color: var(--brand); }
  .jag-keylist .kt { font-size: 14.5px; color: var(--ink-soft); line-height: 1.75; }
  .jag-keylist .kt b { color: var(--brand-ink); font-weight: 700; }

  .jag-disclaimer { display: flex; align-items: flex-start; gap: 12px; background: var(--surface-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 20px; margin-top: 18px; }
  .jag-disclaimer svg { width: 18px; height: 18px; color: var(--muted); flex: none; margin-top: 2px; }
  .jag-disclaimer p { font-size: 12.5px; color: var(--muted); line-height: 1.75; }
  .jag-disclaimer b { color: var(--ink-soft); font-weight: 700; }

  /* はじめに（プロース） */
  .jag-prose { max-width: 820px; }
  .jag-prose :where(p) { font-size: 15px; color: var(--ink-soft); line-height: 1.95; }
  .jag-prose :where(p) + :where(p) { margin-top: 14px; }
  .jag-prose b { color: var(--ink); font-weight: 700; }

  /* 2カラムカード（違い / 注意点 共通） */
  .jag-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .jag-card { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px 26px; box-shadow: var(--shadow-sm); transition: transform .2s var(--ease), box-shadow .2s, border-color .2s; }
  .jag-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: color-mix(in srgb, var(--brand) 26%, var(--line)); }
  .jag-card h3 { display: flex; align-items: center; gap: 11px; font-family: var(--f-jp); font-weight: 700; font-size: 17px; color: var(--ink); margin-bottom: 10px; }
  .jag-card h3::before { content: ""; width: 4px; height: 18px; border-radius: 2px; background: var(--brand); flex: none; }
  .jag-card > p { font-size: 13.5px; color: var(--ink-soft); line-height: 1.8; }
  .jag-card .note { display: flex; align-items: flex-start; gap: 8px; margin-top: 14px; padding: 12px 14px; background: var(--surface-2); border: 1px solid var(--line); border-radius: 10px; font-size: 12.5px; color: var(--muted); line-height: 1.7; }
  .jag-card .note svg { width: 15px; height: 15px; color: var(--muted); flex: none; margin-top: 2px; }

  /* 確認ポイント（番号付きステップ） */
  .jag-checks { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .jag-check { display: grid; grid-template-columns: auto 1fr; gap: 18px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px 26px; align-items: start; }
  .jag-check .cn { font-family: var(--f-latin); font-weight: 700; font-size: 15px; color: #fff; background: var(--brand); width: 34px; height: 34px; border-radius: 9px; display: grid; place-items: center; flex: none; }
  .jag-check .cb { min-width: 0; }
  .jag-h3 { font-family: var(--f-jp); font-weight: 700; font-size: 17px; color: var(--ink); margin-bottom: 8px; }
  .jag-richtext :where(p) { font-size: 14px; color: var(--ink-soft); line-height: 1.85; max-width: 820px; }
  .jag-richtext :where(p) + :where(p) { margin-top: 12px; }
  .jag-richtext .em { color: var(--ink); }
  .jag-richtext b { color: var(--brand-ink); font-weight: 700; }

  .jag-inlinenote { display: flex; align-items: flex-start; gap: 12px; margin-top: 18px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 20px; max-width: 880px; }
  .jag-inlinenote svg { width: 18px; height: 18px; color: var(--brand); flex: none; margin-top: 2px; }
  .jag-inlinenote p { font-size: 13px; color: var(--ink-soft); line-height: 1.75; }

  /* ガイド表 */
  .jag-gtcap { font-size: 12.5px; color: var(--muted); margin-bottom: 12px; }
  .jag-tablewrap { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); box-shadow: var(--shadow-sm); }
  table.jag-gt { width: 100%; border-collapse: collapse; }
  table.jag-gt.tools { min-width: 960px; }
  table.jag-gt thead th { font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; color: var(--ink-soft); background: var(--surface-2); padding: 14px 18px; text-align: left; border-bottom: 1px solid var(--line); white-space: nowrap; }
  table.jag-gt tbody td { padding: 14px 18px; border-bottom: 1px solid var(--line); vertical-align: middle; }
  table.jag-gt tbody tr:last-child td { border-bottom: none; }
  table.jag-gt tbody tr { transition: background .12s; }
  table.jag-gt tbody tr:hover { background: var(--surface-2); }
  .jag-tool { display: flex; align-items: center; gap: 11px; min-width: 150px; }
  .jag-tool .b { width: 32px; height: 32px; border-radius: 9px; display: grid; place-items: center; background: var(--brand-tint); color: var(--brand-ink); font-family: var(--f-latin); font-weight: 700; font-size: 14px; flex: none; }
  .jag-tool .nm { font-family: var(--f-jp); font-weight: 700; font-size: 14px; color: var(--ink); line-height: 1.3; white-space: nowrap; }
  .jag-date { font-family: var(--f-mono); font-size: 12px; color: var(--muted); white-space: nowrap; }
  .jag-detail { font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; color: var(--brand-ink); white-space: nowrap; }
  .jag-detail:hover { text-decoration: underline; text-underline-offset: 3px; }
  .jag-dash { color: var(--faint); font-size: 13px; }

  /* ステータスバッジ */
  .jag-st { display: inline-flex; align-items: center; gap: 6px; flex: none; font-family: var(--f-jp); font-weight: 700; font-size: 12px; line-height: 1.2; padding: 5px 11px; border-radius: 999px; white-space: nowrap; }
  .jag-st .d { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
