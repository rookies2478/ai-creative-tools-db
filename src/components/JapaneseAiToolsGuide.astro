  .jag-faqq .qm { font-family: var(--f-latin); color: var(--brand); font-size: 16px; flex: none; }
  .jag-faqq .ind { margin-left: auto; flex: none; width: 24px; height: 24px; display: grid; place-items: center; transition: transform .3s var(--ease); color: var(--muted); }
