  .jag-faqitem[aria-expanded="true"] .jag-faqq .ind { transform: rotate(45deg); color: var(--brand); }
  .jag-faqa { max-height: 0; overflow: hidden; transition: max-height .35s var(--ease); }
  .jag-faqa-in { padding: 0 6px 26px 46px; color: var(--ink-soft); font-size: 14.5px; line-height: 1.8; }
  .jag-faqa-in a { color: var(--brand-ink); font-weight: 600; }

  /* 注意事項 + 鮮度 */
  .jag-notes { list-style: none; display: flex; flex-direction: column; gap: 12px; max-width: 820px; margin: 0; padding: 0; }
  .jag-notes li { display: grid; grid-template-columns: auto 1fr; gap: 12px; align-items: start; font-size: 13.5px; color: var(--ink-soft); line-height: 1.75; }
  .jag-notes li .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--brand); flex: none; margin-top: 9px; }
  .jag-freshness { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 24px; background: var(--surface); border: 1px solid var(--line); border-radius: 999px; padding: 11px 20px; font-size: 13px; color: var(--ink-soft); max-width: max-content; }
  .jag-freshness svg { width: 16px; height: 16px; color: var(--brand); flex: none; }
  .jag-freshness b { font-weight: 700; color: var(--ink); }
  .jag-freshness .mono { font-family: var(--f-mono); font-size: 12.5px; }

  /* 関連 */
  .jag-finder { background: var(--surface-2); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 34px 34px 30px; }
  .jag-finder h2 { font-size: clamp(20px, 2.4vw, 26px); margin-bottom: 6px; }
  .jag-finder .lead { color: var(--muted); font-size: 14px; margin-bottom: 22px; }
  .jag-taglinks { display: flex; flex-wrap: wrap; gap: 10px; }
  .jag-taglink { font-family: var(--f-jp); font-weight: 600; font-size: 13.5px; padding: 9px 16px; border-radius: 999px; background: var(--surface); border: 1px solid var(--line-strong); color: var(--ink-soft); display: inline-flex; align-items: center; gap: 7px; white-space: nowrap; transition: transform .16s var(--ease), background .16s, border-color .16s, color .16s; }
  .jag-taglink:hover { border-color: var(--brand); color: var(--brand-ink); background: var(--brand-tint); transform: translateY(-1px); }
  .jag-taglink .ld { width: 7px; height: 7px; border-radius: 50%; background: var(--brand); flex: none; }

  /* スクロール表示アニメ */
  @media (prefers-reduced-motion: no-preference) {
    .jag-x .reveal { opacity: 0; transform: translateY(18px); transition: opacity .6s var(--ease), transform .6s var(--ease); }
    .jag-x .reveal.in { opacity: 1; transform: none; }
    .jag-x .reveal[data-stagger] > * { opacity: 0; transform: translateY(16px); transition: opacity .5s var(--ease), transform .5s var(--ease); }
    .jag-x .reveal[data-stagger].in > * { opacity: 1; transform: none; }
    .jag-x .reveal[data-stagger].in > *:nth-child(1) { transition-delay: .04s; }
    .jag-x .reveal[data-stagger].in > *:nth-child(2) { transition-delay: .09s; }
    .jag-x .reveal[data-stagger].in > *:nth-child(3) { transition-delay: .14s; }
    .jag-x .reveal[data-stagger].in > *:nth-child(4) { transition-delay: .19s; }
    .jag-x .reveal[data-stagger].in > *:nth-child(5) { transition-delay: .24s; }
  }
  @media (prefers-reduced-motion: reduce) {
    .jag-x .reveal, .jag-x .reveal[data-stagger] > * { opacity: 1 !important; transform: none !important; }
  }

  /* レスポンシブ */
  @media (max-width: 980px) {
    .jag-cards { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .jag-sec { padding: 48px 0; }
    .jag-conclusion { padding: 24px 22px; }
    .jag-check { padding: 20px; gap: 14px; }
    .jag-card { padding: 22px 20px; }
    .jag-stat + .jag-stat { padding-left: 0; border-left: none; }
  }
</style>

<script>
  // JSは [data-jag] 配下のみ操作（既存サイトに干渉しない）
  (function () {
    document.querySelectorAll('[data-jag]').forEach(function (root) {
      // FAQ 開閉（1つ開くと他は閉じる）
      var faq = root.querySelector('.jag-faq');
      if (faq) {
        faq.addEventListener('click', function (e) {
          var target = e.target as HTMLElement;
          var btn = target.closest('.jag-faqq');
          if (!btn) return;
          var item = btn.closest('.jag-faqitem') as HTMLElement;
          var open = item.getAttribute('aria-expanded') === 'true';
          faq.querySelectorAll('.jag-faqitem').forEach(function (it) {
            it.setAttribute('aria-expanded', 'false');
            var a = it.querySelector('.jag-faqa') as HTMLElement | null;
            if (a) a.style.maxHeight = '';
          });
          if (!open) {
            item.setAttribute('aria-expanded', 'true');
            var a = item.querySelector('.jag-faqa') as HTMLElement | null;
            if (a) a.style.maxHeight = a.scrollHeight + 'px';
          }
        });
      }

      // スクロール表示アニメ（prefers-reduced-motion 尊重・8秒フェイルセーフ）
      var reveals = Array.prototype.slice.call(root.querySelectorAll('.reveal'));
      if (!reveals.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach(function (el) { io.observe(el); });
      setTimeout(function () { reveals.forEach(function (el) { el.classList.add('in'); }); }, 8000);
    });
  })();
</script>
