  { name:'InVideo AI', slug:'invideo-ai', initial:'I', free:'あり', ja:'要確認', commercial:'要確認', wm:'paid',
    wmNote:'無料プランでは透かしあり、有料プランでは透かしなしで出力できるとされています。',
    freeNote:'無料プランあり（透かしあり・エクスポート制限あり）。詳細は公式サイトをご確認ください。' },
  { name:'Runway', slug:'runway', initial:'R', free:'要確認', ja:'要確認', commercial:'要確認', wm:'paid',
    wmNote:'無料プランでは透かしあり、有料プランでは透かしなしとされています。',
    freeNote:'125クレジット（初回のみ・更新なし）とされています。' },
  { name:'Stable Diffusion', slug:'stable-diffusion', initial:'S', free:'あり', ja:'要確認', commercial:'要確認', wm:'meta',
    wmNote:'一部バージョンで不可視透かし（invisible watermark）が埋め込まれる場合があるとされています。可視透かしは通常入りませんが、利用環境やモデルによって異なる可能性があります。',
    freeNote:'ローカル実行は無料（GPU搭載PCと環境構築が必要）。' },
  { name:'Vidu AI', slug:'vidu-ai', initial:'V', free:'要確認', ja:'要確認', commercial:'要確認', wm:'paid',
    wmNote:'無料プランでは透かしありとされています。有料プランの透かし条件は公式サイトをご確認ください。',
    freeNote:'無料枠あり（制限あり）。詳細は公式サイトをご確認ください。' },
];

const DEFAULT_FAQS: Faq[] = [
  { q:'透かしなしで使えるAI画像生成ツールはありますか？', a:'透かし条件はプランや機能によって変わる可能性があります。無料プランでも透かしなしで出力できるツールがある一方、有料プランへの移行で透かしが外れるツールもあります。上の一覧表の「透かし条件」欄で各ツールの状況を確認し、実際の出力画面で透かしの有無をご確認ください。' },
  { q:'無料プランでは透かしが入りますか？', a:'ツールによって異なります。無料プランで透かしなしの出力ができるものもあれば、透かしが入るものもあります。透かし条件はプランや出力形式によって変わる可能性があるため、各ツールの公式情報でご確認ください。無料プランの詳細は<a href="/conditions/free/">無料で使えるツール</a>のページも参照してください。' },
  { q:'有料プランにすると透かしは消えますか？', a:'有料プランでは透かしなしになる場合があります。ただし、出力形式（静止画・動画・編集機能など）によって透かし条件が異なる可能性があります。最新の公式情報で対象プランと機能を確認したうえで、実際の出力画面で透かしの有無をご確認ください。' },
  { q:'YouTubeサムネやSNS画像で透かしは問題になりますか？', a:'YouTubeサムネイル・SNS画像・広告バナー・商品画像などで透かし入りの画像を使うと、見栄えや信頼性に影響する場合があります。収益化を伴う用途では特に注意が必要です。透かしの有無に加え、商用利用条件も公式規約で事前に確認することを推奨します。<a href="/conditions/commercial-use/">商用利用条件を確認しやすいツール</a>のページもご参照ください。本記事は法的助言ではありません。' },
  { q:'商用利用では透かし以外に何を確認すべきですか？', a:'透かしを除去できることと商用利用が許可されていることは別の問題です。商用利用を前提にする場合は、①利用規約における商用利用の定義と許可範囲、②プランごとの条件、③クレジット表記義務、④禁止コンテンツ・用途の制限、を最新の公式規約でご確認ください。<a href="/conditions/commercial-use/">商用利用条件のまとめページ</a>も参考にしてください。本記事は法的助言ではありません。' },
  { q:'透かしの有無はどこで確認すればいいですか？', a:'公式情報や実際の出力画面で確認する必要があります。本サイトの一覧表は確認時点の情報をまとめたものですが、ツール側の方針変更により条件が変わる場合があります。<a href="/tools/">各ツールの詳細ページ</a>に公式情報へのリンクを掲載していますので、あわせてご活用ください。' },
];

const {
  headingHtml = '透かし条件を確認しやすい<span class="hl">AIツール</span>比較',
  lead = 'AI生成画像や動画をSNS画像・YouTubeサムネイル・広告バナー・商品画像などに使う場合、透かしの有無は重要な確認ポイントです。このページでは、透かしなし、または条件付きで透かしを外せる可能性のあるツールを整理しています。透かし条件はプラン・機能・出力形式によって変わる場合があるため、最新情報は各ツールの公式サイト・実際の出力画面でご確認ください。',
  notice = '透かしの有無は、無料プラン・有料プラン・出力形式によって変わる場合があります。また、透かしを除去できることと商用利用が許可されていることは別の問題です。掲載情報は調査時点の内容であり、実務利用前には必ず各ツールの公式サイト・最新の利用規約をご確認ください。本サイトの内容は法的助言ではありません。',
  toolsBase = '/tools/',
  stats = [
    { n:'12', label:'対象ツール' },
    { n:'4',  label:'透かしタイプ' },
    { n:'6',  label:'よくある質問' },
  ],
  points = DEFAULT_POINTS,
  tools = DEFAULT_TOOLS,
  faqs = DEFAULT_FAQS,
  related = [
    { label:'無料で使えるツール', href:'/conditions/free/' },
    { label:'商用利用を確認しやすいツール', href:'/conditions/commercial-use/' },
    { label:'日本語対応ツール', href:'/conditions/japanese/' },
    { label:'透かし・クレジット表記ガイド', href:'/guides/watermark-credit-guide/' },
    { label:'商用利用・著作権ガイド', href:'/guides/commercial-use-copyright/' },
    { label:'AI動画生成ツール一覧', href:'/categories/video-generation/' },
    { label:'全ツール比較表', href:'/comparisons/', solid:true },
    { label:'すべてのツールを見る', href:'/tools/', solid:true },
    { label:'AI画像生成ツール一覧', href:'/categories/image-generation/', solid:true },
  ] as RelatedLink[],
} = Astro.props;

const relStd = related.filter((r) => !r.solid);
const relSolid = related.filter((r) => r.solid);

/* ○/△/× の判定（参考列ごとの意味づけ） */
function mark(field: 'free' | 'ja' | 'commercial', val: string) {
  let cls = 'cond', ch = '△';
  if (field === 'free') { if (val === 'あり') { cls = 'yes'; ch = '○'; } else if (val === 'なし') { cls = 'no'; ch = '×'; } }
  else if (field === 'ja') { if (val === '対応') { cls = 'yes'; ch = '○'; } else if (val === '非対応') { cls = 'no'; ch = '×'; } }
  else if (field === 'commercial') { if (val === '案内あり' || val === 'あり') { cls = 'yes'; ch = '○'; } else if (val === '不可' || val === 'なし') { cls = 'no'; ch = '×'; } }
  return { cls, ch };
}
const ini = (t: Tool) => t.initial ?? t.name.charAt(0);
const presentStatuses = Array.from(new Set(tools.map((t) => t.wm)));
const filterChips: { st: WmStatus | 'all'; label: string }[] = [
  { st: 'all', label: 'すべて' },
  ...(['none','paid','meta','unknown'] as WmStatus[]).filter((s) => presentStatuses.includes(s)).map((s) => ({ st: s, label: STATUS[s].label })),
];
---

<div class="nw-x" data-nw>

  <!-- ===== 見出し ===== -->
  <header class="nw-head">
    <span class="eyebrow">No watermark</span>
    <h1 set:html={headingHtml}></h1>
    <p class="lead">{lead}</p>
    {stats.length > 0 && (
      <div class="stats">
        {stats.map((s) => (<div class="stat"><span class="n">{s.n}</span><span class="t">{s.label}</span></div>))}
      </div>
    )}
  </header>

  <!-- ===== 注意 ===== -->
  {notice && (
    <div class="notice">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p><b>ご利用前の注意：</b>{notice}</p>
    </div>
  )}

  <!-- ===== 透かしステータスの見方 ===== -->
  <section class="nw-sec">
    <div class="sec-head">
      <span class="eyebrow">Status legend</span>
      <h2>透かしステータスの見方</h2>
      <p>各ツールの透かし条件は、確認時点の公式情報をもとに以下の4タイプで整理しています。透かしの有無はプラン・機能・出力形式によって変わる場合があります。実務利用前には実際の出力画面と公式情報でご確認ください。</p>
    </div>
    <div class="status-grid">
      <div class="status-card none"><span class="st none"><span class="d"></span>透かしなし <small>none</small></span><p>公式情報上、可視透かしが入らないと案内されているツールです。仕様は変更される可能性があるため、出力画面でご確認ください。</p></div>
      <div class="status-card paid"><span class="st paid"><span class="d"></span>有料で除去 <small>paid</small></span><p>無料プランでは透かしが入り、有料プランで透かしなし出力ができる場合があるツールです。対象プランを公式情報で確認してください。</p></div>
      <div class="status-card meta"><span class="st meta"><span class="d"></span>メタデータ型 <small>meta</small></span><p>可視透かしは入らないものの、C2PAなどの不可視メタデータ（来歴情報）が埋め込まれる場合があるツールです。</p></div>
      <div class="status-card unknown"><span class="st unknown"><span class="d"></span>要確認 <small>unknown</small></span><p>公式情報から透かし条件を確認できていないツールです。利用前に必ず公式情報と出力画面をご確認ください。</p></div>
    </div>
  </section>

  <!-- ===== 比較するときのポイント ===== -->
  <section class="nw-sec band">
    <div class="sec-head">
      <span class="eyebrow">Checkpoints</span>
      <h2>透かし条件を比較するときのポイント</h2>
      <p>「透かしなし」と案内されていても、プランや機能によって条件は変わります。実務で使う前に確認しておきたい観点を整理しました。</p>
    </div>
    <ol class="points">
      {points.map((p, i) => (
        <li><span class="pn">{String(i + 1).padStart(2, '0')}</span><span class="pt"><b>{p.title}：</b><span set:html={p.body}></span></span></li>
      ))}
    </ol>
  </section>

  <!-- ===== 対象ツール一覧 ===== -->
  <section class="nw-sec">
    <div class="sec-head">
      <span class="eyebrow">Tool index</span>
      <h2>対象ツール一覧</h2>
      <p>確認時点で{tools.length}件。「有料で除去」は無料プランで透かしあり、有料プランで除去できる場合があることを示します。透かしステータスで絞り込み、各ツールの詳細ページで条件を確認してください。絞り込み・検索は下の「各ツールの透かし・無料枠条件」にも反映されます。</p>
    </div>

    <div class="statusbar">
      <span class="sb-label">透かし</span>
      <div class="sfilter">
        {filterChips.map((c) => (
          <button class="schip" data-st={c.st} aria-pressed={c.st === 'all' ? 'true' : 'false'}>
            {c.st !== 'all' && (<span class="d" data-tone={c.st}></span>)}{c.label}
          </button>
        ))}
      </div>
      <div class="statusbar-right">
        <label class="nw-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20.5 20.5-4-4"/></svg>
          <input type="search" data-search placeholder="ツール名で検索" aria-label="ツール名で検索" />
        </label>
        <span class="nw-count" data-count><b>{tools.length}</b> 件</span>
      </div>
    </div>

    <div class="nw-table-wrap">
      <table class="nw-tbl">
        <thead>
          <tr><th class="col-tool">ツール</th><th>無料枠</th><th>日本語対応</th><th>商用利用条件</th><th>透かし条件</th><th>詳細</th></tr>
        </thead>
        <tbody>
          {tools.map((t) => {
            const f = mark('free', t.free), j = mark('ja', t.ja), c = mark('commercial', t.commercial);
            return (
              <tr data-name={t.name.toLowerCase()} data-st={t.wm}>
                <td><div class="nw-tool"><span class="b">{ini(t)}</span><span class="nm">{t.name}</span></div></td>
                <td><span class={`mk ${f.cls}`} title={t.free}>{f.ch}</span></td>
                <td><span class={`mk ${j.cls}`} title={t.ja}>{j.ch}</span></td>
                <td><span class={`mk ${c.cls}`} title={t.commercial}>{c.ch}</span></td>
                <td><span class={`st ${STATUS[t.wm].cls}`}><span class="d"></span>{STATUS[t.wm].label}</span></td>
                <td><a class="nw-detail" href={`${toolsBase}${t.slug}/`}>詳細 →</a></td>
              </tr>
            );
          })}
          <tr class="nw-empty-row" hidden><td colspan="6">条件に一致するツールはありません。</td></tr>
        </tbody>
      </table>
    </div>
    <div class="nw-legend">
      <span class="li"><span class="st none"><span class="d"></span>透かしなし</span></span>
