---
/**
 * NoWatermark.astro
 * 「透かし条件を確認しやすいAIツール比較」条件ページ本文
 *  — 見出し ＋ 透かしステータス凡例 ＋ 透かし条件を比較するときのポイント
 *    ＋ 対象ツール表（無料枠/日本語/商用利用 ＋ 透かしステータスバッジ）
 *    ＋ 透かしステータス絞り込み＋検索 ＋ 各ツールの透かし・無料枠条件カード ＋ FAQ ＋ 関連ページ
 *
 * 安全性（Tailwind / 既存ページを壊さない）:
 *  - スタイルは Astro scoped <style>。全セレクタを .nw-x 配下に限定 → 漏れない。
 *  - CSS変数は :root でなく .nw-x 上に定義 → 既存トークンと非衝突。
 *  - 素のリセット（* / body / table 等の global 指定）なし → Tailwind preflight 非干渉。
 *  - 表・カードは SSR で描画。JS は [data-nw] 配下のみ操作（絞り込み/検索/FAQ/表示アニメ）。
 *
 * ヘッダー / フッター / パンくず / 条件ナビ は既存 Layout 側のものを使う想定。
 */
export type WmStatus = 'none' | 'paid' | 'meta' | 'unknown';
export interface Tool {
  name: string;
  slug: string;            // /tools/{slug}/ へのリンクに使用
  initial?: string;        // バッジ頭文字（省略時は name の先頭）
  free: string;            // 無料枠: 'あり' | 'なし' | '要確認'
  ja: string;              // 日本語: '対応' | '非対応' | '要確認'
  commercial: string;      // 商用利用: '案内あり' | '不可' | '要確認' など（参考列・○/△/×）
  wm: WmStatus;            // 透かしステータス（バッジ＋絞り込み）
  wmNote: string;          // 透かし条件の説明（プレーンテキスト）
  freeNote: string;        // 無料枠の条件の説明（プレーンテキスト）
}
export interface Point { title: string; body: string; }   // body は HTML 文字列可
export interface Faq { q: string; a: string; }             // a は HTML 文字列可
export interface RelatedLink { label: string; href: string; solid?: boolean; }

export interface Props {
  headingHtml?: string;
  lead?: string;
  notice?: string;
  toolsBase?: string;          // 詳細リンクのベース（既定 '/tools/'）
  stats?: { n: string; label: string }[];
  points?: Point[];
  tools?: Tool[];
  faqs?: Faq[];
  related?: RelatedLink[];
}

const STATUS: Record<WmStatus, { label: string; cls: string }> = {
  none:    { label: '透かしなし',  cls: 'none' },
  paid:    { label: '有料で除去',  cls: 'paid' },
  meta:    { label: 'メタデータ型', cls: 'meta' },
  unknown: { label: '要確認',      cls: 'unknown' },
};

const DEFAULT_POINTS: Point[] = [
  { title:'プランごとの透かし条件', body:'<a href="/conditions/free/">無料プランでは透かしが入る場合があります</a>。有料プランに移行すると透かしなしになる場合があります。プランごとの条件を公式情報で確認してください。' },
  { title:'機能・出力形式ごとの違い', body:'生成画像・編集画像・動画生成で透かし条件が異なる可能性があります。使いたい機能に対応した条件を個別に確認してください。' },
  { title:'用途別の注意点', body:'SNS画像・YouTubeサムネイル・広告バナー・商品画像など、透かしが問題になりやすい用途では特に注意が必要です。実際の出力画面で透かしの有無をご確認ください。' },
  { title:'商用利用条件は別問題', body:'透かしを除去できることと商用利用が許可されていることは別の問題です。<a href="/conditions/commercial-use/">商用利用条件</a>はツールの公式規約で確認する必要があります。本記事は法的助言ではありません。' },
  { title:'公式情報で最終確認', body:'本サイトの情報は確認時点のものです。ツール側の方針変更により条件が変わる場合があります。<a href="/tools/">各ツールの詳細ページ</a>の公式リンクから最新情報をご確認ください。' },
];

const DEFAULT_TOOLS: Tool[] = [
  { name:'Adobe Firefly', slug:'adobe-firefly', initial:'A', free:'要確認', ja:'対応', commercial:'要確認', wm:'meta',
    wmNote:'プランによっては可視透かしが入る場合があります。全プランでC2PAメタデータ（コンテンツクレデンシャル）が埋め込まれるとされています。最新の公式情報と実際の出力画面でご確認ください。',
    freeNote:'無料プランで一定数の生成クレジットがあるとされています（数量は変更の可能性あり）。' },
  { name:'DALL·E', slug:'dalle', initial:'D', free:'要確認', ja:'対応', commercial:'案内あり', wm:'meta',
    wmNote:'C2PAメタデータ（不可視）が埋め込まれる場合があるとされています。可視透かしの有無は出力形式・利用環境によって異なる可能性があります。',
    freeNote:'ChatGPT無料プランで制限付き利用できる場合があります。' },
  { name:'Hailuo AI', slug:'hailuo-ai', initial:'H', free:'要確認', ja:'要確認', commercial:'要確認', wm:'paid',
    wmNote:'無料プランでは透かしありとされています。有料プランの透かし条件は公式サイトをご確認ください。',
