---
import { getCollection } from 'astro:content';
import ToolCard from './ToolCard.astro';

interface Props {
  currentSlug: string;
  category: 'image' | 'video' | 'both';
}

const { currentSlug, category } = Astro.props;
const allTools = await getCollection('tools');
const related = allTools
  .filter((t) => t.slug !== currentSlug && t.data.category === category)
  .slice(0, 3);
---

{related.length > 0 && (
  <section class="mb-10">
    <h2 class="mb-4 text-lg font-semibold text-gray-800">このツールと比較されるAIツール</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>
)}
