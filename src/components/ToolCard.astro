---
import type { CollectionEntry } from 'astro:content';
import ToolLogo from './ToolLogo.astro';
import FreshnessLabel from './FreshnessLabel.astro';
import { getCategoryLabel, getPlatformLabel } from '../data/labelDictionary';

interface Props {
  tool: CollectionEntry<'tools'>;
}

type FreePlan = boolean | 'limited' | 'unknown';
type FourState = 'yes' | 'no' | 'limited' | 'unknown';
type CommercialUse = 'ok' | 'paid-only' | 'limited' | 'no' | 'unknown';
type TriState = boolean | 'partial' | 'unknown';

const { tool } = Astro.props;
const { data, slug } = tool;

function freeBadge(val: FreePlan) {
  if (val === true)      return { text: '無料枠あり',   cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === false)     return { text: '無料枠なし',   cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
  if (val === 'limited') return { text: '無料枠：条件付き', cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
                         return { text: '無料枠：要公式確認', cls: 'bg-slate-50 text-slate-400 ring-1 ring-inset ring-slate-100' };
}

function cuBadge(val: CommercialUse) {
  if (val === 'ok')        return { text: '商用利用：案内あり',      cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === 'paid-only') return { text: '商用利用：有料プラン向け', cls: 'bg-sky-50 text-sky-700 ring-1 ring-inset ring-sky-200' };
  if (val === 'limited')   return { text: '商用利用：条件あり',       cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
  if (val === 'no')        return { text: '商用利用：非対応',         cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
                           return { text: '商用利用：要公式確認',     cls: 'bg-slate-50 text-slate-400 ring-1 ring-inset ring-slate-100' };
}

function jpBadge(ui: TriState, prompt: TriState) {
  if (ui === true)                       return { text: '日本語：対応',  cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (ui === false && prompt === false)   return { text: '日本語：非対応', cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
                                          return { text: '日本語：要確認', cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
}

function wmBadge(val: FourState) {
  if (val === 'no')      return { text: '透かしなし',   cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === 'yes')     return { text: '透かしあり',   cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
  if (val === 'limited') return { text: 'プランによって異なる', cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
                         return { text: '要確認',       cls: 'bg-slate-50 text-slate-400 ring-1 ring-inset ring-slate-100' };
}


const displayPlatforms = (data.platforms ?? []).slice(0, 3);

const fp = freeBadge(data.freePlan);
const cu = cuBadge(data.commercialUse);
const jp = jpBadge(data.japaneseUi, data.japanesePrompt);
const wm = wmBadge(data.watermark);
---

<div class="flex flex-col rounded-2xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-blue-100 hover:shadow-md">
  <!-- Header: logo + name + category -->
  <div class="mb-3 flex items-center gap-3">
    <ToolLogo slug={slug} name={data.name} size="sm" />
    <div class="min-w-0">
      <p class="truncate font-bold text-slate-900">{data.name}</p>
      <span class="text-[10px] font-medium text-blue-600">{getCategoryLabel(data.category)}</span>
    </div>
  </div>

  <!-- Badges -->
  <div class="flex flex-wrap gap-2">
    <span class={`rounded px-2 py-0.5 text-[11px] font-medium ${cu.cls}`}>{cu.text}</span>
    <span class={`rounded px-2 py-0.5 text-[11px] font-medium ${fp.cls}`}>{fp.text}</span>
    <span class={`rounded px-2 py-0.5 text-[11px] font-medium ${jp.cls}`}>{jp.text}</span>
    <span class={`rounded px-2 py-0.5 text-[11px] font-medium ${wm.cls}`}>{wm.text}</span>
    {data.lowestPaidPlan && (
      <span class="rounded px-2 py-0.5 text-xs font-semibold text-slate-800 bg-slate-50 ring-1 ring-inset ring-slate-200">
        {data.lowestPaidPlan}
      </span>
    )}
  </div>

  <!-- Platforms -->
  {displayPlatforms.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1.5">
      {displayPlatforms.map((p) => (
        <span class="rounded px-1.5 py-0.5 text-[10px] font-medium bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200">
          {getPlatformLabel(p)}
        </span>
      ))}
    </div>
  )}

  <!-- 鮮度ラベル -->
  <div class="mt-3">
    <FreshnessLabel verifiedAt={data.verifiedAt} lastReviewed={data.lastReviewed} variant="card" />
  </div>

  <!-- Buttons -->
  <div class="mt-auto pt-4 flex flex-col gap-2">
    <a
      href={`/tools/${slug}/`}
      class="block rounded-lg bg-blue-600 px-4 py-2 text-center text-sm font-semibold text-white transition hover:bg-blue-700"
    >
      詳しく見る
    </a>
    <a
      href={data.officialUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block rounded-lg border border-slate-200 px-4 py-2 text-center text-sm text-slate-600 transition hover:border-slate-300 hover:bg-slate-50"
    >
      公式サイトで確認 ↗
    </a>
  </div>
</div>
