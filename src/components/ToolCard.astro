---
import type { CollectionEntry } from 'astro:content';
import ToolLogo from './ToolLogo.astro';

interface Props {
  tool: CollectionEntry<'tools'>;
}

type FreePlan = boolean | 'limited' | 'unknown';
type FourState = 'yes' | 'no' | 'limited' | 'unknown';
type TriState = boolean | 'partial' | 'unknown';

const { tool } = Astro.props;
const { data, slug } = tool;

function freeBadge(val: FreePlan) {
  if (val === true)      return { text: '無料枠あり',  cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === 'limited') return { text: '制限あり',    cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
  if (val === false)     return { text: '有料のみ',    cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
                         return { text: '要確認',      cls: 'bg-slate-50 text-slate-400 ring-1 ring-inset ring-slate-100' };
}

function cuBadge(val: FourState) {
  if (val === 'yes')     return { text: '商用OK',         cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === 'limited') return { text: '条件あり',        cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
  if (val === 'no')      return { text: '不可の場合あり',  cls: 'bg-red-50 text-red-500 ring-1 ring-inset ring-red-200' };
                         return { text: '要確認',          cls: 'bg-slate-50 text-slate-400 ring-1 ring-inset ring-slate-100' };
}

function jpBadge(ui: TriState, prompt: TriState) {
  if (ui === true)                                                 return { text: '日本語UI',   cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (ui === 'partial' || prompt === true || prompt === 'partial') return { text: '一部日本語', cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
  if (ui === false && prompt === false)                            return { text: '日本語×',    cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
                                                                   return { text: '要確認',    cls: 'bg-slate-50 text-slate-400 ring-1 ring-inset ring-slate-100' };
}

function wmBadge(val: FourState) {
  if (val === 'no')      return { text: '透かしなし',   cls: 'bg-emerald-50 text-emerald-700 ring-1 ring-inset ring-emerald-200' };
  if (val === 'yes')     return { text: '透かしあり',   cls: 'bg-slate-100 text-slate-500 ring-1 ring-inset ring-slate-200' };
  if (val === 'limited') return { text: 'プランによる', cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200' };
                         return { text: '要確認',       cls: 'bg-slate-50 text-slate-400 ring-1 ring-inset ring-slate-100' };
}

function catLabel(cat: string) {
  if (cat === 'image') return '画像生成';
  if (cat === 'video') return '動画生成';
  return '画像・動画';
}

const fp = freeBadge(data.freePlan);
const cu = cuBadge(data.commercialUse);
const jp = jpBadge(data.japaneseUi, data.japanesePrompt);
const wm = wmBadge(data.watermark);
---

<a
  href={`/tools/${slug}/`}
  class="group flex flex-col rounded-2xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-blue-100 hover:shadow-md"
>
  <!-- Header: logo + name + category -->
  <div class="mb-3 flex items-center gap-3">
    <ToolLogo slug={slug} name={data.name} size="sm" />
    <div class="min-w-0">
      <p class="truncate font-bold text-slate-900 group-hover:text-[#0066FF]">{data.name}</p>
      <span class="text-[10px] font-medium text-blue-600">{catLabel(data.category)}</span>
    </div>
  </div>

  <!-- Badges -->
  <div class="flex flex-wrap gap-2">
    <span class={`rounded px-2 py-0.5 text-[11px] font-medium ${cu.cls}`}>{cu.text}</span>
    <span class={`rounded px-2 py-0.5 text-[11px] font-medium ${fp.cls}`}>{fp.text}</span>
    <span class={`rounded px-2 py-0.5 text-[11px] font-medium ${jp.cls}`}>{jp.text}</span>
    <span class={`rounded px-2 py-0.5 text-[11px] font-medium ${wm.cls}`}>{wm.text}</span>
    {data.lowestPaidPlan && (
      <span class="rounded px-2 py-0.5 text-xs font-semibold text-slate-800 bg-slate-50 ring-1 ring-inset ring-slate-200">
        {data.lowestPaidPlan}
      </span>
    )}
  </div>

  <!-- lastReviewed -->
  <p class="mt-3 text-xs text-slate-500">最終確認日: {data.lastReviewed}</p>

  <!-- Link -->
  <p class="mt-2 text-xs font-semibold text-blue-600 group-hover:underline">詳しく見る →</p>
</a>
