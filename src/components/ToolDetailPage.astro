---
import type { GeneratedImage } from '../data/generatedImages';
import type { GeneratedVideo } from '../data/generatedVideos';
import GeneratedVideoSample from './GeneratedVideoSample.astro';
import UsagePolicySummary from './UsagePolicySummary.astro';
import type { UsagePolicyData, LabelOverrides } from './UsagePolicySummary.astro';
import VerifiedSummary from './VerifiedSummary.astro';
import type { VerifiedSummaryData } from './VerifiedSummary.astro';
/*
  ToolDetailPage.astro
  汎用ツール詳細ページコンポーネント（AdobeFireflyTool.astroと同一デザインシステム）
  各ツールの専用ページから toolName その他データを props で受け取る。
*/

export type Mark = 'ok' | 'cond' | 'no' | 'na' | 'paid';
export interface Badge { s: Mark; label: string; }
export interface SpecItem { lb: string; badge?: Badge; text?: string; mono?: boolean; }
export interface InfoCard {
  title: string;
  badge?: Badge;
  sum?: string;
  sumMono?: boolean;
  det?: string;
  wide?: boolean;
  lang?: { label: string; badge: Badge }[];
  feats?: string[];
}
export interface TableCell { html: string; rk?: boolean; me?: boolean; mono?: boolean; }
export interface RichTable { kind?: 'spec' | 'cmp'; headers?: string[]; rows: TableCell[][]; note?: string; }
export interface ToolCard {
  name: string; slug?: string; initial?: string; cat?: string;
  badges?: Badge[]; platforms?: string[]; official?: string;
}
export interface ReadLink { href: string; title: string; desc?: string; }
export interface TagLink { label: string; href: string; }
export interface SourceLink { tag: string; label: string; href: string; }
export interface Faq { q: string; a: string; }
export interface CheckItem { html: string; }

export interface Props {
  toolName: string;
  category?: string;
  checkedDate?: string;
  headingHtml: string;
  lead: string;
  specs: SpecItem[];
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  caution?: string;
  basicInfo: InfoCard[];
  useCases?: string[];
  useCasesDesc?: string;
  pros?: string[];
  cons?: string[];
  limits?: string[];
  quickTable: RichTable;
  about?: string[];
  aboutMore?: { label: string; href: string };
  pricing?: { table: RichTable; notes: string[] };
  commercial?: { lead: string; points: string[]; disclaimer: string; more?: { label: string; href: string } };
  usagePolicy?: UsagePolicyData;
  usagePolicyLabelOverrides?: LabelOverrides;
  usagePolicySdNote?: string;
  watermarkRaw?: string;
  watermarkConditionRaw?: string;
  integrationTitle?: string;
  integration?: string;
  whoFor?: string[];
  whoNot?: string[];
  selectTable?: RichTable;
  versusTable?: RichTable;
  language?: string[];
  watermark?: string[];
  watermarkMore?: { label: string; href: string };
  checklist?: CheckItem[];
  lastChecked?: string;
  nextCheck?: string;
  verifiedDate?: string;
  sources?: SourceLink[];
  faqs?: Faq[];
  relatedTools?: ToolCard[];
  nextReads?: ReadLink[];
  conditions?: TagLink[];
  toolsBase?: string;
  sampleImage?: GeneratedImage | null;
  sampleVideo?: GeneratedVideo | null;
  verifiedSummary?: VerifiedSummaryData;
}

const {
  toolName,
  category = 'AI画像生成',
  checkedDate = '',
  headingHtml,
  lead,
  specs,
  primaryCta,
  secondaryCta,
  caution = '掲載情報は確認時点の内容です。料金・無料枠・商用利用条件・透かし・日本語対応は、プランや用途、時期によって変更される場合があります。最新情報は必ず各公式サイトをご確認ください。本記事は商用利用・著作権・肖像権・商標に関する法的助言ではありません。',
  basicInfo,
  useCases = [],
  useCasesDesc,
  pros = [],
  cons = [],
  limits = [],
  quickTable,
  about = [],
  aboutMore,
  pricing,
  commercial,
  usagePolicy,
  usagePolicyLabelOverrides,
  usagePolicySdNote,
  watermarkRaw,
  watermarkConditionRaw,
  integrationTitle,
  integration,
  whoFor = [],
  whoNot = [],
  selectTable,
  versusTable,
  language = [],
  watermark = [],
  watermarkMore,
  checklist = [],
  lastChecked = '',
  nextCheck = '',
  verifiedDate = '',
  sources = [],
  faqs = [],
  relatedTools = [],
  nextReads = [],
  conditions = [],
  toolsBase = '/tools/',
  sampleImage = null,
  sampleVideo = null,
  verifiedSummary,
} = Astro.props as Props;

const toolUrl = (slug?: string) => slug ? `${toolsBase}${slug}/` : undefined;
const tableClass = (t: RichTable) => `tdp-gt ${t.kind ?? 'cmp'}`;
const cellClass = (c: TableCell) => [c.rk ? 'rk' : '', c.me ? 'me' : '', c.mono ? 'mono' : ''].filter(Boolean).join(' ');
---

<article class="tdp-x" data-tdp>

  <!-- ===== HERO ===== -->
  <header class="tdp-head">
    <div class="tdp-meta">
      <span class="tdp-kicker">Tool detail</span>
      <span class="tdp-cat"><span class="d"></span>{category}</span>
      {checkedDate && <span class="tdp-checked"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>確認 <b>{checkedDate}</b></span>}
    </div>
    <h1 class="tdp-h1" set:html={headingHtml}></h1>
    <p class="tdp-lead">{lead}</p>

    <div class="tdp-spec">
      <div class="tdp-specgrid">
        {specs.map((s) => (
          <div class="tdp-specitem">
            <span class="lb">{s.lb}</span>
            <span class={`vl${s.mono ? ' mono' : ''}`}>
              {s.badge ? <span class={`tdp-st ${s.badge.s} sm`}><span class="d"></span>{s.badge.label}</span> : s.text}
            </span>
          </div>
        ))}
      </div>
    </div>

    <div class="tdp-actions">
      <a href={primaryCta.href} class="btn btn-primary" target="_blank" rel="sponsored nofollow noopener noreferrer">{primaryCta.label} <span class="ext">↗</span></a>
      {secondaryCta ? <a href={secondaryCta.href} class="btn btn-ghost" target="_blank" rel="sponsored nofollow noopener noreferrer">{secondaryCta.label} <span class="ext">↗</span></a> : null}
    </div>

    <div class="tdp-caution">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p><b>ご注意：</b>{caution}</p>
    </div>
  </header>

  {sampleImage && (
    <div class="tdp-sample-wrap">
      <figure class="tdp-sample-fig">
        <img src={sampleImage.file} alt={sampleImage.alt} width="800" height="450" loading="lazy" decoding="async" class="tdp-sample-img" />
        <figcaption class="tdp-sample-cap">
          <span class="tdp-sample-label">{sampleImage.isSameToolAsPage ? 'このツールで作成した実例サンプル' : 'AI生成サンプル（参考）'}</span>
          {sampleImage.isSameToolAsPage ? (
            <p class="tdp-sample-note">この画像は、管理者が本ページで紹介しているツールを使い、共通プロンプトをもとに作成した実例サンプルです。生成結果はプロンプト・設定・モデル・タイミングによって変わる場合があります。商用利用条件は公式情報をご確認ください。本記事は法的助言ではありません。</p>
          ) : (
            <p class="tdp-sample-note">この画像は本ページで紹介しているツールの公式出力・代表結果・実例ではありません。参考ビジュアルとして掲載しています。生成結果はプロンプト・設定・モデル・タイミングによって変わる場合があります。商用利用条件は公式情報をご確認ください。本記事は法的助言ではありません。</p>
          )}
        </figcaption>
      </figure>
    </div>
  )}

  {sampleVideo && (
    <div class="tdp-sample-wrap">
      <GeneratedVideoSample video={sampleVideo} />
    </div>
  )}

  {verifiedSummary && <VerifiedSummary data={verifiedSummary} />}

  <!-- ===== 基本情報 ===== -->
  <section class="tdp-sec">
    <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Basic info</span><h2>基本情報</h2><p>商用利用・無料枠・料金・透かし・日本語対応・対応環境の概要です。各項目は公式情報をもとに整理しています。</p></div>
    <div class="tdp-infogrid reveal" data-stagger>
      {basicInfo.map((c) => (
        <article class={`tdp-infocard${c.wide ? ' wide' : ''}`}>
          <div class="ih"><h3>{c.title}</h3>{c.badge ? <span class={`tdp-st ${c.badge.s}`}><span class="d"></span>{c.badge.label}</span> : null}</div>
          {c.sum ? <p class={`sum${c.sumMono ? ' mono' : ''}`}>{c.sum}</p> : null}
          {c.det ? <p class="det">{c.det}</p> : null}
          {c.lang ? <div class="tdp-lang">{c.lang.map((l) => (<span class="row"><b>{l.label}</b><span class={`tdp-st ${l.badge.s} sm`}><span class="d"></span>{l.badge.label}</span></span>))}</div> : null}
          {c.feats ? <div class="tdp-feats">{c.feats.map((f) => (<span class="tdp-feat">{f}</span>))}</div> : null}
        </article>
      ))}
    </div>
  </section>

  <!-- ===== 向いている用途 ===== -->
  {useCases.length > 0 && (
    <section class="tdp-sec band">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Best for</span><h2>向いている用途</h2>{useCasesDesc ? <p>{useCasesDesc}</p> : <p>{toolName}が特に活用しやすい主な用途です。</p>}</div>
      <ul class="tdp-bullets reveal" data-stagger>
        {useCases.map((u) => (<li set:html={u}></li>))}
      </ul>
    </section>
  )}

  <!-- ===== 強み・注意点 ===== -->
  {(pros.length > 0 || cons.length > 0 || limits.length > 0) && (
    <section class="tdp-sec">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Strengths &amp; cautions</span><h2>強み・注意点</h2><p>公式情報をもとにした強み・弱み・制限の整理です。最終的な判断は公式条件をご確認ください。</p></div>
      <div class="tdp-judge reveal" data-stagger>
        {pros.length > 0 && <div class="tdp-jcol pro"><div class="jh"><span class="ic">○</span>強み</div><ul>{pros.map((x) => (<li set:html={x}></li>))}</ul></div>}
        {cons.length > 0 && <div class="tdp-jcol con"><div class="jh"><span class="ic">×</span>弱み</div><ul>{cons.map((x) => (<li set:html={x}></li>))}</ul></div>}
        {limits.length > 0 && <div class="tdp-jcol lim"><div class="jh"><span class="ic">!</span>制限・注意点</div><ul>{limits.map((x) => (<li set:html={x}></li>))}</ul></div>}
      </div>
    </section>
  )}

  <!-- ===== 比較ポイント早見表 ===== -->
  <section class="tdp-sec band">
    <div class="tdp-sechead reveal"><span class="tdp-eyebrow">At a glance</span><h2>比較ポイント早見表</h2><p>確認日時点の参考値です。プランや用途により異なる場合があります。最新情報は必ず公式サイトでご確認ください。</p></div>
    <div class="reveal">
      <div class="tdp-tablewrap"><table class={tableClass(quickTable)}>
        {quickTable.headers ? <thead><tr>{quickTable.headers.map((h) => (<th>{h}</th>))}</tr></thead> : null}
        <tbody>{quickTable.rows.map((row) => (<tr>{row.map((c) => (<td class={cellClass(c)} set:html={c.html}></td>))}</tr>))}</tbody>
      </table></div>
      {quickTable.note ? <p class="tdp-tnote">{quickTable.note}</p> : null}
    </div>
  </section>

  <!-- ===== 概要 / 料金 / 商用利用 / 連携 ===== -->
  {(about.length > 0 || pricing || commercial || integration) && (
    <section class="tdp-sec">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Overview</span><h2>{toolName}とは</h2></div>
      <div class="tdp-prose reveal">
        {about.map((p) => (<p set:html={p}></p>))}
        {aboutMore ? <a class="tdp-inline-more" href={aboutMore.href}>{aboutMore.label}</a> : null}

        {pricing && <>
          <h3>料金プラン</h3>
          <div class="tdp-tablewrap"><table class={tableClass(pricing.table)}>
            {pricing.table.headers ? <thead><tr>{pricing.table.headers.map((h) => (<th>{h}</th>))}</tr></thead> : null}
            <tbody>{pricing.table.rows.map((row) => (<tr>{row.map((c) => (<td class={cellClass(c)} set:html={c.html}></td>))}</tr>))}</tbody>
          </table></div>
          <ul>{pricing.notes.map((n) => (<li set:html={n}></li>))}</ul>
        </>}

        {commercial && <>
          <h3>商用利用について</h3>
          <p>{commercial.lead}</p>
          <ul>
            {commercial.points.map((p) => (<li set:html={p}></li>))}
            <li>クレジット表記・帰属義務の有無は、プラン・利用規約・生成コンテンツの内容によって異なる場合があります。最新の公式規約でご確認ください。</li>
          </ul>
          <div class="tdp-quote"><b>免責事項：</b>{commercial.disclaimer}</div>
          {commercial.more ? <a class="tdp-inline-more" href={commercial.more.href}>{commercial.more.label}</a> : null}
        </>}

        {usagePolicy && (
          <UsagePolicySummary
            policy={usagePolicy}
            watermark={watermarkRaw}
            watermarkNote={watermarkConditionRaw}
            labelOverrides={usagePolicyLabelOverrides}
            sdNote={usagePolicySdNote}
          />
        )}

        {integration && <>
          <h3>{integrationTitle ?? `${toolName}の連携機能`}</h3>
          <p>{integration}</p>
        </>}
      </div>
    </section>
  )}

  <!-- ===== 向いている人・向いていない人 ===== -->
  {(whoFor.length > 0 || whoNot.length > 0) && (
    <section class="tdp-sec band">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Who it's for</span><h2>向いている人・向いていない人</h2></div>
      <div class="tdp-judge reveal" data-stagger style="grid-template-columns:1fr 1fr;">
        {whoFor.length > 0 && <div class="tdp-jcol pro"><div class="jh"><span class="ic">○</span>向いている人</div><ul>{whoFor.map((x) => (<li set:html={x}></li>))}</ul></div>}
        {whoNot.length > 0 && <div class="tdp-jcol con"><div class="jh"><span class="ic">×</span>向いていない人</div><ul>{whoNot.map((x) => (<li set:html={x}></li>))}</ul></div>}
      </div>
    </section>
  )}

  <!-- ===== 他ツールとの選び分け ===== -->
  {(selectTable || versusTable) && (
    <section class="tdp-sec">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Pick the right tool</span><h2>他ツールとの選び分け</h2><p>用途別に、{toolName}と他の主要ツールの向き・不向きを整理しました。各ツールの最新条件は公式サイトをご確認ください。</p></div>
      <div class="reveal">
        {selectTable && <>
          <div class="tdp-tablewrap"><table class={tableClass(selectTable)}>
            {selectTable.headers ? <thead><tr>{selectTable.headers.map((h) => (<th>{h}</th>))}</tr></thead> : null}
            <tbody>{selectTable.rows.map((row) => (<tr>{row.map((c) => (<td class={cellClass(c)} set:html={c.html}></td>))}</tr>))}</tbody>
          </table></div>
        </>}

        {versusTable && <>
          <div class="tdp-sechead reveal" style="margin-top:44px;margin-bottom:18px;"><h2 style="font-size:21px;">主要ツールとの違い</h2></div>
          <div class="tdp-tablewrap"><table class={tableClass(versusTable)}>
            {versusTable.headers ? <thead><tr>{versusTable.headers.map((h) => (<th>{h}</th>))}</tr></thead> : null}
            <tbody>{versusTable.rows.map((row) => (<tr>{row.map((c) => (<td class={cellClass(c)} set:html={c.html}></td>))}</tr>))}</tbody>
          </table></div>
          {versusTable.note ? <p class="tdp-tnote">{versusTable.note}</p> : null}
        </>}
      </div>
    </section>
  )}

  <!-- ===== 日本語対応 / 透かし ===== -->
  {(language.length > 0 || watermark.length > 0) && (
    <section class="tdp-sec band">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Localization &amp; watermark</span><h2>日本語対応・透かし</h2></div>
      <div class="tdp-prose reveal">
        {language.length > 0 && <>
          <h3>日本語対応</h3>
          <ul>{language.map((x) => (<li set:html={x}></li>))}</ul>
        </>}
        {watermark.length > 0 && <>
          <h3>透かし（ウォーターマーク）</h3>
          <ul>{watermark.map((x) => (<li set:html={x}></li>))}</ul>
        </>}
        {watermarkMore ? <a class="tdp-inline-more" href={watermarkMore.href}>{watermarkMore.label}</a> : null}
      </div>
    </section>
  )}

  <!-- ===== 商用利用前のチェックリスト ===== -->
  {checklist.length > 0 && (
    <section class="tdp-sec">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Checklist</span><h2>商用利用前に確認したいポイント</h2><p>商用案件・クライアントワークで使う前に、最低限おさえておきたい項目です。各項目は公式情報で裏付けてください。</p></div>
      <ul class="tdp-checklist reveal" data-stagger>
        {checklist.map((c) => (
          <li><span class="box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span><span class="tx" set:html={c.html}></span></li>
        ))}
      </ul>
    </section>
  )}

  <!-- ===== 情報の鮮度・参照元 ===== -->
  <section class="tdp-sec band">
    <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Sources</span><h2>情報の鮮度・参照元</h2><p>本ページの情報は、各ツールの公式サイト・料金ページ・利用規約等をもとに整理したものです。掲載内容は確認時点の情報です。</p></div>
    <div class="tdp-srcgrid reveal" data-stagger>
      <div class="tdp-datebox">
        {(lastChecked || verifiedDate) && <div class="row"><b>情報確認日</b><span class="mono">{lastChecked || verifiedDate}</span></div>}
        <p style="margin-top:10px;font-size:12px;color:var(--muted);line-height:1.75;grid-column:1/-1;">料金・利用条件は変更される場合があります。最新情報は公式サイトをご確認ください。商用利用条件や入力素材の扱いは、プランや用途によって異なる場合があります。本記事は法的助言ではありません。</p>
      </div>
      {sources.length > 0 && (
        <div class="tdp-srcbox">
          <h3>参照元</h3>
          <div class="tdp-srclist">
            {sources.map((s) => (<a class="tdp-srclink" href={s.href} target="_blank" rel="noopener noreferrer"><span class="tag">{s.tag}</span>{s.label}<span class="ext">↗</span></a>))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  {faqs.length > 0 && (
    <>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map((f) => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a },
        })),
      })} />
      <section class="tdp-sec">
        <div class="tdp-sechead reveal"><span class="tdp-eyebrow">FAQ</span><h2>よくある質問</h2><p>無料枠・商用利用・用途・日本語対応・透かし・対応環境について、確認のポイントをお答えします。</p></div>
        <div class="tdp-faq reveal">
          {faqs.map((f) => (
            <div class="tdp-faqitem" aria-expanded="false">
              <h3 class="tdp-faqh"><button class="tdp-faqq" type="button"><span class="qm">Q</span>{f.q}<span class="ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg></span></button></h3>
              <div class="tdp-faqa"><div class="tdp-faqa-in" set:html={f.a}></div></div>
            </div>
          ))}
        </div>
      </section>
    </>
  )}

  <!-- ===== 関連ツール ===== -->
  {relatedTools.length > 0 && (
    <section class="tdp-sec band">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Related tools</span><h2>あわせて比較したいAIツール</h2><p>同じカテゴリで{toolName}と比較されることの多いAIツールです。</p></div>
      <div class="tdp-toolcards reveal" data-stagger>
        {relatedTools.map((t) => (
          <article class="tdp-toolcard">
            <div class="th"><span class="b">{t.initial}</span><span><span class="nm">{t.name}</span><br /><span class="ct">{t.cat}</span></span></div>
            {t.badges ? <div class="tags">{t.badges.map((b) => (<span class={`tdp-st ${b.s} sm`}><span class="d"></span>{b.label}</span>))}</div> : null}
            {t.platforms ? <div class="plats">{t.platforms.map((p) => (<span class="plat">{p}</span>))}</div> : null}
            <div class="tact">
              {toolUrl(t.slug) ? <a href={toolUrl(t.slug)}>詳しく見る →</a> : null}
              {t.official ? <a class="ghost" href={t.official} target="_blank" rel="noopener noreferrer">公式 ↗</a> : null}
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- ===== 比較記事 / 次に読む ===== -->
  {nextReads.length > 0 && (
    <section class="tdp-sec">
      <div class="tdp-sechead reveal"><span class="tdp-eyebrow">Next reads</span><h2>比較記事・次に読む</h2><p>{toolName}の比較記事と、あわせて読みたいガイド・比較表です。</p></div>
      <div class="tdp-reads reveal" data-stagger>
        {nextReads.map((r) => (
          <a class="tdp-read" href={r.href}><span class="ar">→</span><span><span class="rt">{r.title}</span>{r.desc ? <span class="rd">{r.desc}</span> : null}</span></a>
        ))}
      </div>
    </section>
  )}

  <!-- ===== 条件別に探す ===== -->
  {conditions.length > 0 && (
    <section class="tdp-sec band" style="padding-bottom:60px;">
      <div class="tdp-finder reveal">
        <h2>条件別に探す</h2>
        <p class="lead">カテゴリ・条件タグから、目的に合うAIツールを探せます。</p>
        <div class="tdp-taglinks">
          {conditions.map((c) => (<a class="tdp-taglink" href={c.href}><span class="ld"></span>{c.label}</a>))}
        </div>
        <div class="tdp-pagenav">
          <a href="/tools/" class="btn btn-ghost">← ツール一覧に戻る</a>
          <a href="/comparisons/" class="btn btn-primary">比較表で見る <span class="arr">→</span></a>
        </div>
      </div>
    </section>
  )}

</article>

<style>
  /* すべて .tdp-x 配下に限定。CSS変数も .tdp-x 上に定義（:root非使用）。 */
  .tdp-x{
    --paper:#F4F4EE; --surface:#FFFFFF; --surface-2:#FAFAF6;
    --ink:#16181D; --ink-soft:#3A3E47; --muted:#6A7180; --faint:#98A0AD;
    --line:#E3E2D9; --line-strong:#D2D1C6;
    --brand:#4B3FE4; --brand-ink:#2E25A6; --brand-tint:#ECEBFB;
    --video:#E1543A; --video-tint:#FCEDE9; --image:#15897F; --image-tint:#E2F1EF;
    --ok:#1E8A4C; --ok-tint:#E6F3EC; --warn:#A06A09; --warn-tint:#F8EFD9;
    --na:#6A7180; --na-tint:#EFEFEA; --paid:#4B3FE4; --paid-tint:#ECEBFB;
    --f-jp:"Zen Kaku Gothic New","Noto Sans JP",system-ui,sans-serif;
    --f-body:"Noto Sans JP",system-ui,sans-serif;
    --f-latin:"Space Grotesk",system-ui,sans-serif;
    --f-mono:"Space Mono",ui-monospace,monospace;
    --radius:14px; --radius-lg:22px;
    --shadow-sm:0 1px 2px rgba(20,22,28,.04),0 1px 3px rgba(20,22,28,.05);
    --shadow-md:0 4px 14px rgba(20,22,28,.06),0 2px 6px rgba(20,22,28,.04);
    --ease:cubic-bezier(.22,.61,.36,1);
    font-family:var(--f-body); color:var(--ink); line-height:1.7; -webkit-font-smoothing:antialiased;
  }
  .tdp-x :where(h1,h2,h3,h4){font-family:var(--f-jp);font-weight:700;line-height:1.32;letter-spacing:.01em;margin:0;}
  .tdp-x :where(p){margin:0;}
  .tdp-x a{color:inherit;text-decoration:none;}

  .tdp-sec{padding:60px 0;}
  .tdp-sec.band{background:var(--surface-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
  .tdp-sechead{max-width:780px;margin-bottom:30px;}
  .tdp-sechead h2{font-size:clamp(23px,2.8vw,32px);font-weight:900;letter-spacing:-.005em;margin:14px 0 11px;}
  .tdp-sechead p{color:var(--muted);font-size:14.5px;}
  .tdp-sechead p b{color:var(--ink-soft);font-weight:700;}
  .tdp-eyebrow{font-family:var(--f-latin);font-size:12px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--muted);display:inline-flex;align-items:center;gap:10px;}
  .tdp-eyebrow::before{content:"";width:22px;height:2px;border-radius:2px;background:var(--brand);}

  /* ===== hero header ===== */
  .tdp-head{padding:30px 0 8px;}
  .tdp-meta{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:18px;}
  .tdp-kicker{font-family:var(--f-latin);font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);}
  .tdp-cat{font-family:var(--f-jp);font-weight:700;font-size:12px;letter-spacing:.04em;color:var(--image);background:var(--image-tint);padding:5px 13px;border-radius:999px;display:inline-flex;align-items:center;gap:7px;white-space:nowrap;}
  .tdp-cat .d{width:6px;height:6px;border-radius:50%;background:currentColor;}
  .tdp-checked{font-family:var(--f-mono);font-size:12px;color:var(--muted);display:inline-flex;align-items:center;gap:7px;margin-left:auto;}
  .tdp-checked svg{width:14px;height:14px;}
  .tdp-checked b{color:var(--ink-soft);font-weight:700;}
  .tdp-h1{font-size:clamp(28px,3.8vw,44px);font-weight:900;letter-spacing:-.01em;line-height:1.22;margin:0 0 16px;max-width:18ch;}
  .tdp-h1 .hl{color:var(--brand-ink);position:relative;}
  .tdp-h1 .hl::after{content:"";position:absolute;left:0;right:0;bottom:.06em;height:.26em;background:color-mix(in srgb,var(--brand) 18%,transparent);z-index:-1;border-radius:2px;}
  .tdp-lead{font-size:16px;color:var(--ink-soft);max-width:680px;}

  /* spec strip */
  .tdp-spec{margin-top:30px;background:var(--surface);border:1px solid var(--line);border-radius:var(--radius-lg);box-shadow:var(--shadow-sm);overflow:hidden;}
  .tdp-specgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(148px,1fr));}
  .tdp-specitem{padding:20px 22px;border-right:1px solid var(--line);display:flex;flex-direction:column;gap:9px;min-width:0;}
  .tdp-specitem:last-child{border-right:none;}
  .tdp-specitem .lb{font-family:var(--f-jp);font-weight:700;font-size:11.5px;color:var(--muted);letter-spacing:.02em;}
  .tdp-specitem .vl{font-size:14px;color:var(--ink);font-weight:700;line-height:1.4;overflow-wrap:anywhere;}
  .tdp-specitem .vl.mono{font-family:var(--f-mono);font-size:12.5px;font-weight:700;color:var(--ink-soft);overflow-wrap:anywhere;}
  .tdp-specitem .tdp-st{white-space:normal;max-width:100%;}
  .tdp-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:22px;}
  .tdp-actions .btn .ext{transition:transform .2s var(--ease);}
  .tdp-actions .btn:hover .ext{transform:translate(2px,-2px);}

  .tdp-caution{display:flex;align-items:flex-start;gap:13px;background:var(--warn-tint);border:1px solid color-mix(in srgb,var(--warn) 26%,var(--line));border-radius:var(--radius);padding:17px 22px;margin-top:24px;max-width:880px;}
  .tdp-caution svg{width:19px;height:19px;color:var(--warn);flex:none;margin-top:2px;}
  .tdp-caution p{font-size:13px;color:var(--ink-soft);line-height:1.75;}
  .tdp-caution b{color:var(--ink);font-weight:700;}

  /* ===== status badges (shared) ===== */
  .tdp-st{display:inline-flex;align-items:center;gap:6px;flex:none;font-family:var(--f-jp);font-weight:700;font-size:12px;line-height:1.2;padding:5px 11px;border-radius:999px;white-space:nowrap;}
  .tdp-st .d{width:6px;height:6px;border-radius:50%;background:currentColor;}
  .tdp-st.ok{color:var(--ok);background:var(--ok-tint);}
  .tdp-st.cond{color:var(--warn);background:var(--warn-tint);}
  .tdp-st.no{color:var(--video);background:var(--video-tint);}
  .tdp-st.na{color:var(--na);background:var(--na-tint);}
  .tdp-st.paid{color:var(--paid);background:var(--paid-tint);}
  .tdp-st.sm{padding:3px 9px;font-size:11px;}

  /* ===== basic info cards ===== */
  .tdp-infogrid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  .tdp-infocard{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:22px 24px;box-shadow:var(--shadow-sm);}
  .tdp-infocard.wide{grid-column:1 / -1;}
  .tdp-infocard .ih{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
  .tdp-infocard .ih h3{font-size:15px;font-weight:700;color:var(--ink);}
  .tdp-infocard .ih .tdp-st{margin-left:auto;}
  .tdp-infocard .sum{font-size:14px;color:var(--ink);font-weight:700;line-height:1.6;margin-bottom:8px;}
  .tdp-infocard .sum.mono{font-family:var(--f-mono);font-size:13px;}
  .tdp-infocard .det{font-size:13px;color:var(--muted);line-height:1.75;}
  .tdp-lang{display:flex;gap:26px;flex-wrap:wrap;}
  .tdp-lang .row{display:flex;align-items:center;gap:9px;font-size:13.5px;color:var(--ink-soft);}
  .tdp-lang .row b{color:var(--muted);font-weight:700;font-size:12.5px;}
  .tdp-feats{display:flex;flex-wrap:wrap;gap:8px;}
  .tdp-feat{font-family:var(--f-jp);font-weight:600;font-size:12.5px;color:var(--ink-soft);background:var(--surface-2);border:1px solid var(--line);border-radius:8px;padding:6px 12px;line-height:1.4;}

  /* ===== use cases / bullet lists ===== */
  .tdp-bullets{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:12px 28px;max-width:880px;}
  .tdp-bullets li{position:relative;padding-left:20px;font-size:14px;color:var(--ink-soft);line-height:1.7;}
  .tdp-bullets li::before{content:"";position:absolute;left:0;top:10px;width:7px;height:7px;border-radius:50%;background:var(--brand);}
  .tdp-bullets li b{color:var(--ink);font-weight:700;}

  /* ===== pros / cons / limits ===== */
  .tdp-judge{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  .tdp-jcol{border-radius:var(--radius-lg);padding:24px 26px;border:1px solid var(--line);}
  .tdp-jcol.pro{background:var(--ok-tint);border-color:color-mix(in srgb,var(--ok) 24%,var(--line));}
  .tdp-jcol.con{background:var(--video-tint);border-color:color-mix(in srgb,var(--video) 22%,var(--line));}
  .tdp-jcol.lim{background:var(--warn-tint);border-color:color-mix(in srgb,var(--warn) 24%,var(--line));}
  .tdp-jcol .jh{display:flex;align-items:center;gap:10px;font-size:15px;font-weight:900;margin-bottom:15px;}
  .tdp-jcol.pro .jh{color:var(--ok);}
  .tdp-jcol.con .jh{color:var(--video);}
  .tdp-jcol.lim .jh{color:var(--warn);}
  .tdp-jcol .jh .ic{width:24px;height:24px;border-radius:7px;display:grid;place-items:center;background:#fff;font-family:var(--f-latin);font-weight:700;font-size:15px;flex:none;}
  .tdp-jcol ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;}
  .tdp-jcol li{font-size:13.5px;color:var(--ink-soft);line-height:1.65;padding-left:22px;position:relative;}
  .tdp-jcol li::before{position:absolute;left:0;top:0;font-family:var(--f-latin);font-weight:700;font-size:13px;}
  .tdp-jcol.pro li::before{content:"○";color:var(--ok);}
  .tdp-jcol.con li::before{content:"×";color:var(--video);}
  .tdp-jcol.lim li::before{content:"!";color:var(--warn);left:4px;}

  /* ===== tables ===== */
  .tdp-tablewrap{overflow-x:auto;border:1px solid var(--line);border-radius:var(--radius);background:var(--surface);box-shadow:var(--shadow-sm);}
  table.tdp-gt{width:100%;border-collapse:collapse;}
  table.tdp-gt.spec{min-width:480px;}
  table.tdp-gt.cmp{min-width:620px;}
  table.tdp-gt thead th{font-family:var(--f-jp);font-weight:700;font-size:12.5px;color:var(--ink-soft);background:var(--surface-2);padding:13px 18px;text-align:left;border-bottom:1px solid var(--line);white-space:nowrap;}
  table.tdp-gt tbody td{padding:13px 18px;border-bottom:1px solid var(--line);vertical-align:top;font-size:13.5px;color:var(--ink-soft);line-height:1.7;}
  table.tdp-gt tbody tr:last-child td{border-bottom:none;}
  table.tdp-gt tbody tr{transition:background .12s;}
  table.tdp-gt tbody tr:hover{background:var(--surface-2);}
  table.tdp-gt .rk{font-family:var(--f-jp);font-weight:700;color:var(--ink);white-space:nowrap;width:1%;}
  table.tdp-gt .mono{font-family:var(--f-mono);font-size:12.5px;color:var(--ink-soft);}
  table.tdp-gt a{color:var(--brand-ink);font-weight:700;}
  table.tdp-gt a:hover{text-decoration:underline;text-underline-offset:3px;}
  table.tdp-gt .me{color:var(--ink);font-weight:700;}
  .tdp-tnote{margin-top:11px;font-size:12px;color:var(--faint);line-height:1.7;}

  /* ===== prose blocks ===== */
  .tdp-prose{max-width:820px;display:flex;flex-direction:column;gap:14px;}
  .tdp-prose h3{font-family:var(--f-jp);font-weight:700;font-size:18px;color:var(--ink);display:flex;align-items:center;gap:11px;margin-top:8px;}
  .tdp-prose h3::before{content:"";width:4px;height:18px;border-radius:2px;background:var(--brand);flex:none;}
  .tdp-prose p{font-size:14.5px;color:var(--ink-soft);line-height:1.85;}
  .tdp-prose ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;}
  .tdp-prose ul li{position:relative;padding-left:20px;font-size:14px;color:var(--ink-soft);line-height:1.75;}
  .tdp-prose ul li::before{content:"";position:absolute;left:0;top:9px;width:7px;height:7px;border-radius:50%;background:var(--brand);}
  .tdp-prose b{color:var(--ink);font-weight:700;}
  .tdp-prose a{color:var(--brand-ink);font-weight:600;}
  .tdp-prose a:hover{text-decoration:underline;text-underline-offset:3px;}
  .tdp-quote{background:var(--surface-2);border:1px solid var(--line);border-left:4px solid var(--warn);border-radius:0 var(--radius) var(--radius) 0;padding:16px 22px;font-size:13.5px;color:var(--ink-soft);line-height:1.8;}
  .tdp-quote b{color:var(--ink);}
  .tdp-inline-more{font-family:var(--f-jp);font-weight:700;font-size:13.5px;color:var(--brand-ink);display:inline-flex;align-items:center;gap:7px;}
  .tdp-inline-more:hover{text-decoration:underline;text-underline-offset:3px;}

  /* ===== checklist ===== */
  .tdp-checklist{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius-lg);padding:26px 32px;display:grid;grid-template-columns:1fr 1fr;gap:2px 36px;max-width:920px;list-style:none;margin:0;}
  .tdp-checklist li{display:grid;grid-template-columns:auto 1fr;gap:13px;align-items:start;padding:12px 0;border-bottom:1px dashed var(--line);}
  .tdp-checklist .box{width:23px;height:23px;border-radius:7px;border:2px solid var(--brand);display:grid;place-items:center;flex:none;margin-top:1px;}
  .tdp-checklist .box svg{width:13px;height:13px;color:var(--brand);}
  .tdp-checklist .tx{font-size:13.5px;color:var(--ink-soft);line-height:1.6;}

  /* ===== sources / freshness ===== */
  .tdp-srcgrid{display:grid;grid-template-columns:1fr 1.4fr;gap:16px;align-items:start;}
  .tdp-datebox{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:22px 24px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;gap:14px;}
  .tdp-datebox .row{display:flex;align-items:center;justify-content:space-between;gap:12px;font-size:13px;color:var(--muted);}
  .tdp-datebox .row b{color:var(--ink-soft);font-weight:700;}
  .tdp-datebox .row .mono{font-family:var(--f-mono);font-size:12.5px;color:var(--ink);}
  .tdp-srcbox{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:22px 24px;box-shadow:var(--shadow-sm);}
  .tdp-srcbox h3{font-size:13px;font-weight:700;color:var(--muted);margin-bottom:14px;letter-spacing:.02em;}
  .tdp-srclist{display:flex;flex-direction:column;gap:10px;}
  .tdp-srclink{display:flex;align-items:center;gap:11px;font-size:13.5px;color:var(--ink-soft);padding:10px 13px;border:1px solid var(--line);border-radius:10px;transition:border-color .15s,background .15s;}
  .tdp-srclink:hover{border-color:var(--brand);background:var(--brand-tint);color:var(--brand-ink);}
  .tdp-srclink .tag{font-family:var(--f-jp);font-weight:700;font-size:11px;color:var(--brand-ink);background:var(--brand-tint);padding:3px 9px;border-radius:6px;flex:none;}
  .tdp-srclink .ext{margin-left:auto;color:var(--faint);}

  /* ===== FAQ ===== */
  .tdp-faq{max-width:860px;}
  .tdp-faqitem{border-bottom:1px solid var(--line);}
  .tdp-faqh{margin:0;padding:0;font-size:inherit;font-weight:inherit;line-height:inherit;}
  .tdp-faqitem:first-child{border-top:1px solid var(--line);}
  .tdp-faqq{width:100%;text-align:left;background:none;border:none;cursor:pointer;display:flex;align-items:center;gap:16px;padding:22px 6px;font-family:var(--f-jp);font-weight:700;font-size:15.5px;color:var(--ink);}
  .tdp-faqq .qm{font-family:var(--f-latin);color:var(--brand);font-size:16px;flex:none;}
  .tdp-faqq .ind{margin-left:auto;flex:none;width:24px;height:24px;display:grid;place-items:center;transition:transform .3s var(--ease);color:var(--muted);}
  .tdp-faqq .ind svg{width:18px;height:18px;}
  .tdp-faqitem[aria-expanded="true"] .tdp-faqq .ind{transform:rotate(45deg);color:var(--brand);}
  .tdp-faqa{max-height:0;overflow:hidden;transition:max-height .35s var(--ease);}
  .tdp-faqa-in{padding:0 6px 24px 44px;color:var(--ink-soft);font-size:14px;line-height:1.8;}

  /* ===== related tool cards ===== */
  .tdp-toolcards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
  .tdp-toolcard{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:22px 24px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;transition:transform .2s var(--ease),box-shadow .2s,border-color .2s;}
  .tdp-toolcard:hover{transform:translateY(-2px);box-shadow:var(--shadow-md);border-color:color-mix(in srgb,var(--brand) 26%,var(--line));}
  .tdp-toolcard .th{display:flex;align-items:center;gap:11px;margin-bottom:14px;}
  .tdp-toolcard .th .b{width:38px;height:38px;border-radius:10px;display:grid;place-items:center;background:var(--brand-tint);color:var(--brand-ink);font-family:var(--f-latin);font-weight:700;font-size:16px;flex:none;}
  .tdp-toolcard .th .nm{font-family:var(--f-jp);font-weight:700;font-size:15px;color:var(--ink);line-height:1.25;}
  .tdp-toolcard .th .ct{font-size:11.5px;color:var(--muted);}
  .tdp-toolcard .tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;}
  .tdp-toolcard .plats{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:16px;}
  .tdp-toolcard .plat{font-family:var(--f-jp);font-weight:600;font-size:11px;color:var(--ink-soft);background:var(--surface-2);border:1px solid var(--line);border-radius:7px;padding:3px 9px;}
  .tdp-toolcard .tact{margin-top:auto;display:flex;align-items:center;gap:14px;padding-top:14px;border-top:1px solid var(--line);}
  .tdp-toolcard .tact a{font-family:var(--f-jp);font-weight:700;font-size:13px;color:var(--brand-ink);}
  .tdp-toolcard .tact a:hover{text-decoration:underline;text-underline-offset:3px;}
  .tdp-toolcard .tact a.ghost{color:var(--muted);margin-left:auto;}

  /* ===== next reads ===== */
  .tdp-reads{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .tdp-read{display:flex;align-items:flex-start;gap:13px;background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);padding:18px 20px;transition:border-color .15s,transform .15s,box-shadow .15s;}
  .tdp-read:hover{border-color:var(--brand);transform:translateY(-1px);box-shadow:var(--shadow-md);}
  .tdp-read .ar{font-family:var(--f-latin);color:var(--brand);font-weight:700;flex:none;margin-top:1px;}
  .tdp-read .rt{font-family:var(--f-jp);font-weight:700;font-size:14px;color:var(--ink);line-height:1.4;}
  .tdp-read .rd{font-size:12.5px;color:var(--muted);margin-top:4px;line-height:1.6;}

  /* ===== conditions tag links ===== */
  .tdp-finder{background:var(--surface-2);border:1px solid var(--line);border-radius:var(--radius-lg);padding:32px 34px 28px;}
  .tdp-finder h2{font-size:clamp(20px,2.4vw,25px);margin-bottom:6px;}
  .tdp-finder .lead{color:var(--muted);font-size:14px;margin-bottom:20px;}
  .tdp-taglinks{display:flex;flex-wrap:wrap;gap:10px;}
  .tdp-taglink{font-family:var(--f-jp);font-weight:600;font-size:13.5px;padding:9px 16px;border-radius:999px;background:var(--surface);border:1px solid var(--line-strong);color:var(--ink-soft);display:inline-flex;align-items:center;gap:7px;white-space:nowrap;transition:transform .16s var(--ease),background .16s,border-color .16s,color .16s;}
  .tdp-taglink:hover{border-color:var(--brand);color:var(--brand-ink);background:var(--brand-tint);transform:translateY(-1px);}
  .tdp-taglink .ld{width:7px;height:7px;border-radius:50%;background:var(--brand);flex:none;}

  .tdp-pagenav{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;padding:28px 0 4px;}
  .tdp-x .btn{display:inline-flex;align-items:center;gap:9px;font-family:var(--f-jp);font-weight:700;font-size:15px;padding:11px 20px;border-radius:999px;border:1px solid transparent;cursor:pointer;transition:transform .18s var(--ease),background .18s;white-space:nowrap;}
  .tdp-x .btn .arr{transition:transform .2s var(--ease);}
  .tdp-x .btn:hover .arr{transform:translateX(3px);}
  .tdp-x .btn-primary{background:var(--brand);color:#fff;box-shadow:0 6px 18px -6px color-mix(in srgb,var(--brand) 65%,transparent);}
  .tdp-x .btn-primary:hover{background:#3A2FCB;transform:translateY(-1px);}
  .tdp-x .btn-ghost{background:var(--surface);color:var(--ink);border-color:var(--line-strong);}

  /* reveal */
  @media (prefers-reduced-motion:no-preference){
    .tdp-x .reveal{opacity:0;transform:translateY(18px);transition:opacity .6s var(--ease),transform .6s var(--ease);}
    .tdp-x .reveal.in{opacity:1;transform:none;}
    .tdp-x .reveal[data-stagger]>*{opacity:0;transform:translateY(16px);transition:opacity .5s var(--ease),transform .5s var(--ease);}
    .tdp-x .reveal[data-stagger].in>*{opacity:1;transform:none;}
    .tdp-x .reveal[data-stagger].in>*:nth-child(1){transition-delay:.04s;}
    .tdp-x .reveal[data-stagger].in>*:nth-child(2){transition-delay:.09s;}
    .tdp-x .reveal[data-stagger].in>*:nth-child(3){transition-delay:.14s;}
    .tdp-x .reveal[data-stagger].in>*:nth-child(4){transition-delay:.19s;}
    .tdp-x .reveal[data-stagger].in>*:nth-child(5){transition-delay:.24s;}
    .tdp-x .reveal[data-stagger].in>*:nth-child(6){transition-delay:.29s;}
  }
  @media (prefers-reduced-motion:reduce){.tdp-x .reveal,.tdp-x .reveal[data-stagger]>*{opacity:1!important;transform:none!important;}}

  /* responsive */
  @media (max-width:980px){
    .tdp-specgrid{grid-template-columns:repeat(2,1fr);}
    .tdp-specitem:nth-child(2){border-right:none;}
    .tdp-specitem{border-bottom:1px solid var(--line);}
    .tdp-infogrid{grid-template-columns:1fr;}
    .tdp-judge{grid-template-columns:1fr;}
    .tdp-toolcards{grid-template-columns:1fr;}
    .tdp-srcgrid{grid-template-columns:1fr;}
  }
  @media (max-width:720px){
    .tdp-sec{padding:46px 0;}
    .tdp-bullets{grid-template-columns:1fr;}
    .tdp-checklist{grid-template-columns:1fr;padding:22px 20px;}
    .tdp-reads{grid-template-columns:1fr;}
    .tdp-specgrid{grid-template-columns:1fr;}
    .tdp-specitem{border-right:none;}
    .tdp-checked{margin-left:0;}
    .tdp-judge{grid-template-columns:1fr !important;}
  }
  /* ===== 実例サンプル ===== */
  .tdp-x .tdp-sample-wrap{padding:0 clamp(20px,5vw,64px) 8px;}
  .tdp-x .tdp-sample-fig{margin:0;border:1px solid var(--line);border-radius:12px;overflow:hidden;background:var(--surface);}
  .tdp-x .tdp-sample-img{display:block;width:100%;height:auto;object-fit:cover;}
  .tdp-x .tdp-sample-cap{padding:14px 18px;display:flex;flex-direction:column;gap:6px;}
  .tdp-x .tdp-sample-label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--brand-ink);background:var(--brand-tint);padding:2px 8px;border-radius:999px;width:fit-content;}
  .tdp-x .tdp-sample-note{font-size:11.5px;line-height:1.75;color:var(--muted);margin:0;}
</style>

<script>
  (function () {
    document.querySelectorAll('[data-tdp]').forEach(function (root) {
      var faq = root.querySelector('.tdp-faq');
      if (faq) {
        faq.addEventListener('click', function (e) {
          var btn = (e.target as HTMLElement).closest('.tdp-faqq'); if (!btn) return;
          var item = btn.closest('.tdp-faqitem'); if (!item) return;
          var open = item.getAttribute('aria-expanded') === 'true';
          faq.querySelectorAll('.tdp-faqitem').forEach(function (it) {
            it.setAttribute('aria-expanded', 'false');
            var a = it.querySelector('.tdp-faqa') as HTMLElement | null; if (a) a.style.maxHeight = '';
          });
          if (!open) {
            item.setAttribute('aria-expanded', 'true');
            var a = item.querySelector('.tdp-faqa') as HTMLElement | null; if (a) a.style.maxHeight = a.scrollHeight + 'px';
          }
        });
      }
      var reveals = Array.prototype.slice.call(root.querySelectorAll('.reveal'));
      if (!reveals.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) { reveals.forEach(function (el) { el.classList.add('in'); }); return; }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) { if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); } });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach(function (el) { io.observe(el); });
      setTimeout(function () { reveals.forEach(function (el) { el.classList.add('in'); }); }, 8000);
    });
  })();
</script>
