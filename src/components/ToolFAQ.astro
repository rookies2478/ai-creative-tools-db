---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs?: FAQItem[];
}

const { faqs } = Astro.props;

if (!faqs || faqs.length === 0) {
  return;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<section class="td-section" aria-label="よくある質問">
  <h2 class="td-section-h">よくある質問</h2>
  <div class="td-faq-list">
    {faqs.map((faq) => (
      <div class="td-faq-item" aria-expanded="false">
        <button class="td-faq-q">
          <span class="qm">Q</span>
          {faq.question}
          <span class="ind">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path d="M12 5v14M5 12h14"/>
            </svg>
          </span>
        </button>
        <div class="td-faq-a">
          <div class="td-faq-a-inner">{faq.answer}</div>
        </div>
      </div>
    ))}
  </div>
</section>
