---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs?: FAQItem[];
}

const { faqs } = Astro.props;

if (!faqs || faqs.length === 0) {
  return;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<section class="mb-8">
  <h2 class="mb-4 text-lg font-semibold text-gray-900">よくある質問</h2>
  <dl class="space-y-4">
    {faqs.map((faq) => (
      <div class="rounded-lg border border-slate-200 bg-white px-5 py-4">
        <dt class="font-semibold text-sm text-slate-900">{faq.question}</dt>
        <dd class="mt-1.5 text-sm leading-relaxed text-slate-700">{faq.answer}</dd>
      </div>
    ))}
  </dl>
</section>
