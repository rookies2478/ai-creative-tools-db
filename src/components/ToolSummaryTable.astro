---
import type { CollectionEntry } from 'astro:content';

interface Props {
  tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;
const { data } = tool;

type FreePlan = boolean | 'limited' | 'unknown';
type TriState = boolean | 'partial' | 'unknown';
type FourState = 'yes' | 'no' | 'limited' | 'unknown';

function freePlanBadge(val: FreePlan) {
  if (val === true)      return { text: '無料プランあり', cls: 'bg-green-100 text-green-800' };
  if (val === false)     return { text: '無料プランなし', cls: 'bg-red-100 text-red-800' };
  if (val === 'limited') return { text: '制限付き無料',   cls: 'bg-yellow-100 text-yellow-800' };
                         return { text: '要確認',          cls: 'bg-gray-100 text-gray-600' };
}

function triLabel(val: TriState) {
  if (val === true)      return { text: '○', cls: 'font-bold text-green-600' };
  if (val === false)     return { text: '×', cls: 'font-bold text-red-500' };
  if (val === 'partial') return { text: '△', cls: 'font-bold text-yellow-600' };
                         return { text: '要確認', cls: 'text-gray-400' };
}

function fourStateBadge(val: FourState) {
  if (val === 'yes')     return { text: '可',       cls: 'bg-green-100 text-green-800' };
  if (val === 'no')      return { text: '不可',     cls: 'bg-red-100 text-red-800' };
  if (val === 'limited') return { text: '条件付き', cls: 'bg-yellow-100 text-yellow-800' };
                         return { text: '要確認',   cls: 'bg-gray-100 text-gray-600' };
}

function commercialUseDetail(val: FourState): { badge: string; badgeCls: string; desc: string } {
  if (val === 'yes')     return { badge: '商用利用可', badgeCls: 'bg-emerald-100 text-emerald-800', desc: '公式情報では商用利用可能とされています。最新情報は公式サイトをご確認ください。' };
  if (val === 'limited') return { badge: '条件あり',   badgeCls: 'bg-amber-100 text-amber-800',     desc: '用途や条件によって制限がある可能性があります。最新情報は公式サイトをご確認ください。' };
  if (val === 'no')      return { badge: '非推奨',     badgeCls: 'bg-red-100 text-red-800',         desc: '商用利用は推奨されません。最新情報は公式サイトをご確認ください。' };
                         return { badge: '要確認',     badgeCls: 'bg-gray-100 text-gray-600',       desc: '公式情報の確認が必要です。最新情報は公式サイトをご確認ください。' };
}

function categoryLabel(cat: 'image' | 'video' | 'both') {
  if (cat === 'image') return '画像生成';
  if (cat === 'video') return '動画生成';
  return '画像・動画生成';
}

const platformLabels: Record<string, string> = {
  web: 'Web',
  discord: 'Discord',
  ios: 'iOS',
  android: 'Android',
  desktop: 'デスクトップ',
  api: 'API',
  local: 'ローカル',
};

const featureLabels: Record<string, string> = {
  textToImage: 'テキスト→画像',
  imageToImage: '画像→画像',
  inpainting: '部分修正',
  outpainting: '画像拡張',
  upscale: '高解像度化',
  backgroundRemoval: '背景削除',
  stylePresets: 'スタイル選択',
  promptAssist: 'プロンプト補助',
  textToVideo: 'テキスト→動画',
  imageToVideo: '画像→動画',
  videoExtend: '動画延長',
  apiAvailable: 'API対応',
};

const useCaseLabels: Record<string, string> = {
  sns: 'SNS投稿',
  blog: 'ブログ',
  ad_creative: '広告クリエイティブ',
  illustration: 'イラスト',
  photo_real: '写真風',
  product_image: '商品画像',
  design: 'デザイン',
  video: '動画',
  youtube: 'YouTube',
  business: 'ビジネス',
};

const featureOrder = [
  'textToImage', 'imageToImage', 'inpainting', 'outpainting',
  'upscale', 'backgroundRemoval', 'stylePresets', 'promptAssist',
  'textToVideo', 'imageToVideo', 'videoExtend', 'apiAvailable',
] as const;

type FeatureKey = typeof featureOrder[number];

const featuresObj = data.features;
const trueFeatureLabels: string[] = featuresObj
  ? featureOrder.filter(k => featuresObj[k as FeatureKey] === true).map(k => featureLabels[k]).slice(0, 8)
  : [];

const fp  = freePlanBadge(data.freePlan);
const cu  = commercialUseDetail(data.commercialUse);
const wm  = fourStateBadge(data.watermark);
const jui = triLabel(data.japaneseUi);
const jpr = triLabel(data.japanesePrompt);
---

<section class="mb-10 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
  <div class="border-b border-gray-200 bg-gray-50 px-4 py-2.5">
    <h2 class="text-sm font-semibold text-gray-700">比較ポイント早見表</h2>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <tbody class="divide-y divide-gray-100">
        <tr>
          <th class="w-36 whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">ツール名</th>
          <td class="px-4 py-3 font-medium text-gray-900">{data.name}</td>
        </tr>
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">カテゴリ</th>
          <td class="px-4 py-3">{categoryLabel(data.category)}</td>
        </tr>
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">無料枠</th>
          <td class="px-4 py-3">
            <span class={`rounded px-2 py-0.5 text-xs font-medium ${fp.cls}`}>{fp.text}</span>
          </td>
        </tr>
        {data.freePlanNote && (
          <tr>
            <th class="whitespace-nowrap bg-gray-50 px-4 py-3 align-top text-left font-medium text-gray-600">無料枠メモ</th>
            <td class="px-4 py-3 text-xs leading-relaxed text-gray-600">{data.freePlanNote}</td>
          </tr>
        )}
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">最安料金</th>
          <td class="px-4 py-3 text-sm text-gray-700">{data.lowestPaidPlan ?? '要確認'}</td>
        </tr>
        {data.paidPlanNote && (
          <tr>
            <th class="whitespace-nowrap bg-gray-50 px-4 py-3 align-top text-left font-medium text-gray-600">有料プランメモ</th>
            <td class="px-4 py-3 text-xs leading-relaxed text-gray-600">{data.paidPlanNote}</td>
          </tr>
        )}
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 align-top text-left font-medium text-gray-600">商用利用</th>
          <td class="px-4 py-3">
            <span class={`rounded px-2 py-0.5 text-xs font-medium ${cu.badgeCls}`}>{cu.badge}</span>
            <p class="mt-1 text-xs leading-relaxed text-gray-500">{cu.desc}</p>
            {data.commercialUseNote && (
              <p class="mt-1 text-xs leading-relaxed text-gray-600">{data.commercialUseNote}</p>
            )}
          </td>
        </tr>
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">日本語UI</th>
          <td class={`px-4 py-3 ${jui.cls}`}>{jui.text}</td>
        </tr>
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">日本語プロンプト</th>
          <td class={`px-4 py-3 ${jpr.cls}`}>{jpr.text}</td>
        </tr>
        {data.japaneseDocs !== undefined && (
          <tr>
            <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">日本語資料</th>
            <td class={`px-4 py-3 font-bold ${data.japaneseDocs ? 'text-green-600' : 'text-red-500'}`}>
              {data.japaneseDocs ? '○' : '×'}
            </td>
          </tr>
        )}
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">透かし</th>
          <td class="px-4 py-3">
            <span class={`rounded px-2 py-0.5 text-xs font-medium ${wm.cls}`}>{wm.text}</span>
          </td>
        </tr>
        {data.watermarkCondition && (
          <tr>
            <th class="whitespace-nowrap bg-gray-50 px-4 py-3 align-top text-left font-medium text-gray-600">透かし条件</th>
            <td class="px-4 py-3 text-xs leading-relaxed text-gray-600">{data.watermarkCondition}</td>
          </tr>
        )}
        {data.platforms && data.platforms.length > 0 && (
          <tr>
            <th class="whitespace-nowrap bg-gray-50 px-4 py-3 align-top text-left font-medium text-gray-600">対応環境</th>
            <td class="px-4 py-3">
              <div class="flex flex-wrap gap-1.5">
                {data.platforms.map(p => (
                  <span class="rounded bg-blue-50 px-2 py-0.5 text-xs text-blue-700">{platformLabels[p] ?? p}</span>
                ))}
              </div>
            </td>
          </tr>
        )}
        {trueFeatureLabels.length > 0 && (
          <tr>
            <th class="whitespace-nowrap bg-gray-50 px-4 py-3 align-top text-left font-medium text-gray-600">主な機能</th>
            <td class="px-4 py-3">
              <div class="flex flex-wrap gap-1.5">
                {trueFeatureLabels.map(label => (
                  <span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-700">{label}</span>
                ))}
                {data.features?.maxResolution && (
                  <span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-700">最大解像度: {data.features.maxResolution}</span>
                )}
                {data.features?.maxVideoDuration && (
                  <span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-700">最大動画尺: {data.features.maxVideoDuration}</span>
                )}
              </div>
            </td>
          </tr>
        )}
        {data.bestFor.length > 0 && (
          <tr>
            <th class="whitespace-nowrap bg-gray-50 px-4 py-3 align-top text-left font-medium text-gray-600">向いている用途</th>
            <td class="px-4 py-3">
              <ul class="space-y-1">
                {data.bestFor.map((item) => (
                  <li class="flex items-start gap-1.5 text-xs text-gray-700">
                    <span class="mt-0.5 shrink-0 text-blue-500">▶</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </td>
          </tr>
        )}
        {data.useCases && data.useCases.length > 0 && (
          <tr>
            <th class="whitespace-nowrap bg-gray-50 px-4 py-3 align-top text-left font-medium text-gray-600">用途</th>
            <td class="px-4 py-3">
              <div class="flex flex-wrap gap-1.5">
                {data.useCases.slice(0, 6).map(uc => (
                  <span class="rounded bg-purple-50 px-2 py-0.5 text-xs text-purple-700">{useCaseLabels[uc] ?? uc}</span>
                ))}
              </div>
            </td>
          </tr>
        )}
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">情報確認日</th>
          <td class="px-4 py-3 text-xs text-gray-600">{data.lastReviewed}</td>
        </tr>
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">次回確認予定</th>
          <td class="px-4 py-3 text-xs text-gray-600">{data.nextReviewDue}</td>
        </tr>
        <tr>
          <th class="whitespace-nowrap bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">公式サイト</th>
          <td class="px-4 py-3">
            <a
              href={data.officialUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-blue-600 hover:underline"
            >
              公式サイトで確認 ↗
            </a>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>
