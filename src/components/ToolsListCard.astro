---
import type { CollectionEntry } from 'astro:content';
import FreshnessLabel from './FreshnessLabel.astro';
import { COMMERCIAL_PLAN_SUMMARIES, getAttributionLabel, getCategoryLabel, getPlatformLabel } from '../data/labelDictionary';

interface Props {
  tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;
const { data, slug } = tool;

const badgeMap: Record<string, { letter: string; color: string }> = {
  'canva-ai-image-generator': { letter: 'C', color: '#0E8E84' },
  'adobe-firefly':            { letter: 'A', color: '#D8453A' },
  'clipdrop':                 { letter: 'C', color: '#2E6FF2' },
  'dalle':                    { letter: 'D', color: '#10A37F' },
  'dreamstudio':              { letter: 'D', color: '#7A3FE8' },
  'fotor-ai':                 { letter: 'F', color: '#6C5CE7' },
  'gemini-image-generation':  { letter: 'G', color: '#3A6FF0' },
  'leonardo-ai':              { letter: 'L', color: '#E89B12' },
  'microsoft-designer':       { letter: 'M', color: '#0078D4' },
  'nightcafe':                { letter: 'N', color: '#2D2A6E' },
  'midjourney':               { letter: 'M', color: '#7A5AE0' },
  'ideogram':                 { letter: 'I', color: '#1A1A2E' },
  'playground-ai':            { letter: 'P', color: '#7C3AED' },
  'seaart-ai':                { letter: 'S', color: '#5B7CFA' },
  'stable-diffusion':         { letter: 'S', color: '#1F63E8' },
  'tensor-art':               { letter: 'T', color: '#FF5A8A' },
  'capcut-ai':                { letter: 'C', color: '#111319' },
  'hailuo-ai':                { letter: 'H', color: '#FF6B35' },
  'haiper':                   { letter: 'H', color: '#6D5BF8' },
  'kling-ai':                 { letter: 'K', color: '#3A6FF0' },
  'luma-ai':                  { letter: 'L', color: '#15897F' },
  'pika':                     { letter: 'P', color: '#10A4C8' },
  'pixverse':                 { letter: 'P', color: '#7B5BFF' },
  'invideo-ai':               { letter: 'I', color: '#E1395B' },
  'runway':                   { letter: 'R', color: '#E1543A' },
  'vidu-ai':                  { letter: 'V', color: '#2EA8E0' },
};

const badge = badgeMap[slug] ?? { letter: data.name[0].toUpperCase(), color: '#4B3FE4' };

function freeLabel(v: unknown): string {
  if (v === true)        return 'あり';
  if (v === false)       return 'なし';
  if (v === 'limited')   return '条件付き';
  return '要公式確認';
}
function freeCommercialLabel(freePlan: unknown, commercialUse: unknown): { sym: string; text: string; cls: string } {
  if (freePlan === false) return { sym: '×', text: '無料プランなし', cls: 'na' };
  if (freePlan === 'unknown') return { sym: '－', text: '要確認', cls: 'na' };
  if (commercialUse === 'ok') return { sym: '○', text: '案内あり', cls: 'ok' };
  if (commercialUse === 'limited') return { sym: '△', text: '条件あり', cls: 'warn' };
  if (commercialUse === 'no') return { sym: '×', text: '不可', cls: 'na' };
  if (commercialUse === 'paid-only') return { sym: '×', text: '有料のみ', cls: 'na' };
  return { sym: '－', text: '要確認', cls: 'na' };
}
function paidCommercialLabel(v: unknown): { sym: string; text: string; cls: string } {
  if (v === 'ok') return { sym: '○', text: '案内あり', cls: 'ok' };
  if (v === 'paid-only') return { sym: '○', text: '案内あり', cls: 'ok' };
  if (v === 'limited') return { sym: '△', text: '条件あり', cls: 'warn' };
  if (v === 'no') return { sym: '×', text: '不可', cls: 'na' };
  return { sym: '－', text: '要確認', cls: 'na' };
}
function freeSym(v: unknown): string {
  if (v === true) return '○';
  if (v === false) return '×';
  if (v === 'limited') return '△';
  return '－';
}
function jaSym(ui: unknown, prompt: unknown): string {
  const label = jaLabel(ui, prompt);
  if (label === '対応') return '○';
  if (label === '部分対応') return '△';
  if (label === '非対応') return '×';
  return '－';
}
function wmSym(v: unknown): string {
  if (v === 'no') return '○';
  if (v === 'yes') return '×';
  if (v === 'limited') return '△';
  return '－';
}
function jaLabel(ui: unknown, prompt: unknown): string {
  if (ui === true) return '対応';
  if (ui === false && prompt === false) return '非対応';
  if (ui === 'partial' || (ui === false && (prompt === true || prompt === 'partial'))) return '部分対応';
  return '要確認';
}
function wmLabel(v: unknown): string {
  if (v === 'no') return '透かしなし';
  if (v === 'yes') return '透かしあり';
  if (v === 'limited') return 'プランによって異なる';
  return '要確認';
}
function inputMaterialLabel(v: unknown): { text: string; cls: string } | null {
  if (v === 'low')    return { text: '入力素材：別途確認', cls: 'imr-low' };
  if (v === 'medium') return { text: '入力素材：注意あり', cls: 'imr-med' };
  if (v === 'high')   return { text: '入力素材：要注意',   cls: 'imr-high' };
  return null;
}
function condClass(field: string, val: string): string {
  if (field === 'free') return val === 'あり' ? 'ok' : val === '条件付き' ? 'warn' : 'na';
  if (field === 'ja') return val === '対応' ? 'ok' : val === '部分対応' ? 'warn' : 'na';
  if (field === 'watermark') {
    if (val === '透かしなし') return 'ok';
    if (val === '透かしあり') return 'warn';
    return 'na';
  }
  return 'na';
}
function priceSortKey(data: { lowestPaidPlan?: string; freePlan: unknown; currency?: string }): number {
  if (!data.lowestPaidPlan) return data.freePlan === false ? 99999 : 0;
  const m = data.lowestPaidPlan.match(/[\d,]+/);
  if (!m) return 99999;
  const n = parseInt(m[0].replace(',', ''), 10);
  return data.currency === 'USD' ? n * 150 : n;
}

const usagePolicySummary: string | null =
  (data.usagePolicy != null && COMMERCIAL_PLAN_SUMMARIES[slug] != null)
    ? COMMERCIAL_PLAN_SUMMARIES[slug]
    : null;

const imrLabel = inputMaterialLabel(data.usagePolicy?.inputMaterialRisk);
const attrLabel = getAttributionLabel(data.watermark as 'yes' | 'no' | 'limited' | 'unknown');
const freeComm  = freeCommercialLabel(data.freePlan, data.commercialUse);
const paidComm  = paidCommercialLabel(data.commercialUse);
const freeVal   = freeLabel(data.freePlan);
const jaVal     = jaLabel(data.japaneseUi, data.japanesePrompt);
const wmVal     = wmLabel(data.watermark);
const freeSymVal = freeSym(data.freePlan);
const jaSymVal   = jaSym(data.japaneseUi, data.japanesePrompt);
const wmSymVal   = wmSym(data.watermark);

const dataFree       = freeVal === 'あり' ? '1' : '0';
const dataCommercial = (data.commercialUse === 'ok' || data.commercialUse === 'paid-only') ? '1' : '0';
const dataJa         = jaVal === '対応' ? '1' : '0';
const dataNowm       = wmVal === '透かしなし' ? '1' : '0';
const dataSortPrice  = priceSortKey({ lowestPaidPlan: data.lowestPaidPlan, freePlan: data.freePlan, currency: data.currency });
const dataUpdated    = data.lastReviewed ?? '';

const catLabel = getCategoryLabel(data.category);

const dataCat = (data.category === 'both') ? 'image' : data.category;

const price = data.lowestPaidPlan ?? '要公式確認';
const displayPlatforms = (data.platforms ?? []).map((p: string) => getPlatformLabel(p));
---

<article class="tool"
  data-cat={dataCat}
  data-name={data.name.toLowerCase()}
  data-free={dataFree}
  data-commercial={dataCommercial}
  data-ja={dataJa}
  data-nowm={dataNowm}
  data-sort-price={dataSortPrice}
  data-updated={dataUpdated}
>
  <div class="tool-head">
    <span class="tool-badge" style={`background:${badge.color};`}>{badge.letter}</span>
    <span>
      <span class="tool-name">{data.name}</span><br />
      <span class="tool-cat">{catLabel}</span>
    </span>
  </div>

  <div class="tool-cond">
    <span class={`cond ${freeComm.cls}`}>
      <span class="ck">商用（無料）</span>
      <span class="cv"><span class="sym">{freeComm.sym}</span>{freeComm.text}</span>
    </span>
    <span class={`cond ${paidComm.cls}`}>
      <span class="ck">商用（有料）</span>
      <span class="cv"><span class="sym">{paidComm.sym}</span>{paidComm.text}</span>
    </span>
    <span class={`cond ${condClass('free', freeVal)}`}>
      <span class="ck">無料枠</span>
      <span class="cv"><span class="sym">{freeSymVal}</span>{freeVal}</span>
    </span>
    <span class={`cond ${condClass('ja', jaVal)}`}>
      <span class="ck">日本語対応</span>
      <span class="cv"><span class="sym">{jaSymVal}</span>{jaVal}</span>
    </span>
    <span class={`cond ${condClass('watermark', wmVal)}`}>
      <span class="ck">透かし</span>
      <span class="cv"><span class="sym">{wmSymVal}</span>{wmVal}</span>
    </span>
  </div>

  {usagePolicySummary && (
    <div class="tool-usage-summary">
      <span class="us-label">商用利用条件</span>
      <span class="us-value">{usagePolicySummary}</span>
    </div>
  )}

  {(imrLabel || attrLabel) && (
    <div class="tool-imr">
      {imrLabel && <span class={`imr-badge ${imrLabel.cls}`}>{imrLabel.text}</span>}
      {attrLabel && <span class={`imr-badge ${attrLabel.cls}`}>{attrLabel.text}</span>}
    </div>
  )}

  {displayPlatforms.length > 0 && (
    <div class="tool-platforms">
      {displayPlatforms.map((p: string) => <span class="plat">{p}</span>)}
    </div>
  )}

  <div class="tool-meta">
    <div>
      <span class="tool-price">{price}</span>
      <div style="margin-top:4px;">
        <FreshnessLabel verifiedAt={data.verifiedAt} lastReviewed={data.lastReviewed} variant="card" />
      </div>
    </div>
    <div class="tool-links">
      <a class="detail" href={`/tools/${slug}/`}>詳しく見る →</a>
      {data.officialUrl && (
        <a class="ext" href={data.officialSourceUrl ?? data.officialUrl} target="_blank" rel="noopener noreferrer">
          {data.officialSourceUrl ? '公式情報 ↗' : '公式サイト ↗'}
        </a>
      )}
    </div>
  </div>

  <div class="tool-condlinks">
    <span class="cl-label">条件別：</span>
    <a class="cl" href="/conditions/commercial-use/">商用利用</a>
    <a class="cl" href="/conditions/free/">無料枠</a>
    <a class="cl" href="/conditions/no-watermark/">透かし</a>
    <a class="cl" href="/conditions/japanese/">日本語</a>
  </div>
</article>
