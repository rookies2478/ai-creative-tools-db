---
const {
  eyebrow = 'Use cases',
  headingHtml = '用途別<span class="hl">AIツール記事</span>一覧',
  lead = '作りたいアウトプットから、関連するAI画像生成・AI動画生成ツールや選び方を探せます。用途によって必要な機能や確認すべき条件は異なります。',
  notice = '掲載内容は確認時点の情報です。最新情報や具体的な利用可否は必ず各公式サイトでご確認ください。本記事群は法的助言ではありません。プランや用途によって条件が異なる場合があります。',
  toolCounts = {} as Record<string, number>,
  feature = {
    label: 'まとめ',
    title: '用途別AI画像生成ツール比較',
    desc: 'サムネ・SNS・広告・EC・ブログ向けに、確認すべき条件を用途ごとに整理した比較記事です。まず全体像をつかみたいときの出発点としてご利用ください。',
    href: '/use-cases/ai-image-use-case-comparison/',
    axes: ['YouTube', 'SNS', '広告', 'EC', 'ブログ', 'イラスト', '写真風'],
    cta: '比較を読む',
  },
  cards = [
    { label: 'YouTube', icon: 'play', title: 'YouTubeサムネイル向け', desc: 'クリック率を意識したサムネイル制作向けツールを比較。文字入れ・商用利用条件・透かしを確認できます。', href: '/use-cases/youtube-thumbnail/' },
    { label: 'SNS', icon: 'share', title: 'SNS投稿向け', desc: 'Instagram・X・TikTokなど向け。縦型・正方形対応・商用利用条件・透かしを確認できます。', href: '/use-cases/sns-post-image/' },
    { label: '広告', icon: 'megaphone', title: '広告クリエイティブ向け', desc: 'Web広告・LP用バナー制作向け。商用利用条件・透かし・文字入れ対応を比較できます。', href: '/use-cases/ad-banner/' },
    { label: 'ブログ', icon: 'doc', title: 'ブログ・アイキャッチ向け', desc: 'WordPress・note・はてなブログ向け。無料枠・商用利用条件・日本語対応を確認できます。', href: '/use-cases/blog-eyecatch/' },
    { label: 'EC', icon: 'bag', title: 'EC商品画像向け', desc: 'Amazon・楽天・自社EC向け商品画像制作。背景除去・高解像度・商用利用条件を確認できます。', href: '/use-cases/ec-product-image/' },
    { label: 'イラスト', icon: 'brush', title: 'アニメイラスト向け', desc: 'アニメ・イラスト調の画像生成に向いているツールを比較できます。', href: '/use-cases/anime-illustration/' },
    { label: '写真風', icon: 'camera', title: 'リアル写真風画像向け', desc: '写真に近いリアルな画像生成に向いているツールを比較できます。', href: '/use-cases/realistic-photo/' },
    { label: 'SNS・ブログ', icon: 'layers', title: 'SNS・ブログアイキャッチ向け', desc: 'SNSとブログ両方のアイキャッチ制作向けツールをまとめて比較できます。', href: '/use-cases/sns-blog-eyecatch/' },
  ],
  relatedHeading = 'あわせて見る',
  relatedLead = '比較記事・ガイド・条件ページからも、目的に合うAIツールを探せます。',
  related = [
    { label: '比較記事一覧', href: '/comparisons/' },
    { label: 'ガイド一覧', href: '/guides/' },
    { label: '商用利用を確認', href: '/conditions/commercial-use/' },
    { label: '無料で試せる', href: '/conditions/free/' },
    { label: 'すべてのツール', href: '/tools/', solid: true },
  ],
} = Astro.props;

const ICONS: Record<string, string> = {
  grid: '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
  play: '<rect x="3" y="5" width="18" height="14" rx="3"/><path d="M11 9.2v5.6l4.5-2.8z"/>',
  share: '<circle cx="6" cy="12" r="2.6"/><circle cx="17.5" cy="6" r="2.6"/><circle cx="17.5" cy="18" r="2.6"/><path d="M8.3 10.8 15.2 7.2M8.3 13.2l6.9 3.6"/>',
  megaphone: '<path d="M4 10v4a1 1 0 0 0 1 1h2l8 4V5L7 9H5a1 1 0 0 0-1 1Z"/><path d="M18 8.5a4 4 0 0 1 0 7"/>',
  doc: '<path d="M6 3h8l4 4v14a0 0 0 0 1 0 0H6a0 0 0 0 1 0 0V3Z"/><path d="M14 3v4h4M9 13h6M9 17h4"/>',
  bag: '<path d="M5 8h14l-1 12H6L5 8Z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/>',
  brush: '<path d="M14 4 20 10l-7.5 7.5a3 3 0 0 1-3 .8L7 21H4v-3l1.7-2.5a3 3 0 0 1 .8-3Z"/><path d="m13 7 4 4"/>',
  camera: '<path d="M3 8a2 2 0 0 1 2-2h2l1.5-2h7L19 6h0a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8Z"/><circle cx="12" cy="13" r="3.2"/>',
  layers: '<path d="M12 3 3 8l9 5 9-5-9-5Z"/><path d="m3 13 9 5 9-5M3 18l9 5 9-5"/>',
};
const iconSvg = (k?: string) => ICONS[k ?? 'grid'] ?? ICONS['grid'];
---

<div class="uci-x" data-uci>
  <!-- ===== ページヘッダー ===== -->
  <header class="uci-head reveal">
    <span class="uci-eyebrow">{eyebrow}</span>
    <h1 class="uci-h1" set:html={headingHtml}></h1>
    <p class="uci-lead">{lead}</p>
  </header>

  <!-- ===== 注意書き ===== -->
  {notice && (
    <div class="uci-notice reveal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p><b>ご利用前に：</b>{notice}</p>
    </div>
  )}

  <!-- ===== 用途別記事 ===== -->
  <section class="uci-sec">
    <div class="uci-sechead reveal">
      <span class="uci-eyebrow">By output</span>
      <h2>用途別記事</h2>
      <p>「何を作りたいか」から記事を選べます。各記事は商用利用・透かし・無料枠などの観点を、要確認ベースで整理しています。</p>
    </div>

    <div class="uci-grid reveal" data-stagger>
      <!-- まとめ（フラッグシップ） -->
      <a class="uci-feature" href={feature.href} aria-label={feature.title}>
        <div class="fc-body">
          <span class="uci-cat brand"><span class="d"></span>{feature.label}</span>
          <h3>{feature.title}</h3>
          <p>{feature.desc}</p>
          {feature.axes && feature.axes.length > 0 && (
            <div class="fc-axes">{feature.axes.map((a) => (<span>{a}</span>))}</div>
          )}
          <span class="fc-cta">{feature.cta ?? '比較を読む'} <span class="ar">→</span></span>
        </div>
        <div class="fc-visual" aria-hidden="true">
          <div class="mhead"><span class="t">用途</span><span class="c">画像</span><span class="c">動画</span></div>
          <div class="mr"><span class="lbl">商用利用</span><span class="m cond">△</span><span class="m cond">△</span></div>
          <div class="mr"><span class="lbl">無料枠</span><span class="m ok">○</span><span class="m cond">△</span></div>
          <div class="mr"><span class="lbl">透かしなし</span><span class="m cond">△</span><span class="m cond">△</span></div>
          <div class="mr"><span class="lbl">日本語対応</span><span class="m ok">○</span><span class="m cond">△</span></div>
        </div>
      </a>

      {cards.map((c) => (
        <a class="uci-card" href={c.href} aria-label={c.title}>
          <div class="uci-cardtop">
            <span class="uci-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={iconSvg(c.icon)}></svg></span>
            <span class="uci-cat brand"><span class="d"></span>{c.label}</span>
            <span class="uci-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
          <h3 class="uci-cardttl">{c.title}</h3>
          <p class="uci-carddesc">{c.desc}</p>
          {toolCounts[c.href] != null && (
            <span class="uci-toolcount">候補ツール：{toolCounts[c.href]}件</span>
          )}
          <span class="uci-read">{c.cta ?? '読む'}<span class="ar">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== あわせて見る ===== -->
  <section class="uci-sec band" style="padding-bottom:64px;">
    <div class="uci-finder reveal">
      <h2>{relatedHeading}</h2>
      <p class="lead">{relatedLead}</p>
      <div class="uci-taglinks">
        {related.map((r) => (
          <a class={`uci-taglink${r.solid ? ' solid' : ''}`} href={r.href}>
            {!r.solid && <span class="ld"></span>}{r.label}
          </a>
        ))}
      </div>
    </div>
  </section>
</div>

<style>
  /* すべて .uci-x 配下に限定。CSS変数も .uci-x 上に定義（:root非使用）。 */
  .uci-x {
    --paper:#F4F4EE; --surface:#FFFFFF; --surface-2:#FAFAF6;
    --ink:#16181D; --ink-soft:#3A3E47; --muted:#6A7180; --faint:#98A0AD;
    --line:#E3E2D9; --line-strong:#D2D1C6;
    --brand:#4B3FE4; --brand-ink:#2E25A6; --brand-tint:#ECEBFB; --on-brand:#FFFFFF;
    --video:#E1543A; --video-tint:#FCEDE9; --image:#15897F; --image-tint:#E2F1EF;
    --ok:#1E8A4C; --ok-tint:#E6F3EC; --warn:#A06A09; --warn-tint:#F8EFD9;
    --f-jp:"Zen Kaku Gothic New","Noto Sans JP",system-ui,sans-serif;
    --f-body:"Noto Sans JP",system-ui,sans-serif;
    --f-latin:"Space Grotesk",system-ui,sans-serif;
    --f-mono:"Space Mono",ui-monospace,monospace;
    --radius:14px; --radius-lg:22px;
    --shadow-sm:0 1px 2px rgba(20,22,28,.04),0 1px 3px rgba(20,22,28,.05);
    --shadow-md:0 4px 14px rgba(20,22,28,.06),0 2px 6px rgba(20,22,28,.04);
    --shadow-lg:0 18px 40px -18px rgba(20,22,28,.22),0 6px 16px rgba(20,22,28,.06);
    --ease:cubic-bezier(.22,.61,.36,1);

    font-family: var(--f-body);
    color: var(--ink);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }
  .uci-x :where(h1,h2,h3) { font-family: var(--f-jp); font-weight: 700; line-height: 1.32; letter-spacing: .01em; margin: 0; }
  .uci-x :where(p) { margin: 0; }
  .uci-x a { color: inherit; text-decoration: none; }

  .uci-eyebrow { font-family: var(--f-latin); font-size: 12px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: var(--muted); display: inline-flex; align-items: center; gap: 10px; }
  .uci-eyebrow::before { content: ""; width: 22px; height: 2px; border-radius: 2px; background: var(--brand); }

  /* ページヘッダー */
  .uci-head { padding: 30px 0 0; max-width: 760px; }
  .uci-h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 900; letter-spacing: -.012em; line-height: 1.18; margin: 16px 0 18px; }
  .uci-h1 .hl { color: var(--brand-ink); position: relative; }
  .uci-h1 .hl::after { content: ""; position: absolute; left: 0; right: 0; bottom: .08em; height: .26em; background: color-mix(in srgb, var(--brand) 18%, transparent); z-index: -1; border-radius: 2px; }
  .uci-lead { font-size: 15.5px; color: var(--ink-soft); max-width: 680px; }

  /* 注意書き */
  .uci-notice { display: flex; align-items: flex-start; gap: 12px; margin-top: 26px; background: var(--surface-2); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 20px; max-width: 880px; }
  .uci-notice svg { width: 18px; height: 18px; color: var(--muted); flex: none; margin-top: 2px; }
  .uci-notice p { font-size: 12.5px; color: var(--muted); line-height: 1.75; }
  .uci-notice b { color: var(--ink-soft); font-weight: 700; }

  /* セクション */
  .uci-sec { padding: 44px 0 56px; }
  .uci-sec.band { background: var(--surface-2); border-top: 1px solid var(--line); padding: 56px 0; }
  .uci-sechead { max-width: 760px; margin-bottom: 28px; }
  .uci-sechead h2 { font-size: clamp(21px, 2.6vw, 30px); font-weight: 900; letter-spacing: -.005em; margin: 14px 0 10px; }
  .uci-sechead p { color: var(--muted); font-size: 14.5px; }

  /* カテゴリバッジ */
  .uci-cat { align-self: flex-start; font-family: var(--f-jp); font-weight: 700; font-size: 11.5px; padding: 4px 11px; border-radius: 999px; display: inline-flex; align-items: center; gap: 6px; line-height: 1.2; }
  .uci-cat .d { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .uci-cat.brand { color: var(--brand-ink); background: var(--brand-tint); }

  /* グリッド */
  .uci-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }

  /* 通常カード */
  .uci-card { position: relative; display: flex; flex-direction: column; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 24px 26px 22px; box-shadow: var(--shadow-sm); transition: transform .22s var(--ease), box-shadow .22s, border-color .22s; overflow: hidden; }
  .uci-card::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; background: var(--brand); transform: scaleX(0); transform-origin: left; transition: transform .3s var(--ease); }
  .uci-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: color-mix(in srgb, var(--brand) 30%, var(--line)); }
  .uci-card:hover::before { transform: scaleX(1); }

  .uci-cardtop { display: flex; align-items: center; gap: 11px; margin-bottom: 16px; }
  .uci-ico { width: 38px; height: 38px; border-radius: 11px; background: var(--brand-tint); color: var(--brand-ink); display: grid; place-items: center; flex: none; transition: background .22s, color .22s; }
  .uci-ico svg { width: 20px; height: 20px; }
  .uci-card:hover .uci-ico { background: var(--brand); color: #fff; }
  .uci-cardtop .uci-cat { margin: 0; }
  .uci-arrow { margin-left: auto; width: 30px; height: 30px; border-radius: 50%; border: 1px solid var(--line-strong); display: grid; place-items: center; color: var(--muted); transition: transform .22s var(--ease), background .22s, color .22s, border-color .22s; flex: none; }
  .uci-arrow svg { width: 15px; height: 15px; }
  .uci-card:hover .uci-arrow { background: var(--brand); border-color: var(--brand); color: #fff; transform: translateX(3px); }

  .uci-cardttl { font-size: 17px; font-weight: 700; line-height: 1.42; color: var(--ink); margin-bottom: 10px; text-wrap: pretty; }
  .uci-card:hover .uci-cardttl { color: var(--brand-ink); }
  .uci-carddesc { font-size: 13px; color: var(--muted); line-height: 1.78; flex: 1; }
  .uci-toolcount { display: inline-block; margin-top: 10px; font-family: var(--f-jp); font-size: 11.5px; font-weight: 600; color: var(--muted); background: var(--surface-2); border: 1px solid var(--line); border-radius: 999px; padding: 3px 11px; }
  .uci-read { margin-top: 18px; font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; color: var(--brand-ink); display: inline-flex; align-items: center; gap: 5px; white-space: nowrap; }
  .uci-read .ar { transition: transform .2s var(--ease); }
  .uci-card:hover .uci-read .ar { transform: translateX(3px); }

  /* まとめ（フラッグシップ）カード */
  .uci-feature { grid-column: 1 / -1; display: grid; grid-template-columns: 1.2fr .8fr; gap: 0; border: 1px solid color-mix(in srgb, var(--brand) 28%, var(--line)); border-radius: var(--radius-lg); overflow: hidden; background: var(--surface); transition: transform .25s var(--ease), box-shadow .25s; }
  .uci-feature:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .uci-feature .fc-body { padding: 36px 38px; display: flex; flex-direction: column; gap: 13px; justify-content: center; }
  .uci-feature .fc-body h3 { font-size: clamp(21px, 2.4vw, 26px); line-height: 1.32; color: var(--ink); }
  .uci-feature:hover .fc-body h3 { color: var(--brand-ink); }
  .uci-feature .fc-body p { color: var(--muted); font-size: 14.5px; line-height: 1.7; }
  .fc-axes { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 2px; }
  .fc-axes span { font-family: var(--f-jp); font-weight: 600; font-size: 12px; color: var(--ink-soft); background: var(--surface-2); border: 1px solid var(--line); padding: 5px 11px; border-radius: 999px; }
  .fc-cta { margin-top: 8px; font-family: var(--f-jp); font-weight: 700; font-size: 14.5px; color: var(--brand-ink); display: inline-flex; align-items: center; gap: 8px; }
  .fc-cta .ar { transition: transform .2s var(--ease); }
  .uci-feature:hover .fc-cta .ar { transform: translateX(4px); }

  .uci-feature .fc-visual { background: var(--ink); padding: 30px; display: flex; flex-direction: column; justify-content: center; gap: 9px; }
  .fc-visual .mhead { display: grid; grid-template-columns: 1fr 40px 40px; gap: 12px; padding: 0 14px 6px; align-items: center; }
  .fc-visual .mhead .t { font-family: var(--f-jp); font-weight: 700; font-size: 11px; color: rgba(255,255,255,.55); }
  .fc-visual .mhead .c { justify-self: center; font-family: var(--f-mono); font-size: 9.5px; letter-spacing: .04em; color: rgba(255,255,255,.55); }
  .fc-visual .mr { display: grid; grid-template-columns: 1fr 40px 40px; gap: 12px; align-items: center; padding: 11px 14px; background: rgba(255,255,255,.06); border-radius: 10px; }
  .fc-visual .mr .lbl { color: #fff; font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; }
  .fc-visual .mr .m { width: 24px; height: 24px; border-radius: 50%; display: grid; place-items: center; font-size: 12px; font-weight: 700; justify-self: center; }
  .fc-visual .m.ok { background: rgba(70,192,124,.16); color: #74D69E; }
  .fc-visual .m.cond { background: rgba(216,163,62,.16); color: #E6C067; }

  /* あわせて見る */
  .uci-finder { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 34px 34px 30px; box-shadow: var(--shadow-sm); }
  .uci-finder h2 { font-size: clamp(20px, 2.4vw, 26px); margin-bottom: 6px; }
  .uci-finder .lead { color: var(--muted); font-size: 14px; margin-bottom: 22px; }
  .uci-taglinks { display: flex; flex-wrap: wrap; gap: 10px; }
  .uci-taglink { font-family: var(--f-jp); font-weight: 600; font-size: 13.5px; padding: 9px 16px; border-radius: 999px; background: var(--surface); border: 1px solid var(--line-strong); color: var(--ink-soft); display: inline-flex; align-items: center; gap: 7px; white-space: nowrap; transition: transform .16s var(--ease), background .16s, border-color .16s, color .16s; }
  .uci-taglink:hover { border-color: var(--brand); color: var(--brand-ink); background: var(--brand-tint); transform: translateY(-1px); }
  .uci-taglink .ld { width: 7px; height: 7px; border-radius: 50%; background: var(--brand); flex: none; }
  .uci-taglink.solid { background: var(--ink); border-color: var(--ink); color: var(--surface); }
  .uci-taglink.solid:hover { background: var(--brand); border-color: var(--brand); color: #fff; }

  /* スクロール表示アニメ */
  @media (prefers-reduced-motion: no-preference) {
    .uci-x .reveal { opacity: 0; transform: translateY(18px); transition: opacity .6s var(--ease), transform .6s var(--ease); }
    .uci-x .reveal.in { opacity: 1; transform: none; }
    .uci-x .reveal[data-stagger] > * { opacity: 0; transform: translateY(16px); transition: opacity .5s var(--ease), transform .5s var(--ease); }
    .uci-x .reveal[data-stagger].in > * { opacity: 1; transform: none; }
    .uci-x .reveal[data-stagger].in > *:nth-child(1) { transition-delay: .03s; }
    .uci-x .reveal[data-stagger].in > *:nth-child(2) { transition-delay: .07s; }
    .uci-x .reveal[data-stagger].in > *:nth-child(3) { transition-delay: .11s; }
    .uci-x .reveal[data-stagger].in > *:nth-child(4) { transition-delay: .15s; }
    .uci-x .reveal[data-stagger].in > *:nth-child(5) { transition-delay: .19s; }
    .uci-x .reveal[data-stagger].in > *:nth-child(6) { transition-delay: .23s; }
    .uci-x .reveal[data-stagger].in > *:nth-child(7) { transition-delay: .27s; }
    .uci-x .reveal[data-stagger].in > *:nth-child(8) { transition-delay: .31s; }
    .uci-x .reveal[data-stagger].in > *:nth-child(9) { transition-delay: .35s; }
  }
  @media (prefers-reduced-motion: reduce) {
    .uci-x .reveal, .uci-x .reveal[data-stagger] > * { opacity: 1 !important; transform: none !important; }
  }

  /* レスポンシブ */
  @media (max-width: 980px) {
    .uci-grid { grid-template-columns: 1fr 1fr; }
    .uci-feature { grid-template-columns: 1fr; }
    .uci-feature .fc-visual { order: -1; }
  }
  @media (max-width: 720px) {
    .uci-sec { padding: 36px 0 48px; }
    .uci-sec.band { padding: 44px 0; }
    .uci-grid { grid-template-columns: 1fr; }
    .uci-feature .fc-body { padding: 26px 22px; }
    .uci-finder { padding: 26px 22px; }
  }
</style>

<script>
  // JSは [data-uci] 配下のみ操作（既存サイトに干渉しない）
  (function () {
    document.querySelectorAll('[data-uci]').forEach(function (root) {
      var reveals = Array.prototype.slice.call(root.querySelectorAll('.reveal'));
      if (!reveals.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach(function (el) { io.observe(el); });
      setTimeout(function () { reveals.forEach(function (el) { el.classList.add('in'); }); }, 8000);
    });
  })();
</script>
