export interface Point { title: string; sub: string; }
export interface Badge { s: Mark; label: string; }
export interface WmCheck { title: string; bodyHtml: string; }      // 透かし条件で確認すべきポイント
export interface ToolDetail {
  name: string;
  slug?: string;
  initial?: string;
  watermark: string;       // 透かし条件
  freeNote: string;        // 無料プランの注意
  commercial?: Badge;      // 商用利用
  platforms: string;       // 対応プラットフォーム（カンマ/読点区切り）
}
export interface StatusRow {
  name: string;
  slug?: string;
  initial?: string;
  watermark?: Badge;       // 透かし
  freePlan?: Badge;        // 無料プラン
  commercial?: Badge;      // 商用利用
  date?: string;
}
export interface NoteItem { lead: string; body: string; }
export interface UseCheck { situation: string; points: string; }
export interface CheckItem { html: string; }
export interface Faq { q: string; a: string; }
export interface RelatedLink { label: string; href: string; }

export interface Props {
  headingHtml?: string;
  lead?: string;
  checkedDate?: string;
  nextCheckDate?: string;
  stats?: Stat[];
  conclusionHtml?: string;
  disclaimer?: string;
  points?: Point[];
