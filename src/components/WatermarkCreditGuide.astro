    { name: 'Playground AI', slug: 'playground-ai', initial: 'P', freePlan: { s: 'ok', label: '〇 無料プランあり' }, commercial: { s: 'cond', label: '△ 条件付き' }, date: '2026-06-06' },
    { name: 'Runway', slug: 'runway', initial: 'R', watermark: { s: 'cond', label: '△ 条件付き' }, freePlan: { s: 'cond', label: '△ 制限付き無料' }, commercial: { s: 'cond', label: '△ 条件付き' }, date: '2026-06-05' },
    { name: 'SeaArt AI', slug: 'seaart-ai', initial: 'S', freePlan: { s: 'ok', label: '〇 無料プランあり' }, date: '2026-06-06' },
    { name: 'Stable Diffusion', slug: 'stable-diffusion', initial: 'S', watermark: { s: 'cond', label: '△ 条件付き' }, freePlan: { s: 'ok', label: '〇 無料プランあり' }, commercial: { s: 'cond', label: '△ 条件付き' }, date: '2026-06-06' },
    { name: 'Tensor.Art', slug: 'tensor-art', initial: 'T', freePlan: { s: 'ok', label: '〇 無料プランあり' }, commercial: { s: 'cond', label: '△ 条件付き' }, date: '2026-05-14' },
    { name: 'Vidu AI', slug: 'vidu-ai', initial: 'V', watermark: { s: 'cond', label: '△ 条件付き' }, freePlan: { s: 'cond', label: '△ 制限付き無料' }, date: '2026-06-04' },
  ],
  checklist = [
    { html: '使用するプランで<b>透かしなし出力が可能か</b>確認した' },
    { html: '可視透かしがない場合でも、<b>不可視メタデータ（C2PA等）</b>が埋め込まれるか確認した' },
    { html: '使用目的（SNS・ブログ・広告・納品物等）で<b>商用利用が許可されているか</b>確認した' },
    { html: '無料プランの場合、<b>商用利用が可能か</b>確認した' },
    { html: '<b>AI生成コンテンツであることの開示・明示</b>が必要か確認した' },
    { html: '<b>第三者の著作権・肖像権</b>に関わる内容が含まれていないか確認した' },
    { html: '<b>最新の公式利用規約</b>を確認した' },
  ],
  faqs = [
    { q: '透かしなしで使えるAI画像生成ツールはありますか？', a: '透かしなし出力が可能なツールは存在します。ただし多くの場合、有料プランへの移行が必要です。また「透かしなし」であっても、C2PAなどの不可視メタデータが埋め込まれる場合や、商用利用に別途条件が設けられている場合があります。最新の条件は各ツールの公式サイトでご確認ください。' },
    { q: '無料プランでも透かしなしで出力できますか？', a: 'ツールによって異なります。Runway・Pika・Kling AIなど多くの動画生成ツールでは、無料プランでは透かしが付与される場合があります。Adobe Firefly・Leonardo AIなど一部の画像生成ツールでは、無料プランでも透かしなし出力ができる場合がありますが、生成回数やクレジットに上限があります。最新の条件は各公式サイトでご確認ください。' },
    { q: '透かしがなければ商用利用できますか？', a: '透かしなし出力ができることと、商用利用が許可されていることは別の問題です。商用利用の可否はツールの利用規約で別に定められています。透かしがなくても商用利用に制限がある場合や、追加条件が設けられている場合があります。商用利用を検討する場合は、各ツールの最新利用規約を必ずご確認ください。このページは法的助言ではありません。' },
    { q: '透かしを消すために有料プランが必要ですか？', a: '多くのツールでは、有料プランに移行することで透かしなし出力が可能になります。ただし有料プランでも、出力形式・サイズ・用途によって条件が異なる場合があります。また公式に認められていない方法で透かしを削除することは、利用規約違反になる可能性があります。必ず公式のプランや方法で対応することを推奨します。' },
    { q: 'SNSやブログで使う前に何を確認すればよいですか？', a: '使用するプランで商用利用が許可されているか（ブログの収益化の有無も影響する場合があります）、AI生成コンテンツであることの開示・明示が必要かどうか、第三者の著作権・肖像権に関わる内容が含まれていないか、投稿するプラットフォームのAI生成コンテンツに関するポリシーを確認することを推奨します。' },
  ],
  notes = [
    '各ツールの料金・利用規約・透かし条件は予告なく変更されます。利用前に必ず公式サイトの最新情報をご確認ください。',
    '本ページは法的アドバイスではありません。重要な商用利用の場面では、専門家（弁護士等）への相談を推奨します。',
    '透かし・商用利用の最終的な判断は、各ツールの最新の公式利用規約に基づいてください。',
  ],
  footnote = 'このガイドは情報提供を目的としており、法的アドバイスではありません。商用利用の判断は各ツールの最新利用規約と専門家への相談に基づいて行ってください。',
  related = [
    { label: 'ツール一覧', href: '/tools/' },
    { label: '透かしなしツール', href: '/conditions/no-watermark/' },
    { label: '無料で使えるツール', href: '/conditions/free/' },
    { label: '商用利用を確認しやすいツール', href: '/conditions/commercial-use/' },
    { label: '商用利用・著作権ガイド', href: '/guides/commercial-use-copyright/' },
    { label: '無料ツールの選び方', href: '/guides/free-ai-image-tools/' },
  ],
  toolsBase = '/tools/',
} = Astro.props as Props;

const toolUrl = (slug?: string) => slug ? `${toolsBase}${slug}/` : undefined;
---

<article class="wcg-x" data-wcg>
  <!-- ===== 記事ヘッダー ===== -->
  <header class="wcg-head">
    <div class="wcg-meta">
      <span class="wcg-pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 5h16M4 12h16M4 19h10"/></svg>
        ガイド
      </span>
      <span class="wcg-checked">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        記事内容の最終確認 <b>{checkedDate}</b>
      </span>
    </div>
    <h1 class="wcg-h1" set:html={headingHtml}></h1>
    <p class="wcg-lead">{lead}</p>
    <div class="wcg-stats">
      {stats.map((s) => (
        <div class="wcg-stat"><span class="n">{s.n}</span><span class="t">{s.label}</span></div>
      ))}
    </div>
  </header>

  <!-- ===== 結論 + 免責 ===== -->
  <section class="wcg-sec reveal">
    <div class="wcg-conclusion">
      <div class="ttl"><span class="k">Conclusion</span></div>
      <h2>このガイドの結論</h2>
      <div set:html={conclusionHtml}></div>
    </div>
    <div class="wcg-disclaimer">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p><b>免責事項：</b>{disclaimer}</p>
    </div>
  </section>

  <!-- ===== 選びのポイント ===== -->
  <section class="wcg-sec">
    <div class="wcg-sechead reveal">
      <span class="wcg-eyebrow">How to choose</span>
      <h2>透かしなしAI画像生成ツール選びのポイント</h2>
      <p>「透かしなし」と書かれていても、実際の条件はプラン・用途・出力形式で変わります。判断を誤らないために押さえておきたい4つの観点です。</p>
    </div>
    <ol class="wcg-points reveal" data-stagger>
      {points.map((p, i) => (
        <li class="wcg-pcard">
          <span class="pn">{i + 1}</span>
          <div class="pt">
            <h3>{p.title}</h3>
            <p>{p.sub}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ===== 透かし条件で確認すべきポイント ===== -->
  <section class="wcg-sec band">
    <div class="wcg-sechead reveal">
      <span class="wcg-eyebrow">Key factors</span>
      <h2>透かし条件で確認すべきポイント</h2>
      <p>透かしのルールはプランや出力形式で細かく分かれます。利用前に、次の4点を順に確認しておきましょう。</p>
    </div>
    <ol class="wcg-checks reveal" data-stagger>
      {wmChecks.map((c, i) => (
        <li class="wcg-check">
          <span class="cn">{i + 1}</span>
          <div class="cb">
            <h3 class="wcg-h3">{c.title}</h3>
            <div class="wcg-richtext" set:html={c.bodyHtml}></div>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <!-- ===== 主要ツールの詳細比較（カード） ===== -->
  <section class="wcg-sec">
    <div class="wcg-sechead reveal">
      <span class="wcg-eyebrow">Tool comparison</span>
      <h2>透かしなし・条件付き透かしの主要ツール比較</h2>
      <p>以下は <b>{detailsAsOf}</b> 時点の調査に基づく目安です。プランや時期によって変更される可能性があります。詳細は各ツールの詳細ページおよび公式サイトでご確認ください。</p>
    </div>
    <p class="wcg-gtcap reveal">各行の確認日と公式サイトをご確認ください。</p>
    <div class="wcg-dgrid reveal" data-stagger>
      {toolDetails.map((t) => (
        <article class="wcg-dcard">
          <header class="dh">
            <span class="b">{t.initial}</span>
            {toolUrl(t.slug)
              ? <a class="nm" href={toolUrl(t.slug)}>{t.name}</a>
              : <span class="nm">{t.name}</span>}
            {t.commercial
              ? <span class={`wcg-st ${t.commercial.s}`}><span class="d"></span>{t.commercial.label}</span>
              : null}
          </header>
          <dl class="dl">
            <div class="drow"><dt>透かし条件</dt><dd>{t.watermark}</dd></div>
            <div class="drow"><dt>無料プランの注意</dt><dd>{t.freeNote}</dd></div>
            <div class="drow"><dt>対応プラットフォーム</dt><dd><span class="plats">{t.platforms.split(/[、,]/).map((p) => (<span class="plat">{p.trim()}</span>))}</span></dd></div>
          </dl>
        </article>
      ))}
    </div>
    <p class="wcg-foot reveal">※ 「商用利用」のマークは記事の編集方針に基づく目安です（★＝有料プラン向け／〇＝公式情報で可能／△＝条件付き／要確認＝公式情報で断定できず）。法的判断の根拠ではありません。</p>
  </section>

  <!-- ===== 無料プランと有料プランの違い ===== -->
  <section class="wcg-sec band">
    <div class="wcg-sechead reveal">
      <span class="wcg-eyebrow">Free vs paid</span>
      <h2>無料プランと有料プランの違い</h2>
      <p>透かしと商用利用は、無料プランと有料プランで扱いが大きく変わります。それぞれで起きやすいことを整理します。</p>
    </div>
    <div class="wcg-twocol reveal" data-stagger>
      <div class="wcg-panel free">
        <h3 class="ph"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg></span>無料プランで注意すること</h3>
        <ul>
          {freeCautions.map((c) => (<li><b>{c.lead}：</b>{c.body}</li>))}
        </ul>
      </div>
      <div class="wcg-panel paid">
        <h3 class="ph"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 3v18M3 12h18"/></svg></span>有料プランへの移行で変わること</h3>
        <ul>
          {paidChanges.map((c) => (<li><b>{c.lead}：</b>{c.body}</li>))}
        </ul>
      </div>
    </div>
    <div class="wcg-inlinenote reveal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p>{planDiffNote}</p>
    </div>
  </section>

  <!-- ===== 商用利用時の重要注意点 ===== -->
  <section class="wcg-sec">
    <div class="wcg-sechead reveal">
      <span class="wcg-eyebrow">Commercial use</span>
      <h2>商用利用時の重要注意点</h2>
      <p>透かしなし＝商用OK、ではありません。用途ごとに確認すべき観点が異なります。</p>
    </div>
    <div class="wcg-callout reveal">
      <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z"/></svg></span>
      <div class="ct">
        <strong>{commercialCallout.title}</strong>
        <p>{commercialCallout.body}</p>
      </div>
    </div>
    <div class="wcg-subsec reveal" style="margin-top:34px;">
      <h3 class="wcg-h3">用途別の主な確認ポイント</h3>
      <p class="wcg-gtcap" style="margin-top:6px;">各行の確認日と公式サイトをご確認ください。</p>
      <div class="wcg-tablewrap">
        <table class="wcg-gt usecase">
          <thead><tr><th>用途</th><th>主な確認ポイント</th></tr></thead>
          <tbody>
            {useChecks.map((u) => (
              <tr>
                <td class="wcg-situation">{u.situation}</td>
                <td class="wcg-note">{u.points}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ===== 主要ツールの透かし状況一覧表 ===== -->
  <section class="wcg-sec band">
    <div class="wcg-sechead reveal">
      <span class="wcg-eyebrow">Status index</span>
      <h2>主要ツールの透かし状況（確認時点）</h2>
      <p>以下は <b>{statusAsOf}</b> 時点の調査に基づく目安です。プランや時期によって変更される可能性があります。</p>
    </div>
    <div class="reveal">
      <p class="wcg-gtcap">各行の確認日と公式サイトをご確認ください。</p>
      <div class="wcg-tablewrap">
        <table class="wcg-gt tools">
          <thead><tr><th>ツール</th><th>透かし</th><th>無料プラン</th><th>商用利用</th><th>最終確認日</th><th>詳細</th></tr></thead>
          <tbody>
            {statusTools.map((t) => (
              <tr>
                <td><div class="wcg-tool"><span class="b">{t.initial}</span><span class="nm">{t.name}</span></div></td>
                <td>{t.watermark ? <span class={`wcg-st ${t.watermark.s}`}><span class="d"></span>{t.watermark.label}</span> : <span class="wcg-dash">—</span>}</td>
                <td>{t.freePlan ? <span class={`wcg-st ${t.freePlan.s}`}><span class="d"></span>{t.freePlan.label}</span> : <span class="wcg-dash">—</span>}</td>
                <td>{t.commercial ? <span class={`wcg-st ${t.commercial.s}`}><span class="d"></span>{t.commercial.label}</span> : <span class="wcg-dash">—</span>}</td>
                <td class="wcg-date">{t.date}</td>
                <td>{toolUrl(t.slug) ? <a class="wcg-detail" href={toolUrl(t.slug)}>詳細 →</a> : null}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="wcg-legend">
        <span class="li"><span class="wcg-st ok"><span class="d"></span>〇</span> なし（透かし）・可（商用利用）・あり（無料プラン）</span>
        <span class="li"><span class="wcg-st cond"><span class="d"></span>△</span> 条件付き・制限付き</span>
        <span class="li"><span class="wcg-st no"><span class="d"></span>×</span> あり（透かし）・不可（商用利用）・なし（無料プラン）</span>
      </div>
      <p class="wcg-foot">※ この表は法的判断の根拠ではありません。必ず各ツールの最新公式情報をご確認ください。</p>
    </div>
  </section>

  <!-- ===== チェックリスト ===== -->
  <section class="wcg-sec">
    <div class="wcg-sechead reveal">
      <span class="wcg-eyebrow">Checklist</span>
      <h2>ツール利用前のチェックリスト</h2>
      <p>透かしなしで生成・利用を始める前に、最低限おさえておきたい項目です。重要な用途では各項目を公式情報で裏付けてください。</p>
    </div>
    <ul class="wcg-checklist reveal" data-stagger>
      {checklist.map((c) => (
        <li><span class="box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg></span><span class="tx" set:html={c.html}></span></li>
      ))}
    </ul>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="wcg-sec band">
    <div class="wcg-sechead reveal">
      <span class="wcg-eyebrow">FAQ</span>
      <h2>よくある質問</h2>
      <p>透かしなし出力・無料プラン・商用利用・有料プランへの切り替え・SNS/ブログ利用について、確認のポイントをお答えします。</p>
    </div>
    <div class="wcg-faq reveal">
      {faqs.map((f) => (
        <div class="wcg-faqitem" aria-expanded="false">
          <button class="wcg-faqq" type="button"><span class="qm">Q</span>{f.q}<span class="ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg></span></button>
          <div class="wcg-faqa"><div class="wcg-faqa-in" set:html={f.a}></div></div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 注意事項 + 鮮度 ===== -->
  <section class="wcg-sec">
    <div class="wcg-sechead reveal"><span class="wcg-eyebrow">Notes</span><h2>注意事項</h2></div>
    <ul class="wcg-notes reveal">
      {notes.map((n) => (<li><span class="dot"></span>{n}</li>))}
    </ul>
    <div class="wcg-freshness reveal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
      <span><b>情報の鮮度：</b>記事内容の最終確認日 <span class="mono">{checkedDate}</span>（次回確認予定 <span class="mono">{nextCheckDate}</span>）</span>
    </div>
    <div class="wcg-disclaimer reveal" style="margin-top:18px;max-width:820px;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
      <p>{footnote}</p>
    </div>
  </section>

  <!-- ===== 関連ページ ===== -->
  <section class="wcg-sec" style="padding-bottom:0;">
    <div class="wcg-finder reveal">
      <h2>関連ページ</h2>
      <p class="lead">他のガイド・条件ページからも、透かし・商用利用の条件を確認できます。</p>
      <div class="wcg-taglinks">
        {related.map((r) => (<a class="wcg-taglink" href={r.href}><span class="ld"></span>{r.label}</a>))}
      </div>
    </div>
  </section>
</article>

<style>
  /* すべて .wcg-x 配下に限定。CSS変数も .wcg-x 上に定義（:root非使用）。 */
  .wcg-x {
    --paper:#F4F4EE; --surface:#FFFFFF; --surface-2:#FAFAF6;
    --ink:#16181D; --ink-soft:#3A3E47; --muted:#6A7180; --faint:#98A0AD;
    --line:#E3E2D9; --line-strong:#D2D1C6;
    --brand:#4B3FE4; --brand-ink:#2E25A6; --brand-tint:#ECEBFB;
    --video:#E1543A; --video-tint:#FCEDE9; --image:#15897F; --image-tint:#E2F1EF;
    --ok:#1E8A4C; --ok-tint:#E6F3EC; --warn:#A06A09; --warn-tint:#F8EFD9;
    --na:#6A7180; --na-tint:#EFEFEA; --paid:#4B3FE4; --paid-tint:#ECEBFB;
    --f-jp:"Zen Kaku Gothic New","Noto Sans JP",system-ui,sans-serif;
    --f-body:"Noto Sans JP",system-ui,sans-serif;
    --f-latin:"Space Grotesk",system-ui,sans-serif;
    --f-mono:"Space Mono",ui-monospace,monospace;
    --radius:14px; --radius-lg:22px;
