---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogType?: string;
  jsonLd?: string;
  noindex?: boolean;
  homePage?: boolean;
}

const {
  title,
  description = '生成AI画像・動画ツールを商用利用・料金・著作権で比較',
  canonicalPath,
  ogType = 'website',
  jsonLd,
  noindex = false,
  homePage = false,
} = Astro.props;

const canonicalUrl = canonicalPath && Astro.site
  ? new URL(canonicalPath, Astro.site).href
  : undefined;
---

<!doctype html>
<html lang="ja" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Design-token fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=Noto+Sans+JP:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:site_name" content="AIクリエイティブナビ" />
    <meta property="og:image" content="https://aicreative-db.com/ogp.png" />
    <title>{title}</title>
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    {import.meta.env.PROD && (
      <>
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-YTH7GM5ZGT"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-YTH7GM5ZGT');
        </script>
        <script is:inline>
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "wo9noh1ex6");
        </script>
      </>
    )}
  </head>
  <body class:list={['min-h-screen text-slate-900 antialiased', homePage ? 'body-paper' : 'bg-white']}>

    <!-- ===== HEADER ===== -->
    <header class="nv-topbar">
      <div class="nv-inner">
        <a href="/" class="nv-logo">
          <span class="nv-mark">AI</span>
          <span class="nv-wordmark">
            <span class="nv-name">AIクリエイティブナビ</span>
            <span class="nv-sub">aicreative-db.com</span>
          </span>
        </a>

        <nav class="nv-nav">
          <a href="/categories/video-generation/">AI動画生成</a>
          <a href="/categories/image-generation/">AI画像生成</a>
          <a href="/comparisons/">比較表</a>
          <a href="/guides/commercial-use-copyright/">商用利用ガイド</a>
        </nav>

        <div class="nv-actions">
          <a href="/tools/" class="nv-cta">ツールを探す <span class="nv-arr">→</span></a>

          <details class="nv-mobile-details">
            <summary class="nv-menu" aria-label="メニューを開く">
              <svg class="nv-icon-menu" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <line x1="3" y1="6" x2="19" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="3" y1="11" x2="19" y2="11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="3" y1="16" x2="19" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </summary>
            <div class="nv-mobile-panel">
              <a href="/tools/" class="nv-mobile-cta">ツールを探す →</a>
              <nav class="nv-mobile-nav" aria-label="モバイルメニュー">
                <a href="/categories/video-generation/">AI動画生成</a>
                <a href="/categories/image-generation/">AI画像生成</a>
                <a href="/comparisons/">比較表</a>
                <a href="/guides/commercial-use-copyright/">商用利用ガイド</a>
                <div class="nv-mobile-divider"></div>
                <a href="/conditions/free/">無料で試せる</a>
                <a href="/conditions/commercial-use/">商用利用OK</a>
                <a href="/conditions/japanese/">日本語対応</a>
                <a href="/conditions/no-watermark/">透かしなし</a>
              </nav>
            </div>
          </details>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="nf-footer">
      <div class="nf-inner">

        <div class="nf-grid">
          <!-- About -->
          <div class="nf-about">
            <a href="/" class="nv-logo nf-logo-light">
              <span class="nv-mark">AI</span>
              <span class="nv-wordmark">
                <span class="nv-name">AIクリエイティブナビ</span>
                <span class="nv-sub">aicreative-db.com</span>
              </span>
            </a>
            <p class="nf-desc">AI動画生成・AI画像生成を中心に、料金・無料枠・商用利用条件・日本語対応などを比較するAIクリエイティブツール比較メディアです。</p>
          </div>

          <!-- カテゴリ -->
          <div class="nf-col">
            <h4>Categories</h4>
            <ul>
              <li><a href="/categories/image-generation/">AI画像生成ツール</a></li>
              <li><a href="/categories/video-generation/">AI動画生成ツール</a></li>
              <li><a href="/categories/video-editing/">AI動画編集ツール</a></li>
              <li><a href="/categories/avatar-video/">AIアバター動画ツール</a></li>
              <li><a href="/categories/design/">AIデザインツール</a></li>
              <li><a href="/categories/voice-narration/">AI音声・ナレーションツール</a></li>
              <li><a href="/comparisons/">比較表</a></li>
            </ul>
          </div>

          <!-- 目的別 -->
          <div class="nf-col">
            <h4>条件から探す</h4>
            <ul>
              <li><a href="/conditions/free/">無料で試せるAIツール</a></li>
              <li><a href="/conditions/commercial-use/">商用利用を確認しやすいAIツール</a></li>
              <li><a href="/conditions/japanese/">日本語対応AIツール</a></li>
              <li><a href="/conditions/no-watermark/">透かしなしAIツール</a></li>
            </ul>
          </div>

          <!-- ガイド＋サイト情報 -->
          <div class="nf-col">
            <h4>ガイド・サイト情報</h4>
            <ul>
              <li><a href="/guides/commercial-use-copyright/">商用利用・著作権ガイド</a></li>
              <li><a href="/guides/free-ai-image-tools/">無料ツールの選び方</a></li>
              <li><a href="/guides/watermark-credit-guide/">透かし・クレジット表記</a></li>
              <li><a href="/guides/japanese-ai-image-tools/">日本語対応ツールの選び方</a></li>
              <li><a href="/about/">運営者情報</a></li>
              <li><a href="/editorial-policy/">掲載方針・比較基準</a></li>
              <li><a href="/privacy-policy/">プライバシーポリシー</a></li>
              <li><a href="/contact/">お問い合わせ</a></li>
              <li><a href="/disclaimer/">免責事項</a></li>
            </ul>
          </div>
        </div>

        <div class="nf-bottom">
          <span class="nf-copy">© 2026 AIクリエイティブナビ</span>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ===== HEADER ===== */
  .nv-topbar {
    position: sticky;
    top: 0;
    z-index: 60;
    background: color-mix(in srgb, var(--paper) 82%, transparent);
    backdrop-filter: saturate(1.2) blur(14px);
    -webkit-backdrop-filter: saturate(1.2) blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .nv-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 28px;
    display: flex;
    align-items: center;
    gap: 28px;
    height: 68px;
  }
  .nv-logo {
    display: flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .nv-mark {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: var(--brand);
    color: var(--on-brand);
    display: grid;
    place-items: center;
    font-family: var(--f-latin);
    font-weight: 700;
    font-size: 17px;
    box-shadow: var(--shadow-sm);
    flex-shrink: 0;
  }
  .nv-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .nv-name {
    font-family: var(--f-jp);
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
  }
  .nv-sub {
    font-family: var(--f-latin);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .nv-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: 6px;
  }
  .nv-nav a {
    font-family: var(--f-jp);
    font-weight: 600;
    font-size: 14.5px;
    color: var(--ink-soft);
    padding: 9px 13px;
    border-radius: 9px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .nv-nav a:hover {
    background: var(--surface);
    color: var(--brand-ink);
  }
  .nv-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .nv-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--f-jp);
    font-weight: 700;
    font-size: 14px;
    color: var(--on-brand);
    background: var(--brand);
    padding: 10px 20px;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 6px 18px -6px color-mix(in srgb, var(--brand) 65%, transparent);
    transition: background 0.18s, transform 0.18s;
  }
  .nv-cta:hover {
    background: var(--brand-press);
    transform: translateY(-1px);
  }
  .nv-arr {
    transition: transform 0.2s var(--ease);
  }
  .nv-cta:hover .nv-arr {
    transform: translateX(3px);
  }
  /* ===== HAMBURGER BUTTON (summary) ===== */
  .nv-mobile-details {
    display: none;
    position: relative;
    flex-shrink: 0;
  }
  /* suppress default triangle marker */
  .nv-mobile-details > summary { list-style: none; }
  .nv-mobile-details > summary::-webkit-details-marker { display: none; }
  .nv-menu::-webkit-details-marker { display: none; }
  .nv-menu::marker { content: ""; }

  .nv-menu {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 9px;
    border: 1px solid var(--line-strong);
    background: var(--surface);
    color: var(--ink);
    cursor: pointer;
    touch-action: manipulation;
    position: relative;
    z-index: 120;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
    -webkit-touch-callout: none;
    user-select: none;
  }
  .nv-menu svg {
    width: 22px;
    height: 22px;
    display: block;
    flex: 0 0 auto;
    pointer-events: none;
  }
  /* ===== MOBILE PANEL ===== */
  .nv-mobile-panel {
    position: fixed;
    top: 68px;
    left: 16px;
    right: 16px;
    max-width: calc(100vw - 32px);
    z-index: 110;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 8px 32px -8px rgba(20,22,28,.22);
    padding: 12px 14px 20px;
    max-height: calc(100svh - 90px);
    overflow-y: auto;
  }
  .nv-mobile-cta {
    display: block;
    font-family: var(--f-jp);
    font-weight: 700;
    font-size: 15px;
    text-align: center;
    text-decoration: none;
    color: #fff;
    background: #4B3FE4;
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 10px;
    -webkit-tap-highlight-color: transparent;
  }
  .nv-mobile-cta:hover,
  .nv-mobile-cta:focus {
    background: #2E25A6;
  }
  .nv-mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .nv-mobile-nav a {
    display: block;
    font-family: var(--f-jp);
    font-weight: 600;
    font-size: 16px;
    color: var(--ink);
    text-decoration: none;
    padding: 12px 14px;
    border-radius: 10px;
    transition: background 0.15s, color 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .nv-mobile-nav a:hover,
  .nv-mobile-nav a:focus {
    background: var(--surface-2);
    color: var(--brand-ink);
  }
  .nv-mobile-divider {
    height: 1px;
    background: var(--line);
    margin: 10px 0;
  }

  @media (max-width: 720px) {
    .nv-nav { display: none; }
    .nv-cta { display: none; }
    .nv-mobile-details { display: block; }
    .nv-inner { padding: 0 18px; gap: 12px; }
  }

  /* ===== FOOTER ===== */
  .nf-footer {
    background: var(--ink);
    color: #fff;
    padding: 64px 0 32px;
  }
  .nf-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 28px;
  }
  .nf-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 44px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }
  .nf-logo-light .nv-name { color: #fff; }
  .nf-logo-light .nv-sub  { color: rgba(255,255,255,.4); }
  .nf-desc {
    color: rgba(255, 255, 255, 0.6);
    font-size: 13px;
    line-height: 1.8;
    margin-top: 16px;
    max-width: 340px;
  }
  .nf-col h4 {
    font-family: var(--f-latin);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 16px;
    font-weight: 600;
  }
  .nf-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .nf-col a {
    color: rgba(255, 255, 255, 0.72);
    font-size: 13.5px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .nf-col a:hover { color: #fff; }
  .nf-bottom {
    padding-top: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nf-copy {
    color: rgba(255, 255, 255, 0.5);
    font-size: 12.5px;
    font-family: var(--f-mono);
  }
  @media (max-width: 980px) {
    .nf-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .nf-about {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 720px) {
    .nf-grid { grid-template-columns: 1fr; }
    .nf-inner { padding: 0 18px; }
    .nf-footer { padding: 48px 0 24px; }
  }

  /* focus-visible */
  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 3px;
    border-radius: 6px;
  }
</style>
