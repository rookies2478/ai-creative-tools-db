---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogType?: string;
}

const {
  title,
  description = '生成AI画像・動画ツールを商用利用・料金・著作権で比較',
  canonicalPath,
  ogType = 'website',
} = Astro.props;

const canonicalUrl = canonicalPath && Astro.site
  ? new URL(canonicalPath, Astro.site).href
  : undefined;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:site_name" content="AIクリエイティブツール比較DB" />
    <meta property="og:image" content="https://aicreative-db.com/ogp.png" />
    <title>{title}</title>
    {import.meta.env.PROD && (
      <>
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-YTH7GM5ZG7"></script>
        <script is:inline>
          {`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-YTH7GM5ZG7');
          `}
        </script>
        <script type="text/javascript" is:inline>
          {`
            (function(c,l,a,r,i,t,y){
                c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
            })(window, document, "clarity", "script", "wo9noh1ex6");
          `}
        </script>
      </>
    )}
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased">

    <!-- ===== HEADER ===== -->
    <header class="sticky top-0 z-30 border-b border-slate-100 bg-white/95 backdrop-blur-sm">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3.5">

        <!-- Brand -->
        <a href="/" class="flex items-center gap-1.5 font-black tracking-tight text-[#002B61]">
          <span class="text-xl text-blue-600">AI</span><span class="text-base">クリエイティブDB</span>
        </a>

        <!-- Center nav — desktop only -->
        <nav class="hidden items-center gap-6 text-sm text-slate-600 lg:flex">
          <a href="/tools/"                           class="hover:text-[#0066FF]">ツールを探す</a>
          <a href="/compare/"                         class="hover:text-[#0066FF]">比較表</a>
          <a href="/categories/free/"                 class="hover:text-[#0066FF]">無料ツール</a>
          <a href="/guides/commercial-use-copyright/" class="hover:text-[#0066FF]">商用利用ガイド</a>
        </nav>

        <!-- Right CTA -->
        <a href="/tools/" class="rounded-lg bg-[#0066FF] px-3.5 py-2 text-xs font-semibold text-white hover:bg-blue-700 sm:px-5 sm:text-sm">
          <span class="hidden sm:inline">条件から探す</span>
          <span class="sm:hidden">ツールを探す</span>
        </a>

      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="border-t border-slate-100 bg-slate-50 py-12">
      <div class="mx-auto max-w-5xl px-6">

        <!-- Brand -->
        <div class="mb-8">
          <p class="text-base font-bold text-[#002B61]">AIクリエイティブツール比較DB</p>
          <p class="mt-0.5 text-xs text-slate-400">生成AI画像・動画ツールを商用利用・料金・著作権で比較</p>
        </div>

        <!-- Link columns -->
        <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">

          <!-- カテゴリ -->
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">カテゴリ</p>
            <ul class="space-y-2 text-xs text-slate-500">
              <li><a href="/tools/"                     class="hover:text-blue-600 hover:underline underline-offset-4">AI画像生成ツール</a></li>
              <li><a href="/video-generators/"          class="hover:text-blue-600 hover:underline underline-offset-4">AI動画生成ツール</a></li>
              <li><a href="/compare/"                   class="hover:text-blue-600 hover:underline underline-offset-4">比較表</a></li>
            </ul>
          </div>

          <!-- 目的別 -->
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">目的別</p>
            <ul class="space-y-2 text-xs text-slate-500">
              <li><a href="/categories/free/"           class="hover:text-blue-600 hover:underline underline-offset-4">無料で試せるAIツール</a></li>
              <li><a href="/categories/commercial-use/" class="hover:text-blue-600 hover:underline underline-offset-4">商用利用を確認しやすいAIツール</a></li>
              <li><a href="/categories/japanese/"       class="hover:text-blue-600 hover:underline underline-offset-4">日本語対応AIツール</a></li>
              <li><a href="/categories/no-watermark/"   class="hover:text-blue-600 hover:underline underline-offset-4">透かしなしAIツール</a></li>
            </ul>
          </div>

          <!-- ガイド -->
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">ガイド</p>
            <ul class="space-y-2 text-xs text-slate-500">
              <li><a href="/guides/commercial-use-copyright/" class="hover:text-blue-600 hover:underline underline-offset-4">商用利用・著作権ガイド</a></li>
              <li><a href="/guides/free-ai-image-tools/"      class="hover:text-blue-600 hover:underline underline-offset-4">無料ツールの選び方</a></li>
              <li><a href="/guides/watermark-credit-guide/"   class="hover:text-blue-600 hover:underline underline-offset-4">透かし・クレジット表記</a></li>
              <li><a href="/guides/japanese-ai-image-tools/"  class="hover:text-blue-600 hover:underline underline-offset-4">日本語対応ツールの選び方</a></li>
            </ul>
          </div>

          <!-- サイト情報 -->
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">サイト情報</p>
            <ul class="space-y-2 text-xs text-slate-500">
              <li><a href="/about/"            class="hover:text-blue-600 hover:underline underline-offset-4">運営者情報</a></li>
              <li><a href="/editorial-policy/" class="hover:text-blue-600 hover:underline underline-offset-4">掲載方針・比較基準</a></li>
              <li><a href="/privacy-policy/"   class="hover:text-blue-600 hover:underline underline-offset-4">プライバシーポリシー</a></li>
              <li><a href="/contact/"          class="hover:text-blue-600 hover:underline underline-offset-4">お問い合わせ</a></li>
              <li><a href="/disclaimer/"       class="hover:text-blue-600 hover:underline underline-offset-4">免責事項</a></li>
            </ul>
          </div>

        </div>

        <p class="mt-10 text-center text-xs text-slate-400">© 2026 AIクリエイティブツール比較DB</p>
      </div>
    </footer>

  </body>
</html>
