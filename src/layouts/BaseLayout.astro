---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'AI画像生成・動画生成ツールを比較できるDB型SEOメディア',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <header class="border-b border-gray-200 bg-white px-6 py-4">
      <a href="/" class="text-lg font-bold hover:text-blue-600">
        AI画像生成・動画生成ツール比較DB
      </a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-gray-200 bg-white px-6 py-4 text-center text-sm text-gray-500">
      © 2026 AI画像生成・動画生成ツール比較DB
    </footer>
  </body>
</html>
