---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'AIアバター動画とAI動画生成は何が違いますか？',
    a: 'AI動画生成はテキストや画像からゼロで映像を作るサービスです。AIアバター動画はテキスト原稿からアバターが話す解説動画を作るサービスです。顔出しなしで解説動画を作りたい場合はアバター動画ツールが向いています。<a href="/categories/video-generation/">AI動画生成ツール一覧</a>もご参照ください。',
  },
  {
    q: '日本語の解説動画を作れますか？',
    a: '日本語対応のアバター動画ツールもありますが、対応状況はツールによって異なります。日本語の音声品質・字幕生成の精度は各ツールの公式情報でご確認ください。',
  },
  {
    q: '他者の顔を使ってアバターを作ることはできますか？',
    a: 'ツールによってはカスタムアバター機能で自分の顔を使ったアバター生成ができます。ただし他者の顔を本人の同意なく使用することは肖像権の観点から問題になる場合があります。詳細は各ツールの利用規約と関連法令をご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: '商用利用（YouTube収益化・クライアント案件）で使えますか？',
    a: '商用利用条件はツール・プランによって異なります。収益化コンテンツへの利用前に、必ず各ツールの公式利用規約をご確認ください。本記事は法的助言ではありません。<a href="/conditions/commercial-use/">商用利用を確認しやすいAIツール</a>のページもご参照ください。',
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a.replace(/<[^>]+>/g, '')
    }
  }))
});

const tools = [
  { name: 'HeyGen',    free: '要確認', ja: '対応',  commercial: '要確認', note: '多言語AIアバター動画の代表ツール。カスタムアバター機能あり。詳細ページは準備中です。',  href: '' },
  { name: 'Synthesia', free: '要確認', ja: '対応',  commercial: '要確認', note: 'eラーニング・企業研修向けが強み。AIアバターの種類が豊富。詳細ページは準備中です。', href: '' },
  { name: 'D-ID',      free: '要確認', ja: '要確認', commercial: '要確認', note: 'テキストと写真からアバター動画を生成するAPI対応ツール。詳細ページは準備中です。',   href: '' },
  { name: 'InVideo AI',free: '要確認', ja: '要確認', commercial: '要確認', note: 'テキストから解説動画・ナレーション動画を自動生成。AIアバター機能も搭載。',           href: '/tools/invideo-ai/' },
];

function mark(val: string) {
  if (val === 'あり' || val === '対応') return { cls: 'yes', ch: '○' };
  if (val === 'なし' || val === '非対応') return { cls: 'no', ch: '×' };
  return { cls: 'cond', ch: '△' };
}
---

<BaseLayout
  title="AIアバター動画ツール比較｜顔出しなし解説動画・研修動画・営業動画の作り方"
  description="AIアバターを使った解説動画・研修動画・営業動画ツールの比較ページです。AI動画生成との違い、選び方、肖像権・音声の注意点を整理しています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/avatar-video/"
  jsonLd={faqJsonLd}
>
  <div class="mx-auto max-w-5xl px-6 py-10">

    <!-- パンくず -->
    <nav class="mb-5 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>AIアバター動画</span>
    </nav>

    <!-- カテゴリナビ -->
    <nav class="mb-8">
      <p class="mb-2 text-xs font-semibold text-slate-500 uppercase tracking-widest">カテゴリから探す</p>
      <div class="flex flex-wrap gap-2 text-sm">
        <a href="/categories/video-generation/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI動画生成</a>
        <a href="/categories/image-generation/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI画像生成</a>
        <a href="/categories/avatar-video/" class="rounded-full border border-indigo-400 bg-indigo-50 px-3 py-1.5 font-semibold text-indigo-700" aria-current="page">AIアバター動画</a>
        <a href="/categories/video-editing/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI動画編集</a>
        <a href="/categories/design/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AIデザイン</a>
        <a href="/categories/voice-narration/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI音声・ナレーション</a>
      </div>
    </nav>

  </div>

  <div class="cp-x" data-cp>
    <div class="mx-auto max-w-5xl px-6">

      <!-- Hero -->
      <header class="cp-head">
        <span class="eyebrow">Avatar video</span>
        <h1>AIアバター動画<br><span class="hl">ツール比較</span></h1>
        <p class="lead">
          AIアバターを使った解説動画・研修動画・営業動画ツールの比較・選び方を整理するページです。
          顔出し不要でテキスト原稿からアバターが話す動画を生成できるサービスを対象としています。
          <a href="/categories/video-generation/">AI動画生成</a>や<a href="/categories/video-editing/">AI動画編集</a>との違いについても整理しています。
        </p>
        <div class="stats">
          <div class="stat"><span class="n">4</span><span class="t">参照ツール</span></div>
          <div class="stat"><span class="n">5</span><span class="t">比較ポイント</span></div>
          <div class="stat"><span class="n">4</span><span class="t">よくある質問</span></div>
        </div>
      </header>

      <!-- Notice -->
      <div class="notice">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
        <p><b>ご利用前の注意：</b>掲載情報は調査時点の内容です。肖像権・音声・商用利用条件は変更される場合があります。実務利用前には必ず各ツールの公式サイト・利用規約をご確認ください。本サイトの内容は法的助言ではありません。</p>
      </div>

      <!-- AI動画生成との違い -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">Category difference</span>
          <h2>AI動画生成との違い</h2>
          <p>「AI動画生成」と「AIアバター動画」は用途が異なります。どちらが自分の目的に合うかを確認してください。</p>
        </div>
        <div class="comp-grid">
          <div class="comp-card blue">
            <p class="comp-label">AI動画生成</p>
            <ul>
              <li>テキストや画像からゼロで映像を生成する</li>
              <li>Runway・Pika・Kling AIなどが代表例</li>
              <li>架空の映像・風景・モーション生成が得意</li>
              <li>SNS・広告・試作向けの短尺動画が中心</li>
            </ul>
          </div>
          <div class="comp-card indigo">
            <p class="comp-label">AIアバター動画</p>
            <ul>
              <li>テキスト原稿からAIアバターが話す動画を生成</li>
              <li>顔出し不要で解説・プレゼン動画を作れる</li>
              <li>YouTube・eラーニング・研修・営業説明動画向け</li>
              <li>アバターの外見・声・言語を選べる場合が多い</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- 比較ポイント (band) -->
      <section class="cp-sec band">
        <div class="sec-head">
          <span class="eyebrow">Checkpoints</span>
          <h2>AIアバター動画ツールを選ぶ比較ポイント</h2>
          <p>用途に合ったツールを選ぶために、事前に確認しておきたい観点を整理しました。</p>
        </div>
        <ol class="points">
          <li>
            <span class="pn">01</span>
            <span class="pt"><b>日本語対応：</b>日本語テキストを読み上げられるか、日本語の声があるか。日本向けコンテンツには重要な確認ポイントです。</span>
          </li>
          <li>
            <span class="pn">02</span>
            <span class="pt"><b>アバターの種類・カスタマイズ：</b>選べるアバターの数、カスタムアバター（自分の顔を使う）への対応。カスタムアバター生成を利用する際は、本人の同意なく他者の顔・音声を使用しないよう注意が必要です。</span>
          </li>
          <li>
            <span class="pn">03</span>
            <span class="pt"><b>動画の長さ・品質：</b>生成できる動画の長さ（分単位）、解像度、自然な動きの品質。用途によって必要なスペックが異なります。</span>
          </li>
          <li>
            <span class="pn">04</span>
            <span class="pt"><b>料金と無料枠：</b>無料プランの生成可能時間・透かしの有無・月額コスト。<a href="/conditions/free/">無料で試せるAIツール</a>のページも参考にしてください。</span>
          </li>
          <li>
            <span class="pn">05</span>
            <span class="pt"><b>商用利用条件：</b>YouTube収益化・クライアント案件・広告での利用前に、必ず公式利用規約をご確認ください。<a href="/conditions/commercial-use/">商用利用を確認しやすいAIツール</a>もご参照ください。本記事は法的助言ではありません。</span>
          </li>
        </ol>
      </section>

      <!-- 対象ツール一覧 -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">Tool index</span>
          <h2>対象ツール一覧</h2>
          <p>AIアバター動画の代表的なサービスを整理しています。HeyGen・Synthesia・D-IDはデータベースへの掲載準備中です。掲載が完了次第、詳細ページからご確認いただけます。</p>
        </div>
        <div class="cp-table-wrap">
          <table class="cp-tbl">
            <thead>
              <tr>
                <th class="col-tool">ツール</th>
                <th>無料枠</th>
                <th>日本語</th>
                <th>商用利用</th>
                <th>詳細</th>
              </tr>
            </thead>
            <tbody>
              {tools.map((t) => {
                const f = mark(t.free), j = mark(t.ja), c = mark(t.commercial);
                return (
                  <tr>
                    <td><div class="cp-tool"><span class="b">{t.name.charAt(0)}</span><span class="nm">{t.name}</span></div></td>
                    <td><span class={`mk ${f.cls}`} title={t.free}>{f.ch}</span></td>
                    <td><span class={`mk ${j.cls}`} title={t.ja}>{j.ch}</span></td>
                    <td><span class={`mk ${c.cls}`} title={t.commercial}>{c.ch}</span></td>
                    <td>{t.href ? <a class="cp-detail" href={t.href}>詳細 →</a> : <span class="cp-soon">準備中</span>}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p class="note">※ 値は確認時点の参考情報です。無料枠・商用利用条件はプランや出力形式により異なる場合があります。最新情報は必ず公式サイトでご確認ください。</p>
      </section>

      <!-- 各ツールの特徴 (band) -->
      <section class="cp-sec band">
        <div class="sec-head">
          <span class="eyebrow">Per-tool notes</span>
          <h2>各ツールの特徴・向いている用途</h2>
          <p>確認時点の公式情報をもとにした整理です。条件・仕様は変更される可能性があります。実務利用前に必ず公式情報をご確認ください。</p>
        </div>
        <div class="note-grid">
          {tools.map((t) => (
            <article class="note-card">
              <div class="nc-head">
                <span class="nc-b">{t.name.charAt(0)}</span>
                {t.href
                  ? <a class="nc-name" href={t.href}>{t.name}</a>
                  : <span class="nc-name nc-plain">{t.name}</span>
                }
                {!t.href && <span class="nc-badge">準備中</span>}
              </div>
              <div class="nc-fields">
                <div class="nc-f">
                  <span class="nc-lbl">特徴・用途</span>
                  <p>{t.note}</p>
                </div>
                <div class="nc-f">
                  <span class="nc-lbl">商用利用・条件の確認</span>
                  <p>商用利用条件はプラン・用途によって異なります。YouTube収益化・クライアント案件に使う前に公式利用規約をご確認ください。本記事は法的助言ではありません。</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- 肖像権・音声の注意 -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">Important notice</span>
          <h2>肖像権・音声・第三者素材の確認ポイント</h2>
          <p>AIアバター動画では、顔・音声・素材の権利に関する注意点があります。利用前に各ツールの利用規約と関連法令をご確認ください。</p>
        </div>
        <div class="warn-card">
          <ul class="warn-list">
            <li>
              <span class="wi">▸</span>
              <span><b>他者の顔・肖像を使わない：</b>カスタムアバター機能で他者の顔や肖像を本人の同意なく使用することは、肖像権・プライバシーの観点から問題になる可能性があります。利用前に各ツールの利用規約と関連法令をご確認ください。</span>
            </li>
            <li>
              <span class="wi">▸</span>
              <span><b>音声クローン・AI音声の利用：</b>他者の声を無断でクローンしたり、AI音声に本人と誤解させるような使い方をすることは、声の権利（パブリシティ権等）の観点から問題になる場合があります。各ツールの利用規約と関連法令をご確認ください。</span>
            </li>
            <li>
              <span class="wi">▸</span>
              <span><b>第三者素材の使用：</b>動画内で使用する画像・音楽・映像素材が第三者の著作物である場合は、権利者からの許諾または商用利用可能なライセンスの確認が必要です。</span>
            </li>
          </ul>
          <p class="warn-note">本記事は法的助言ではありません。具体的な利用可否については各ツールの公式規約および専門家にご確認ください。</p>
        </div>
      </section>

      <!-- FAQ -->
      <section class="cp-sec band">
        <div class="sec-head">
          <span class="eyebrow">FAQ</span>
          <h2>よくある質問</h2>
          <p>AIアバター動画ツールの選び方・注意点についてお答えします。</p>
        </div>
        <div class="faq-list">
          {faqs.map((f) => (
            <div class="faq-item" aria-expanded="false">
              <button class="faq-q"><span class="qm">Q</span>{f.q}<span class="ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14"/></svg></span></button>
              <div class="faq-a"><div class="faq-a-inner" set:html={f.a}></div></div>
            </div>
          ))}
        </div>
      </section>

      <!-- 関連ページ -->
      <section class="cp-sec">
        <div class="finder">
          <h2>関連ページ</h2>
          <p class="finder-lead">他のカテゴリ・条件・ガイドからも、用途に合ったAIツールを探せます。</p>
          <div class="taglinks">
            <a class="taglink" href="/categories/video-generation/"><span class="ld"></span>AI動画生成ツール一覧</a>
            <a class="taglink" href="/categories/video-editing/"><span class="ld"></span>AI動画編集ツール</a>
            <a class="taglink" href="/categories/voice-narration/"><span class="ld"></span>AI音声・ナレーションツール</a>
            <a class="taglink" href="/use-cases/faceless-video/"><span class="ld"></span>顔出しなし動画向けAIツール</a>
            <a class="taglink" href="/conditions/free/"><span class="ld"></span>無料で試せるAIツール</a>
            <a class="taglink" href="/conditions/commercial-use/"><span class="ld"></span>商用利用を確認しやすいAIツール</a>
            <a class="taglink" href="/conditions/japanese/"><span class="ld"></span>日本語対応AIツール</a>
          </div>
          <div class="taglinks row">
            <a class="taglink solid" href="/tools/">すべてのツールを見る</a>
            <a class="taglink solid" href="/comparisons/">比較記事一覧</a>
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .cp-x {
    --paper: #F4F4EE; --surface: #FFFFFF; --surface-2: #FAFAF6;
    --ink: #16181D; --ink-soft: #3A3E47; --muted: #6A7180; --faint: #98A0AD;
    --line: #E3E2D9; --line-strong: #D2D1C6;
    --brand: #4B3FE4; --on-brand: #FFFFFF; --brand-tint: #ECEBFB; --brand-ink: #2E25A6;
    --ok: #1E8A4C; --ok-tint: #E6F3EC; --warn: #A06A09; --warn-tint: #F8EFD9; --na: #6A7180; --na-tint: #EFEFEA;
    --radius: 14px; --radius-lg: 22px;
    --ease: cubic-bezier(.22,.61,.36,1);
    display: block; color: var(--ink); font-family: "Noto Sans JP", system-ui, sans-serif; line-height: 1.7;
  }

  .cp-x .eyebrow { font-size: 12px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: var(--muted); display: inline-flex; align-items: center; gap: 10px; }
  .cp-x .eyebrow::before { content: ""; width: 22px; height: 2px; border-radius: 2px; background: var(--brand); }

  .cp-x h1, .cp-x h2, .cp-x h3 { font-weight: 700; line-height: 1.32; color: var(--ink); }
  .cp-x a { text-decoration: none; }

  /* Hero */
  .cp-x .cp-head { padding: 8px 0 48px; }
  .cp-x .cp-head h1 { font-size: clamp(27px, 3.6vw, 42px); font-weight: 900; letter-spacing: -.01em; line-height: 1.24; margin: 16px 0; }
  .cp-x .cp-head h1 .hl { color: var(--brand-ink); position: relative; }
  .cp-x .cp-head h1 .hl::after { content: ""; position: absolute; left: 0; right: 0; bottom: .08em; height: .26em; background: color-mix(in srgb, var(--brand) 18%, transparent); z-index: -1; border-radius: 2px; }
  .cp-x .lead { font-size: 15.5px; color: var(--ink-soft); max-width: 700px; }
  .cp-x .lead a { color: var(--brand-ink); font-weight: 600; }
  .cp-x .lead a:hover { text-decoration: underline; }
  .cp-x .stats { display: flex; flex-wrap: wrap; gap: 10px 26px; margin-top: 24px; }
  .cp-x .stat { display: flex; align-items: baseline; gap: 8px; }
  .cp-x .stat + .stat { padding-left: 26px; border-left: 1px solid var(--line); }
  .cp-x .stat .n { font-weight: 700; font-size: 24px; color: var(--ink); line-height: 1; }
  .cp-x .stat .t { font-size: 12.5px; color: var(--muted); white-space: nowrap; }

  /* Notice */
  .cp-x .notice { display: flex; align-items: flex-start; gap: 12px; background: var(--warn-tint); border: 1px solid color-mix(in srgb, var(--warn) 28%, var(--line)); border-radius: var(--radius); padding: 16px 20px; margin-bottom: 60px; }
  .cp-x .notice svg { width: 18px; height: 18px; color: var(--warn); flex: none; margin-top: 2px; }
  .cp-x .notice p { font-size: 13px; color: var(--ink-soft); line-height: 1.7; }
  .cp-x .notice b { color: var(--warn); font-weight: 700; }

  /* Sections */
  .cp-x .cp-sec { padding: 60px 0; }
  .cp-x .cp-sec.band { background: var(--surface-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); padding-left: max(24px, calc(50vw - 600px)); padding-right: max(24px, calc(50vw - 600px)); }
  .cp-x .sec-head { max-width: 760px; margin-bottom: 36px; }
  .cp-x .sec-head h2 { font-size: clamp(22px, 2.8vw, 32px); font-weight: 900; letter-spacing: -.005em; margin: 14px 0 10px; }
  .cp-x .sec-head p { color: var(--muted); font-size: 15px; }

  /* Comparison grid */
  .cp-x .comp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .cp-x .comp-card { border-radius: var(--radius); padding: 22px 22px 20px; }
  .cp-x .comp-card .comp-label { font-size: 14px; font-weight: 700; margin-bottom: 12px; }
  .cp-x .comp-card ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
