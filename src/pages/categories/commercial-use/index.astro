---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeBox from '../../../components/NoticeBox.astro';
import CompareTablePreview from '../../../components/CompareTablePreview.astro';
import ConditionChips from '../../../components/ConditionChips.astro';

const tools = await getCollection('tools');
const filtered = tools.filter(
  (t) => t.data.commercialUse === 'yes' || t.data.commercialUse === 'limited'
);
---

<BaseLayout
  title="商用利用を確認しやすいAI画像・動画生成ツール比較 | AIクリエイティブツール比較DB"
  description="AI画像生成・動画生成ツールを商用利用条件、著作権、透かし、料金で比較。副業・制作案件・SNS運用で使う前の確認に役立つ一覧です。"
  canonicalPath="/categories/commercial-use/"
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>商用利用を確認しやすいツール</span>
    </nav>

    <h1 class="mb-3 text-3xl font-bold text-gray-900">商用利用を確認しやすいAI画像・動画生成ツール</h1>
    <p class="mb-6 text-gray-600 leading-relaxed">
      AI画像・動画生成ツールを仕事や副業で使う場合は、商用利用条件や著作権、透かしの扱いを事前に確認することが重要です。このページでは、商用利用の確認がしやすいツールを一覧で整理しています。
    </p>

    <ConditionChips currentPath="/categories/commercial-use/" />

    <NoticeBox />

    <section class="mt-8">
      <h2 class="mb-1 text-lg font-semibold text-gray-800">対象ツール一覧</h2>
      <p class="mb-4 text-sm text-gray-500">確認時点で {filtered.length} 件。「△（条件あり）」はプラン・用途・生成内容によって条件が変わる場合があります。各ツールの詳細ページで注意事項を確認してください。</p>
      <CompareTablePreview tools={filtered} limit={filtered.length} />
    </section>

    <section class="mt-12">
      <h2 class="mb-6 text-xl font-semibold text-gray-800">よくある質問</h2>
      <div class="space-y-6">
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">「条件あり」と表示されていれば商用利用できますか？</p>
          <p class="mt-2 text-sm text-gray-600">
            利用できる場合がありますが、プラン・用途・生成コンテンツの内容・利用規約によって条件が変わります。実際に使う前に、必ず各ツールの最新公式情報をご確認ください。
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">無料プランで作った画像や動画も商用利用できますか？</p>
          <p class="mt-2 text-sm text-gray-600">
            ツールによって異なります。無料プランでは、透かし・解像度・クレジット表記・利用範囲の制限がある場合があります。商用利用を検討する場合は、各ツールの無料プラン条件を公式情報で確認してください。
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">クライアント案件や広告に使う場合は何を確認すべきですか？</p>
          <p class="mt-2 text-sm text-gray-600">
            ツールの利用規約、プラン条件、生成コンテンツの内容、素材や入力画像の権利、納品先での利用範囲を確認してください。必要に応じて専門家への相談も検討してください。
          </p>
        </div>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-sm font-semibold text-gray-600">関連ページ</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/compare/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">全ツール比較表</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用・著作権ガイド</a></li>
        <li><a href="/tools/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">すべてのツールを見る</a></li>
        <li><a href="/categories/free/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">無料で使えるツール</a></li>
        <li><a href="/categories/japanese/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">日本語対応ツール</a></li>
        <li><a href="/categories/no-watermark/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">透かしなしツール</a></li>
      </ul>
    </section>

    <nav class="mt-8 border-t border-gray-200 pt-6 text-sm">
      <a href="/tools/" class="text-blue-600 hover:underline">← ツール一覧に戻る</a>
    </nav>

  </div>
</BaseLayout>
