---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeBox from '../../../components/NoticeBox.astro';
import CompareTablePreview from '../../../components/CompareTablePreview.astro';
import ConditionChips from '../../../components/ConditionChips.astro';

const tools = await getCollection('tools');
const filtered = tools.filter(
  (t) => t.data.commercialUse === 'ok' || t.data.commercialUse === 'paid-only' || t.data.commercialUse === 'limited'
);
---

<BaseLayout
  title="商用利用向けAI画像生成ツール比較｜公式規約・料金・利用条件を確認"
  description="AI画像生成・AI動画生成ツールを商用利用条件・料金・透かしで比較。プラン・用途によって条件が変わるため、実務利用前に公式規約を確認することを推奨します。最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/commercial-use/"
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>商用利用を確認しやすいツール</span>
    </nav>

    <h1 class="mb-3 text-3xl font-bold text-gray-900">商用利用向けAI画像生成ツール比較</h1>
    <p class="mb-4 text-gray-600 leading-relaxed">
      AI画像・動画生成ツールを仕事や副業で使う場合は、商用利用条件を事前に確認することが重要です。
    </p>

    <div class="mb-6 rounded-lg border border-amber-200 bg-amber-50 px-5 py-3.5 text-sm text-amber-800 leading-relaxed">
      商用利用の可否は、<strong>プラン・生成内容・利用目的・各ツールの規約</strong>によって変わる場合があります。このページは公式情報をもとにした一般的な整理であり、実務利用前には必ず最新の公式規約をご確認ください。このページは法的助言ではありません。
    </div>

    <ConditionChips currentPath="/categories/commercial-use/" />

    <NoticeBox />

    <section class="mt-8 rounded-xl border border-slate-200 bg-white px-6 py-5">
      <h2 class="mb-3 text-base font-bold text-[#002B61]">比較時に見るポイント</h2>
      <ul class="space-y-2 text-sm text-slate-700">
        <li class="flex gap-2"><span class="mt-0.5 text-slate-400">▸</span>公式規約で商用利用がどう案内されているか</li>
        <li class="flex gap-2"><span class="mt-0.5 text-slate-400">▸</span>商用利用が有料プラン限定かどうか</li>
        <li class="flex gap-2"><span class="mt-0.5 text-slate-400">▸</span>生成物の利用範囲や禁止事項（用途によって制限がある可能性があります）</li>
      </ul>
      <p class="mt-4 text-xs text-slate-500">料金・商用利用条件は変更される場合があります。最新情報は各公式サイトをご確認ください。</p>
    </section>

    <section class="mt-8">
      <h2 class="mb-1 text-lg font-semibold text-gray-800">対象ツール一覧</h2>
      <p class="mb-4 text-sm text-gray-500">確認時点で {filtered.length} 件。「条件あり」はプラン・用途・生成内容によって条件が変わる場合があります。各ツールの詳細ページで注意事項を確認してください。</p>
      <CompareTablePreview tools={filtered} limit={filtered.length} />
    </section>

    <section class="mt-8">
      <h2 class="mb-3 text-sm font-semibold text-gray-700">各ツールの商用利用に関する注意点</h2>
      <p class="mb-3 text-xs text-gray-500">確認時点の公式情報をもとにした整理です。条件・規約は変更される可能性があります。実務利用前に必ず公式情報をご確認ください。</p>
      <div class="space-y-3">
        {filtered.map((tool) => (
          <div class="rounded-lg border border-slate-200 bg-white px-4 py-3">
            <div class="flex items-baseline gap-2 mb-1">
              <a href={`/tools/${tool.slug}/`} class="font-semibold text-sm text-slate-900 hover:text-blue-600 hover:underline">{tool.data.name}</a>
              <span class="text-xs text-slate-400">商用利用：{
                tool.data.commercialUse === 'ok'        ? '公式情報で可能' :
                tool.data.commercialUse === 'paid-only' ? '有料プラン向け' :
                tool.data.commercialUse === 'limited'   ? '条件あり' :
                tool.data.commercialUse === 'no'        ? '不可の場合あり' : '要確認'
              }</span>
            </div>
            <p class="text-xs text-slate-600 leading-relaxed">{tool.data.commercialUseNote}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="mb-6 text-xl font-semibold text-gray-800">よくある質問</h2>
      <div class="space-y-6">
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">「条件あり」と表示されていれば商用利用できますか？</p>
          <p class="mt-2 text-sm text-gray-600">
            利用できる場合がありますが、プラン・用途・生成コンテンツの内容・利用規約によって条件が変わります。実際に使う前に、必ず各ツールの最新公式情報をご確認ください。
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">無料プランで作った画像や動画も商用利用できますか？</p>
          <p class="mt-2 text-sm text-gray-600">
            ツールによって異なります。無料プランでは、透かし・解像度・クレジット表記・利用範囲の制限がある場合があります。商用利用を検討する場合は、各ツールの無料プラン条件を公式情報で確認してください。
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">クライアント案件や広告に使う場合は何を確認すべきですか？</p>
          <p class="mt-2 text-sm text-gray-600">
            ツールの利用規約、プラン条件、生成コンテンツの内容、素材や入力画像の権利、納品先での利用範囲を確認してください。必要に応じて専門家への相談も検討してください。
          </p>
        </div>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-sm font-semibold text-gray-600">関連ページ</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/compare/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">全ツール比較表</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用・著作権ガイド</a></li>
        <li><a href="/tools/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">すべてのツールを見る</a></li>
        <li><a href="/categories/free/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">無料で使えるツール</a></li>
        <li><a href="/categories/japanese/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">日本語対応ツール</a></li>
        <li><a href="/categories/no-watermark/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">透かしなしツール</a></li>
      </ul>
    </section>

    <nav class="mt-8 border-t border-gray-200 pt-6 text-sm">
      <a href="/tools/" class="text-blue-600 hover:underline">← ツール一覧に戻る</a>
    </nav>

  </div>
</BaseLayout>
