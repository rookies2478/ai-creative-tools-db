---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'AI画像生成とAIデザインツールはどう違いますか？',
    a: 'AI画像生成はテキストプロンプトから画像を生成することに特化しています。AIデザインツールはテンプレートや既存素材をもとにバナー・SNS投稿・LP素材などの実務用デザインを補助する機能が中心です。Canva AIやAdobe Fireflyは両方の機能を持つ場合があります。<a href="/categories/image-generation/">AI画像生成ツール一覧</a>もご参照ください。',
  },
  {
    q: 'Canva AIはAIデザインツールとして使えますか？',
    a: 'Canva AIはテンプレート編集・AI画像生成・テキスト生成補助など複数のAI機能を統合しています。SNS投稿・バナー・プレゼン資料の制作補助として広く利用されています。詳細な機能・料金は公式サイトをご確認ください。',
  },
  {
    q: '商用利用前に確認すべきことは？',
    a: '広告・クライアント案件・収益化コンテンツへの利用を前提にする場合は、各ツールの公式利用規約で商用利用条件をご確認ください。使用するテンプレート・素材・フォントごとに条件が異なる場合があります。本記事は法的助言ではありません。<a href="/guides/commercial-use-copyright/">商用利用・著作権の考え方ガイド</a>もご参照ください。',
  },
  {
    q: 'AIが生成したデザインの著作権はどうなりますか？',
    a: 'AIが生成したデザインの著作権については、各国の法令・判例および各ツールの利用規約によって取り扱いが異なります。商用利用を前提にする場合は、利用するツールの規約と最新の法的情報を確認することを推奨します。本記事は法的助言ではありません。<a href="/guides/commercial-use-copyright/">商用利用・著作権の考え方ガイド</a>もご参照ください。',
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a.replace(/<[^>]+>/g, '')
    }
  }))
});

const tools = [
  {
    name: 'Canva AI画像生成',
    slug: 'canva-ai-image-generator',
    free: 'あり',
    ja: '対応',
    commercial: '要確認',
    useNote: 'SNS投稿・バナー・プレゼン資料向けテンプレートが豊富。AI画像生成機能とデザイン編集を組み合わせて使える。チーム共有・ブランドキット機能あり。',
    wmNote: '無料プランでは一部機能やエクスポートに制限がある場合があります。透かし条件・商用利用条件は各プランの公式情報をご確認ください。',
  },
  {
    name: 'Adobe Firefly',
    slug: 'adobe-firefly',
    free: '要確認',
    ja: '対応',
    commercial: '要確認',
    useNote: 'AdobeのAI画像生成・デザイン補助サービス。Photoshop・Illustratorとの連携が強み。プロフェッショナルなクリエイティブ制作向け。',
    wmNote: 'プランによっては可視透かしが入る場合があります。全プランでC2PAメタデータが埋め込まれるとされています。最新の公式情報と実際の出力画面でご確認ください。',
  },
  {
    name: 'Microsoft Designer',
    slug: 'microsoft-designer',
    free: 'あり',
    ja: '対応',
    commercial: '要確認',
    useNote: 'AI生成画像とデザインテンプレートを組み合わせてSNS投稿画像を作成。Microsoft 365との連携が強み。手軽なバナー・サムネイル制作向け。',
    wmNote: '無料プランでの透かし条件は公式情報をご確認ください。商用利用条件は各プランの利用規約でご確認ください。',
  },
];

function mark(val: string) {
  if (val === 'あり' || val === '対応') return { cls: 'yes', ch: '○' };
  if (val === 'なし' || val === '非対応') return { cls: 'no', ch: '×' };
  return { cls: 'cond', ch: '△' };
}
---

<BaseLayout
  title="AIデザインツール比較｜バナー・SNS投稿・LP制作向けAIツール"
  description="AIを活用したデザイン自動化ツールの比較ページです。Canva AI・Adobe Firefly・Microsoft DesignerなどのAIデザインツールを用途・料金・特徴で比較。バナー・SNS投稿・LP制作向けの選び方を整理しています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/design/"
  jsonLd={faqJsonLd}
>
  <div class="mx-auto max-w-5xl px-6 py-10">

    <!-- パンくず -->
    <nav class="mb-5 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>AIデザイン</span>
    </nav>

    <!-- カテゴリナビ -->
    <nav class="mb-8">
      <p class="mb-2 text-xs font-semibold text-slate-500 uppercase tracking-widest">カテゴリから探す</p>
      <div class="flex flex-wrap gap-2 text-sm">
        <a href="/categories/video-generation/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI動画生成</a>
        <a href="/categories/image-generation/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI画像生成</a>
        <a href="/categories/avatar-video/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AIアバター動画</a>
        <a href="/categories/video-editing/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI動画編集</a>
        <a href="/categories/design/" class="rounded-full border border-violet-400 bg-violet-50 px-3 py-1.5 font-semibold text-violet-700" aria-current="page">AIデザイン</a>
        <a href="/categories/voice-narration/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI音声・ナレーション</a>
      </div>
    </nav>

  </div>

  <div class="cp-x" data-cp>
    <div class="mx-auto max-w-5xl px-6">

      <!-- Hero -->
      <header class="cp-head">
        <span class="eyebrow">AI design</span>
        <h1>AIデザイン<span class="hl">ツール比較</span></h1>
        <p class="lead">
          AIを活用してバナー・SNS投稿画像・LP素材などのデザイン制作を補助するツールの比較・選び方を整理するページです。
          <a href="/categories/image-generation/">AI画像生成</a>との違い、用途別の使い分けの参考にしてください。
        </p>
        <div class="stats">
          <div class="stat"><span class="n">3</span><span class="t">掲載ツール</span></div>
          <div class="stat"><span class="n">5</span><span class="t">比較ポイント</span></div>
          <div class="stat"><span class="n">4</span><span class="t">よくある質問</span></div>
        </div>
      </header>

      <!-- Notice -->
      <div class="notice">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
        <p><b>ご利用前の注意：</b>掲載情報は調査時点の内容です。料金・商用利用条件・テンプレート利用条件は変更される場合があります。実務利用前には必ず各ツールの公式サイト・利用規約をご確認ください。本サイトの内容は法的助言ではありません。</p>
      </div>

      <!-- AI画像生成との違い -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">Category difference</span>
          <h2>AI画像生成との違い</h2>
          <p>「AI画像生成」と「AIデザインツール」は用途が異なります。どちらが自分の目的に合うかを確認してください。</p>
        </div>
        <div class="comp-grid">
          <div class="comp-card blue">
            <p class="comp-label">AI画像生成</p>
            <ul>
              <li>テキストプロンプトから画像をゼロで生成する</li>
              <li>Midjourney・Stable Diffusion・Adobe Fireflyなどが代表例</li>
              <li>イラスト・写真風・コンセプトアートなど多様なスタイルに対応</li>
              <li>素材・アイキャッチ・コンセプトアート制作向け</li>
            </ul>
          </div>
          <div class="comp-card violet">
            <p class="comp-label">AIデザイン</p>
            <ul>
              <li>テンプレートやブランドガイドラインをもとにデザインを自動生成・調整する</li>
              <li>Canva AI・Adobe Firefly・Microsoft Designerなどが代表例</li>
              <li>バナー・SNS投稿・LP・プレゼン資料など実務用途に特化</li>
              <li>ノンデザイナーでも使いやすい操作体験が多い</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- 比較ポイント (band) -->
      <section class="cp-sec band">
        <div class="sec-head">
          <span class="eyebrow">Checkpoints</span>
          <h2>AIデザインツールを選ぶ比較ポイント</h2>
          <p>用途に合ったツールを選ぶために、事前に確認しておきたい観点を整理しました。</p>
        </div>
        <ol class="points">
          <li>
            <span class="pn">01</span>
            <span class="pt"><b>テンプレートの種類と用途：</b>SNS・バナー・LP・プレゼンなど用途に合ったテンプレートがあるか。テンプレートの利用条件（商用利用の可否）も確認が必要です。</span>
          </li>
          <li>
            <span class="pn">02</span>
            <span class="pt"><b>AI画像生成との統合：</b>デザインとAI画像生成をシームレスに組み合わせて使えるか。素材生成とレイアウト調整を一画面で完結できると効率的です。</span>
          </li>
          <li>
            <span class="pn">03</span>
            <span class="pt"><b>日本語UIの対応：</b>日本語でテキスト入力・メニュー操作ができるか。日本語フォントの品質も用途によって重要な確認ポイントです。</span>
          </li>
          <li>
            <span class="pn">04</span>
            <span class="pt"><b>ブランド管理機能：</b>チームで使う場合、ブランドカラー・フォント・ロゴを共有管理できるか。Canva AIはブランドキット機能が充実しています。</span>
          </li>
          <li>
            <span class="pn">05</span>
            <span class="pt"><b>商用利用・素材利用の確認：</b>作成したデザインを広告・クライアント案件に使う場合は、各ツールの公式利用規約を必ずご確認ください。使用するテンプレート・フォント・素材ごとに条件が異なる場合があります。本記事は法的助言ではありません。</span>
          </li>
        </ol>
      </section>

      <!-- 対象ツール一覧 -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">Tool index</span>
          <h2>対象ツール一覧</h2>
          <p>確認時点で{tools.length}件。各ツールの詳細ページから公式情報へのリンクをご確認いただけます。最新の機能・料金は各公式サイトをご確認ください。</p>
        </div>
        <div class="cp-table-wrap">
          <table class="cp-tbl">
            <thead>
              <tr>
                <th class="col-tool">ツール</th>
                <th>無料枠</th>
                <th>日本語</th>
                <th>商用利用</th>
                <th>詳細</th>
              </tr>
            </thead>
            <tbody>
              {tools.map((t) => {
                const f = mark(t.free), j = mark(t.ja), c = mark(t.commercial);
                return (
                  <tr>
                    <td><div class="cp-tool"><span class="b">{t.name.charAt(0)}</span><span class="nm">{t.name}</span></div></td>
                    <td><span class={`mk ${f.cls}`} title={t.free}>{f.ch}</span></td>
                    <td><span class={`mk ${j.cls}`} title={t.ja}>{j.ch}</span></td>
                    <td><span class={`mk ${c.cls}`} title={t.commercial}>{c.ch}</span></td>
                    <td><a class="cp-detail" href={`/tools/${t.slug}/`}>詳細 →</a></td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p class="note">※ ○=あり・対応　△=要確認　×=なし・非対応。値は確認時点の参考情報です。最新情報は必ず公式サイトでご確認ください。</p>
      </section>

      <!-- 各ツールの特徴 (band) -->
      <section class="cp-sec band">
        <div class="sec-head">
          <span class="eyebrow">Per-tool notes</span>
          <h2>各ツールの特徴・向いている用途</h2>
          <p>確認時点の公式情報をもとにした整理です。条件・仕様は変更される可能性があります。実務利用前に必ず公式情報をご確認ください。</p>
        </div>
        <div class="note-grid">
          {tools.map((t) => (
            <article class="note-card">
              <div class="nc-head">
                <span class="nc-b">{t.name.charAt(0)}</span>
                <a class="nc-name" href={`/tools/${t.slug}/`}>{t.name}</a>
              </div>
              <div class="nc-fields">
                <div class="nc-f">
                  <span class="nc-lbl">特徴・向いている用途</span>
                  <p>{t.useNote}</p>
                </div>
                <div class="nc-f">
                  <span class="nc-lbl">透かし・商用利用の確認</span>
                  <p>{t.wmNote}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">FAQ</span>
          <h2>よくある質問</h2>
          <p>AIデザインツールの選び方・注意点についてお答えします。</p>
        </div>
        <div class="faq-list">
          {faqs.map((f) => (
            <div class="faq-item" aria-expanded="false">
              <button class="faq-q"><span class="qm">Q</span>{f.q}<span class="ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14"/></svg></span></button>
              <div class="faq-a"><div class="faq-a-inner" set:html={f.a}></div></div>
            </div>
          ))}
        </div>
      </section>

      <!-- 関連ページ -->
      <section class="cp-sec band">
        <div class="finder">
          <h2>関連ページ</h2>
          <p class="finder-lead">他のカテゴリ・条件・ガイドからも、用途に合ったAIツールを探せます。</p>
          <div class="taglinks">
            <a class="taglink" href="/categories/image-generation/"><span class="ld"></span>AI画像生成ツール一覧</a>
            <a class="taglink" href="/categories/video-generation/"><span class="ld"></span>AI動画生成ツール一覧</a>
            <a class="taglink" href="/categories/voice-narration/"><span class="ld"></span>AI音声・ナレーションツール</a>
            <a class="taglink" href="/comparisons/canva-ai-vs-adobe-firefly/"><span class="ld"></span>Canva AI vs Adobe Firefly 比較</a>
            <a class="taglink" href="/conditions/free/"><span class="ld"></span>無料で試せるAIツール</a>
            <a class="taglink" href="/conditions/commercial-use/"><span class="ld"></span>商用利用を確認しやすいAIツール</a>
            <a class="taglink" href="/guides/commercial-use-copyright/"><span class="ld"></span>商用利用・著作権の考え方ガイド</a>
          </div>
          <div class="taglinks row">
            <a class="taglink solid" href="/tools/">すべてのツールを見る</a>
            <a class="taglink solid" href="/comparisons/">比較記事一覧</a>
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .cp-x {
    --paper: #F4F4EE; --surface: #FFFFFF; --surface-2: #FAFAF6;
    --ink: #16181D; --ink-soft: #3A3E47; --muted: #6A7180; --faint: #98A0AD;
    --line: #E3E2D9; --line-strong: #D2D1C6;
    --brand: #4B3FE4; --on-brand: #FFFFFF; --brand-tint: #ECEBFB; --brand-ink: #2E25A6;
    --ok: #1E8A4C; --ok-tint: #E6F3EC; --warn: #A06A09; --warn-tint: #F8EFD9; --na: #6A7180; --na-tint: #EFEFEA;
    --radius: 14px; --radius-lg: 22px;
    --ease: cubic-bezier(.22,.61,.36,1);
    display: block; color: var(--ink); font-family: "Noto Sans JP", system-ui, sans-serif; line-height: 1.7;
  }

  .cp-x .eyebrow { font-size: 12px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: var(--muted); display: inline-flex; align-items: center; gap: 10px; }
  .cp-x .eyebrow::before { content: ""; width: 22px; height: 2px; border-radius: 2px; background: var(--brand); }
  .cp-x h1, .cp-x h2, .cp-x h3 { font-weight: 700; line-height: 1.32; color: var(--ink); }
  .cp-x a { text-decoration: none; }

  .cp-x .cp-head { padding: 8px 0 48px; }
  .cp-x .cp-head h1 { font-size: clamp(27px, 3.6vw, 42px); font-weight: 900; letter-spacing: -.01em; line-height: 1.24; margin: 16px 0; text-wrap: balance; }
  .cp-x .cp-head h1 .hl { color: var(--brand-ink); position: relative; }
  .cp-x .cp-head h1 .hl::after { content: ""; position: absolute; left: 0; right: 0; bottom: .08em; height: .26em; background: color-mix(in srgb, var(--brand) 18%, transparent); z-index: -1; border-radius: 2px; }
  .cp-x .lead { font-size: 15.5px; color: var(--ink-soft); max-width: 700px; }
  .cp-x .lead a { color: var(--brand-ink); font-weight: 600; }
  .cp-x .lead a:hover { text-decoration: underline; }
  .cp-x .stats { display: flex; flex-wrap: wrap; gap: 10px 26px; margin-top: 24px; }
  .cp-x .stat { display: flex; align-items: baseline; gap: 8px; }
  .cp-x .stat + .stat { padding-left: 26px; border-left: 1px solid var(--line); }
  .cp-x .stat .n { font-weight: 700; font-size: 24px; color: var(--ink); line-height: 1; }
  .cp-x .stat .t { font-size: 12.5px; color: var(--muted); white-space: nowrap; }

  .cp-x .notice { display: flex; align-items: flex-start; gap: 12px; background: var(--warn-tint); border: 1px solid color-mix(in srgb, var(--warn) 28%, var(--line)); border-radius: var(--radius); padding: 16px 20px; margin-bottom: 60px; }
  .cp-x .notice svg { width: 18px; height: 18px; color: var(--warn); flex: none; margin-top: 2px; }
  .cp-x .notice p { font-size: 13px; color: var(--ink-soft); line-height: 1.7; }
  .cp-x .notice b { color: var(--warn); font-weight: 700; }

  .cp-x .cp-sec { padding: 60px 0; }
  .cp-x .cp-sec.band { background: var(--surface-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); padding-left: max(24px, calc(50vw - 600px)); padding-right: max(24px, calc(50vw - 600px)); }
  .cp-x .sec-head { max-width: 760px; margin-bottom: 36px; }
  .cp-x .sec-head h2 { font-size: clamp(22px, 2.8vw, 32px); font-weight: 900; letter-spacing: -.005em; margin: 14px 0 10px; }
  .cp-x .sec-head p { color: var(--muted); font-size: 15px; }

  .cp-x .comp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .cp-x .comp-card { border-radius: var(--radius); padding: 22px 22px 20px; }
  .cp-x .comp-card .comp-label { font-size: 14px; font-weight: 700; margin-bottom: 12px; }
  .cp-x .comp-card ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .cp-x .comp-card li { font-size: 13px; line-height: 1.6; }
  .cp-x .comp-card li::before { content: "▸ "; }
  .cp-x .comp-card.blue { border: 1px solid #BFDBFE; background: #EFF6FF; }
  .cp-x .comp-card.blue .comp-label { color: #1D4ED8; }
  .cp-x .comp-card.blue li { color: #1D4ED8; }
  .cp-x .comp-card.violet { border: 1px solid #DDD6FE; background: #F5F3FF; }
  .cp-x .comp-card.violet .comp-label { color: #5B21B6; }
  .cp-x .comp-card.violet li { color: #5B21B6; }

  .cp-x .points { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 30px 32px; list-style: none; display: flex; flex-direction: column; gap: 20px; margin: 0; }
  .cp-x .points li { display: grid; grid-template-columns: auto 1fr; gap: 14px; align-items: start; }
  .cp-x .points .pn { font-weight: 700; font-size: 13px; color: var(--brand); background: var(--brand-tint); width: 28px; height: 28px; border-radius: 8px; display: grid; place-items: center; flex: none; }
  .cp-x .points .pt { font-size: 14px; color: var(--ink-soft); line-height: 1.7; }
  .cp-x .points .pt b { color: var(--ink); font-weight: 700; }
