              <th class="px-3 py-2.5">画像→動画</th>
              <th class="px-3 py-2.5">SNS向き</th>
              <th class="px-3 py-2.5">初心者向き</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {tableData.map((row) => (
              <tr class="bg-white even:bg-slate-50">
                <td class="px-3 py-3 font-medium text-slate-900 whitespace-nowrap">
                  <a href={`/tools/${row.slug}/`} class="hover:text-blue-600 hover:underline">{row.name}</a>
                </td>
                <td class="px-3 py-3 text-slate-600 text-xs">{row.freePlan}</td>
                <td class="px-3 py-3 text-slate-600 text-xs whitespace-nowrap">{row.commercial}</td>
                <td class="px-3 py-3 text-slate-600 text-xs">{row.watermark}</td>
                <td class="px-3 py-3 text-slate-600 text-xs">{row.jpUi}</td>
                <td class="px-3 py-3 text-slate-600 text-xs">{row.jpPrompt}</td>
                <td class="px-3 py-3 text-slate-600 text-xs">{row.textToVideo}</td>
                <td class="px-3 py-3 text-slate-600 text-xs">{row.imageToVideo}</td>
                <td class="px-3 py-3 text-slate-600 text-xs">{row.sns}</td>
                <td class="px-3 py-3 text-slate-600 text-xs">{row.beginner}</td>
              </tr>
            ))}
