import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';

const allTools = await getCollection('tools');
const videoTools = allTools.filter(
  (t) => t.data.category === 'video' || t.data.category === 'both'
);

const targetSlugs = ['runway', 'pika', 'kling-ai', 'luma-ai', 'haiper', 'capcut-ai'];
const tools = targetSlugs
  .map((slug) => videoTools.find((t) => t.slug === slug))
  .filter(Boolean);

type FourState = 'yes' | 'no' | 'limited' | 'unknown';
type CommercialUse = 'ok' | 'paid-only' | 'limited' | 'no' | 'unknown';

function freePlanLabel(val: boolean | 'limited' | 'unknown'): string {
  if (val === true) return '〇 無料あり';
  if (val === 'limited') return '△ 制限付き';
  return '不明';
}

function commercialLabel(val: CommercialUse): string {
  if (val === 'ok') return '〇 公式情報で可能';
  if (val === 'paid-only') return '★ 有料のみ';
  if (val === 'no') return '× 不可';
  if (val === 'limited') return '△ 条件付き';
  return '要確認';
}

function watermarkLabel(val: FourState): string {
  if (val === 'yes') return '× あり';
  if (val === 'no') return '〇 なし';
  if (val === 'limited') return '△ 条件付き';
  return '確認中';
}

function boolLabel(val: boolean | undefined): string {
  if (val === true) return '〇';
  if (val === false) return '△';
  return '要確認';
}

