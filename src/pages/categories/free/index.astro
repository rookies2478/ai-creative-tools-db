---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeBox from '../../../components/NoticeBox.astro';
import CompareTablePreview from '../../../components/CompareTablePreview.astro';
import ConditionChips from '../../../components/ConditionChips.astro';

const tools = await getCollection('tools');
const filtered = tools.filter(
  (t) => t.data.freePlan === true || t.data.freePlan === 'limited'
);
---

<BaseLayout
  title="無料で使えるAI画像生成ツール比較｜無料枠・商用利用・透かしを確認"
  description="無料枠のあるAI画像生成・AI動画生成ツールを比較。無料プランの生成回数・透かし・商用利用条件はツールごとに異なります。最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/free/"
>
  <div class="mx-auto max-w-5xl px-6 py-12">

    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>無料で使えるツール</span>
    </nav>

    <h1 class="mb-3 text-3xl font-bold text-slate-900">無料で使えるAI画像生成ツール比較</h1>
    <p class="mb-4 text-slate-600 leading-relaxed">
      無料枠のあるAI画像・動画生成ツールを、商用利用・透かし・日本語対応・料金目安とあわせて比較できます。
      「無料」と書かれていても、生成できる回数・クレジット上限・透かしの有無・<a href="/categories/commercial-use/" class="text-blue-600 hover:underline">商用利用条件</a>はツールごとに大きく異なります。
      <a href="/categories/japanese/" class="text-blue-600 hover:underline">日本語プロンプト</a>に対応しているかどうかも、初心者が選ぶ際の重要な基準です。
      無料枠や利用条件は変更される可能性があるため、最新情報は各ツールの公式サイトでご確認ください。
    </p>

    <div class="mb-6 rounded-lg border border-amber-200 bg-amber-50 px-5 py-3.5 text-sm text-amber-800 leading-relaxed">
      無料で使える場合でも、<strong>生成回数・クレジット・透かし・商用利用条件</strong>はツールによって大きく異なります。各ツールの無料枠メモと公式情報を確認してください。
    </div>

    <ConditionChips currentPath="/categories/free/" />

    <NoticeBox />

    <!-- 無料枠の見方 -->
    <section class="mt-8 rounded-xl border border-slate-200 bg-slate-50 px-6 py-5">
      <h2 class="mb-4 text-base font-bold text-[#002B61]">無料枠の見方</h2>
      <p class="mb-4 text-xs leading-relaxed text-slate-600">
        「無料」と書かれていても、商用利用・透かし・生成回数・出力品質・利用条件はツールごとに異なります。<br/>
        無料枠や利用条件は変更される場合があります。最新情報は各ツールの公式サイト・料金ページをご確認ください。本記事は法的助言ではありません。
      </p>
      <dl class="grid gap-3 sm:grid-cols-2">
        {[
          {
            term: '完全無料',
            desc: '料金なしで継続利用できるもの。ただし機能制限がある場合があります。',
          },
          {
            term: '無料プランあり',
            desc: '無料アカウントで一部機能を使えるもの。生成回数や解像度に制限がある場合があります。',
          },
          {
            term: '無料クレジット制',
            desc: '登録時や定期的に付与されるクレジット内で使えるもの。上限を超えると有料になります。',
          },
          {
            term: '体験版・トライアル',
            desc: '一定期間または一部機能を試せるもの。期間終了後は有料プランへの移行が必要です。',
          },
          {
            term: '制限あり無料',
            desc: '透かし、商用利用条件、出力サイズ、待ち時間などの制限があるもの。',
          },
        ].map(({ term, desc }) => (
          <div class="rounded-lg border border-slate-100 bg-white px-4 py-3">
            <dt class="mb-0.5 text-xs font-bold text-slate-800">{term}</dt>
            <dd class="text-xs leading-relaxed text-slate-500">{desc}</dd>
          </div>
        ))}
      </dl>
    </section>

    <div class="mt-6">
      <a href="/compare/free-ai-image-generators/" class="flex items-center gap-2 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700 hover:bg-emerald-100 hover:border-emerald-300">
        <span aria-hidden="true">📊</span>
        無料プランを比較表で見る — 無料枠・回数・透かしをまとめて比較
      </a>
    </div>

    <section class="mt-8 rounded-xl border border-slate-200 bg-white px-6 py-5">
      <h2 class="mb-3 text-base font-bold text-[#002B61]">無料で使えるAI画像生成ツールを選ぶポイント</h2>
      <ul class="space-y-3 text-sm text-slate-700">
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>無料枠の有無：</strong>完全無料・無料プランあり・クレジット制など、形態はツールによって異なります。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>生成回数・クレジット制限：</strong>1日あたり・月あたりの上限があるツールが多く、上限を超えると有料プランへの移行が必要な場合があります。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>透かしの有無：</strong>無料プランでは透かしが入る場合があります。<a href="/categories/no-watermark/" class="text-blue-600 hover:underline">透かしなしのツール</a>は別ページでまとめています。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>商用利用条件：</strong>無料プランでの商用利用が可能かはツールと規約によって異なります。<a href="/categories/commercial-use/" class="text-blue-600 hover:underline">商用利用条件を確認しやすいツール</a>も参照してください。商用利用を前提にする場合は、最新の公式規約をご確認ください。本記事は法的助言ではありません。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>日本語対応：</strong>日本語プロンプトで思い通りの画像を生成できるかは、ツールのモデルによって精度が異なります。<a href="/categories/japanese/" class="text-blue-600 hover:underline">日本語対応ツール</a>はこちらからご確認いただけます。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>初心者向けか：</strong>GUIの使いやすさ・プリセットの充実度・日本語UIの有無など、操作ハードルもツールごとに大きく異なります。<a href="/tools/" class="text-blue-600 hover:underline">各ツールの詳細ページ</a>で強み・弱みを確認できます。</span>
        </li>
      </ul>
      <p class="mt-4 text-xs text-slate-500">料金・無料枠・商用利用条件は変更される場合があります。最新情報は各公式サイトをご確認ください。</p>
    </section>

    <section class="mt-8">
      <h2 class="mb-1 text-lg font-semibold text-slate-800">対象ツール一覧</h2>
      <p class="mb-4 text-sm text-slate-500">確認時点で {filtered.length} 件。無料枠の内容（クレジット数・解像度・透かし・商用利用条件）はツールごとに異なります。</p>
      <CompareTablePreview tools={filtered} limit={filtered.length} />
    </section>

    <section class="mt-8">
      <h2 class="mb-3 text-sm font-semibold text-slate-700">各ツールの無料枠・透かし条件</h2>
      <p class="mb-3 text-xs text-slate-500">確認時点の情報です。詳細は各ツールの詳細ページおよび公式情報でご確認ください。</p>
      <div class="overflow-x-auto rounded-xl border border-slate-100 shadow-sm">
        <table class="w-full min-w-[520px] text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-[11px] font-semibold uppercase tracking-wide text-slate-500">
              <th class="px-4 py-2.5 whitespace-nowrap">ツール名</th>
              <th class="px-4 py-2.5">無料枠の条件</th>
              <th class="px-4 py-2.5">透かし条件</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {filtered.map((tool) => (
              <tr class="bg-white even:bg-slate-50">
                <td class="px-4 py-3 font-medium text-slate-900 whitespace-nowrap">
                  <a href={`/tools/${tool.slug}/`} class="hover:text-blue-600 hover:underline">{tool.data.name}</a>
                </td>
                <td class="px-4 py-3 text-slate-600">{tool.data.freePlanNote ?? '—'}</td>
                <td class="px-4 py-3 text-slate-600">{tool.data.watermarkCondition ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="mb-6 text-xl font-semibold text-slate-800">よくある質問</h2>
      <div class="space-y-6">
        <div class="rounded-lg border border-slate-200 px-5 py-4">
          <p class="font-medium text-slate-800">無料のAI画像生成ツールでも商用利用できますか？</p>
          <p class="mt-2 text-sm text-slate-600">ツールや利用規約によって異なります。無料プランでの商用利用が認められている場合もありますが、透かし・クレジット表記・利用範囲の制限がある場合があります。商用利用を前提にする場合は、最新の公式規約をご確認ください。本記事は法的助言ではありません。詳しくは<a href="/categories/commercial-use/" class="text-blue-600 hover:underline">商用利用を確認しやすいツール</a>のページもご参照ください。</p>
        </div>
        <div class="rounded-lg border border-slate-200 px-5 py-4">
          <p class="font-medium text-slate-800">無料プランでは透かしが入りますか？</p>
          <p class="mt-2 text-sm text-slate-600">ツールによって異なります。無料プランで透かしなしの出力ができるものもあれば、有料プランへの移行が必要なものもあります。上の表の「透かし条件」欄で各ツールの状況を確認できます。詳しくは<a href="/categories/no-watermark/" class="text-blue-600 hover:underline">透かしなしツール</a>のページもご参照ください。</p>
        </div>
        <div class="rounded-lg border border-slate-200 px-5 py-4">
          <p class="font-medium text-slate-800">日本語プロンプトでも使えますか？</p>
          <p class="mt-2 text-sm text-slate-600">日本語プロンプトを受け付けるツールは多いですが、精度はツールやモデルによって異なります。英語プロンプトの方が精度が高い場合が多く、固有名詞・専門用語は英語入力が推奨されることもあります。<a href="/categories/japanese/" class="text-blue-600 hover:underline">日本語対応ツール</a>のページでまとめて確認できます。</p>
        </div>
        <div class="rounded-lg border border-slate-200 px-5 py-4">
          <p class="font-medium text-slate-800">無料ツールと有料ツールは何が違いますか？</p>
          <p class="mt-2 text-sm text-slate-600">多くのツールで、有料プランに移行すると解像度・生成速度・月間クレジット数・追加機能が解放されます。また、有料プランでのみ商用利用が可能とされているツールもあります。用途に合わせて<a href="/tools/" class="text-blue-600 hover:underline">各ツールの詳細ページ</a>で比較してください。</p>
        </div>
        <div class="rounded-lg border border-slate-200 px-5 py-4">
          <p class="font-medium text-slate-800">YouTubeサムネやSNS画像に無料ツールで生成した画像を使う場合の注意点は？</p>
          <p class="mt-2 text-sm text-slate-600">収益化を伴う用途（YouTube広告、アフィリエイト、有料サービスのSNS告知など）は商用利用と判断される場合があります。無料プランの商用利用可否、透かし条件、クレジット表記義務を各ツールの公式規約で事前に確認することを推奨します。無料枠や利用条件は変更される可能性があります。本記事は法的助言ではありません。</p>
        </div>
        <div class="rounded-lg border border-slate-200 px-5 py-4">
          <p class="font-medium text-slate-800">無料で使い続けることはできますか？</p>
          <p class="mt-2 text-sm text-slate-600">クレジット制のツールは上限に達すると課金が必要になる場合があります。また、無料枠の内容はサービス側の方針変更により変わる場合があります。利用前に公式の料金ページをご確認ください。</p>
        </div>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-sm font-semibold text-slate-600">関連ページ</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/compare/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">全ツール比較表</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">商用利用・著作権ガイド</a></li>
        <li><a href="/tools/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">すべてのツールを見る</a></li>
        <li><a href="/categories/free-video/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">無料AI動画生成ツールを比較</a></li>
        <li><a href="/categories/commercial-use/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">商用利用を確認しやすいツール</a></li>
        <li><a href="/categories/japanese/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">日本語対応ツール</a></li>
        <li><a href="/categories/no-watermark/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">透かしなしツール</a></li>
      </ul>
    </section>

    <nav class="mt-8 border-t border-slate-200 pt-6 text-sm">
      <a href="/tools/" class="text-blue-600 hover:underline">← ツール一覧に戻る</a>
    </nav>

  </div>
</BaseLayout>
