  { name: 'Adobe Firefly',        slug: 'adobe-firefly',            initial: 'A', role: '画像生成', commercial: '無料:条件付き / 有料:案内あり',       free: '要確認',     jp: '対応',   note: 'プランによる', price: '$9.99/月（Firefly Standard・プロモ適用時）', platforms: 'Web', date: '2026-06-10' },
