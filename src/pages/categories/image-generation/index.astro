const splitChips = (s: string) => s.split(/[、,]/).map((p) => p.trim()).filter(Boolean);
---

<BaseLayout
  title="AI画像生成ツールおすすめ比較｜無料・アニメ・イラスト・商用利用・日本語対応"
  description="AI画像生成ツール（Midjourney・Adobe Firefly・Canva AI・Stable Diffusionなど）のおすすめ比較ページ。アニメ・イラスト・実写・SNS・広告など用途別に無料枠・透かし・スマホ対応・商用利用条件・日本語対応を横断確認できます。最新情報は各公式サイトをご確認ください。"
  canonicalPath="/categories/image-generation/"
  jsonLd={faqJsonLd}
>

  <div class="mx-auto max-w-5xl px-6 py-10">

    <!-- パンくず -->
    <nav class="mb-5 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>AI画像生成ツール</span>
    </nav>

    <!-- カテゴリナビ -->
    <nav class="mb-8">
      <p class="mb-2 text-xs font-semibold text-slate-500 uppercase tracking-widest">カテゴリから探す</p>
      <div class="flex flex-wrap gap-2 text-sm">
        <a href="/categories/video-generation/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI動画生成</a>
        <a href="/categories/image-generation/" class="rounded-full border border-indigo-400 bg-indigo-50 px-3 py-1.5 font-semibold text-indigo-700" aria-current="page">AI画像生成</a>
        <a href="/categories/avatar-video/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AIアバター動画</a>
        <a href="/categories/video-editing/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI動画編集</a>
        <a href="/categories/design/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AIデザイン</a>
        <a href="/categories/voice-narration/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI音声・ナレーション</a>
      </div>
    </nav>

  </div>

  <div class="cig-x" data-cig>
    <div class="mx-auto max-w-5xl px-6">

      <!-- ===== Hero ===== -->
      <header class="cig-head">
        <div class="cig-meta">
          <span class="cig-pill">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.8"/><path d="m21 15-4.5-4.5L7 21"/></svg>
            AI IMAGE GENERATION
          </span>
          <span class="cig-checked">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            記事内容の最終確認 <b>2026-06-10</b>
          </span>
        </div>
        <h1 class="cig-h1">AI画像生成<span class="phrase-nowrap">ツールを</span><span class="hl">比較する</span></h1>
        <p class="cig-lead">イラスト、写真風画像、SNS投稿、広告バナー、ブログアイキャッチ、YouTubeサムネイル、EC商品画像、デザイン案や企画ラフなど、作りたい画像の用途に合わせてAI画像生成ツールの選び方を整理します。ツールによって無料枠・透かし・商用利用条件・日本語対応・画像編集機能・得意な画風が異なります。無料枠・透かし・商用利用条件・日本語対応を横断的に確認できます。</p>
        <div class="cig-stats">
          <div class="cig-stat"><span class="n">16</span><span class="t">AI画像生成ツール</span></div>
          <div class="cig-stat"><span class="n">6</span><span class="t">用途別に比較</span></div>
          <div class="cig-stat"><span class="n">12</span><span class="t">よくある質問</span></div>
        </div>
      </header>

      <!-- 無料比較CTA -->
      <div class="cig-free-cta reveal">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
        <span>無料で試せるAI画像生成ツールを比較したい方は→</span>
        <a href="/comparisons/free-ai-image-generators/">無料で使えるAI画像生成ツールを比較する →</a>
      </div>

      <!-- Notice -->
      <div class="cig-notice">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
        <p><b>ご利用前の注意：</b>AI画像生成ツールは、プラン・生成方式・素材利用・商用利用条件によって扱いが異なる場合があります。生成画像の商用利用、第三者素材、人物・ブランド・ロゴの利用条件は、各ツールの公式情報をご確認ください。本記事は法的助言ではありません。</p>
      </div>

      <!-- ===== 用途別おすすめ早見表 ===== -->
      <section class="cig-sec">
        <div class="cig-sechead reveal">
          <span class="cig-eyebrow">Quick guide</span>
          <h2>用途別おすすめ早見表</h2>
          <p>AI画像生成ツールは、用途によって向いているツールが変わります。まずは作りたい画像の種類から候補を絞り、下の比較表で料金・無料枠・透かし・商用利用条件を確認してください。</p>
        </div>
        <div class="reveal">
          <div class="cig-tablewrap">
            <table class="cig-gt guide">
              <thead>
                <tr><th>用途</th><th>候補ツール</th><th>向いている理由</th><th>確認ポイント</th><th>詳細</th></tr>
              </thead>
              <tbody>
                <tr>
                  <td class="cig-situation">初心者がまず試したい</td>
                  <td class="cig-cand">Canva AI / Microsoft Designer</td>
                  <td class="cig-note">デザイン作成と一緒に使いやすく、画像生成だけでなく編集・配置まで進めやすい候補</td>
                  <td class="cig-note">無料枠、テンプレート、商用利用条件</td>
                  <td><span class="cig-linklist"><a href="/tools/canva-ai-image-generator/">Canva AI →</a><a href="/tools/microsoft-designer/">Microsoft Designer →</a></span></td>
                </tr>
                <tr>
                  <td class="cig-situation">SNS・ブログ画像を作りたい</td>
                  <td class="cig-cand">Canva AI / Adobe Firefly / DALL·E</td>
                  <td class="cig-note">ブログアイキャッチやSNS投稿向けの素材作成に使いやすい候補</td>
                  <td class="cig-note">画像サイズ、文字入れ、編集機能、利用条件</td>
                  <td><span class="cig-linklist"><a href="/tools/canva-ai-image-generator/">Canva AI →</a><a href="/tools/adobe-firefly/">Adobe Firefly →</a><a href="/tools/dalle/">DALL·E →</a></span></td>
                </tr>
                <tr>
                  <td class="cig-situation">商用・広告バナー用途を検討したい</td>
                  <td class="cig-cand">Adobe Firefly / Canva AI</td>
                  <td class="cig-note">デザイン制作や広告素材作成の流れに組み込みやすい候補</td>
                  <td class="cig-note">プラン別の利用条件、素材・フォント・テンプレートの扱い、商用利用条件</td>
                  <td><span class="cig-linklist"><a href="/tools/adobe-firefly/">Adobe Firefly →</a><a href="/guides/commercial-use-copyright/">利用条件の考え方 →</a></span></td>
                </tr>
                <tr>
                  <td class="cig-situation">イラスト・ゲーム素材を作りたい</td>
                  <td class="cig-cand">Midjourney / Leonardo AI / Stable Diffusion</td>
