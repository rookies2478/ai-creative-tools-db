  .cig-h1 .hl { color: var(--brand-ink); position: relative; }
  .cig-h1 .hl::after { content: ""; position: absolute; left: 0; right: 0; bottom: .08em; height: .26em; background: color-mix(in srgb, var(--brand) 20%, transparent); z-index: -1; border-radius: 2px; }
  .cig-lead { font-size: 15.5px; color: var(--ink-soft); max-width: 720px; }
  .cig-stats { display: flex; flex-wrap: wrap; gap: 10px 26px; margin-top: 24px; }
  .cig-stat { display: flex; align-items: baseline; gap: 8px; }
  .cig-stat + .cig-stat { padding-left: 26px; border-left: 1px solid var(--line); }
  .cig-stat .n { font-family: var(--f-latin); font-weight: 700; font-size: 24px; color: var(--ink); line-height: 1; }
  .cig-stat .t { font-size: 12.5px; color: var(--muted); white-space: nowrap; }

  /* 無料比較CTA */
  .cig-free-cta { display: flex; align-items: center; flex-wrap: wrap; gap: 10px; background: var(--brand-tint); border: 1px solid color-mix(in srgb, var(--brand) 28%, var(--line)); border-radius: var(--radius); padding: 14px 20px; margin: 20px 0 0; font-size: 13.5px; color: var(--brand-ink); }
  .cig-free-cta svg { width: 16px; height: 16px; flex: none; }
  .cig-free-cta span { color: var(--ink-soft); }
  .cig-free-cta a { font-weight: 700; color: var(--brand-ink); border-bottom: 1px solid color-mix(in srgb, var(--brand) 40%, transparent); }
  .cig-free-cta a:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* Notice */
  .cig-notice { display: flex; align-items: flex-start; gap: 14px; background: var(--warn-tint); border: 1px solid color-mix(in srgb, var(--warn) 28%, var(--line)); border-radius: var(--radius); padding: 18px 22px; margin: 28px 0 0; }
  .cig-notice svg { width: 18px; height: 18px; color: var(--warn); flex: none; margin-top: 2px; }
  .cig-notice p { font-size: 13.5px; color: var(--ink-soft); line-height: 1.75; }
  .cig-notice p b { color: var(--ink); font-weight: 700; }

  /* 選びのポイント */
  .cig-points { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; list-style: none; margin: 0 0 18px; padding: 0; }
  .cig-pcard { position: relative; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 22px 24px; display: flex; align-items: flex-start; gap: 15px; transition: transform .2s var(--ease), box-shadow .2s, border-color .2s; }
  .cig-pcard:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: color-mix(in srgb, var(--brand) 30%, var(--line)); }
  .cig-pcard .pn { font-family: var(--f-latin); font-weight: 700; font-size: 16px; color: var(--brand); background: var(--brand-tint); width: 38px; height: 38px; border-radius: 10px; display: grid; place-items: center; flex: none; }
  .cig-pcard h3 { font-size: 15.5px; line-height: 1.4; color: var(--ink); margin-bottom: 5px; }
  .cig-pcard .pt p { font-size: 12.5px; color: var(--muted); line-height: 1.7; }
  .cig-pcard .pt p a { color: var(--brand-ink); font-weight: 600; }
  .cig-pcard .pt p a:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* タグリンク */
  .cig-taglinks { display: flex; flex-wrap: wrap; gap: 10px; }
  .cig-taglink { font-family: var(--f-jp); font-weight: 600; font-size: 13.5px; padding: 9px 16px; border-radius: 999px; background: var(--surface); border: 1px solid var(--line-strong); color: var(--ink-soft); display: inline-flex; align-items: center; gap: 8px; white-space: nowrap; transition: transform .16s var(--ease), background .16s, border-color .16s, color .16s; }
  .cig-taglink:hover { border-color: var(--brand); color: var(--brand-ink); background: var(--brand-tint); transform: translateY(-1px); }
  .cig-taglink .ld { width: 7px; height: 7px; border-radius: 50%; background: var(--brand); flex: none; }

  /* 表（共通） */
  .cig-gtcap { font-family: var(--f-mono); font-size: 12px; color: var(--muted); margin-bottom: 12px; }
  .cig-tablewrap { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--radius); background: var(--surface); box-shadow: var(--shadow-sm); }
  table.cig-gt { width: 100%; border-collapse: collapse; }
  table.cig-gt.guide { min-width: 880px; }
  table.cig-gt.diff { min-width: 720px; }
  table.cig-gt.cross { min-width: 1000px; }
  table.cig-gt.char { min-width: 760px; }
  table.cig-gt thead th { font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; color: var(--ink-soft); background: var(--surface-2); padding: 14px 18px; text-align: left; border-bottom: 1px solid var(--line); white-space: nowrap; }
  table.cig-gt tbody td { padding: 14px 18px; border-bottom: 1px solid var(--line); vertical-align: top; }
  table.cig-gt tbody tr:last-child td { border-bottom: none; }
  table.cig-gt tbody tr { transition: background .12s; }
  table.cig-gt tbody tr:hover { background: var(--surface-2); }
  table.cig-gt tbody tr.is-current { background: var(--brand-tint); }
  table.cig-gt tbody tr.is-current:hover { background: color-mix(in srgb, var(--brand) 14%, var(--surface)); }
  .cig-note { font-size: 13px; color: var(--ink-soft); line-height: 1.7; }
  .cig-note.nowrap { white-space: nowrap; }
  .cig-situation { font-family: var(--f-jp); font-weight: 700; font-size: 14px; color: var(--ink); min-width: 150px; }
  .cig-cand { font-family: var(--f-jp); font-weight: 600; font-size: 13px; color: var(--brand-ink); min-width: 150px; line-height: 1.6; }
  .cig-catcell { font-family: var(--f-jp); font-weight: 700; font-size: 14px; color: var(--ink); white-space: nowrap; }
  .cig-curtag { display: inline-block; margin-left: 8px; font-size: 10.5px; font-weight: 700; color: var(--brand-ink); background: color-mix(in srgb, var(--brand) 16%, #fff); border: 1px solid color-mix(in srgb, var(--brand) 30%, var(--line)); padding: 2px 8px; border-radius: 999px; vertical-align: middle; }
  .cig-linklist { display: flex; flex-direction: column; gap: 4px; }
  .cig-linklist a { font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; color: var(--brand-ink); white-space: nowrap; }
  .cig-linklist a:hover { text-decoration: underline; text-underline-offset: 3px; }
  .cig-tool { display: flex; align-items: center; gap: 11px; min-width: 140px; }
  .cig-tool .b { width: 32px; height: 32px; border-radius: 9px; display: grid; place-items: center; background: var(--brand-tint); color: var(--brand-ink); font-family: var(--f-latin); font-weight: 700; font-size: 14px; flex: none; }
  .cig-tool .nm { font-family: var(--f-jp); font-weight: 700; font-size: 14px; color: var(--ink); line-height: 1.3; white-space: nowrap; }
  a.nm:hover { color: var(--brand-ink); text-decoration: underline; text-underline-offset: 3px; }
  .cig-detail { font-family: var(--f-jp); font-weight: 700; font-size: 12.5px; color: var(--brand-ink); white-space: nowrap; }
  .cig-detail:hover { text-decoration: underline; text-underline-offset: 3px; }
  .cig-userbadge { display: inline-flex; font-family: var(--f-jp); font-weight: 700; font-size: 12px; color: var(--ink-soft); background: var(--surface-2); border: 1px solid var(--line); border-radius: 999px; padding: 4px 11px; white-space: nowrap; }
  .cig-foot { margin-top: 14px; font-size: 12px; color: var(--faint); line-height: 1.7; max-width: 920px; }

  /* 参考ビジュアル */
  .cig-refvisual { display: grid; grid-template-columns: 1.05fr 1fr; gap: 26px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 20px; box-shadow: var(--shadow-sm); margin: 0 0 28px; }
  .cig-refvisual .img { border-radius: var(--radius); overflow: hidden; background: #11131a; aspect-ratio: 16/9; }
  .cig-refvisual .img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cig-refvisual figcaption { align-self: center; }
  .cig-refvisual .cap { font-size: 12.5px; color: var(--muted); line-height: 1.7; margin-bottom: 14px; }
  .cig-refvisual .genmeta { display: flex; flex-direction: column; gap: 9px; margin: 0 0 14px; }
  .cig-refvisual .genmeta > div { display: grid; grid-template-columns: 78px 1fr; gap: 12px; align-items: start; }
  .cig-refvisual .genmeta dt { font-family: var(--f-jp); font-weight: 700; font-size: 11.5px; color: var(--muted); }
  .cig-refvisual .genmeta dd { margin: 0; font-size: 12.5px; color: var(--ink-soft); line-height: 1.6; }
  .cig-refvisual .genmeta dd.mono { font-family: var(--f-mono); font-size: 11.5px; word-break: break-word; }
  .cig-refvisual .genmeta dd a { color: var(--brand-ink); font-weight: 600; }
  .cig-refvisual .note { font-size: 11px; color: var(--faint); line-height: 1.65; }

  /* クイックピック */
  .cig-pickgrid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
  .cig-pickcard { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px 26px; display: flex; flex-direction: column; }
  .cig-pickcard .ph { font-size: 15.5px; font-weight: 900; color: var(--ink); margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid var(--line); }
  .cig-pickcard ul { list-style: none; margin: 0 0 16px; padding: 0; display: flex; flex-direction: column; gap: 11px; }
  .cig-pickcard li { font-size: 13px; color: var(--muted); line-height: 1.55; }
  .cig-pickcard li .nm { font-family: var(--f-jp); font-weight: 700; font-size: 14px; color: var(--ink); }
  .cig-pickcard li a.nm:hover { color: var(--brand-ink); text-decoration: underline; text-underline-offset: 3px; }
  .cig-pickcard li .nt { display: block; margin-top: 1px; }
  .cig-morelink { margin-top: auto; font-family: var(--f-jp); font-weight: 700; font-size: 13px; color: var(--brand-ink); }
  .cig-morelink:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* ツールカード */
  .cig-cardgrid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
  .cig-cardgrid.two { grid-template-columns: repeat(2,1fr); max-width: 760px; }
  .cig-tcard { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 22px 24px; display: flex; flex-direction: column; box-shadow: var(--shadow-sm); transition: transform .2s var(--ease), box-shadow .2s, border-color .2s; }
  .cig-tcard:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: color-mix(in srgb, var(--brand) 26%, var(--line)); }
  .cig-tcard .th { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .cig-tcard .th .b { width: 40px; height: 40px; border-radius: 10px; display: grid; place-items: center; background: var(--brand-tint); color: var(--brand-ink); font-family: var(--f-latin); font-weight: 700; font-size: 17px; flex: none; }
  .cig-tcard .ti { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .cig-tcard .ti .nm { font-family: var(--f-jp); font-weight: 700; font-size: 16px; color: var(--ink); line-height: 1.25; }
  .cig-tcard .ti .role { font-family: var(--f-mono); font-size: 11px; color: var(--muted); letter-spacing: .04em; }
  .cig-tcard .tmeta { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 12px; margin-bottom: 14px; }
  .cig-tcard .tmeta .m { font-size: 12.5px; color: var(--ink-soft); display: flex; align-items: baseline; gap: 7px; line-height: 1.45; }
  .cig-tcard .tmeta .m i { font-style: normal; font-family: var(--f-jp); font-weight: 700; font-size: 10.5px; color: var(--muted); background: var(--surface-2); border: 1px solid var(--line); border-radius: 6px; padding: 2px 7px; flex: none; }
  .cig-tcard .tprice { font-size: 12.5px; color: var(--ink-soft); line-height: 1.6; padding: 12px 0; border-top: 1px dashed var(--line); border-bottom: 1px dashed var(--line); margin-bottom: 14px; }
  .cig-tcard .tprice .lbl { font-family: var(--f-jp); font-weight: 700; font-size: 10.5px; color: var(--muted); margin-right: 9px; }
  .cig-tcard .tplats { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 18px; }
  .cig-tcard .plat { font-family: var(--f-jp); font-weight: 600; font-size: 11.5px; color: var(--ink-soft); background: var(--surface-2); border: 1px solid var(--line); border-radius: 7px; padding: 3px 9px; }
  .cig-tcard .tf { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: auto; }
  .cig-tcard .tdate { font-family: var(--f-mono); font-size: 11.5px; color: var(--muted); white-space: nowrap; }
  .cig-tcard .tlinks { display: inline-flex; align-items: center; gap: 14px; }
  .cig-tcard .tlinks .primary { font-family: var(--f-jp); font-weight: 700; font-size: 13px; color: var(--brand-ink); white-space: nowrap; }
  .cig-tcard .tlinks .primary:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* 比較記事カード */
  .cig-artgrid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
  .cig-artcard { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 24px 26px; display: flex; flex-direction: column; transition: transform .2s var(--ease), box-shadow .2s, border-color .2s; }
  .cig-artcard:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: color-mix(in srgb, var(--brand) 28%, var(--line)); }
  .cig-artcard .tag { font-family: var(--f-jp); font-weight: 700; font-size: 11px; color: var(--brand-ink); background: var(--brand-tint); border-radius: 999px; padding: 4px 11px; align-self: flex-start; margin-bottom: 13px; }
  .cig-artcard h3 { font-size: 18px; font-weight: 900; color: var(--ink); margin-bottom: 8px; }
  .cig-artcard p { font-size: 13px; color: var(--muted); line-height: 1.7; margin-bottom: 16px; }
  .cig-artcard .go { margin-top: auto; font-family: var(--f-jp); font-weight: 700; font-size: 13px; color: var(--brand-ink); }
  .cig-artcard:hover .go { text-decoration: underline; text-underline-offset: 3px; }

  /* 注意点 */
  .cig-cautions { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .cig-caution { display: grid; grid-template-columns: auto 1fr; gap: 16px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 22px 24px; align-items: start; }
  .cig-caution .ic { width: 24px; height: 24px; color: var(--warn); flex: none; margin-top: 1px; }
  .cig-caution .ic svg { width: 24px; height: 24px; }
  .cig-caution strong { display: block; font-family: var(--f-jp); font-weight: 900; font-size: 15px; color: var(--ink); margin-bottom: 6px; }
  .cig-caution p { font-size: 13px; color: var(--ink-soft); line-height: 1.75; }
  .cig-caution p a { color: var(--brand-ink); font-weight: 600; }
  .cig-caution p a:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* 向いている/向いていない */
  .cig-twocol { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .cig-panel { border-radius: var(--radius-lg); padding: 26px 28px; border: 1px solid var(--line); }
  .cig-panel.pos { background: var(--ok-tint); border-color: color-mix(in srgb, var(--ok) 24%, var(--line)); }
  .cig-panel.neg { background: var(--no-tint); border-color: color-mix(in srgb, var(--no) 24%, var(--line)); }
  .cig-panel .ph { display: flex; align-items: center; gap: 11px; font-size: 16px; font-weight: 900; margin-bottom: 16px; }
  .cig-panel.pos .ph { color: var(--ok); }
  .cig-panel.neg .ph { color: var(--no); }
  .cig-panel .ph .ic { width: 24px; height: 24px; border-radius: 7px; display: grid; place-items: center; flex: none; }
  .cig-panel.pos .ph .ic { background: color-mix(in srgb, var(--ok) 16%, #fff); }
  .cig-panel.neg .ph .ic { background: color-mix(in srgb, var(--no) 16%, #fff); }
  .cig-panel .ph .ic svg { width: 16px; height: 16px; }
  .cig-panel ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 11px; }
  .cig-panel li { font-size: 13.5px; color: var(--ink-soft); line-height: 1.7; padding-left: 16px; position: relative; }
  .cig-panel li::before { content: ""; position: absolute; left: 0; top: 9px; width: 6px; height: 6px; border-radius: 50%; }
  .cig-panel.pos li::before { background: var(--ok); }
  .cig-panel.neg li::before { background: var(--no); }

  /* FAQ */
  .cig-faq { max-width: 880px; }
  .cig-faqitem { border-bottom: 1px solid var(--line); }
  .cig-faqitem:first-child { border-top: 1px solid var(--line); }
  .cig-faqq { width: 100%; text-align: left; background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 16px; padding: 24px 6px; font-family: var(--f-jp); font-weight: 700; font-size: 16px; color: var(--ink); }
  .cig-faqq .qm { font-family: var(--f-latin); color: var(--brand); font-size: 16px; flex: none; }
  .cig-faqq .ind { margin-left: auto; flex: none; width: 24px; height: 24px; display: grid; place-items: center; transition: transform .3s var(--ease); color: var(--muted); }
  .cig-faqq .ind svg { width: 18px; height: 18px; }
  .cig-faqitem[aria-expanded="true"] .cig-faqq .ind { transform: rotate(45deg); color: var(--brand); }
  .cig-faqa { max-height: 0; overflow: hidden; transition: max-height .35s var(--ease); }
  .cig-faqa-in { padding: 0 6px 26px 46px; color: var(--ink-soft); font-size: 14.5px; line-height: 1.8; }
  .cig-faqa-in a { color: var(--brand-ink); font-weight: 600; }
  .cig-faqa-in a:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* 注意事項 + 鮮度 + 免責 */
  .cig-notes { list-style: none; display: flex; flex-direction: column; gap: 12px; max-width: 880px; margin: 0; padding: 0; }
  .cig-notes li { display: grid; grid-template-columns: auto 1fr; gap: 12px; align-items: start; font-size: 13.5px; color: var(--ink-soft); line-height: 1.75; }
  .cig-notes li .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--brand); flex: none; margin-top: 9px; }
  .cig-freshness { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 24px; background: var(--surface); border: 1px solid var(--line); border-radius: 999px; padding: 11px 20px; font-size: 13px; color: var(--ink-soft); max-width: max-content; }
  .cig-freshness svg { width: 16px; height: 16px; color: var(--brand); flex: none; }
  .cig-freshness b { font-weight: 700; color: var(--ink); }
  .cig-freshness .mono { font-family: var(--f-mono); font-size: 12.5px; }
  .cig-disclaimer { display: flex; align-items: flex-start; gap: 12px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 20px; }
  .cig-disclaimer svg { width: 18px; height: 18px; color: var(--muted); flex: none; margin-top: 2px; }
  .cig-disclaimer p { font-size: 12.5px; color: var(--muted); line-height: 1.75; }

  /* 関連ページ */
  .cig-finder { background: var(--surface-2); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 34px 34px 30px; }
  .cig-finder h2 { font-size: clamp(20px, 2.4vw, 26px); margin-bottom: 6px; }
  .cig-finder .lead { color: var(--muted); font-size: 14px; margin-bottom: 24px; }
  .cig-relgrid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 28px 40px; }
  .cig-relcol h4 { font-family: var(--f-latin); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; font-weight: 600; }
  .cig-relcol ul { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 9px 18px; }
  .cig-relcol a { display: inline-flex; align-items: center; gap: 8px; font-family: var(--f-jp); font-weight: 600; font-size: 13.5px; color: var(--ink-soft); transition: color .15s; }
  .cig-relcol a:hover { color: var(--brand-ink); }
  .cig-relcol a .ld { width: 6px; height: 6px; border-radius: 50%; background: var(--brand); flex: none; }

  /* スクロール表示アニメ */
  @media (prefers-reduced-motion: no-preference) {
    .cig-x .reveal { opacity: 0; transform: translateY(18px); transition: opacity .6s var(--ease), transform .6s var(--ease); }
    .cig-x .reveal.in { opacity: 1; transform: none; }
    .cig-x .reveal[data-stagger] > * { opacity: 0; transform: translateY(16px); transition: opacity .5s var(--ease), transform .5s var(--ease); }
    .cig-x .reveal[data-stagger].in > * { opacity: 1; transform: none; }
    .cig-x .reveal[data-stagger].in > *:nth-child(1) { transition-delay: .04s; }
    .cig-x .reveal[data-stagger].in > *:nth-child(2) { transition-delay: .09s; }
    .cig-x .reveal[data-stagger].in > *:nth-child(3) { transition-delay: .14s; }
    .cig-x .reveal[data-stagger].in > *:nth-child(4) { transition-delay: .19s; }
    .cig-x .reveal[data-stagger].in > *:nth-child(5) { transition-delay: .24s; }
    .cig-x .reveal[data-stagger].in > *:nth-child(6) { transition-delay: .29s; }
    .cig-x .reveal[data-stagger].in > *:nth-child(7) { transition-delay: .34s; }
    .cig-x .reveal[data-stagger].in > *:nth-child(8) { transition-delay: .39s; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cig-x .reveal, .cig-x .reveal[data-stagger] > * { opacity: 1 !important; transform: none !important; }
  }

  /* レスポンシブ */
  @media (max-width: 980px) {
    .cig-pickgrid { grid-template-columns: 1fr; }
    .cig-refvisual { grid-template-columns: 1fr; }
    .cig-relgrid { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .cig-sec { padding: 48px 0; }
    .cig-points { grid-template-columns: 1fr; }
    .cig-cardgrid, .cig-cardgrid.two, .cig-artgrid, .cig-twocol { grid-template-columns: 1fr; }
    .cig-tcard .tmeta { grid-template-columns: 1fr; }
    .cig-relcol ul { grid-template-columns: 1fr; }
    .cig-stat + .cig-stat { padding-left: 0; border-left: none; }
    .cig-finder { padding: 26px 22px; }
  }
</style>

<script>
  (function () {
    document.querySelectorAll('[data-cig]').forEach(function (root) {
      var faq = root.querySelector('.cig-faq');
      if (faq) {
        faq.addEventListener('click', function (e) {
          var btn = (e.target as HTMLElement).closest('.cig-faqq');
          if (!btn) return;
          var item = btn.closest('.cig-faqitem') as HTMLElement;
          var open = item.getAttribute('aria-expanded') === 'true';
          faq.querySelectorAll('.cig-faqitem').forEach(function (it) {
            it.setAttribute('aria-expanded', 'false');
            var a = it.querySelector('.cig-faqa') as HTMLElement | null;
            if (a) a.style.maxHeight = '';
          });
          if (!open) {
            item.setAttribute('aria-expanded', 'true');
            var a = item.querySelector('.cig-faqa') as HTMLElement | null;
            if (a) a.style.maxHeight = a.scrollHeight + 'px';
          }
        });
      }

      var reveals = Array.prototype.slice.call(root.querySelectorAll('.reveal'));
      if (!reveals.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach(function (el) { io.observe(el); });
      setTimeout(function () { reveals.forEach(function (el) { el.classList.add('in'); }); }, 8000);
    });
  })();
</script>
