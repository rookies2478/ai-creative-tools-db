---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { generatedImages } from '../../../data/generatedImages';

const allTools = await getCollection('tools');
const imageTools = allTools.filter((t) => t.data.category === 'image' || t.data.category === 'both');
const videoTools = allTools.filter((t) => t.data.category === 'video' || t.data.category === 'both');

const primaryImageSlugs = ['midjourney', 'adobe-firefly', 'canva-ai-image-generator', 'leonardo-ai', 'stable-diffusion', 'dalle', 'ideogram', 'microsoft-designer', 'seaart-ai', 'fotor-ai', 'gemini-image-generation', 'nightcafe', 'playground-ai', 'clipdrop', 'dreamstudio', 'tensor-art'];
const primaryImageTools = primaryImageSlugs
  .map((s) => imageTools.find((t) => t.slug === s))
  .filter(Boolean);

const primaryVideoSlugs = ['runway', 'pika', 'kling-ai', 'luma-ai', 'hailuo-ai', 'haiper'];
const primaryVideoTools = primaryVideoSlugs
  .map((s) => videoTools.find((t) => t.slug === s))
  .filter(Boolean);

const referenceImage = generatedImages.find((img) => img.pageSlug === 'categories/image-generation' && img.sampleType === 'reference-visual');

const faqs = [
  {
    q: 'AI画像生成ツールは無料でも使えますか？',
    a: '無料で試せるツールもありますが、生成回数・画像サイズ・透かし・商用利用条件などに制限がある場合があります。最新情報は各公式サイトをご確認ください。<a href="/conditions/free/">無料枠のあるツール一覧</a>もご参照ください。',
  },
  {
    q: 'AI画像生成ツールを商用利用する前に何を確認すべきですか？',
    a: '料金プラン・生成物の利用条件・人物画像やブランドロゴ・第三者素材の扱い・利用規約の最新状況などを確認してください。プランによって商用利用の条件が異なるツールも多くあります。本記事は法的助言ではありません。<a href="/conditions/commercial-use/">商用利用条件を確認しやすいツール</a>や<a href="/guides/commercial-use-copyright/">商用利用・著作権の考え方ガイド</a>もご参照ください。',
  },
  {
    q: '日本語プロンプトに対応していれば日本語で十分ですか？',
    a: '日本語で指示できるツールもありますが、細かい画風や構図の指定では英語プロンプトの方が意図を伝えやすい場合があります。ツールごとの対応状況は<a href="/conditions/japanese/">日本語対応ツール</a>のページでご確認ください。',
  },
  {
    q: '人物や著名人・ブランドロゴを含む画像を生成しても問題ありませんか？',
    a: '人物・著名人・ブランドロゴ・第三者の商標や著作物を含む画像の生成・利用については、各ツールの利用規約に加え、肖像権・著作権・商標権などの観点から個別に確認が必要です。本記事は法的助言ではなく、問題がないことを保証するものではありません。',
  },
  {
    q: 'テキストから画像を生成する方式と画像を編集する方式の違いは何ですか？',
    a: 'テキストプロンプトから画像を新規生成する「テキスト→画像（text-to-image）」と、既存画像を入力として加工・変換する「画像→画像（image-to-image）」では、向いているツールや使い方が異なります。また、Canva AIのようにデザインテンプレートと組み合わせて使う「デザイン補助」型のツールもあります。目的に合わせて選択することをおすすめします。',
  },
  {
    q: 'AI画像生成・AI動画生成・AIデザインツールはどう違いますか？',
    a: 'AI画像生成ツール（Midjourney・Stable Diffusionなど）はプロンプトから静止画を生成します。AI動画生成ツール（Runway・Kling AIなど）はテキストや画像から映像を生成します。AIデザインツール（Canva AI・Adobe Fireflyなど）はテンプレートやデザイン作業と一体化した形で画像生成・編集を行います。用途によって使い分けるか、組み合わせて活用するケースもあります。',
  },
  {
    q: 'AI画像生成ツールで生成した画像の著作権は誰のものですか？',
    a: 'AI生成画像の著作権・所有権の扱いは、ツールのプラン・利用規約・生成に使用した素材の権利状況・各国の法律などによって異なります。本記事は法的助言ではありません。商用利用や重要な場面での利用前には、各ツールの公式利用規約を確認し、必要に応じて専門家へご相談ください。',
  },
  {
    q: '透かしなしで使えるAI画像生成ツールはありますか？',
    a: '透かし（ウォーターマーク）の有無はツールやプランによって異なります。有料プランで透かしなしになるツール、無料プランでも透かしなしの場合があるツールなど、条件はさまざまです。SNS投稿や商用成果物への利用を検討する場合は、利用前に各ツールの公式情報をご確認ください。<a href="/conditions/no-watermark/">透かしなしで使いやすいAIツール</a>もご参照ください。',
  },
  {
    q: '初心者はどのAI画像生成ツールから試すとよいですか？',
    a: 'デザイン作業と一体化して使いやすいCanva AIやMicrosoft Designerは、初めてAI画像生成を試す方の比較候補として挙げられることがあります。Googleアカウントがあれば手軽に始められるGemini画像生成も候補の一つです。ツールの操作感・生成できる画風・無料枠の条件はそれぞれ異なるため、実際に無料枠で試してみることをおすすめします。商用利用条件は各ツールの公式規約をご確認ください。',
  },
  {
    q: 'スマホで使えるAI画像生成ツールはありますか？',
    a: 'スマホからの利用は、ブラウザ経由での利用・専用アプリの有無・ログイン要否・保存形式・透かし条件などを確認する必要があります。公式情報では、Canva AIはiOS/Androidアプリが案内されており、Gemini画像生成もiOS/Androidアプリ経由での利用が確認されています。その他のツールはWebブラウザ経由でのスマホ利用が想定されますが、操作性・対応状況はツールや時期によって異なります。スマホ対応状況は変更される場合があるため、最新情報は各公式サイトをご確認ください。<a href="/conditions/free/">無料枠のあるAIツール比較</a>もご参照ください。',
  },
  {
    q: 'アニメ・イラスト調の画像生成に向いているツールはどれですか？',
    a: 'アニメ・イラスト調の画像生成では、Stable Diffusion系ツール（DreamStudio・Tensor.Artなど）、SeaArt AI、Leonardo AIなどが候補として挙がることがあります。用途や画風によって向いているツールは変わり、「アニメ調に強い」とされるツールでも生成結果はプロンプト・モデル・設定によって大きく異なります。既存キャラクター・著作物を模したプロンプトを使う場合は、著作権・商標権の観点から別途確認が必要です。<a href="/use-cases/anime-illustration/">アニメ・イラスト向けツール比較</a>もご参照ください。本記事は法的助言ではありません。',
  },
  {
    q: 'AI画像生成ツールを無料で試すときに最初に確認すべき点は何ですか？',
    a: '無料枠で試す前に確認しておくとよい点として、①生成回数・クレジットの上限、②透かしの有無、③商用利用条件（無料プランでは商用不可のツールも多い）、④日本語プロンプトへの対応状況、⑤アカウント登録の要否があります。特に商用目的での利用を検討している場合は、無料枠での試用段階から利用規約を確認することをおすすめします。最新情報は各公式サイトをご確認ください。<a href="/conditions/free/">無料枠のあるAIツール比較</a>・<a href="/guides/ai-image-commercial-use-checklist/">AI画像生成商用利用チェックリスト</a>もご参照ください。本記事は法的助言ではありません。',
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a.replace(/<[^>]+>/g, '')
    }
  }))
});

const imageToolCards = [
