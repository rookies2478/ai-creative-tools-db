---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeBox from '../../../components/NoticeBox.astro';
import CompareTablePreview from '../../../components/CompareTablePreview.astro';
import ConditionChips from '../../../components/ConditionChips.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';

const tools = await getCollection('tools');

const faqs = [
  {
    q: '日本語対応AI画像生成ツールとは何ですか？',
    a: '日本語UIや日本語プロンプトに対応しているAI画像生成ツールの総称です。ただし「日本語対応」の範囲はツールによって異なり、操作画面だけが日本語化されているもの、日本語の指示（プロンプト）で画像を生成できるもの、画像内に日本語文字を描画できるものなど、対応の種類は様々です。詳細は各ツールの詳細ページでご確認ください。',
  },
  {
    q: '日本語プロンプトだけで画像生成できますか？',
    a: '多くのツールで日本語プロンプトを受け付けますが、精度はツールやモデルによって異なります。細かいニュアンス・スタイル指定・専門用語などは英語プロンプトの方が意図が通りやすい場合があります。「一部対応（△）」と表示されているツールでは特に、英語プロンプトも試すことをおすすめします。',
  },
  {
    q: '画像内に日本語文字を入れられますか？',
    a: '画像内への日本語文字の描画は、ほとんどのAI画像生成ツールで安定しない場合があります。日本語プロンプトに対応していても、生成画像の中に正確な日本語テキストを挿入することは技術的に難しく、文字が崩れたり読めなかったりすることがあります。SNS画像やバナーにテキストを入れる場合は、別途画像編集ツールでテキストを追加することを検討してください。',
  },
  {
    q: '日本語UIがないツールでも使えますか？',
    a: '日本語UIがなくても、日本語プロンプトに対応しているツールであれば指示を日本語で書いて画像生成できます。ただし設定や料金ページが英語のみの場合、初心者には操作ハードルが上がります。英語が苦手な方は、日本語UIに対応したツールか、日本語ドキュメントが整備されているツールから始めるのが安心です。',
  },
  {
    q: '商用利用時に日本語対応以外で確認すべきことは？',
    a: 'SNS画像・YouTubeサムネイル・広告バナーなど収益化を伴う用途では、商用利用条件・透かしの有無・クレジット表記義務を各ツールの公式規約で確認することが重要です。日本語UIや日本語プロンプトへの対応とは別に、商用利用可否はプランや生成内容によって変わる場合があります。最新の公式規約を必ずご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: '初心者にはどのタイプの日本語対応ツールが向いていますか？',
    a: '操作に慣れていない方には、日本語UIと日本語ドキュメントの両方に対応しているツールが向いています。設定・料金・ヘルプを日本語で確認できると、疑問が出たときに対処しやすくなります。まず無料枠で試してみることも選択肢の一つです。無料で使えるツールは別ページでまとめています。',
  },
];
const filtered = tools.filter(
  (t) =>
    t.data.japaneseUi === true ||
    t.data.japaneseUi === 'partial' ||
    t.data.japanesePrompt === true ||
    t.data.japanesePrompt === 'partial'
);

function uiText(val: boolean | 'partial' | 'unknown') {
  if (val === true)      return { text: '○',  cls: 'text-emerald-600 font-bold' };
  if (val === 'partial') return { text: '△',  cls: 'text-amber-600 font-bold' };
  if (val === false)     return { text: '×',  cls: 'text-slate-400 font-bold' };
                         return { text: '?',  cls: 'text-slate-400' };
}
---

<BaseLayout
  title="日本語対応AI画像生成ツール比較｜日本語UI・日本語プロンプト対応を確認"
  description="日本語UIや日本語プロンプトに対応したAI画像生成・AI動画生成ツールを比較。日本語対応の範囲はツールごとに異なります。最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/japanese/"
>
  <div class="mx-auto max-w-5xl px-6 py-12">

    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>日本語対応</span>
    </nav>

    <h1 class="mb-3 text-3xl font-bold text-slate-900">日本語対応AI画像生成ツール比較</h1>
    <p class="mb-4 text-slate-600 leading-relaxed">
      日本語UIや日本語プロンプトに対応しているAI画像・動画生成ツールを整理しています。英語が苦手な方や、国内向けの制作・SNS運用でAIツールを使いたい方が対象です。
      <a href="/categories/free/" class="text-blue-600 hover:underline">無料で使えるツール</a>や
      <a href="/categories/commercial-use/" class="text-blue-600 hover:underline">商用利用条件を確認しやすいツール</a>、
      <a href="/categories/no-watermark/" class="text-blue-600 hover:underline">透かしなしのツール</a>とあわせて比較する際もご活用ください。
    </p>

    <div class="mb-6 rounded-lg border border-blue-200 bg-blue-50 px-5 py-3.5 text-sm text-blue-800 leading-relaxed">
      日本語対応には<strong>「日本語UI」「日本語プロンプト」「日本語ドキュメント」</strong>の3種類があります。操作画面が日本語でも、プロンプトは英語の方が精度が高い場合があります。また、日本語プロンプトに対応していても、画像内の文字や細かい指示は崩れる可能性があります。ツールごとに対応範囲が異なるため、詳細ページでご確認ください。
    </div>

    <ConditionChips currentPath="/categories/japanese/" />

    <NoticeBox />

    <section class="mt-8 rounded-xl border border-slate-200 bg-white px-6 py-5">
      <h2 class="mb-3 text-base font-bold text-[#002B61]">日本語対応の3つの種類と選ぶポイント</h2>
      <ul class="space-y-3 text-sm text-slate-700">
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>日本語UI：</strong>操作画面・メニュー・設定が日本語で表示されます。英語が苦手な初心者でも操作しやすく、ツール自体の設定や料金プランの確認がスムーズです。UIが日本語化されているだけでも、学習コストが大きく下がります。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>日本語プロンプト：</strong>日本語の指示で画像生成できます。ただし細かいスタイル指定や専門的な表現は、英語プロンプトの方が安定しやすい場合があります。「一部対応（△）」ツールでは英語プロンプトも併用することをおすすめします。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>画像内の日本語文字：</strong>生成した画像の中に日本語テキストを描画する機能は、ほとんどのツールで安定しない場合があります。文字が崩れたり読めなかったりすることがあるため、テキスト入りバナーやサムネイルを作る場合は別途画像編集ツールでの追加を検討してください。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>商用利用・透かし条件：</strong>SNS画像・YouTubeサムネイル・広告バナーで使う場合は、日本語対応とは別に商用利用可否と透かしの有無を確認する必要があります。<a href="/categories/commercial-use/" class="text-blue-600 hover:underline">商用利用条件を確認しやすいツール</a>と<a href="/categories/no-watermark/" class="text-blue-600 hover:underline">透かしなしツール</a>もあわせて参照してください。商用利用を前提にする場合は、最新の公式規約を必ずご確認ください。本記事は法的助言ではありません。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 text-slate-400">▸</span>
          <span><strong>日本語ドキュメント：</strong>ヘルプやFAQが日本語で確認できるかは、トラブル時の対処しやすさに影響します。初めてAI画像生成ツールを使う方は、日本語ドキュメントが整備されているツールを選ぶと安心です。</span>
        </li>
      </ul>
      <p class="mt-4 text-xs text-slate-500">日本語対応状況はアップデートにより変わる場合があります。最新情報は各ツールの公式サイトでご確認ください。</p>
    </section>

    <section class="mt-8">
      <h2 class="mb-1 text-lg font-semibold text-slate-800">対象ツール一覧</h2>
      <p class="mb-2 text-sm text-slate-500">確認時点で {filtered.length} 件。</p>
      <div class="mb-4 flex flex-wrap gap-4 text-sm text-slate-500">
        <span class="flex items-center gap-1"><span class="font-bold text-emerald-600">○</span>対応</span>
        <span class="flex items-center gap-1"><span class="font-bold text-amber-600">△</span>一部対応（設定・一部画面のみ、または英語推奨）</span>
        <span class="flex items-center gap-1"><span class="font-bold text-slate-400">×</span>非対応</span>
      </div>
      <CompareTablePreview tools={filtered} limit={filtered.length} />
    </section>

    <section class="mt-8">
      <h2 class="mb-3 text-sm font-semibold text-slate-700">日本語対応詳細</h2>
      <p class="mb-3 text-xs text-slate-500">確認時点の情報です。詳細は各ツールの詳細ページおよび公式情報でご確認ください。</p>
      <div class="overflow-x-auto rounded-xl border border-slate-100 shadow-sm">
        <table class="w-full min-w-[480px] text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-[11px] font-semibold uppercase tracking-wide text-slate-500">
              <th class="px-4 py-2.5 whitespace-nowrap">ツール名</th>
              <th class="px-4 py-2.5 whitespace-nowrap">日本語UI</th>
              <th class="px-4 py-2.5 whitespace-nowrap">日本語プロンプト</th>
              <th class="px-4 py-2.5 whitespace-nowrap">日本語ドキュメント</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {filtered.map((tool) => {
              const ui = uiText(tool.data.japaneseUi);
              const prompt = uiText(tool.data.japanesePrompt);
              const docs = tool.data.japaneseDocs === true ? { text: '○', cls: 'text-emerald-600 font-bold' }
                         : tool.data.japaneseDocs === false ? { text: '×', cls: 'text-slate-400 font-bold' }
                         : { text: '?', cls: 'text-slate-400' };
              return (
                <tr class="bg-white even:bg-slate-50">
                  <td class="px-4 py-3 font-medium text-slate-900 whitespace-nowrap">
                    <a href={`/tools/${tool.slug}/`} class="hover:text-blue-600 hover:underline">{tool.data.name}</a>
                  </td>
                  <td class={`px-4 py-3 ${ui.cls}`}>{ui.text}</td>
                  <td class={`px-4 py-3 ${prompt.cls}`}>{prompt.text}</td>
                  <td class={`px-4 py-3 ${docs.cls}`}>{docs.text}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <GuideFAQ items={faqs} title="よくある質問" />

    <section class="mt-12">
      <h2 class="mb-4 text-sm font-semibold text-slate-600">関連ページ</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/compare/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">全ツール比較表</a></li>
        <li><a href="/guides/japanese-ai-image-tools/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">日本語対応ツールの選び方</a></li>
        <li><a href="/tools/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">すべてのツールを見る</a></li>
        <li><a href="/categories/free/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">無料で使えるツール</a></li>
        <li><a href="/categories/commercial-use/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">商用利用を確認しやすいツール</a></li>
        <li><a href="/categories/no-watermark/" class="rounded-full border border-slate-200 px-4 py-1.5 hover:bg-slate-100 hover:border-slate-300">透かしなしツール</a></li>
      </ul>
    </section>

    <nav class="mt-8 border-t border-slate-200 pt-6 text-sm">
      <a href="/tools/" class="text-blue-600 hover:underline">← ツール一覧に戻る</a>
    </nav>

  </div>
</BaseLayout>
