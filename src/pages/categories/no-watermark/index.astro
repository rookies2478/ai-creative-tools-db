---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeBox from '../../../components/NoticeBox.astro';
import CompareTablePreview from '../../../components/CompareTablePreview.astro';
import ConditionChips from '../../../components/ConditionChips.astro';

const tools = await getCollection('tools');
const filtered = tools.filter((t) => t.data.watermark === 'no' || t.data.watermark === 'limited');
---

<BaseLayout
  title="透かしなしAI画像生成ツール比較｜無料枠・商用利用条件も確認"
  description="透かしなし、または有料プランで透かしを外せるAI画像生成・AI動画生成ツールを比較。透かし条件と商用利用条件は別問題のため、最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/no-watermark/"
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>透かしなし</span>
    </nav>

    <h1 class="mb-3 text-3xl font-bold text-gray-900">透かしなしAI画像生成ツール比較</h1>
    <p class="mb-4 text-gray-600 leading-relaxed">
      AI生成画像や動画を広告、SNS、LP素材などで使う場合、透かしの有無は重要な確認ポイントです。このページでは、透かしなし、または条件付きで透かしを外せるツールを整理しています。
    </p>

    <div class="mb-6 rounded-lg border border-amber-200 bg-amber-50 px-5 py-3.5 text-sm text-amber-800 leading-relaxed">
      透かしの有無は、<strong>無料プラン・有料プラン・出力形式</strong>によって変わる場合があります。各ツールの透かし条件と公式情報を確認してください。また、透かしを除去できることと商用利用が許可されていることは別の問題です。
      <a href="/guides/commercial-use-copyright/" class="ml-1 text-amber-900 underline hover:text-amber-700">商用利用・著作権ガイド →</a>
    </div>

    <ConditionChips currentPath="/categories/no-watermark/" />

    <NoticeBox />

    <section class="mt-8 rounded-xl border border-slate-200 bg-white px-6 py-5">
      <h2 class="mb-3 text-base font-bold text-[#002B61]">比較時に見るポイント</h2>
      <ul class="space-y-2 text-sm text-slate-700">
        <li class="flex gap-2"><span class="mt-0.5 text-slate-400">▸</span>無料プランでも透かしなしで使えるか</li>
        <li class="flex gap-2"><span class="mt-0.5 text-slate-400">▸</span>透かし除去が有料プラン限定かどうか</li>
        <li class="flex gap-2"><span class="mt-0.5 text-slate-400">▸</span>透かし条件と商用利用条件をあわせて確認できるか</li>
      </ul>
      <p class="mt-4 text-xs text-slate-500">料金・無料枠・商用利用条件は変更される場合があります。最新情報は各公式サイトをご確認ください。</p>
    </section>

    <section class="mt-8">
      <h2 class="mb-1 text-lg font-semibold text-gray-800">対象ツール一覧</h2>
      <p class="mb-4 text-sm text-gray-500">確認時点で {filtered.length} 件。「プランによる」は無料プランで透かしあり、有料プランで除去できる場合があることを示します。</p>
      <CompareTablePreview tools={filtered} limit={filtered.length} />
    </section>

    <section class="mt-8">
      <h2 class="mb-3 text-sm font-semibold text-gray-700">各ツールの透かし・無料枠条件</h2>
      <p class="mb-3 text-xs text-gray-500">確認時点の情報です。詳細は各ツールの詳細ページおよび公式情報でご確認ください。</p>
      <div class="overflow-x-auto rounded-xl border border-slate-100 shadow-sm">
        <table class="w-full min-w-[520px] text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-[11px] font-semibold uppercase tracking-wide text-slate-500">
              <th class="px-4 py-2.5 whitespace-nowrap">ツール名</th>
              <th class="px-4 py-2.5">透かし条件</th>
              <th class="px-4 py-2.5">無料枠の条件</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {filtered.map((tool) => (
              <tr class="bg-white even:bg-slate-50">
                <td class="px-4 py-3 font-medium text-slate-900 whitespace-nowrap">
                  <a href={`/tools/${tool.slug}/`} class="hover:text-blue-600 hover:underline">{tool.data.name}</a>
                </td>
                <td class="px-4 py-3 text-slate-600">{tool.data.watermarkCondition ?? '—'}</td>
                <td class="px-4 py-3 text-slate-600">{tool.data.freePlanNote ?? '有料のみ'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="mb-6 text-xl font-semibold text-gray-800">よくある質問</h2>
      <div class="space-y-6">
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">透かしなしなら商用利用もできますか？</p>
          <p class="mt-2 text-sm text-gray-600">透かしを除去できることと商用利用が認められていることは別の問題です。商用利用条件はツールの公式規約で確認する必要があります。有料プランでは商用利用可能と案内されている場合がありますが、用途によって制限がある可能性があります。</p>
        </div>
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">無料プランで透かしを外せるツールはありますか？</p>
          <p class="mt-2 text-sm text-gray-600">ツールによって条件が異なります。無料プランでも透かしなしで出力できるものもあれば、有料プラン限定のものもあります。各ツールの詳細ページおよび公式情報でご確認ください。</p>
        </div>
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">透かし条件は変わることがありますか？</p>
          <p class="mt-2 text-sm text-gray-600">はい、サービス側の方針変更により透かし条件が変わる場合があります。最新情報は各ツールの公式サイトをご確認ください。本記事は法的助言ではありません。</p>
        </div>
      </div>
    </section>

    <section class="mt-12">
      <h2 class="mb-4 text-sm font-semibold text-gray-600">関連ページ</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/compare/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">全ツール比較表</a></li>
        <li><a href="/guides/watermark-credit-guide/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">透かし・クレジット表記ガイド</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用・著作権ガイド</a></li>
        <li><a href="/tools/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">すべてのツールを見る</a></li>
        <li><a href="/categories/free/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">無料で使えるツール</a></li>
        <li><a href="/categories/commercial-use/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用を確認しやすいツール</a></li>
        <li><a href="/categories/japanese/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">日本語対応ツール</a></li>
      </ul>
    </section>

    <nav class="mt-8 border-t border-gray-200 pt-6 text-sm">
      <a href="/tools/" class="text-blue-600 hover:underline">← ツール一覧に戻る</a>
    </nav>

  </div>
</BaseLayout>
