---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'AI動画編集とAI動画生成はどう違いますか？',
    a: 'AI動画生成はテキストや画像からゼロで動画を作るサービスです。AI動画編集は撮影済みの動画素材やAI生成素材をAIで字幕追加・カット・加工するサービスです。用途によって向いているツールが異なります。<a href="/categories/video-generation/">AI動画生成ツール一覧</a>もご参照ください。',
  },
  {
    q: 'CapCut AIはAI動画編集ツールですか？',
    a: 'CapCut AIはテンプレート編集・字幕自動生成・AIエフェクトなど動画編集補助機能を多数持ちます。一方でAI動画生成機能も搭載されており、両方の性質を持つツールです。SNS・ショート動画向けの動画編集に強みがあります。',
  },
  {
    q: 'AI動画生成で作った動画はそのまま使えますか？',
    a: '生成した動画をそのまま使うことも可能ですが、字幕追加・長さ調整・BGM追加・複数クリップの結合などが必要な場合は動画編集ツールを組み合わせるのが一般的です。CapCut AIやRunwayはAI生成素材の編集にも対応しています。',
  },
  {
    q: '商用利用前に確認すべきことは？',
    a: '収益化コンテンツや広告・クライアント案件への利用を前提にする場合は、各ツールの公式利用規約で商用利用条件をご確認ください。使用する素材・音源・テンプレートごとに利用条件が異なることがあります。本記事は法的助言ではありません。<a href="/guides/commercial-use-copyright/">商用利用・著作権の考え方ガイド</a>もご参照ください。',
  },
  {
    q: 'AI動画編集ツールはスマホでも使えますか？',
    a: 'CapCut AIはスマホアプリが提供されているとされています。InVideo AIはブラウザベースのツールですが、スマホ操作の使い勝手はプランやデバイス環境によって異なる場合があるとされています。スマホで問題なく使えるとは断定できません。用途・操作性は各公式サイトをご確認ください。',
  },
  {
    q: 'AI動画生成ツールで作った動画を編集するにはどうすればよいですか？',
    a: 'RunwayやPika・Kling AIなどのAI動画生成ツールで作ったクリップは、動画ファイルとしてエクスポートし、CapCut AIやInVideo AIなど動画編集ツールに取り込んで字幕追加・カット・BGM調整などの編集が可能とされています。各ツールの対応フォーマット・エクスポート条件は異なる場合があります。また、生成したクリップの利用条件（商用利用・透かし）は元の生成ツールの規約に従いますので、編集ツールへの取り込み前に確認してください。本記事は法的助言ではありません。<a href="/categories/video-generation/">AI動画生成ツール一覧</a>もご参照ください。',
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a.replace(/<[^>]+>/g, '')
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "AIクリエイティブナビ",
          "item": "https://aicreative-db.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "AI動画編集",
          "item": "https://aicreative-db.com/categories/video-editing/"
        }
      ]
    }
  ]
});

const tools = [
  {
    name: 'CapCut AI',
    slug: 'capcut-ai',
    free: 'あり',
    ja: '対応',
    commercial: '要確認',
    wmNote: '公式ヘルプによると、通常の編集機能で作成した動画は多くの場合、無料でも透かしなしで書き出せます。テンプレート利用時はCapCutのブランドクリップが末尾に自動追加される場合がありますが削除可能です。Pro素材等は条件確認が必要です。',
    useNote: 'SNS・ショート動画・縦型動画に特化。自動字幕・AI音声・背景削除など多数のAI機能。スマホアプリおよびPCブラウザで利用できるとされています。操作感はデバイスや環境によって異なる場合があります。',
  },
  {
    name: 'InVideo AI',
    slug: 'invideo-ai',
    free: 'あり',
    ja: '要確認',
    commercial: '要確認',
    wmNote: '無料プランでは透かしあり、有料プランで透かしなし出力ができるとされています。最新の公式情報をご確認ください。',
    useNote: 'テキストから解説動画を自動生成・編集。AIナレーション・字幕生成に対応。YouTube・SNS向けテンプレートが豊富。',
  },
  {
    name: 'Runway',
    slug: 'runway',
    free: '要確認',
    ja: '要確認',
    commercial: '要確認',
    wmNote: '無料プランでは透かしあり、有料プランでは透かしなしとされています。最新の公式情報をご確認ください。',
    useNote: 'AI動画生成に加えてVideo-to-Video編集機能あり。背景削除・フレーム補間など高度な編集。クリエイター・プロ向けのハイエンドAIツール。',
  },
];

function mark(val: string) {
  if (val === 'あり' || val === '対応') return { cls: 'yes', ch: '○' };
  if (val === 'なし' || val === '非対応') return { cls: 'no', ch: '×' };
  return { cls: 'cond', ch: '△' };
}
---

<BaseLayout
  title="AI動画編集ツール比較｜AIを使った動画編集・字幕・カット自動化"
  description="撮影済み動画・AI動画生成素材への字幕自動生成・カット補助・BGM調整など後処理工程向けAI動画編集ツールの比較ページです。ゼロから動画を生成する /categories/video-generation/ とは異なり、素材の編集・仕上げに特化したツールを整理しています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/video-editing/"
  jsonLd={faqJsonLd}
>
  <div class="mx-auto max-w-5xl px-6 py-10">

    <!-- パンくず -->
    <nav class="mb-5 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>AI動画編集</span>
    </nav>

    <!-- カテゴリナビ -->
    <nav class="mb-8">
      <p class="mb-2 text-xs font-semibold text-slate-500 uppercase tracking-widest">カテゴリから探す</p>
      <div class="flex flex-wrap gap-2 text-sm">
        <a href="/categories/video-generation/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI動画生成</a>
        <a href="/categories/image-generation/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI画像生成</a>
        <a href="/categories/avatar-video/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AIアバター動画</a>
        <a href="/categories/video-editing/" class="rounded-full border border-purple-400 bg-purple-50 px-3 py-1.5 font-semibold text-purple-700" aria-current="page">AI動画編集</a>
        <a href="/categories/design/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AIデザイン</a>
        <a href="/categories/voice-narration/" class="rounded-full border border-slate-300 px-3 py-1.5 text-slate-600 hover:bg-slate-50">AI音声・ナレーション</a>
      </div>
    </nav>

  </div>

  <div class="cp-x" data-cp>
    <div class="mx-auto max-w-5xl px-6">

      <!-- Hero -->
      <header class="cp-head">
        <span class="eyebrow">Video editing</span>
        <h1>AI動画編集<span class="hl">ツール比較</span></h1>
        <p class="lead">
          AIを活用した動画編集ツールの比較・選び方を整理するページです。
          <a href="/categories/video-generation/">AI動画生成</a>で作った素材の編集、撮影済み動画への字幕追加・カット補助・BGM調整など、編集工程でAIを活用したいときの参考にしてください。
        </p>
        <div class="stats">
          <div class="stat"><span class="n">3</span><span class="t">掲載ツール</span></div>
          <div class="stat"><span class="n">7</span><span class="t">比較ポイント</span></div>
          <div class="stat"><span class="n">6</span><span class="t">よくある質問</span></div>
        </div>
      </header>

      <!-- Notice -->
      <div class="notice">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>
        <p><b>ご利用前の注意：</b>掲載情報は調査時点の内容です。料金・商用利用条件・透かし条件は変更される場合があります。実務利用前には必ず各ツールの公式サイト・利用規約をご確認ください。本サイトの内容は法的助言ではありません。</p>
      </div>

      <!-- AI動画生成との違い -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">Category difference</span>
          <h2>AI動画生成との違い</h2>
          <p>「AI動画生成」と「AI動画編集」は入力・用途が異なります。どちらが自分の目的に合うかを確認してください。</p>
        </div>
        <div class="comp-grid">
          <div class="comp-card blue">
            <p class="comp-label">AI動画生成</p>
            <ul>
              <li>テキストや画像からゼロで動画を生成する</li>
              <li>Runway・Pika・Kling AIなどが代表例</li>
              <li>撮影素材がなくても動画を作れる</li>
              <li>SNS・広告・試作向けの短尺動画が中心</li>
            </ul>
          </div>
          <div class="comp-card violet">
            <p class="comp-label">AI動画編集</p>
            <ul>
              <li>既存の動画素材をAIで編集・加工する</li>
              <li>字幕自動生成・カット補助・BGM提案など</li>
              <li>撮影した動画やAI生成素材を入力として使う</li>
              <li>YouTube・解説動画・Vlog・SNS広告向けが中心</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- 比較ポイント (band) -->
      <section class="cp-sec band">
        <div class="sec-head">
          <span class="eyebrow">Checkpoints</span>
          <h2>AI動画編集ツールを選ぶ比較ポイント</h2>
          <p>用途に合ったツールを選ぶために、事前に確認しておきたい観点を整理しました。</p>
        </div>
        <ol class="points">
          <li>
            <span class="pn">01</span>
            <span class="pt"><b>字幕・テロップの自動生成：</b>音声から自動で字幕を生成できるか、日本語対応の精度はどうか。SNS動画・YouTube向けに字幕は重要な要素です。</span>
          </li>
          <li>
            <span class="pn">02</span>
            <span class="pt"><b>カット・トリミングの補助：</b>AIが動画の中から必要なシーンを自動選別・カットできるか。長尺素材の編集効率に影響します。</span>
          </li>
          <li>
            <span class="pn">03</span>
            <span class="pt"><b>BGM・音声の自動調整：</b>BGM生成・音量調整・ノイズ除去などの音声編集機能。品質に直結する確認ポイントです。</span>
          </li>
          <li>
            <span class="pn">04</span>
            <span class="pt"><b>書き出し形式・解像度：</b>SNS・YouTube向けの形式（縦型・横型・アスペクト比）に対応しているか。プラットフォームごとの要件を確認してください。</span>
          </li>
          <li>
            <span class="pn">05</span>
            <span class="pt"><b>透かし（ウォーターマーク）：</b>無料プランでは透かしが入るツールが多く、公開用コンテンツには有料プランが必要な場合があります。<a href="/conditions/no-watermark/">透かし条件を確認しやすいAIツール</a>もご参照ください。</span>
          </li>
          <li>
            <span class="pn">06</span>
            <span class="pt"><b>商用利用・素材利用の確認：</b>編集した動画を収益化コンテンツや広告・クライアント案件に使う場合は、各ツールの公式利用規約を必ずご確認ください。使用する素材・音源・テンプレートごとに条件が異なる場合があります。本記事は法的助言ではありません。</span>
          </li>
          <li>
            <span class="pn">07</span>
            <span class="pt"><b>第三者素材の利用：</b>他者が撮影した映像・写真・音源を編集素材として使う場合は、それぞれの権利者から許諾を得てください。ツール側が許可しても素材の権利はツールが保証するものではありません。</span>
          </li>
        </ol>
      </section>

      <!-- 対象ツール一覧 -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">Tool index</span>
          <h2>対象ツール一覧</h2>
          <p>確認時点で{tools.length}件。各ツールの詳細ページから公式情報へのリンクをご確認いただけます。最新の機能・料金は各公式サイトをご確認ください。</p>
        </div>
        <div class="cp-table-wrap">
          <table class="cp-tbl">
            <thead>
              <tr>
                <th class="col-tool">ツール</th>
                <th>無料枠</th>
                <th>日本語</th>
                <th>商用利用</th>
                <th>詳細</th>
              </tr>
            </thead>
            <tbody>
              {tools.map((t) => {
                const f = mark(t.free), j = mark(t.ja), c = mark(t.commercial);
                return (
                  <tr>
                    <td><div class="cp-tool"><span class="b">{t.name.charAt(0)}</span><span class="nm">{t.name}</span></div></td>
                    <td><span class={`mk ${f.cls}`} title={t.free}>{f.ch}</span></td>
                    <td><span class={`mk ${j.cls}`} title={t.ja}>{j.ch}</span></td>
                    <td><span class={`mk ${c.cls}`} title={t.commercial}>{c.ch}</span></td>
                    <td><a class="cp-detail" href={`/tools/${t.slug}/`}>詳細 →</a></td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p class="note">※ ○=あり・対応　△=要確認　×=なし・非対応。値は確認時点の参考情報です。最新情報は必ず公式サイトでご確認ください。</p>
      </section>

      <!-- 各ツールの特徴 (band) -->
      <section class="cp-sec band">
        <div class="sec-head">
          <span class="eyebrow">Per-tool notes</span>
          <h2>各ツールの特徴・向いている用途</h2>
          <p>確認時点の公式情報をもとにした整理です。条件・仕様は変更される可能性があります。実務利用前に必ず公式情報をご確認ください。</p>
        </div>
        <div class="note-grid">
          {tools.map((t) => (
            <article class="note-card">
              <div class="nc-head">
                <span class="nc-b">{t.name.charAt(0)}</span>
                <a class="nc-name" href={`/tools/${t.slug}/`}>{t.name}</a>
              </div>
              <div class="nc-fields">
                <div class="nc-f">
                  <span class="nc-lbl">特徴・向いている用途</span>
                  <p>{t.useNote}</p>
                </div>
                <div class="nc-f">
                  <span class="nc-lbl">透かし条件</span>
                  <p>{t.wmNote}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="cp-sec">
        <div class="sec-head">
          <span class="eyebrow">FAQ</span>
          <h2>よくある質問</h2>
          <p>AI動画編集ツールの選び方・注意点についてお答えします。</p>
        </div>
        <div class="faq-list">
          {faqs.map((f) => (
            <div class="faq-item" aria-expanded="false">
              <button class="faq-q"><span class="qm">Q</span>{f.q}<span class="ind"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M5 12h14"/></svg></span></button>
              <div class="faq-a"><div class="faq-a-inner" set:html={f.a}></div></div>
            </div>
          ))}
        </div>
      </section>

      <!-- 関連ページ -->
      <section class="cp-sec band">
        <div class="finder">
          <h2>関連ページ</h2>
          <p class="finder-lead">他のカテゴリ・条件・ガイドからも、用途に合ったAIツールを探せます。</p>
          <div class="taglinks">
            <a class="taglink" href="/categories/video-generation/"><span class="ld"></span>AI動画生成ツール一覧</a>
            <a class="taglink" href="/categories/avatar-video/"><span class="ld"></span>AIアバター動画ツール</a>
            <a class="taglink" href="/categories/voice-narration/"><span class="ld"></span>AI音声・ナレーションツール</a>
            <a class="taglink" href="/comparisons/invideo-ai-vs-capcut-ai/"><span class="ld"></span>InVideo AI vs CapCut AI 比較</a>
            <a class="taglink" href="/comparisons/runway-vs-pika/"><span class="ld"></span>Runway vs Pika 比較</a>
            <a class="taglink" href="/use-cases/shorts/"><span class="ld"></span>縦型・Shorts向けAIツール</a>
            <a class="taglink" href="/conditions/free/"><span class="ld"></span>無料で試せるAIツール</a>
            <a class="taglink" href="/conditions/no-watermark/"><span class="ld"></span>透かし条件で選ぶ</a>
            <a class="taglink" href="/conditions/commercial-use/"><span class="ld"></span>商用利用を確認しやすいAIツール</a>
            <a class="taglink" href="/guides/commercial-use-copyright/"><span class="ld"></span>商用利用・著作権の考え方ガイド</a>
          </div>
          <div class="taglinks row">
            <a class="taglink solid" href="/tools/">すべてのツールを見る</a>
            <a class="taglink solid" href="/comparisons/">比較記事一覧</a>
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .cp-x {
    --paper: #F4F4EE; --surface: #FFFFFF; --surface-2: #FAFAF6;
    --ink: #16181D; --ink-soft: #3A3E47; --muted: #6A7180; --faint: #98A0AD;
    --line: #E3E2D9; --line-strong: #D2D1C6;
    --brand: #4B3FE4; --on-brand: #FFFFFF; --brand-tint: #ECEBFB; --brand-ink: #2E25A6;
    --ok: #1E8A4C; --ok-tint: #E6F3EC; --warn: #A06A09; --warn-tint: #F8EFD9; --na: #6A7180; --na-tint: #EFEFEA;
    --radius: 14px; --radius-lg: 22px;
    --ease: cubic-bezier(.22,.61,.36,1);
    display: block; color: var(--ink); font-family: "Noto Sans JP", system-ui, sans-serif; line-height: 1.7;
  }

  .cp-x .eyebrow { font-size: 12px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: var(--muted); display: inline-flex; align-items: center; gap: 10px; }
  .cp-x .eyebrow::before { content: ""; width: 22px; height: 2px; border-radius: 2px; background: var(--brand); }
  .cp-x h1, .cp-x h2, .cp-x h3 { font-weight: 700; line-height: 1.32; color: var(--ink); }
  .cp-x a { text-decoration: none; }

  .cp-x .cp-head { padding: 8px 0 48px; }
  .cp-x .cp-head h1 { font-size: clamp(27px, 3.6vw, 42px); font-weight: 900; letter-spacing: -.01em; line-height: 1.24; margin: 16px 0; text-wrap: balance; }
  .cp-x .cp-head h1 .hl { color: var(--brand-ink); position: relative; }
  .cp-x .cp-head h1 .hl::after { content: ""; position: absolute; left: 0; right: 0; bottom: .08em; height: .26em; background: color-mix(in srgb, var(--brand) 18%, transparent); z-index: -1; border-radius: 2px; }
  .cp-x .lead { font-size: 15.5px; color: var(--ink-soft); max-width: 700px; }
  .cp-x .lead a { color: var(--brand-ink); font-weight: 600; }
  .cp-x .lead a:hover { text-decoration: underline; }
  .cp-x .stats { display: flex; flex-wrap: wrap; gap: 10px 26px; margin-top: 24px; }
  .cp-x .stat { display: flex; align-items: baseline; gap: 8px; }
  .cp-x .stat + .stat { padding-left: 26px; border-left: 1px solid var(--line); }
  .cp-x .stat .n { font-weight: 700; font-size: 24px; color: var(--ink); line-height: 1; }
  .cp-x .stat .t { font-size: 12.5px; color: var(--muted); white-space: nowrap; }

