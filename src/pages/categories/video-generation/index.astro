---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';
import NoticeBox from '../../../components/NoticeBox.astro';

const allTools = await getCollection('tools');
const videoTools = allTools.filter(
  (t) => t.data.category === 'video' || t.data.category === 'both'
);

const faqs = [
  {
    q: '無料で使えるAI動画生成ツールはありますか？',
    a: 'Runway・Pika・Kling AI・Luma AI・Haiper・CapCut AIはいずれも無料枠が用意されています。ただし無料プランの生成回数・クレジット上限・透かし条件はツールごとに大きく異なります。無料枠・透かし・商用利用条件の詳細な比較は<a href="/conditions/free/" class="text-blue-600 hover:underline">無料で使えるAI動画生成ツール比較ページ</a>をご参照ください。最新情報は各ツールの公式サイトをご確認ください。',
  },
  {
    q: 'AI動画生成ツールは商用利用できますか？',
    a: 'ツールやプランによって条件が異なります。無料プランでの商用利用が不可とされているものや、有料プラン限定のもの、条件付きで可能とされるものがあります。商用利用を前提にする場合は、各ツールの最新の公式利用規約を必ずご確認ください。本ページは法的助言ではありません。',
  },
  {
    q: '透かしなしで使えるAI動画生成ツールはありますか？',
    a: '多くのツールでは無料プランで透かしが付与される場合があります。有料プランでは透かしが入らない場合があるとされているツールもありますが、条件はプランや利用状況によって異なります。最新の条件は各ツールの公式サイトでご確認ください。',
  },
  {
    q: 'テキストから動画生成と画像から動画生成は何が違いますか？',
    a: 'テキストから動画生成（text-to-video）は文章による指示から動画を生成する方式です。画像から動画生成（image-to-video）は既存の静止画をもとに動きを付ける方式で、手持ちの写真やイラストを素材として活用できます。目的や持っている素材によって向き不向きがあるため、両方を試してみることをおすすめします。',
  },
  {
    q: 'AI動画生成ツールを使う前に確認すべきことはありますか？',
    a: '料金プランと無料枠の範囲（クレジット数・更新頻度）、生成物の利用条件（商用利用の可否）、透かしの有無、人物・ブランド・第三者素材を使う場合の制約などを事前に確認することをおすすめします。また、クレジット制のツールでは生成に失敗した場合でもクレジットが消費される可能性があります。最新情報は公式サイト・公式規約をご確認ください。本記事は法的助言ではありません。',
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a.replace(/<[^>]+>/g, '')
    }
  }))
});
---

<BaseLayout
  title="AI動画生成ツール一覧｜無料・商用利用・日本語対応で比較"
  description="AI動画生成ツールを無料プラン、商用利用条件、日本語対応、透かしの有無などで比較できる一覧ページです。Runway、Pika、Kling AIなどの特徴を整理しています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/video-generation/"
  jsonLd={faqJsonLd}
>
  <div class="mx-auto max-w-5xl px-6 py-12">

    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>AI動画生成ツール一覧</span>
    </nav>

    <h1 class="mb-3 text-3xl font-bold text-slate-900">AI動画生成ツール一覧</h1>

    <p class="mb-4 leading-relaxed text-slate-600">
      AI動画生成ツールを、無料プランの有無、商用利用条件、日本語対応、透かしの有無、用途別の特徴で比較できる一覧ページです。
      Runway・Pika・Kling AIなど主要ツールの情報を整理しています。
    </p>
    <div class="mb-6 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700 leading-relaxed">
      <p class="mb-1.5">掲載情報は公式サイト・利用規約をもとに整理していますが、内容は変更される可能性があります。<strong>最新情報は必ず公式サイトをご確認ください。</strong>商用利用・著作権に関しては断定的な記載を避けており、法的助言ではありません。</p>
      <ul class="mt-2 space-y-1 text-xs text-amber-700 list-disc list-inside">
        <li>生成時間はツールやサーバー混雑状況によって変わる場合があります</li>
        <li>クレジット制のツールでは、生成に失敗した場合でもクレジットが消費される可能性があります</li>
        <li>人物・著名人・ブランドロゴ・第三者素材を使用する場合は、別途利用条件の確認が必要です</li>
      </ul>
    </div>

    <!-- NoticeBox -->
    <div class="mb-8">
      <NoticeBox />
    </div>

    <!-- ツール一覧 -->
    <section class="mb-12">
      <h2 class="mb-4 border-b border-slate-200 pb-2 text-xl font-semibold text-slate-800">
        AI動画生成ツール（{videoTools.length}件）
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {videoTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>

    <!-- 選び方セクション -->
    <section class="mb-12 rounded-xl border border-slate-200 bg-white px-6 py-6">
      <h2 class="mb-4 text-lg font-semibold text-slate-900">AI動画生成ツールの選び方</h2>
      <ul class="space-y-3 text-sm text-slate-700">
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span>
            <strong>無料で試せるか：</strong>クレジット制・月更新・初回限り など、無料枠の形態はツールによって異なります。長期利用や本格利用には有料プランへの移行が必要になる場合があります。
          </span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span>
            <strong>商用利用条件を確認できるか：</strong>広告・クライアントワーク・収益化コンテンツへの利用を前提にする場合、各ツールの公式利用規約で商用利用の条件を事前に確認することを推奨します。無料プランでは商用利用が不可とされているツールも多くあります。
          </span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span>
            <strong>透かしの有無：</strong>多くのツールで無料プランでは透かしが付与される場合があります。透かしの条件はプランや利用状況によって変わるため、公式情報をご確認ください。
          </span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span>
            <strong>日本語で使いやすいか：</strong>日本語UIに対応しているツールは限られています（確認時点ではCapCut AIが対応）。日本語プロンプトについてはKling AI・Haiper・CapCut AIが対応しているとされています。英語UIのツールでも日本語プロンプトを試せる場合があります。
          </span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span>
            <strong>画像から動画を作れるか：</strong>Runway・Pika・Kling AI・Luma AI・Haiperはimage-to-video（画像→動画）に対応しているとされています。静止画にモーションを加えたい場合に活用できます。
          </span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span>
            <strong>テキスト→動画・画像→動画・動画編集補助の違い：</strong>テキストから動画を生成するtext-to-video、静止画を動かすimage-to-video、既存動画を編集・加工するassistの3用途は異なります。Runway・Pika・Kling AI・Luma AI・Haiperは生成系、CapCut AIはテンプレート編集・自動字幕などの編集補助系として特化しています。
          </span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span>
            <strong>解像度・生成時間・クレジット消費：</strong>生成動画の解像度（HD・4K等）や生成にかかる時間はプランとツールによって異なります。動画生成は画像生成よりもクレジット消費が大きい傾向があります。無料プランの解像度制限や生成時間の制限も確認することを推奨します。
          </span>
        </li>
      </ul>
      <p class="mt-4 text-xs text-slate-500">各条件の詳細は各ツールの詳細ページおよび公式サイトでご確認ください。</p>
    </section>

    <!-- 向いている人 / 向いていない人 -->
    <section class="mb-12 rounded-xl border border-slate-200 bg-white px-6 py-6">
      <h2 class="mb-5 text-lg font-semibold text-slate-900">AI動画生成ツールが向いている人・向いていない人</h2>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <h3 class="mb-3 text-sm font-bold text-emerald-700">向いている人</h3>
          <ul class="space-y-2 text-sm text-slate-700">
            <li class="flex gap-2"><span class="mt-0.5 shrink-0 text-emerald-500">✓</span><span>SNS動画やショート動画を短時間で作りたい人</span></li>
            <li class="flex gap-2"><span class="mt-0.5 shrink-0 text-emerald-500">✓</span><span>手持ちの画像素材から簡単な動画を作りたい人</span></li>
            <li class="flex gap-2"><span class="mt-0.5 shrink-0 text-emerald-500">✓</span><span>広告・LP・YouTube用の動画案をまず試作したい人</span></li>
            <li class="flex gap-2"><span class="mt-0.5 shrink-0 text-emerald-500">✓</span><span>実写撮影前に構図や雰囲気をAIで検討したい人</span></li>
          </ul>
        </div>
        <div>
          <h3 class="mb-3 text-sm font-bold text-rose-700">向いていない人</h3>
          <ul class="space-y-2 text-sm text-slate-700">
            <li class="flex gap-2"><span class="mt-0.5 shrink-0 text-rose-400">✗</span><span>長尺動画を細かく編集したい人（AI生成は短尺・短時間が中心）</span></li>
            <li class="flex gap-2"><span class="mt-0.5 shrink-0 text-rose-400">✗</span><span>厳密な人物表現やブランド表現が必要な人（生成品質の制御に限界がある場合があります）</span></li>
            <li class="flex gap-2"><span class="mt-0.5 shrink-0 text-rose-400">✗</span><span>利用条件を確認せずに商用案件へ使いたい人（プランや用途によって条件が異なります）</span></li>
            <li class="flex gap-2"><span class="mt-0.5 shrink-0 text-rose-400">✗</span><span>毎回まったく同じ構図・品質を完全に再現したい人（生成結果に揺れが生じる場合があります）</span></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 関連ページリンク -->
    <section class="mb-12">
      <h2 class="mb-4 text-lg font-semibold text-slate-800">関連ページ</h2>

      <div class="mb-4">
        <p class="mb-2 text-sm font-semibold text-slate-700">ツール別詳細ページ</p>
        <ul class="flex flex-wrap gap-3">
          {['runway', 'pika', 'kling-ai', 'luma-ai', 'haiper', 'capcut-ai'].map((slug) => {
            const tool = videoTools.find((t) => t.slug === slug);
            return tool ? (
              <li>
                <a
                  href={`/tools/${slug}/`}
                  class="rounded-full border border-slate-200 px-4 py-2 text-sm hover:bg-slate-100 hover:border-slate-300"
                >
                  {tool.data.name}
                </a>
              </li>
            ) : null;
          })}
        </ul>
      </div>

      <div>
        <p class="mb-2 text-sm font-semibold text-slate-700">まとめページ</p>
        <ul class="flex flex-wrap gap-3">
          <li>
            <a href="/conditions/free/" class="rounded-full border border-slate-200 px-4 py-2 text-sm hover:bg-slate-100 hover:border-slate-300">
              無料で使えるAI動画生成ツール比較
            </a>
          </li>
          <li>
            <a href="/tools/" class="rounded-full border border-slate-200 px-4 py-2 text-sm hover:bg-slate-100 hover:border-slate-300">
              AI画像生成・動画生成ツール一覧
            </a>
          </li>
          <li>
            <a href="/conditions/commercial-use/" class="rounded-full border border-slate-200 px-4 py-2 text-sm hover:bg-slate-100 hover:border-slate-300">
              商用利用を確認しやすいAIツール
            </a>
          </li>
          <li>
            <a href="/conditions/no-watermark/" class="rounded-full border border-slate-200 px-4 py-2 text-sm hover:bg-slate-100 hover:border-slate-300">
              透かしなしで使いやすいAIツール
            </a>
          </li>
          <li>
            <a href="/comparisons/runway-vs-pika/" class="rounded-full border border-blue-300 bg-blue-50 px-4 py-2 text-sm text-blue-700 hover:bg-blue-100">
              Runway vs Pika 比較
            </a>
          </li>
          <li>
            <a href="/comparisons/" class="rounded-full border border-slate-200 px-4 py-2 text-sm hover:bg-slate-100 hover:border-slate-300">
              全ツール比較表
            </a>
          </li>
          <li>
            <a href="/conditions/japanese/" class="rounded-full border border-slate-200 px-4 py-2 text-sm hover:bg-slate-100 hover:border-slate-300">
              日本語対応ツール
            </a>
          </li>
        </ul>
      </div>
    </section>

    <!-- FAQ -->
    <GuideFAQ items={faqs} title="よくある質問" />

    <nav class="mt-8 border-t border-slate-200 pt-6 text-sm">
      <a href="/tools/" class="text-blue-600 hover:underline">← ツール一覧に戻る</a>
    </nav>

  </div>
</BaseLayout>
