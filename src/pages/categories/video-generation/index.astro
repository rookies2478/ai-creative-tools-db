  .cvg-panel li { font-size: 13.5px; color: var(--ink-soft); line-height: 1.7; padding-left: 16px; position: relative; }
  .cvg-panel li::before { content: ""; position: absolute; left: 0; top: 9px; width: 6px; height: 6px; border-radius: 50%; }
  .cvg-panel.pos li::before { background: var(--ok); }
  .cvg-panel.neg li::before { background: var(--no); }

  /* FAQ */
  .cvg-faq { max-width: 880px; }
  .cvg-faqitem { border-bottom: 1px solid var(--line); }
  .cvg-faqitem:first-child { border-top: 1px solid var(--line); }
  .cvg-faqq { width: 100%; text-align: left; background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 16px; padding: 24px 6px; font-family: var(--f-jp); font-weight: 700; font-size: 16px; color: var(--ink); }
  .cvg-faqq .qm { font-family: var(--f-latin); color: var(--brand); font-size: 16px; flex: none; font-weight: 700; }
  .cvg-faqq .ind { margin-left: auto; flex: none; width: 24px; height: 24px; display: grid; place-items: center; transition: transform .3s var(--ease); color: var(--muted); }
  .cvg-faqq .ind svg { width: 18px; height: 18px; }
  .cvg-faqitem[aria-expanded="true"] .cvg-faqq .ind { transform: rotate(45deg); color: var(--brand); }
  .cvg-faqa { max-height: 0; overflow: hidden; transition: max-height .35s var(--ease); }
  .cvg-faqa-in { padding: 0 6px 26px 46px; color: var(--ink-soft); font-size: 14.5px; line-height: 1.8; }
  .cvg-faqa-in a { color: var(--brand-ink); font-weight: 600; }
  .cvg-faqa-in a:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* 注意事項 + 鮮度 */
  .cvg-notes { list-style: none; display: flex; flex-direction: column; gap: 12px; max-width: 880px; margin: 0; padding: 0; }
  .cvg-notes li { display: grid; grid-template-columns: auto 1fr; gap: 12px; align-items: start; font-size: 13.5px; color: var(--ink-soft); line-height: 1.75; }
  .cvg-notes li .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--brand); flex: none; margin-top: 9px; }
  .cvg-freshness { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-top: 24px; background: var(--surface); border: 1px solid var(--line); border-radius: 999px; padding: 11px 20px; font-size: 13px; color: var(--ink-soft); max-width: max-content; }
  .cvg-freshness svg { width: 16px; height: 16px; color: var(--brand); flex: none; }
  .cvg-freshness b { font-weight: 700; color: var(--ink); }
  .cvg-freshness .mono { font-family: var(--f-mono); font-size: 12.5px; }
  .cvg-disclaimer { display: flex; align-items: flex-start; gap: 12px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 20px; }
  .cvg-disclaimer svg { width: 18px; height: 18px; color: var(--muted); flex: none; margin-top: 2px; }
  .cvg-disclaimer p { font-size: 12.5px; color: var(--muted); line-height: 1.75; }

  /* 関連ページ */
  .cvg-finder { background: var(--surface-2); border: 1px solid var(--line); border-radius: var(--radius-lg); padding: 34px 34px 30px; }
  .cvg-finder h2 { font-size: clamp(20px, 2.4vw, 26px); margin-bottom: 6px; }
  .cvg-finder .lead { color: var(--muted); font-size: 14px; margin-bottom: 24px; }
  .cvg-relgrid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 28px 40px; }
  .cvg-relcol h4 { font-family: var(--f-latin); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; font-weight: 600; }
  .cvg-relcol ul { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 9px 18px; }
  .cvg-relcol a { display: inline-flex; align-items: center; gap: 8px; font-family: var(--f-jp); font-weight: 600; font-size: 13.5px; color: var(--ink-soft); transition: color .15s; }
  .cvg-relcol a:hover { color: var(--brand-ink); }
  .cvg-relcol a .ld { width: 6px; height: 6px; border-radius: 50%; background: var(--brand); flex: none; }

  /* スクロール表示アニメ */
  @media (prefers-reduced-motion: no-preference) {
    .cvg-x .reveal { opacity: 0; transform: translateY(18px); transition: opacity .6s var(--ease), transform .6s var(--ease); }
    .cvg-x .reveal.in { opacity: 1; transform: none; }
    .cvg-x .reveal[data-stagger] > * { opacity: 0; transform: translateY(16px); transition: opacity .5s var(--ease), transform .5s var(--ease); }
    .cvg-x .reveal[data-stagger].in > * { opacity: 1; transform: none; }
    .cvg-x .reveal[data-stagger].in > *:nth-child(1) { transition-delay: .04s; }
    .cvg-x .reveal[data-stagger].in > *:nth-child(2) { transition-delay: .09s; }
    .cvg-x .reveal[data-stagger].in > *:nth-child(3) { transition-delay: .14s; }
    .cvg-x .reveal[data-stagger].in > *:nth-child(4) { transition-delay: .19s; }
    .cvg-x .reveal[data-stagger].in > *:nth-child(5) { transition-delay: .24s; }
    .cvg-x .reveal[data-stagger].in > *:nth-child(6) { transition-delay: .29s; }
    .cvg-x .reveal[data-stagger].in > *:nth-child(7) { transition-delay: .34s; }
    .cvg-x .reveal[data-stagger].in > *:nth-child(8) { transition-delay: .39s; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cvg-x .reveal, .cvg-x .reveal[data-stagger] > * { opacity: 1 !important; transform: none !important; }
  }

  /* レスポンシブ */
  @media (max-width: 980px) {
    .cvg-pickgrid { grid-template-columns: 1fr; }
    .cvg-splitgrid { grid-template-columns: 1fr 1fr; }
    .cvg-relgrid { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .cvg-sec { padding: 48px 0; }
    .cvg-points { grid-template-columns: 1fr; }
    .cvg-cardgrid, .cvg-cardgrid.two, .cvg-artgrid, .cvg-twocol, .cvg-splitgrid { grid-template-columns: 1fr; }
    .cvg-tcard .tmeta { grid-template-columns: 1fr; }
    .cvg-relcol ul, .cvg-relcol:first-child ul { grid-template-columns: 1fr; }
    .cvg-stat + .cvg-stat { padding-left: 0; border-left: none; }
    .cvg-finder { padding: 26px 22px; }
  }
</style>

<script>
  (function () {
    document.querySelectorAll('[data-cvg]').forEach(function (root) {
      var faq = root.querySelector('.cvg-faq');
      if (faq) {
        faq.addEventListener('click', function (e) {
          var btn = (e.target as HTMLElement).closest('.cvg-faqq');
          if (!btn) return;
          var item = btn.closest('.cvg-faqitem') as HTMLElement;
          var open = item.getAttribute('aria-expanded') === 'true';
          faq.querySelectorAll('.cvg-faqitem').forEach(function (it) {
            it.setAttribute('aria-expanded', 'false');
            var a = it.querySelector('.cvg-faqa') as HTMLElement | null;
            if (a) a.style.maxHeight = '';
          });
          if (!open) {
            item.setAttribute('aria-expanded', 'true');
            var a = item.querySelector('.cvg-faqa') as HTMLElement | null;
            if (a) a.style.maxHeight = a.scrollHeight + 'px';
          }
        });
      }

      var reveals = Array.prototype.slice.call(root.querySelectorAll('.reveal'));
      if (!reveals.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        reveals.forEach(function (el) { el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach(function (el) { io.observe(el); });
      setTimeout(function () { reveals.forEach(function (el) { el.classList.add('in'); }); }, 8000);
    });
  })();
</script>
