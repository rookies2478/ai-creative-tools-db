---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';
import NoticeBox from '../../../components/NoticeBox.astro';

const allTools = await getCollection('tools');
const videoTools = allTools.filter(
  (t) => t.data.category === 'video' || t.data.category === 'both'
);

const primarySlugs = ['runway', 'pika', 'kling-ai', 'luma-ai', 'hailuo-ai', 'haiper', 'vidu-ai', 'pixverse'];
const editingSlugs = ['capcut-ai', 'invideo-ai'];
const avatarSlugs = ['heygen', 'synthesia', 'd-id'];

const primaryTools = primarySlugs
  .map((s) => videoTools.find((t) => t.slug === s))
  .filter(Boolean);
const editingTools = editingSlugs
  .map((s) => allTools.find((t) => t.slug === s))
  .filter(Boolean);
const avatarTools = avatarSlugs
  .map((s) => allTools.find((t) => t.slug === s))
  .filter(Boolean);

const faqs = [
  {
    q: 'AI動画生成ツールと動画編集ツールの違いは？',
    a: 'AI動画生成ツール（Runway・Pika・Kling AIなど）はテキストや画像を入力として動画を新規に生成します。動画編集ツール（CapCut AIなど）は既存の素材にテンプレート適用・自動字幕・エフェクト付与などの編集処理を加えるものです。目的に応じて使い分けてください。',
  },
  {
    q: 'AI動画生成ツールとAIアバター動画ツールの違いは？',
    a: 'AI動画生成ツールはテキストや画像からシーン・映像を生成します。AIアバター動画ツール（HeyGen・Synthesia・D-IDなど）はAIが生成した人物アバターが話すスタイルの動画を作成するものです。スライド説明・製品解説・研修動画など、話者映像が必要な用途ではアバター動画ツールが向いている場合があります。詳しくは<a href="/categories/avatar-video/" class="text-blue-600 hover:underline">AIアバター動画カテゴリ</a>をご参照ください。',
  },
  {
    q: '無料で使えるAI動画生成ツールはありますか？',
    a: 'Runway・Pika・Kling AI・Luma AI・Haiper・Hailuo AI・Vidu AIはいずれも無料枠が用意されています。ただし無料プランの生成回数・クレジット上限・透かし条件・商用利用条件はツールごとに大きく異なります。最新情報は各ツールの公式サイトをご確認ください。<a href="/conditions/free/" class="text-blue-600 hover:underline">無料枠のあるAIツール比較ページ</a>もご参照ください。',
  },
  {
    q: '商用利用やYouTube利用時に確認すべき点は？',
    a: '商用利用・YouTube投稿を前提にする場合、①プランごとの商用利用条件、②透かしの有無、③生成物の著作権・所有権に関する規定、④人物・ブランドロゴ・第三者素材を含む場合の制約、を各ツールの公式利用規約で事前に確認することを推奨します。無料プランでは商用利用が制限されているツールも多くあります。本ページは法的助言ではありません。確認の手順は<a href="/guides/ai-commercial-use-checklist/" class="text-blue-600 hover:underline">商用利用前に確認したいチェックリスト</a>、よくあるトラブル事例は<a href="/guides/ai-commercial-use-trouble-cases/" class="text-blue-600 hover:underline">商用利用で起こりやすいトラブル例と確認ポイント</a>もご参照ください。',
  },
  {
    q: '日本語プロンプトでも使えますか？',
    a: '日本語プロンプトに対応しているとされるツールとしてKling AI・Haiper・CapCut AIなどが挙げられます。英語UIのツールでも日本語プロンプトを入力できる場合がありますが、細かい表現や映像スタイルの指定では英語プロンプトの方が意図を伝えやすいケースがあります。日本語UIに対応しているのは確認時点ではCapCut AIのみです。最新の対応状況は各公式サイトをご確認ください。',
  },
];

---

<BaseLayout
  title="AI動画生成ツール一覧｜横断比較・用途別・商用利用・日本語対応"
  description="AI動画生成ツール（Runway・Pika・Kling AI・Luma AIなど）を横断比較表・用途別導線・商用利用条件・日本語対応で整理した一覧ページです。動画編集・アバター動画との違いも解説。最新情報は公式サイトをご確認ください。"
  canonicalPath="/categories/video-generation/"
>
  <div class="mx-auto max-w-5xl px-6 py-12">

    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>AI動画生成ツール一覧</span>
    </nav>

    <h1 class="mb-3 text-3xl font-bold text-slate-900">AI動画生成ツール一覧</h1>

    <p class="mb-4 leading-relaxed text-slate-600">
      AI動画生成ツールは、テキストや画像から動画を作成したり、短尺動画・広告動画・SNS向け動画などの制作を支援するAIツールです。このページでは、無料枠、日本語対応、出力形式、透かし条件、商用利用条件の確認ポイントなどをもとに、AI動画生成ツールを比較できるよう整理しています。商用利用や権利関係の条件はプランや用途によって異なる場合があるため、利用前に公式情報をご確認ください。
    </p>

    <div class="mb-6 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700 leading-relaxed">
      <p class="mb-1.5">掲載情報は公式サイト・利用規約をもとに整理していますが、内容は変更される可能性があります。<strong>最新情報は必ず公式サイトをご確認ください。</strong>商用利用・著作権に関しては断定的な記載を避けており、法的助言ではありません。</p>
      <ul class="mt-2 space-y-1 text-xs text-amber-700 list-disc list-inside">
        <li>生成時間はツールやサーバー混雑状況によって変わる場合があります</li>
        <li>クレジット制のツールでは、生成に失敗した場合でもクレジットが消費される可能性があります</li>
        <li>人物・著名人・ブランドロゴ・第三者素材を使用する場合は、別途利用条件の確認が必要です</li>
      </ul>
    </div>

    <!-- NoticeBox -->
    <div class="mb-8">
      <NoticeBox />
    </div>

    <!-- AI動画生成・AI動画編集・AIアバター動画の違い -->
    <section class="mb-10 rounded-xl border border-slate-200 bg-white px-6 py-6">
      <h2 class="mb-3 text-lg font-semibold text-slate-900">AI動画生成・AI動画編集・AIアバター動画の違い</h2>
      <p class="mb-4 text-sm text-slate-600 leading-relaxed">
        「動画系AIツール」は大きく3種類に分かれます。目的に合ったカテゴリを選ぶことが、ツール選びの第一歩です。
      </p>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[600px] border-collapse text-sm">
          <thead>
            <tr class="bg-slate-100 text-left text-xs font-semibold text-slate-600">
              <th class="border border-slate-200 px-3 py-2">カテゴリ</th>
              <th class="border border-slate-200 px-3 py-2">何をするツールか</th>
              <th class="border border-slate-200 px-3 py-2">代表ツール</th>
              <th class="border border-slate-200 px-3 py-2">向いている用途</th>
            </tr>
          </thead>
          <tbody class="text-xs text-slate-700">
            <tr class="bg-blue-50">
              <td class="border border-slate-200 px-3 py-2 font-bold text-blue-800">AI動画生成<br/><span class="font-normal text-blue-600">（このページ）</span></td>
              <td class="border border-slate-200 px-3 py-2">テキストや画像から映像を新規に生成する</td>
              <td class="border border-slate-200 px-3 py-2">Runway・Pika・Kling AI・Luma AI・Haiper・Hailuo AI</td>
              <td class="border border-slate-200 px-3 py-2">SNS動画・コンセプトムービー・画像の動画化</td>
            </tr>
            <tr class="even:bg-slate-50">
              <td class="border border-slate-200 px-3 py-2 font-bold text-slate-800">AI動画編集</td>
              <td class="border border-slate-200 px-3 py-2">既存の動画素材にテンプレート・字幕・エフェクトを加える</td>
              <td class="border border-slate-200 px-3 py-2">CapCut AI・InVideo AI</td>
              <td class="border border-slate-200 px-3 py-2">テンプレート編集・自動字幕・既存素材の仕上げ</td>
            </tr>
            <tr class="even:bg-slate-50">
              <td class="border border-slate-200 px-3 py-2 font-bold text-slate-800">AIアバター動画</td>
              <td class="border border-slate-200 px-3 py-2">AIが生成した人物アバターが話す動画を生成する</td>
              <td class="border border-slate-200 px-3 py-2">HeyGen・Synthesia・D-ID</td>
              <td class="border border-slate-200 px-3 py-2">研修動画・製品解説・ナレーション付き説明動画</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-slate-500">
        動画編集ツールについては<a href="/categories/video-editing/" class="text-blue-600 hover:underline">動画編集カテゴリ</a>、アバター動画については<a href="/categories/avatar-video/" class="text-blue-600 hover:underline">AIアバター動画カテゴリ</a>をご参照ください。
      </p>
    </section>

    <!-- 用途別導線 -->
    <section class="mb-10 rounded-xl border border-blue-100 bg-blue-50 px-6 py-5">
      <h2 class="mb-3 text-sm font-semibold text-blue-800">用途別ページへ</h2>
      <div class="flex flex-wrap gap-2 text-sm">
        <a href="/use-cases/youtube/" class="rounded-full border border-blue-200 bg-white px-3 py-1.5 text-blue-700 hover:bg-blue-100">YouTube動画向け</a>
        <a href="/use-cases/shorts/" class="rounded-full border border-blue-200 bg-white px-3 py-1.5 text-blue-700 hover:bg-blue-100">Shorts・縦型動画向け</a>
        <a href="/use-cases/faceless-video/" class="rounded-full border border-blue-200 bg-white px-3 py-1.5 text-blue-700 hover:bg-blue-100">顔出しなし動画向け</a>
        <a href="/use-cases/ad-video/" class="rounded-full border border-blue-200 bg-white px-3 py-1.5 text-blue-700 hover:bg-blue-100">広告動画向け</a>
        <a href="/categories/avatar-video/" class="rounded-full border border-purple-200 bg-white px-3 py-1.5 text-purple-700 hover:bg-purple-100">AIアバター動画</a>
        <a href="/categories/video-editing/" class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-slate-700 hover:bg-slate-100">動画編集・テンプレート活用</a>
        <a href="/categories/image-generation/" class="rounded-full border border-emerald-200 bg-white px-3 py-1.5 text-emerald-700 hover:bg-emerald-100">AI画像生成も比較</a>
      </div>
    </section>

    <!-- 比較ポイント -->
    <section class="mb-10 rounded-xl border border-slate-200 bg-white px-6 py-6">
      <h2 class="mb-3 text-lg font-semibold text-slate-900">AI動画生成ツールを選ぶときの比較ポイント</h2>
      <ul class="space-y-3 text-sm text-slate-700">
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span><strong>入力タイプ：</strong>テキストから動画を生成する「テキスト→動画」、画像から動画を生成する「画像→動画」、既存動画を入力する「動画→動画」など、ツールによって対応する入力タイプが異なります。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span><strong>生成できる動画の長さや解像度：</strong>多くのツールで無料プランは生成尺・解像度に制限があります。プランごとの上限は公式サイトでご確認ください。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span><strong>無料枠の有無と制限：</strong>クレジット制・月更新・初回限りなど、無料枠の形態はツールによって異なります。生成失敗時のクレジット消費についても公式情報をご確認ください。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span><strong>日本語UIまたは日本語プロンプトへの対応：</strong>日本語UIと日本語プロンプト対応は別問題です。細かい映像スタイルの指定では英語プロンプトの方が意図を伝えやすい場合があります。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span><strong>透かし条件：</strong>無料プランでは透かしが付与される場合があります。SNS投稿や商用利用を前提とする場合は透かし条件の確認が重要です。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span><strong>商用利用条件の確認ポイント：</strong>広告・YouTube・クライアントワーク等の商用利用を前提にする場合は、公式利用規約でプランごとの条件を事前に確認してください。本ページは法的助言ではありません。</span>
        </li>
        <li class="flex gap-2">
          <span class="mt-0.5 shrink-0 text-slate-400">▸</span>
          <span><strong>用途との相性：</strong>SNS向け短尺・YouTube・広告動画・顔出しなし動画・ナレーション動画など、目的によって向いているツールが異なります。</span>
        </li>
      </ul>
      <p class="mt-3 text-xs text-slate-500">各条件の詳細は各ツールの詳細ページおよび公式サイトでご確認ください。</p>
    </section>

    <!-- 横断比較表 -->
    <section class="mb-12">
      <h2 class="mb-3 border-b border-slate-200 pb-2 text-xl font-semibold text-slate-800">AI動画生成ツール 横断比較表</h2>
      <div class="mb-3 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-xs text-amber-700 leading-relaxed">
        料金、無料枠、商用利用条件、透かしの有無、生成した動画の利用条件は変更される場合があります。人物・ロゴ・商標・第三者素材を含む動画では、各サービスの規約や権利者の許諾確認が必要になる場合があります。本ページは法的助言ではありません。利用前に必ず公式情報をご確認ください。
      </div>
      <p class="mb-2 text-xs text-slate-400 sm:hidden text-center">← 横にスクロールできます →</p>
      <div class="relative">
        <div class="overflow-x-auto">
        <table class="w-full min-w-[1000px] border-collapse text-sm">
          <thead>
            <tr class="bg-slate-100 text-left text-xs font-semibold text-slate-600">
              <th class="border border-slate-200 px-3 py-2">ツール名</th>
              <th class="border border-slate-200 px-3 py-2">主な用途</th>
              <th class="border border-slate-200 px-3 py-2">入力タイプ</th>
              <th class="border border-slate-200 px-3 py-2">無料枠</th>
              <th class="border border-slate-200 px-3 py-2">商用利用条件</th>
              <th class="border border-slate-200 px-3 py-2">日本語対応</th>
              <th class="border border-slate-200 px-3 py-2">透かし</th>
              <th class="border border-slate-200 px-3 py-2">動画延長</th>
              <th class="border border-slate-200 px-3 py-2">最大動画尺</th>
              <th class="border border-slate-200 px-3 py-2">詳細</th>
            </tr>
          </thead>
          <tbody>
            {primaryTools.map((tool) => {
              const cu = tool.data.commercialUse;
              const cuLabel =
                cu === 'ok' ? 'プラン・用途により異なる（要公式確認）' :
                cu === 'paid-only' ? '有料プラン前提の場合あり（要公式確認）' :
                cu === 'limited' ? '条件付きで利用可能な場合あり（要公式確認）' :
                '要公式確認';
              const wm = tool.data.watermark;
              const wmLabel =
                wm === 'no' ? 'なし（条件による）' :
                wm === 'yes' ? 'あり' :
                wm === 'free-only' ? '無料プランのみ' :
                wm === 'limited' ? '無料プランはあり（有料は要確認）' :
                '要確認';
              const jpLabel =
                tool.data.japaneseUi ? 'UI対応' :
                tool.data.japanesePrompt === true || tool.data.japanesePrompt === 'yes' ? 'プロンプトのみ' :
                tool.data.japanesePrompt === 'partial' ? '部分対応' :
                '非対応／要確認';
              const f = tool.data.features ?? {};
              const inputLabel =
                f.textToVideo && f.imageToVideo ? 'テキスト・画像' :
                f.textToVideo ? 'テキスト' :
                f.imageToVideo ? '画像' : '—';
              return (
                <tr class="even:bg-slate-50 hover:bg-blue-50">
                  <td class="border border-slate-200 px-3 py-2 font-medium text-slate-800">
                    <a href={`/tools/${tool.slug}/`} class="hover:underline text-blue-700">{tool.data.name}</a>
                  </td>
                  <td class="border border-slate-200 px-3 py-2 text-slate-700 text-xs">
                    {tool.data.bestFor?.[0] ?? '—'}
                  </td>
                  <td class="border border-slate-200 px-3 py-2 text-xs text-slate-600">{inputLabel}</td>
                  <td class="border border-slate-200 px-3 py-2">
                    {tool.data.freePlan && tool.data.freePlan !== 'no' ? (
                      <span class="rounded bg-emerald-100 px-1.5 py-0.5 text-xs text-emerald-700">あり</span>
                    ) : (
                      <span class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-500">なし／要確認</span>
                    )}
                  </td>
                  <td class="border border-slate-200 px-3 py-2 text-xs text-slate-600">{cuLabel}</td>
                  <td class="border border-slate-200 px-3 py-2 text-xs text-slate-600">{jpLabel}</td>
                  <td class="border border-slate-200 px-3 py-2 text-xs text-slate-600">{wmLabel}</td>
                  <td class="border border-slate-200 px-3 py-2 text-xs text-slate-600">
                    {tool.data.features?.videoExtend === true ? (
                      <span class="rounded bg-emerald-100 px-1.5 py-0.5 text-emerald-700">対応</span>
                    ) : tool.data.features?.videoExtend === false ? (
                      <span class="rounded bg-slate-100 px-1.5 py-0.5 text-slate-500">非対応</span>
                    ) : (
                      <span class="text-slate-400">要確認</span>
                    )}
                  </td>
                  <td class="border border-slate-200 px-3 py-2 text-xs text-slate-600">
                    {tool.data.features?.maxVideoDuration ?? <span class="text-slate-400">要確認</span>}
                  </td>
                  <td class="border border-slate-200 px-3 py-2">
                    <a href={`/tools/${tool.slug}/`} class="text-blue-600 hover:underline text-xs">詳細 →</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
        </div>
        <div class="pointer-events-none absolute inset-y-0 right-0 w-10 bg-gradient-to-l from-white to-transparent sm:hidden"></div>
      </div>
      <p class="mt-2 text-xs text-slate-400">商用利用条件・透かし条件はプランや時期により変更される場合があります。各ツールの公式利用規約を必ずご確認ください。</p>
      <p class="mt-1 text-xs text-slate-400">最大動画尺や延長機能は、モデル・プラン・提供時期によって変わる場合があります。最新情報は各ツールの公式サイトをご確認ください。</p>
    </section>


    <!-- 用途別3カード -->
    <section class="mb-12">
      <h2 class="mb-1 border-b border-slate-200 pb-2 text-xl font-semibold text-slate-800">迷ったら、用途別にこのあたりから確認</h2>
      <p class="mb-4 text-sm text-slate-500">目的に合いそうなツールを用途別に整理しています。詳細は各ツールの詳細ページおよび公式サイトでご確認ください。</p>
      <div class="grid gap-4 sm:grid-cols-3">

        <!-- カード1：映像品質重視 -->
        <div class="flex flex-col rounded-xl border border-slate-200 bg-white px-5 py-5 shadow-sm">
          <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-violet-600">映像品質を重視したい</p>
          <ul class="mb-4 flex-1 space-y-2 text-sm text-slate-700">
            <li><a href="/tools/runway/" class="text-blue-600 hover:underline">Runway</a> — 多機能・映像表現幅広め</li>
            <li><a href="/tools/luma-ai/" class="text-blue-600 hover:underline">Luma AI</a> — 自然な動き・フォトリアル寄り</li>
            <li><a href="/tools/kling-ai/" class="text-blue-600 hover:underline">Kling AI</a> — リアル系・日本語プロンプト対応とされる</li>
          </ul>
          <a href="/comparisons/kling-ai-vs-luma-ai/" class="mt-auto text-right text-xs font-semibold text-blue-600 hover:underline">関連ページを見る →</a>
        </div>

