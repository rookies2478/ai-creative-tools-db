---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ComparisonLegend from '../../../components/ComparisonLegend.astro';
import ComparisonFootnote from '../../../components/ComparisonFootnote.astro';

const allTools = await getCollection('tools');
const videoTools = allTools.filter(
  (t) => t.data.category === 'video' || t.data.category === 'both'
);

const primarySlugs = ['runway', 'pika', 'kling-ai', 'luma-ai', 'hailuo-ai', 'haiper', 'vidu-ai', 'pixverse'];
const primaryTools = primarySlugs
  .map((s) => videoTools.find((t) => t.slug === s))
  .filter(Boolean);

const faqs = [
  {
    q: 'AI動画生成ツールと動画編集ツールの違いは？',
    a: 'AI動画生成ツール（Runway・Pika・Kling AIなど）はテキストや画像を入力として動画を新規に生成します。動画編集ツール（CapCut AIなど）は既存の素材にテンプレート適用・自動字幕・エフェクト付与などの編集処理を加えるものです。目的に応じて使い分けてください。',
  },
  {
    q: 'AI動画生成ツールとAIアバター動画ツールの違いは？',
    a: 'AI動画生成ツールはテキストや画像からシーン・映像を生成します。AIアバター動画ツール（HeyGen・Synthesia・D-IDなど）はAIが生成した人物アバターが話すスタイルの動画を作成するものです。スライド説明・製品解説・研修動画など、話者映像が必要な用途ではアバター動画ツールが向いている場合があります。詳しくは<a href="/categories/avatar-video/">AIアバター動画カテゴリ</a>をご参照ください。',
  },
  {
    q: '無料で使えるAI動画生成ツールはありますか？',
    a: 'Runway・Pika・Kling AI・Luma AI・Haiper・Hailuo AI・<a href="/tools/vidu-ai/">Vidu AI</a>はいずれも無料枠が用意されています。動画生成ツールを比較する場合は、RunwayやKling AIに加えてVidu AIの無料枠・料金も確認しておくと選びやすくなります。ただし無料プランの生成回数・クレジット上限・透かし条件・商用利用条件はツールごとに大きく異なります。最新情報は各ツールの公式サイトをご確認ください。<a href="/conditions/free/">無料枠のあるAIツール比較ページ</a>もご参照ください。',
  },
  {
    q: '商用利用やYouTube利用時に確認すべき点は？',
    a: '商用利用・YouTube投稿を前提にする場合、①プランごとの商用利用条件、②透かしの有無、③生成物の著作権・所有権に関する規定、④人物・ブランドロゴ・第三者素材を含む場合の制約、を各ツールの公式利用規約で事前に確認することを推奨します。無料プランでは商用利用が制限されているツールも多くあります。本ページは法的助言ではありません。',
  },
  {
    q: '日本語プロンプトでも使えますか？',
    a: '日本語プロンプトに対応しているとされるツールとしてKling AI・Haiper・CapCut AIなどが挙げられます。英語UIのツールでも日本語プロンプトを入力できる場合がありますが、細かい表現や映像スタイルの指定では英語プロンプトの方が意図を伝えやすいケースがあります。日本語UIに対応しているのは確認時点ではCapCut AIのみです。最新の対応状況は各公式サイトをご確認ください。',
  },
  {
    q: '画像から動画を作れるAIツールはありますか？',
    a: 'Runway・Pika・Kling AI・Luma AI・Haiper などが画像→動画生成（image-to-video）に対応しているとされています。静止画にモーションを加えてSNS用の短尺動画やコンセプトムービーを作る用途で候補に挙がることがあります。入力画像に人物・ブランドロゴ・第三者素材が含まれる場合は、各ツールの利用条件に加えて権利関係の別途確認が必要です。最新情報は各公式サイトをご確認ください。',
  },
  {
    q: '透かしなしで使えるAI動画生成ツールはありますか？',
    a: '透かしの有無はツールおよびプランによって異なります。公式情報では、Runwayは無料プランで透かしありとされています。Luma AIは有料のPlus以上で透かしなしが案内されています。Kling AIは有料プランで透かしなしが案内されているとされています。透かし条件はSNS投稿・商用利用前に必ず各公式サイトをご確認ください。<a href="/conditions/no-watermark/">透かしなしで使いやすいAIツール</a>もご参照ください。本記事は法的助言ではありません。',
  },
  {
    q: '生成動画の著作権や肖像権はどう確認すればよいですか？',
    a: 'AI生成動画の著作権・所有権の扱いはツール・プラン・利用規約・各国の法律によって異なります。公式情報では、RunwayはユーザーがOwnershipを保持するとされていますが、その他のツールは規約上確認が必要なものが多い状況です。また、生成動画に実在の人物・著名人の顔・ブランドロゴ・商標・第三者の著作物が含まれる場合は、ツールの利用規約とは別に肖像権・商標権・著作権の観点から個別確認が必要です。本記事は法的助言ではありません。重要な商用利用の場面では専門家（弁護士等）へのご相談を推奨します。<a href="/guides/commercial-use-copyright/">商用利用・著作権の考え方ガイド</a>もご参照ください。',
  },
  {
    q: '動画生成AIのランキングはどのように見ればよいですか？',
    a: 'ランキングは評価軸（料金・無料枠・日本語対応・画像から動画・商用利用条件・透かし有無など）によって結果が大きく変わります。「映像品質を重視したい」「まず無料枠から試したい」「日本語プロンプトで使いたい」など、目的別に候補を絞ることをおすすめします。本ページの用途別おすすめ早見表や<a href="/guides/video-generation-credit-cost-comparison/">料金・クレジット比較ガイド</a>も参考にしてください。ランキングは目的や評価軸によって変わるため、絶対的な順位として断定するものではありません。最新情報は各公式サイトをご確認ください。',
  },
  {
    q: 'スマホで使えるAI動画生成ツールはありますか？',
    a: 'スマホからの利用は、ブラウザ経由での利用・専用アプリの有無・生成時間・透かし条件・ログイン要否などを確認する必要があります。公式情報では、CapCut AIはiOS/Androidアプリが案内されています。その他のツールはWebブラウザ経由でのスマホ利用が想定されますが、対応状況・使い勝手はツールや時期によって異なります。スマホ対応状況・無料枠は変更される場合があるため、最新情報は各公式サイトをご確認ください。<a href="/conditions/free/">無料枠のあるAIツール比較</a>もご参照ください。',
  },
  {
    q: '広告・プロモーション動画向きのAIツールはどれですか？',
    a: '広告・プロモーション動画の用途では、①映像品質と表現の自由度、②プランごとの商用利用条件、③透かしの有無、④素材（人物・ブランドロゴ・商標）の扱いを重点的に確認することをおすすめします。公式情報ではRunwayが映像制作向けの多機能ワークフローと商用利用の条件を案内しており、Kling AI・Luma AIも映像品質で候補に挙がることがあります。商用利用を前提にする場合は、各ツールの公式利用規約でプランごとの条件を事前に確認してください。本記事は法的助言ではありません。<a href="/guides/commercial-use-copyright/">商用利用・著作権の考え方ガイド</a>もご参照ください。',
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map((faq) => ({
        "@type": "Question",
        "name": faq.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.a.replace(/<[^>]+>/g, '')
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "AIクリエイティブナビ",
          "item": "https://aicreative-db.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "AI動画生成",
          "item": "https://aicreative-db.com/categories/video-generation/"
        }
      ]
    }
  ]
});

const videoToolCards = [
  { name: 'Runway',    slug: 'runway',    initial: 'R', role: '動画生成', commercial: '全プランで案内あり（透かし等：要確認）', free: '要確認', jp: '要確認', note: 'プランによる', price: '$12/月（Standard・年払い）/ $14/月（月払い）', platforms: 'Web、API', date: '2026-06-08' },
  { name: 'Pika',      slug: 'pika',      initial: 'P', role: '動画生成', commercial: '無料:不可 / 有料:一部で案内（要確認）', free: '要確認', jp: '要確認', note: 'プランによる', price: '$8/月（年払い）', platforms: 'Web', date: '2026-06-08' },
  { name: 'Kling AI',  slug: 'kling-ai',  initial: 'K', role: '動画生成', commercial: '無料:非商用のみ / 有料Standard以上:案内あり', free: '要確認', jp: '要確認', note: 'プランによる', price: 'USD建て（要公式確認）', platforms: 'Web', date: '2026-06-08' },
  { name: 'Luma AI',   slug: 'luma-ai',   initial: 'L', role: '動画生成', commercial: '無料:非商用のみ / 有料Plus以上:案内あり', free: '無料枠あり', jp: '要確認', note: '無料:透かしあり', price: '$30/月（Plus・月払い）', platforms: 'Web、API', date: '2026-06-08' },
  { name: 'Hailuo AI', slug: 'hailuo-ai', initial: 'H', role: '動画生成', commercial: '要確認', free: '要確認', jp: '要確認', note: 'プランによる', price: '要公式確認', platforms: 'Web', date: '2026-06-08' },
  { name: 'Haiper',    slug: 'haiper',    initial: 'H', role: '動画生成（サービス変更済み）', commercial: '要確認', free: '要確認', jp: '要確認', note: '⚠️コンシューマー向けサービスは2025年2月シャットダウン済み。現役おすすめではありません。', price: '要公式確認（サービス変更あり）', platforms: 'Web、iOS、API（要確認）', date: '2026-06-15' },
  { name: 'Vidu AI',   slug: 'vidu-ai',   initial: 'V', role: '動画生成', commercial: '要確認', free: '要確認', jp: '要確認', note: 'プランによる', price: '要公式確認', platforms: 'Web', date: '2026-06-08' },
  { name: 'PixVerse',  slug: 'pixverse',  initial: 'P', role: '動画生成', commercial: '要確認', free: '要確認', jp: '対応', note: 'プランによる', price: '要公式確認', platforms: 'Web', date: '2026-06-08' },
];

const editToolCards = [
  { name: 'CapCut AI',  slug: 'capcut-ai',  initial: 'C', role: '動画編集', commercial: '要確認', free: '無料枠あり', jp: '対応', note: '通常編集は透かしなし（条件あり）', price: '要公式確認', platforms: 'Web、iOS、Android', date: '2026-07-12' },
  { name: 'InVideo AI', slug: 'invideo-ai', initial: 'I', role: '動画編集', commercial: '要確認', free: '無料枠あり', jp: '要確認', note: 'プランによる', price: '約$20/月〜', platforms: 'Web', date: '2026-06-08' },
];

const splitChips = (s: string) => s.split(/[、,]/).map((p) => p.trim()).filter(Boolean);

type VidExtra = { freeCount: string; smartphone: string; textLabel: string; trend: string; commercialCheck: string };
const vidExtra: Record<string, VidExtra> = {
  'runway':    { freeCount: '△あり（初回限定）',   smartphone: '△（ブラウザ経由）', textLabel: '!別論点',  trend: 'リアル寄り',           commercialCheck: '確認項目少なめ（全プランで案内）' },
  'pika':      { freeCount: '△あり（要確認）',     smartphone: '△（ブラウザ経由）', textLabel: '!別論点',  trend: '両方対応',             commercialCheck: 'プランや用途による' },
  'kling-ai':  { freeCount: '△あり（要確認）',     smartphone: '△（ブラウザ経由）', textLabel: '!別論点',  trend: 'リアル寄り',           commercialCheck: 'プランや用途による' },
