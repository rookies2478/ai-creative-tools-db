const tableRows = [
  {
    name: 'Canva AI画像生成',
    slug: 'canva-ai-image-generator',
    freeType: '無料プラン（回数制限あり）',
    watermark: '要確認',
    japanese: '◯',
    commercialNote: '用途やプランによって条件が異なる場合があります。最新情報は公式サイトをご確認ください。',
  },
  {
    name: 'Adobe Firefly',
    slug: 'adobe-firefly',
    freeType: '無料クレジット（月次）',
    watermark: '要確認',
    japanese: '◯',
    commercialNote: '公式情報の確認が必要です。プランによって条件が変わる場合があります。',
  },
  {
    name: 'DALL·E',
    slug: 'dalle',
    freeType: 'ChatGPT無料プラン経由（制限あり）',
    watermark: '要確認',
    japanese: '△',
    commercialNote: '最新情報はOpenAI公式サイトをご確認ください。',
  },
  {
    name: 'Stable Diffusion',
    slug: 'stable-diffusion',
    freeType: 'ローカル実行（環境構築が必要）',
    watermark: '基本なし（設定による）',
    japanese: '△',
    commercialNote: 'モデルごとのライセンス条件を確認してください。',
  },
  {
    name: 'Leonardo AI',
    slug: 'leonardo-ai',
    freeType: '無料プラン（日次トークン制）',
    watermark: '要確認',
    japanese: '△',
    commercialNote: '有料プランでは条件が変わる場合があります。最新情報は公式サイトをご確認ください。',
  },
  {
    name: 'Midjourney',
    slug: 'midjourney',
    freeType: '無料プランなし（有料のみ）',
    watermark: '要確認',
    japanese: '△',
    commercialNote: '公式情報の確認が必要です。プランによって条件が異なります。',
  },
];

const relatedLinks = [
  { href: '/categories/free/', label: '無料枠あり・ツール一覧' },
  { href: '/tools/', label: 'ツール一覧' },
  { href: '/compare/', label: '比較表' },
  { href: '/categories/no-watermark/', label: '透かしなしツール' },
  { href: '/guides/commercial-use-copyright/', label: '商用利用と著作権ガイド' },
  { href: '/use-cases/youtube-thumbnail/', label: 'YouTubeサムネ向け比較' },
  { href: '/use-cases/sns-blog-eyecatch/', label: 'SNS・ブログアイキャッチ向け比較' },
];

const checkpoints = [
  {
    icon: '🆓',
    title: '完全無料か、無料枠ありか',
