---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeBox from '../../../components/NoticeBox.astro';

const tools = [
  {
    name: 'Canva AI画像生成',
    slug: 'canva-ai-image-generator',
    freeNote: '無料プランあり（生成回数に制限）',
    point: '無料プランでも画像生成機能を試せます。ただし、生成できる回数やデザインテンプレートの利用範囲はプランによって異なります。',
    bestFor: 'デザイン初心者・SNS用ビジュアル作成',
    caution: '無料プランの生成回数・商用利用条件は変更される場合があります。公式サイト・利用規約をご確認ください。',
  },
  {
    name: 'Adobe Firefly',
    slug: 'adobe-firefly',
    freeNote: '無料クレジットあり（月次リセット）',
