---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';

const faqs = [
  {
    q: 'MidjourneyとAdobe Fireflyはどちらが画質が良いですか？',
    a: 'Midjourneyはアート・イラスト・写真風など幅広いスタイルで高い表現力が評価されています。Adobe Fireflyは写実的・実用的な素材生成に向いているとされています。用途や好みによって評価が分かれますので、両方試して比較することをおすすめします。',
  },
  {
    q: 'Adobe Fireflyは無料で商用利用できますか？',
    a: 'Adobe公式情報上、Fireflyは商用利用を想定したサービスとして案内されています。ただしβ（ベータ）表示の機能は商用利用対象外とされています。プランや用途によって条件が異なる可能性があるため、利用前にAdobe公式のユーザーガイドラインをご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'Midjourneyは日本語プロンプトで使えますか？',
    a: '日本語プロンプトを一部理解する場合がありますが、英語プロンプトと比べて精度が低い傾向があります。UIは英語のみです。日本語環境での使いやすさを重視する場合はAdobe Fireflyが有利です。',
  },
  {
    q: 'MidjourneyはYouTubeサムネイルに使えますか？',
    a: '公式情報上、有料プランでは商用利用ができる場合があります。ただし、YouTubeサムネイルへの利用が商用利用に該当するかは最新の公式利用規約をご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'Adobe Fireflyの透かしはどのプランで消えますか？',
    a: 'プランによっては可視透かしが入る場合があります。また全プラン共通でC2PAの不可視メタデータが埋め込まれる場合があります。具体的な条件はAdobe公式サイトでご確認ください。',
  },
  {
    q: 'どちらが初心者に使いやすいですか？',
    a: 'Adobe Fireflyは日本語UI対応、プロンプト補助機能があり、初心者に取り組みやすい設計です。Midjourneyは英語UIのみで、操作にDiscordまたはWebアプリの習熟が必要ですが、短いプロンプトでも高品質な画像を生成できるとされています。',
  },
];

const comparisonRows = [
  {
    item: '料金（最低プラン）',
    mj: '$10/月（Basicプラン・月払い）',
    ff: '$9.99/月（Firefly Standardプラン）',
  },
  {
    item: '無料プラン',
    mj: 'なし（2024年末廃止）',
    ff: 'あり（クレジット数・条件は要確認）',
  },
  {
    item: '商用利用',
    mj: '有料プランで可能な場合あり（条件あり）',
    ff: '商用利用を想定した設計（β機能は対象外）',
  },
  {
    item: '日本語UI',
    mj: '非対応（英語のみ）',
    ff: '対応',
  },
  {
    item: '日本語プロンプト',
    mj: '一部対応（英語より精度低め）',
    ff: '対応',
  },
  {
    item: '透かし',
    mj: '有料プランでは透かしなし（要確認）',
    ff: 'プランによっては可視透かしあり。全プランでC2PAメタデータ埋め込み',
  },
  {
    item: '対応環境',
    mj: 'Discord・Web',
    ff: 'Web（Photoshop・Illustrator連携可）',
  },
  {
    item: '表現の自由度',
    mj: 'スタイルの幅が広い・アート表現に強み',
    ff: '実用的な素材向け・スタイルの幅は狭め',
  },
  {
    item: '初心者向けか',
    mj: '英語UI・要習熟',
    ff: '日本語UI・プロンプト補助あり',
  },
];

const relatedLinks = [
  { href: '/tools/midjourney/', label: 'Midjourney詳細' },
  { href: '/tools/adobe-firefly/', label: 'Adobe Firefly詳細' },
  { href: '/categories/commercial-use/', label: '商用利用確認しやすいAIツール' },
  { href: '/categories/free/', label: '無料枠ありAIツール' },
  { href: '/categories/japanese/', label: '日本語対応AIツール' },
  { href: '/categories/no-watermark/', label: '透かしなしAIツール' },
  { href: '/compare/', label: 'AI画像・動画ツール比較表' },
];
---

<BaseLayout
  title="MidjourneyとAdobe Fireflyを比較：商用利用・料金・日本語対応・用途の違い | AIクリエイティブナビ"
  description="MidjourneyとAdobe Fireflyを料金・無料枠・商用利用条件・日本語対応・透かし・向いている用途の観点で比較。YouTubeサムネ・SNS・広告・企業利用など用途別のおすすめも整理しています。"
  canonicalPath="/compare/midjourney-vs-adobe-firefly/"
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <!-- パンくずナビ -->
    <nav class="mb-6 text-sm text-slate-500" aria-label="パンくずリスト">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/compare/" class="hover:underline">比較表</a>
      <span class="mx-1">/</span>
      <span>MidjourneyとAdobe Firefly比較</span>
    </nav>

    <!-- H1 -->
    <h1 class="mb-4 text-3xl font-bold text-[#002B61]">
      MidjourneyとAdobe Fireflyを比較：商用利用・料金・日本語対応・用途の違い
    </h1>

    <!-- 最終確認日 -->
    <p class="mb-6 text-xs text-slate-400">最終確認：2026年5月14日 ／ 掲載情報は変更される場合があります</p>

    <!-- 注意ボックス -->
    <div class="mb-8 rounded-lg border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800 leading-relaxed">
      <p class="mb-1 font-semibold">ご確認ください</p>
      <ul class="mt-2 space-y-1.5 list-disc list-inside">
        <li>料金・無料枠・商用利用条件・透かし条件は変更される場合があります。</li>
        <li>最新情報は各ツールの<strong>公式サイト・料金ページ・利用規約</strong>をご確認ください。</li>
        <li>本記事は情報提供を目的としており、<strong>法的助言ではありません</strong>。</li>
      </ul>
    </div>

    <!-- ============================================================ -->
    <!-- 結論サマリー                                                  -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <div class="rounded-xl border border-blue-100 bg-blue-50 px-6 py-5">
        <h2 class="mb-3 text-lg font-bold text-blue-900">結論：どちらを選ぶべきか</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="rounded-lg bg-white border border-blue-100 px-5 py-4">
            <p class="mb-2 text-sm font-bold text-slate-800">品質・表現重視 → <a href="/tools/midjourney/" class="text-blue-600 hover:underline">Midjourney</a></p>
            <p class="text-xs leading-relaxed text-slate-600">
              スタイルの幅が広く、アート・イラスト・写真風など高品質なビジュアル生成に定評があります。
              英語環境に慣れており、クリエイティブな表現を追求したい方に向いています。有料プランのみ（無料プランなし）。
            </p>
          </div>
          <div class="rounded-lg bg-white border border-blue-100 px-5 py-4">
            <p class="mb-2 text-sm font-bold text-slate-800">商用・日本語・手軽さ重視 → <a href="/tools/adobe-firefly/" class="text-blue-600 hover:underline">Adobe Firefly</a></p>
            <p class="text-xs leading-relaxed text-slate-600">
              日本語UIに対応し、Adobe公式情報上では商用利用を想定した設計として案内されています。
              無料枠もあり、Adobe製品ユーザーや日本語環境を重視する方に向いています。
              ただし商用利用の詳細条件は公式規約をご確認ください。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 基本比較表                                                    -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">MidjourneyとAdobe Fireflyの基本比較表</h2>
      <p class="mb-4 text-sm text-slate-500">
        以下は参考情報です。内容は変更される場合があります。最新情報は各公式サイトでご確認ください。
      </p>
      <div class="overflow-x-auto rounded-xl border border-slate-100 shadow-sm">
        <table class="w-full min-w-[560px] text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">
              <th class="px-4 py-3 w-1/3">比較項目</th>
              <th class="px-4 py-3 w-1/3">Midjourney</th>
              <th class="px-4 py-3 w-1/3">Adobe Firefly</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map(({ item, mj, ff }, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                <td class="px-4 py-3 font-medium text-slate-700 text-xs">{item}</td>
                <td class="px-4 py-3 text-slate-600 text-xs leading-relaxed">{mj}</td>
                <td class="px-4 py-3 text-slate-600 text-xs leading-relaxed">{ff}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-slate-400">
        情報は確認時点のものです。最新の料金・条件は各公式サイトをご参照ください。
      </p>
    </section>

    <!-- ============================================================ -->
    <!-- 料金・無料枠の違い                                            -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">料金・無料枠の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-5">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed">
            <li><span class="font-medium">無料プラン：</span>なし（2024年末に廃止されたとされています）</li>
            <li><span class="font-medium">最低プラン：</span>Basicプラン $10/月（年払いで$8/月）</li>
            <li><span class="font-medium">上位プラン：</span>Standard $30/月〜、Pro $60/月〜、Mega $120/月〜</li>
          </ul>
          <p class="mt-3 text-xs text-slate-400">最新料金は<a href="https://www.midjourney.com" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">Midjourney公式サイト</a>でご確認ください。</p>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Adobe Firefly</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed">
            <li><span class="font-medium">無料プラン：</span>あり（一定数の生成クレジット付与。数量は変更の可能性あり）</li>
            <li><span class="font-medium">有料プラン：</span>Firefly Standard $9.99/月〜</li>
            <li><span class="font-medium">備考：</span>Creative Cloud All Appsに含まれる場合あり</li>
          </ul>
          <p class="mt-3 text-xs text-slate-400">最新料金は<a href="https://www.adobe.com/products/firefly/plans.html" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">Adobe公式料金ページ</a>でご確認ください。</p>
        </div>
      </div>

      <div class="rounded-lg border border-slate-100 bg-slate-50 px-5 py-4 text-sm text-slate-600 leading-relaxed">
        <p>
          <strong>まず試したい方：</strong>Adobe Fireflyは無料枠があるため、費用をかけずに試すことができます（生成回数・条件は要確認）。
          Midjourneyは有料プランのみですが、品質を重視するユーザーから高い評価を受けています。
          <a href="/categories/free/" class="text-blue-600 hover:underline ml-1">無料枠があるAIツール一覧も参考にしてください →</a>
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 商用利用条件の違い                                            -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">商用利用条件の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-5">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            公式情報上、有料プランでは商用利用ができる場合があります。ただし、<strong>年間総収益が100万ドル超の企業はPro/Megaプランへのアップグレードが利用規約上必要</strong>とされています。
            条件・規約は変更される可能性があるため、利用前に最新の公式利用規約をご確認ください。
          </p>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Adobe Firefly</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            Adobe公式情報上、Fireflyは商用利用を想定したAI生成サービスとして案内されています。
            ただし<strong>β（ベータ）表示の機能は商用利用対象外</strong>とされています。
            第三者素材の使用、利用プラン、用途によって条件が変わる可能性があります。
          </p>
        </div>
      </div>

      <div class="rounded-lg border border-amber-100 bg-amber-50 px-5 py-4 text-sm text-amber-800 leading-relaxed">
        <p class="font-semibold mb-1">商用利用を前提にする場合は</p>
        <p>
          どちらのツールも「絶対に商用利用できる」とは断言できません。プランや用途によって条件が異なる可能性があります。
          商用利用前は必ず最新の公式規約をご確認ください。本記事は法的助言ではありません。
          <a href="/categories/commercial-use/" class="text-blue-600 hover:underline ml-1">商用利用を確認しやすいAIツール一覧も参考に →</a>
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 生成品質・表現の自由度                                        -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">生成品質・表現の自由度の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>アート・イラスト・写真風など幅広いスタイルに対応</li>
            <li>業界トップクラスの画像品質と評される場合が多い</li>
            <li>v6以降、プロンプト精度が向上しているとされる</li>
            <li>スタイル指定の自由度が高い</li>
          </ul>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Adobe Firefly</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>写実的・実用的な素材生成に向いているとされる</li>
            <li>スタイルの幅はMidjourneyより狭い傾向</li>
            <li>Photoshop連携でのインペイント・アウトペインティングが可能</li>
            <li>プロンプト補助機能あり（初心者向け）</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 日本語対応                                                    -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">日本語対応の違い</h2>

      <div class="overflow-x-auto rounded-xl border border-slate-100 shadow-sm mb-4">
        <table class="w-full min-w-[400px] text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">
              <th class="px-4 py-3">項目</th>
              <th class="px-4 py-3">Midjourney</th>
              <th class="px-4 py-3">Adobe Firefly</th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-white">
              <td class="px-4 py-3 font-medium text-slate-700 text-xs">日本語UI</td>
              <td class="px-4 py-3 text-slate-600 text-xs">非対応（英語のみ）</td>
              <td class="px-4 py-3 text-xs"><span class="text-emerald-700 font-medium">対応</span></td>
            </tr>
            <tr class="bg-slate-50">
              <td class="px-4 py-3 font-medium text-slate-700 text-xs">日本語プロンプト</td>
              <td class="px-4 py-3 text-slate-600 text-xs">一部対応（精度は英語より低め）</td>
              <td class="px-4 py-3 text-xs"><span class="text-emerald-700 font-medium">対応</span></td>
            </tr>
            <tr class="bg-white">
              <td class="px-4 py-3 font-medium text-slate-700 text-xs">日本語ドキュメント</td>
              <td class="px-4 py-3 text-slate-600 text-xs">非対応</td>
              <td class="px-4 py-3 text-xs"><span class="text-emerald-700 font-medium">対応</span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="text-sm text-slate-600 leading-relaxed">
        日本語環境での使いやすさはAdobe Fireflyが優位です。
        Midjourneyは英語UIのみのため、日本語利用者には操作の習熟が必要になります。
        <a href="/categories/japanese/" class="text-blue-600 hover:underline ml-1">日本語対応AIツール一覧も参考に →</a>
      </p>
    </section>

    <!-- ============================================================ -->
    <!-- 透かし条件                                                    -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">透かし（ウォーターマーク）条件の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-4">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-2 font-bold text-slate-900">Midjourney</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            公式情報上、有料プランでは生成画像に透かしは付与されない場合があります。最新の条件は公式サイトでご確認ください。
          </p>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-2 font-bold text-slate-900">Adobe Firefly</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            プランによっては可視透かしが入る場合があります。全プラン共通でC2PA標準の不可視メタデータ（コンテンツクレデンシャル）が埋め込まれる場合があります。
          </p>
        </div>
      </div>

      <p class="text-sm text-slate-600 leading-relaxed">
        透かし条件は利用用途に影響します。商用利用時は透かしの有無を必ず確認してください。
        <a href="/categories/no-watermark/" class="text-blue-600 hover:underline ml-1">透かしなしAIツール一覧も参考に →</a>
      </p>
    </section>

    <!-- ============================================================ -->
    <!-- 用途別おすすめ                                               -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-5 text-2xl font-bold text-[#002B61]">用途別おすすめ</h2>

      <div class="space-y-4">
        {[
          {
            useCase: 'YouTubeサムネイル',
            mj: '品質重視のサムネ制作向き。ただし商用利用条件（公式規約）を要確認',
            ff: '商用利用を想定した設計。日本語でのプロンプト入力もしやすい',
            recommend: 'どちらも利用規約の確認が必要',
          },
          {
            useCase: 'SNS画像',
            mj: 'スタイルの幅が広く、個性的なビジュアル生成に向く',
            ff: '日本語対応・Photoshop連携で素材加工しやすい',
            recommend: '用途・頻度によって判断',
          },
          {
            useCase: '広告バナー・商用素材',
            mj: '有料プランで商用利用可能な場合あり。規約条件あり',
            ff: 'Adobe公式情報上、商用利用を想定した設計として案内（β機能は対象外）',
            recommend: '商用利用前に最新規約を必ず確認',
          },
          {
            useCase: 'コンセプトアート・イラスト',
            mj: 'アート表現・スタイル探索に強み',
            ff: '写実的素材向き。アート表現の自由度はMidjourneyより狭め',
            recommend: 'Midjourneyが向いている傾向',
          },
          {
            useCase: '企業・チーム利用',
            mj: '年間収益100万ドル超の企業はPro/Megaプランへの移行が必要（規約）',
            ff: 'Adobe Creative Cloud環境・チームとの連携に向く',
            recommend: '規模・Adobe導入状況によって判断',
          },
          {
            useCase: '初心者',
