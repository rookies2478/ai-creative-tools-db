---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';

const faqs = [
  {
    q: 'Stable DiffusionとMidjourneyはどちらが無料で使えますか？',
    a: 'Stable Diffusionはローカル環境（自分のPC）で無料実行できます。ただしGPU搭載PCと環境構築が必要です。Midjourneyは現在無料プランが提供されていない場合があります（2024年末に廃止されたとされています）。クラウド経由で手軽に試したい場合は、別途無料枠があるツールも参考にしてください。',
  },
  {
    q: 'Stable Diffusionは商用利用できますか？',
    a: '利用するモデルのバージョンによってライセンスが異なります。SD 1.x/2.x（CreativeML Open RAIL-M）は条件付きで商用利用できる場合があります。SD 3.x以降（Stability AI Community License）は年間総収益100万ドル未満の場合に商用利用できる場合があるとされています。コミュニティ配布のカスタムモデル・LoRAはそれぞれ独自のライセンスを持つ場合があり、個別確認が必要です。本記事は法的助言ではありません。',
  },
  {
    q: 'Midjourneyは商用利用できますか？',
    a: '公式情報上、有料プランでは商用利用ができる場合があります。ただし年間総収益が100万ドル超の企業はPro/Megaプランへのアップグレードが利用規約上必要とされています。条件・規約は変更される可能性があるため、利用前に最新の公式利用規約をご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'Stable Diffusionは日本語で使えますか？',
    a: 'AUTOMATIC1111 Web UIなど一部の実装では日本語化拡張機能を導入することで日本語UIにできる場合があります。日本語プロンプトは一部対応ですが、英語プロンプトの方が精度が高い傾向があります。MidjourneyはUIが英語のみです。日本語環境での利用を重視する場合はどちらも追加の対応が必要になる点に注意してください。',
  },
  {
    q: '初心者にはStable DiffusionとMidjourneyのどちらが向いていますか？',
    a: 'Midjourneyはブラウザ（Web版）またはDiscordから比較的手軽に高品質な画像を生成できるとされています。ただし英語UIのみです。Stable Diffusionはローカル環境構築（GPU・依存ライブラリ等）の知識が必要で、初心者には難易度が高い場合があります。クラウド経由のサービスを使えば環境構築は不要ですが、別途費用が発生する場合があります。',
  },
  {
    q: 'Stable DiffusionはYouTubeサムネイルや広告に使えますか？',
    a: '利用するモデルのライセンスによって条件が異なります。商用利用を前提にする場合は、使用するモデルのライセンス（SD 3.x以降はStability AI Community License等）を必ずご確認ください。また、コミュニティ配布のモデル・LoRAはそれぞれ独自のライセンスを持つ場合があり、個別確認が必要です。本記事は法的助言ではありません。',
  },
];

const comparisonRows = [
  {
    item: '料金',
    sd: 'ローカル実行は無料（GPU搭載PC・環境構築が必要）。クラウドサービス経由は別途課金',
    mj: '$10/月（Basicプラン・月払い）。無料プランなし',
  },
  {
    item: '無料プラン',
    sd: 'ローカル実行は無料（要環境構築）',
    mj: 'なし（2024年末廃止とされる）',
  },
  {
    item: '利用形態',
    sd: 'ローカル実行・API・クラウドサービス',
    mj: 'Discord・Web版（クラウドのみ）',
  },
  {
    item: '商用利用',
    sd: 'モデル・バージョン・ライセンスによって異なる（要個別確認）',
    mj: '有料プランで可能な場合あり（条件あり。大企業は上位プランが必要とされる）',
  },
  {
    item: '日本語UI',
    sd: '一部対応（実装・拡張機能による）',
    mj: '非対応（英語のみ）',
  },
  {
    item: '日本語プロンプト',
    sd: '一部対応（英語より精度低め。翻訳拡張機能の利用が推奨される場合あり）',
    mj: '一部対応（英語より精度低め）',
  },
  {
    item: '透かし',
    sd: '一部バージョンで不可視透かしが埋め込まれる場合あり',
    mj: '有料プランでは透かしなし（要確認）',
  },
  {
    item: 'カスタマイズ性',
    sd: 'モデル選択・LoRA・拡張機能など高度なカスタマイズが可能',
    mj: 'スタイルプリセット・パラメータ調整（カスタムモデル不可）',
  },
  {
    item: 'オープンソース',
    sd: 'あり（モデルウェイトが公開）',
    mj: 'なし（クローズドサービス）',
  },
  {
    item: '初心者向けか',
    sd: '環境構築・知識が必要。難易度高め',
    mj: 'Web版で比較的手軽。英語UIへの慣れが必要',
  },
];

const relatedLinks = [
  { href: '/tools/stable-diffusion/', label: 'Stable Diffusion詳細' },
  { href: '/tools/midjourney/', label: 'Midjourney詳細' },
  { href: '/categories/commercial-use/', label: '商用利用確認しやすいAIツール' },
  { href: '/categories/free/', label: '無料枠ありAIツール' },
  { href: '/categories/japanese/', label: '日本語対応AIツール' },
  { href: '/categories/no-watermark/', label: '透かしなしAIツール' },
  { href: '/compare/', label: 'AI画像・動画ツール比較表' },
];
---

<BaseLayout
  title="Stable DiffusionとMidjourneyを比較：無料・商用利用・画質・自由度の違い | AIクリエイティブツール比較DB"
  description="Stable DiffusionとMidjourneyを料金・無料枠・ローカル利用・商用利用条件・カスタマイズ性・日本語対応・透かし・用途の観点で比較。YouTubeサムネ・SNS・広告・コンセプトアートなど用途別のおすすめも整理しています。"
  canonicalPath="/compare/stable-diffusion-vs-midjourney/"
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <!-- パンくずナビ -->
    <nav class="mb-6 text-sm text-gray-500" aria-label="パンくずリスト">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/compare/" class="hover:underline">比較表</a>
      <span class="mx-1">/</span>
      <span>Stable DiffusionとMidjourney比較</span>
    </nav>

    <!-- H1 -->
    <h1 class="mb-4 text-3xl font-bold text-gray-900">
      Stable DiffusionとMidjourneyを比較：無料・商用利用・画質・自由度の違い
    </h1>

    <!-- 最終確認日 -->
    <p class="mb-6 text-xs text-slate-400">最終確認：2026年5月14日 ／ 掲載情報は変更される場合があります</p>

    <!-- 注意ボックス -->
    <div class="mb-8 rounded-lg border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800 leading-relaxed">
      <p class="mb-1 font-semibold">ご確認ください</p>
      <ul class="mt-2 space-y-1.5 list-disc list-inside">
        <li>料金・無料枠・商用利用条件・透かし条件は変更される場合があります。</li>
        <li>Stable Diffusionは利用するモデル・配布元・ライセンスによって条件が異なる場合があります。</li>
        <li>最新情報は各ツールの<strong>公式サイト・料金ページ・利用規約・モデルライセンス</strong>をご確認ください。</li>
        <li>本記事は情報提供を目的としており、<strong>法的助言ではありません</strong>。</li>
      </ul>
    </div>

    <!-- ============================================================ -->
    <!-- 結論サマリー                                                  -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <div class="rounded-xl border border-blue-100 bg-blue-50 px-6 py-5">
        <h2 class="mb-3 text-lg font-bold text-blue-900">結論：どちらを選ぶべきか</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="rounded-lg bg-white border border-blue-100 px-5 py-4">
            <p class="mb-2 text-sm font-bold text-slate-800">無料・ローカル・自由度重視 → <a href="/tools/stable-diffusion/" class="text-blue-600 hover:underline">Stable Diffusion</a></p>
            <p class="text-xs leading-relaxed text-slate-600">
              オープンソースでモデルウェイトが公開されており、GPU搭載PCがあればローカル環境で無料実行できます。
              カスタムモデル・LoRAを活用した高度な生成が可能で、自由度・カスタマイズ性を重視する方に向いています。
              ただし環境構築に技術知識が必要で、商用利用条件は利用するモデルによって異なるため個別確認が必要です。
            </p>
          </div>
          <div class="rounded-lg bg-white border border-blue-100 px-5 py-4">
            <p class="mb-2 text-sm font-bold text-slate-800">高品質ビジュアル・手軽さ重視 → <a href="/tools/midjourney/" class="text-blue-600 hover:underline">Midjourney</a></p>
            <p class="text-xs leading-relaxed text-slate-600">
              アート・イラスト・写真風など幅広いスタイルで高品質な画像生成に定評があります。
              Web版またはDiscordから操作でき、環境構築不要で利用できます。
              英語UIのみで有料プランのみの提供です。商用利用条件は最新の公式規約をご確認ください。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 基本比較表                                                    -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">Stable DiffusionとMidjourneyの基本比較表</h2>
      <p class="mb-4 text-sm text-slate-500">
        以下は参考情報です。内容は変更される場合があります。最新情報は各公式サイトでご確認ください。
      </p>
      <div class="overflow-x-auto rounded-xl border border-slate-100 shadow-sm">
        <table class="w-full min-w-[560px] text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">
              <th class="px-4 py-3 w-1/3">比較項目</th>
              <th class="px-4 py-3 w-1/3">Stable Diffusion</th>
              <th class="px-4 py-3 w-1/3">Midjourney</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map(({ item, sd, mj }, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                <td class="px-4 py-3 font-medium text-slate-700 text-xs">{item}</td>
                <td class="px-4 py-3 text-slate-600 text-xs leading-relaxed">{sd}</td>
                <td class="px-4 py-3 text-slate-600 text-xs leading-relaxed">{mj}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-slate-400">
        情報は確認時点のものです。最新の料金・条件は各公式サイトをご参照ください。
      </p>
    </section>

    <!-- ============================================================ -->
    <!-- 料金・無料枠の違い                                            -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">料金・無料枠の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-5">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Stable Diffusion</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed">
            <li><span class="font-medium">ローカル実行：</span>無料（GPU搭載PCと環境構築が必要）</li>
            <li><span class="font-medium">クラウドサービス：</span>Dream Studioなど有料サービス経由では別途費用が発生</li>
            <li><span class="font-medium">API利用：</span>Stability AI APIは別途従量課金</li>
          </ul>
          <p class="mt-3 text-xs text-slate-400">最新情報は<a href="https://stability.ai" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">Stability AI公式サイト</a>でご確認ください。</p>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed">
            <li><span class="font-medium">無料プラン：</span>なし（2024年末に廃止されたとされています）</li>
            <li><span class="font-medium">最低プラン：</span>Basicプラン $10/月（年払いで$8/月）</li>
            <li><span class="font-medium">上位プラン：</span>Standard $30/月〜、Pro $60/月〜、Mega $120/月〜</li>
          </ul>
          <p class="mt-3 text-xs text-slate-400">最新料金は<a href="https://www.midjourney.com" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">Midjourney公式サイト</a>でご確認ください。</p>
        </div>
      </div>

      <div class="rounded-lg border border-slate-100 bg-slate-50 px-5 py-4 text-sm text-slate-600 leading-relaxed">
        <p>
          <strong>費用を抑えたい方：</strong>Stable Diffusionはローカル環境があれば生成自体は無料ですが、GPU搭載PCの準備が必要です。
          Midjourneyは環境構築不要ですが有料プランのみです。
          <a href="/categories/free/" class="text-blue-600 hover:underline ml-1">無料枠があるAIツール一覧も参考にしてください →</a>
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- ローカル利用・Web利用の違い                                   -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">ローカル利用・Web利用の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-5">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Stable Diffusion</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>ローカル環境（Windows/Mac/Linux）で実行可能</li>
            <li>AUTOMATIC1111 Web UI・ComfyUIなどのフロントエンドで操作</li>
            <li>標準的な構成では生成データが外部に送信されにくい</li>
            <li>GPU搭載PCと環境構築の知識が必要</li>
            <li>API経由でのクラウド利用も可能</li>
          </ul>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>クラウドのみ（ローカル実行不可）</li>
            <li>Discord経由またはWeb版で利用</li>
            <li>環境構築不要で手軽に使い始められる</li>
            <li>生成データはMidjourneyのサーバーに送信される</li>
          </ul>
        </div>
      </div>

      <div class="rounded-lg border border-slate-100 bg-slate-50 px-5 py-4 text-sm text-slate-600 leading-relaxed">
        <p>
          プライバシーを重視する場合や、インターネット環境がない場所での利用を想定している場合は、ローカル実行が可能なStable Diffusionが候補になります（標準的な構成での傾向であり、利用する実装・拡張機能によって異なる場合があります）。
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 商用利用条件の違い                                            -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">商用利用条件の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-5">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Stable Diffusion</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-3">
            <strong>利用するモデルのバージョン・配布元によってライセンスが異なります。</strong>
          </p>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>SD 1.x/2.x（CreativeML Open RAIL-M）：条件付きで商用利用できる場合あり</li>
            <li>SD 3.x以降（Stability AI Community License）：年間総収益100万ドル未満は商用利用できる場合があるとされている。100万ドル以上はエンタープライズ契約が必要とされている</li>
            <li>コミュニティ配布のカスタムモデル・LoRAは独自のライセンスを持つ場合があり、個別確認が必要</li>
          </ul>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            公式情報上、有料プランでは商用利用ができる場合があります。ただし、<strong>年間総収益が100万ドル超の企業はPro/Megaプランへのアップグレードが利用規約上必要</strong>とされています。
            条件・規約は変更される可能性があるため、利用前に最新の公式利用規約をご確認ください。
          </p>
        </div>
      </div>

      <div class="rounded-lg border border-amber-100 bg-amber-50 px-5 py-4 text-sm text-amber-800 leading-relaxed">
        <p class="font-semibold mb-1">商用利用を前提にする場合は</p>
        <p>
          どちらのツールも「絶対に商用利用できる」とは断言できません。Stable Diffusionは利用するモデルやプランによって条件が異なる可能性があります。
          商用利用前は必ず最新の公式規約およびモデルライセンスをご確認ください。本記事は法的助言ではありません。
          <a href="/categories/commercial-use/" class="text-blue-600 hover:underline ml-1">商用利用を確認しやすいAIツール一覧も参考に →</a>
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 生成品質・表現の自由度                                        -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">生成品質・表現の自由度の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Stable Diffusion</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>カスタムモデル・LoRAを活用することで特定スタイルへの特化が可能</li>
            <li>モデルの選択次第で幅広いスタイルに対応</li>
            <li>テキスト→画像、画像→画像、インペインティング、アウトペインティングに対応</li>
            <li>コミュニティから多数のモデルが公開されている</li>
          </ul>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>アート・イラスト・写真風など幅広いスタイルに対応</li>
            <li>業界トップクラスの画像品質と評される場合が多い</li>
            <li>v6以降、プロンプト精度が向上しているとされる</li>
            <li>スタイルプリセット対応。カスタムモデルの追加は非対応</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- カスタマイズ性の違い                                          -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-[#002B61]">カスタマイズ性の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-4">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Stable Diffusion</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>モデルウェイトが公開されており、モデルを自由に選択・切り替え可能</li>
            <li>LoRA・Embedding・Hypernetworkなどファインチューニング手法に対応</li>
            <li>AUTOMATIC1111 Web UI・ComfyUIなど多様なフロントエンドが存在</li>
            <li>拡張機能による機能追加が可能</li>
          </ul>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
