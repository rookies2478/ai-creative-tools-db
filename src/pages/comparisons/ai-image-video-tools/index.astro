---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';

const tools = await getCollection('tools');

const faqs = [
  {
    q: 'AI画像生成とAI動画生成の違いは何ですか？',
    a: 'AI画像生成は静止画（jpg/png等）を生成するツールです。AI動画生成はテキストや画像から数秒〜数十秒の動画クリップを生成するツールです。用途・必要なスペック・料金体系が大きく異なるため、目的に応じて選ぶことが重要です。',
  },
  {
    q: '画像生成と動画生成、どちらを先に試せばいいですか？',
    a: 'まず用途を明確にすることをおすすめします。SNS投稿画像・ブログアイキャッチ・ECサイト商品画像などの静止画用途なら画像生成ツール、SNS動画・プロモーション動画・プレゼン素材などの動画用途なら動画生成ツールが適しています。無料プランがあるツールから試すのが取り組みやすい方法です。',
  },
  {
    q: '商用利用する場合、画像と動画で確認ポイントは違いますか？',
    a: '基本的な確認事項（利用規約・プランごとの商用利用条件・透かし）は共通していますが、AI動画生成では音声・BGM素材の権利、人物・背景素材の権利、プラットフォームごとのポリシーなど追加で確認すべき点があります。商用利用前は必ず各ツールの最新公式規約をご確認ください。本記事は法的助言ではありません。',
  },
];
---

<BaseLayout
  title="AI画像生成・AI動画生成ツール比較｜用途・特徴・選び方ガイド"
  description="AI画像生成ツールとAI動画生成ツールの違いと選び方を解説。用途別の向き不向き、商用利用・透かし・無料プランの確認ポイントを整理しています。実務利用前に公式規約を必ずご確認ください。本記事は法的助言ではありません。"
  canonicalPath="/comparisons/ai-image-video-tools/"
>
  <div class="mx-auto max-w-5xl px-6 py-12">

    <nav class="mb-6 text-sm text-slate-500" aria-label="パンくずリスト">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/comparisons/" class="hover:underline">比較記事一覧</a>
      <span class="mx-1">/</span>
      <span>AI画像・動画ツール比較</span>
    </nav>

    <h1 class="mb-3 text-2xl font-bold text-slate-900 sm:text-3xl">
      AI画像生成・AI動画生成ツール比較
    </h1>
    <p class="mb-8 text-sm leading-relaxed text-slate-500">
      AI画像生成ツールとAI動画生成ツールの違いと、用途ごとの選び方を整理しています。
      商用利用・透かし・無料プランの確認ポイントも共通して解説します。
    </p>

    <!-- AI画像生成とAI動画生成の違い -->
    <section class="mb-10">
      <h2 class="mb-4 text-lg font-bold text-slate-800">AI画像生成とAI動画生成の違い</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-blue-100 bg-blue-50 p-5">
          <p class="mb-2 font-bold text-blue-800">AI画像生成ツール</p>
          <ul class="space-y-1 text-sm text-blue-900">
            <li>• テキストから静止画（png/jpg）を生成</li>
            <li>• SNS投稿画像・ブログアイキャッチ・ECサイト商品画像などに活用</li>
            <li>• 比較的低コストで利用できるツールが多い</li>
            <li>• 無料プランがあるツールも多数</li>
          </ul>
          <a href="/categories/image-generation/" class="mt-3 inline-block text-sm font-medium text-blue-600 hover:underline">AI画像生成ツール一覧 →</a>
        </div>
        <div class="rounded-xl border border-violet-100 bg-violet-50 p-5">
          <p class="mb-2 font-bold text-violet-800">AI動画生成ツール</p>
          <ul class="space-y-1 text-sm text-violet-900">
            <li>• テキストや静止画から短い動画クリップを生成</li>
            <li>• SNS動画・プロモーション動画・プレゼン素材などに活用</li>
            <li>• 画像生成よりも高負荷・高コストになる傾向</li>
            <li>• 音声・BGM素材の権利確認が追加で必要</li>
          </ul>
          <a href="/categories/video-generation/" class="mt-3 inline-block text-sm font-medium text-violet-600 hover:underline">AI動画生成ツール一覧 →</a>
        </div>
      </div>
    </section>

    <!-- 画像生成向きの用途 -->
    <section class="mb-10">
      <h2 class="mb-4 text-lg font-bold text-slate-800">画像生成ツールが向いている用途</h2>
      <div class="rounded-xl border border-slate-100 bg-white p-5">
        <ul class="space-y-2 text-sm text-slate-700">
          <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">▸</span><span>ブログ・記事のアイキャッチ画像</span></li>
          <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">▸</span><span>SNS投稿用静止画</span></li>
          <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">▸</span><span>ECサイトの商品イメージ素材</span></li>
          <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">▸</span><span>広告バナーのベース素材</span></li>
          <li class="flex items-start gap-2"><span class="text-blue-400 mt-0.5">▸</span><span>イラスト・コンセプトアート</span></li>
        </ul>
      </div>
    </section>

    <!-- 動画生成向きの用途 -->
    <section class="mb-10">
      <h2 class="mb-4 text-lg font-bold text-slate-800">動画生成ツールが向いている用途</h2>
      <div class="rounded-xl border border-slate-100 bg-white p-5">
        <ul class="space-y-2 text-sm text-slate-700">
          <li class="flex items-start gap-2"><span class="text-violet-400 mt-0.5">▸</span><span>SNS向けショート動画素材</span></li>
          <li class="flex items-start gap-2"><span class="text-violet-400 mt-0.5">▸</span><span>プレゼンテーション・提案資料の動画素材</span></li>
          <li class="flex items-start gap-2"><span class="text-violet-400 mt-0.5">▸</span><span>商品・サービスのプロモーション動画</span></li>
          <li class="flex items-start gap-2"><span class="text-violet-400 mt-0.5">▸</span><span>静止画から動きのある素材への変換</span></li>
        </ul>
      </div>
    </section>

    <!-- 比較ポイント -->
    <section class="mb-10">
      <h2 class="mb-4 text-lg font-bold text-slate-800">商用利用・無料プランの比較ポイント</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="bg-slate-50">
              <th class="border border-slate-200 px-4 py-2 text-left font-semibold text-slate-700">確認項目</th>
              <th class="border border-slate-200 px-4 py-2 text-left font-semibold text-slate-700">AI画像生成</th>
              <th class="border border-slate-200 px-4 py-2 text-left font-semibold text-slate-700">AI動画生成</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border border-slate-200 px-4 py-2 font-medium text-slate-700">無料プランの有無</td>
              <td class="border border-slate-200 px-4 py-2 text-slate-600">あり（多数）</td>
              <td class="border border-slate-200 px-4 py-2 text-slate-600">あり（一部）</td>
            </tr>
            <tr class="bg-slate-50">
              <td class="border border-slate-200 px-4 py-2 font-medium text-slate-700">透かし</td>
              <td class="border border-slate-200 px-4 py-2 text-slate-600">無料プランでは入る場合が多い</td>
              <td class="border border-slate-200 px-4 py-2 text-slate-600">無料プランでは入る場合が多い</td>
            </tr>
            <tr>
              <td class="border border-slate-200 px-4 py-2 font-medium text-slate-700">商用利用条件</td>
              <td class="border border-slate-200 px-4 py-2 text-slate-600">プランによって異なる</td>
              <td class="border border-slate-200 px-4 py-2 text-slate-600">プランによって異なる。音声素材の権利も確認要</td>
            </tr>
            <tr class="bg-slate-50">
              <td class="border border-slate-200 px-4 py-2 font-medium text-slate-700">日本語対応</td>
              <td class="border border-slate-200 px-4 py-2 text-slate-600">対応ツールあり</td>
              <td class="border border-slate-200 px-4 py-2 text-slate-600">英語UIが多い</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-2 text-xs text-slate-400">※ 各条件は変更される場合があります。最新情報は各公式サイトでご確認ください。本記事は法的助言ではありません。</p>
    </section>

    <!-- 関連リンク -->
    <section class="mb-10">
      <h2 class="mb-4 text-lg font-bold text-slate-800">関連ページ</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/categories/image-generation/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:border-slate-300">AI画像生成ツール一覧</a>
        <a href="/categories/video-generation/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:border-slate-300">AI動画生成ツール一覧</a>
        <a href="/comparisons/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:border-slate-300">比較記事一覧</a>
        <a href="/conditions/free/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:border-slate-300">無料で使えるツール</a>
        <a href="/conditions/commercial-use/" class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:border-slate-300">商用利用条件を確認しやすいツール</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-10">
      <h2 class="mb-6 text-lg font-bold text-slate-800">よくある質問</h2>
      <GuideFAQ items={faqs} />
    </section>

    <!-- 免責事項 -->
    <div class="rounded-xl border border-amber-100 bg-amber-50 p-5 text-sm leading-relaxed text-amber-800">
      <p class="font-semibold mb-1">免責事項</p>
      <p>
        本ページの情報は公式サイト・公式規約を参考に整理したものですが、内容の正確性・完全性を保証するものではありません。
        商用利用条件・著作権・透かし条件はプランや用途、時期によって変わる可能性があります。
        実務利用前には必ず各ツールの最新公式情報をご確認ください。本ページは法的助言ではありません。
      </p>
    </div>

  </div>
</BaseLayout>