---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ComparisonGuide from '../../../components/ComparisonGuide.astro';

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://aicreative-db.com/" },
    { "@type": "ListItem", "position": 2, "name": "比較記事", "item": "https://aicreative-db.com/comparisons/" },
    { "@type": "ListItem", "position": 3, "name": "AI画像・動画ツール比較", "item": "https://aicreative-db.com/comparisons/ai-image-video-tools/" },
  ],
});
---

<BaseLayout
  title="AI画像生成・AI動画生成ツールの使い分け方｜どちらを選ぶか比較 | AIクリエイティブナビ"
  description="AI画像生成ツールとAI動画生成ツールの違いと使い分け方を解説。静止画向き・動画向き・両方使うケースを整理し、商用利用・透かし・無料プランの確認ポイントもまとめています。実務利用前に公式規約を必ずご確認ください。本記事は法的助言ではありません。"
  canonicalPath="/comparisons/ai-image-video-tools/"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-5xl px-6 py-12">

    <nav class="mb-6 text-sm text-slate-500" aria-label="パンくずリスト">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/comparisons/" class="hover:underline">比較記事一覧</a>
      <span class="mx-1">/</span>
      <span>AI画像・動画ツール比較</span>
    </nav>

    <ComparisonGuide
      heading="AI画像生成・AI動画生成ツールの使い分け方比較"
      lead="静止画が必要なのか・動画クリップが必要なのか、まず「何を作りたいか」で選ぶツールは変わります。このページでは画像生成と動画生成の違い・向いている用途・両方使うケース・確認ポイントを整理します。どちらを選べばよいかわからない場合は、用途セクションの「画像生成が向いている用途 / 動画生成が向いている用途」を先に確認してください。商用利用条件・透かし・無料プランは両カテゴリで共通して確認が必要です。実務利用前に公式規約を必ずご確認ください。本記事は法的助言ではありません。"
    />

  </div>
</BaseLayout>
