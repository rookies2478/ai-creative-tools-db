---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';
import { getEntry } from 'astro:content';

const [toolDalle, toolMidjourney] = await Promise.all([
  getEntry('tools', 'dalle'),
  getEntry('tools', 'midjourney'),
]);
const toolDates = [toolDalle?.data.lastReviewed, toolMidjourney?.data.lastReviewed].filter(Boolean) as string[];
const latestDate = toolDates.length ? toolDates.sort().at(-1)! : null;
function formatDate(iso: string): string {
  const [y, m, d] = iso.split('-');
  return `${y}年${Number(m)}月${Number(d)}日`;
}

const faqs = [
  {
    q: 'DALL·EとMidjourneyはどちらが画質が良いですか？',
    a: 'Midjourneyはアート・イラスト・写真風など幅広いスタイルで高い表現力が評価されています。DALL·Eはプロンプトへの忠実度が高く、ChatGPTと組み合わせた指示通りの生成に向いているとされています。用途や好みによって評価が分かれますので、両方試して比較することをおすすめします。',
  },
  {
    q: 'DALL·Eは無料で使えますか？',
    a: 'ChatGPTの無料プランで制限付きの利用ができる場合があります。利用可能回数はプランや時期により変わる可能性があるため、最新の状況はOpenAI公式ヘルプをご確認ください。',
  },
  {
    q: 'DALL·EとMidjourneyは商用利用できますか？',
    a: 'DALL·EはOpenAI公式情報上、生成画像の商用利用ができる場合があります。Midjourneyは公式情報上、有料プランで商用利用できる場合があります（年間総収益100万ドル超の企業はPro/Megaプランへのアップグレードが必要とされています）。どちらも用途・生成内容・プランによって条件が異なる可能性があります。商用利用前は必ず最新の公式規約をご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'DALL·Eは日本語で使えますか？',
    a: 'ChatGPT経由のため、ChatGPTの日本語UIに準拠して利用できる場合があります。日本語プロンプトも一部対応していますが、画像内への日本語テキスト生成は精度が低い傾向があります。Midjourneyは英語UIのみです。',
  },
  {
    q: 'DALL·Eに透かしは入りますか？',
    a: '従来型の可視透かしは付与されませんが、C2PA標準の不可視メタデータが埋め込まれる場合があります。Midjourneyは有料プランでは透かしが入らない場合があります。最新の条件は各公式サイトでご確認ください。',
  },
  {
    q: 'ChatGPTを使っていますが、DALL·EとMidjourneyどちらが使いやすいですか？',
    a: 'ChatGPTをすでに利用している場合、DALL·EはChatGPT上で追加設定なしに利用できます。日本語UIで操作でき、チャット形式での指示も可能です。Midjourneyは別途サービスへの登録とDiscordまたはWeb版の操作が必要です。手軽さではDALL·Eが向いています。',
  },
  {
    q: 'ブログアイキャッチやSNS画像にはどちらが向いていますか？',
    a: 'ブログアイキャッチでは、記事内容に沿った説明的な画像案を作りたい場合はDALL·E（ChatGPT経由）が取り組みやすい選択肢です。雰囲気のあるビジュアルやアート調の画像案を作りたい場合はMidjourneyが候補になります。SNS投稿画像も同様に、用途・求めるクオリティ・費用の観点で検討してください。',
  },
  {
    q: '商用利用前に何を確認すべきですか？',
    a: '利用するプランの規約・生成物の扱いに関する条件・人物画像やブランドロゴ・第三者素材が含まれる場合の条件を、OpenAIとMidjourney各々の公式規約で別々に確認してください。透かし、生成回数、出力サイズの条件もプランによって異なる場合があります。本記事は法的助言ではありません。',
  },
];

const comparisonRows = [
  {
    item: '料金（最低プラン）',
    dalle: 'ChatGPT Plus等の有料プランで利用枠拡大（詳細は公式参照）',
    mj: '$10/月（Basicプラン・月払い）',
  },
  {
    item: '無料プラン',
    dalle: 'ChatGPT無料プランで制限付き利用できる場合あり',
    mj: 'なし（2024年末廃止とされる）',
  },
  {
    item: '商用利用',
    dalle: 'OpenAI公式情報上、商用利用できる場合あり（条件あり）',
    mj: '有料プランで可能な場合あり（条件・大企業は上位プランが必要）',
  },
  {
    item: '日本語UI',
    dalle: 'ChatGPTに準拠（対応）',
    mj: '非対応（英語のみ）',
  },
  {
    item: '日本語プロンプト',
    dalle: '一部対応（画像内テキストは精度低め）',
    mj: '一部対応（英語より精度低め）',
  },
  {
    item: '透かし',
    dalle: '可視透かしなし。C2PAメタデータ（不可視）が埋め込まれる場合あり',
    mj: '有料プランでは透かしなし（要確認）',
  },
  {
    item: 'ChatGPT連携',
    dalle: 'ChatGPT上で追加設定なしに利用可能',
    mj: '非対応（別サービス）',
  },
  {
    item: '対応環境',
    dalle: 'Web（ChatGPT）・API',
    mj: 'Discord・Web',
  },
  {
    item: '表現の自由度',
    dalle: 'プロンプト忠実度が高い・スタイルの幅は限定的傾向',
    mj: 'スタイルの幅が広い・アート表現に強み',
  },
  {
    item: '初心者向けか',
    dalle: 'ChatGPTの日本語UIで操作しやすい',
    mj: '英語UI・要習熟',
  },
  {
    item: '生成後の編集しやすさ',
    dalle: 'ChatGPT上でインペインティング（部分修正）・テキスト指示での再生成に対応',
    mj: 'Vary（バリエーション生成）・Zoom Out・パン等に対応。外部ツールでの編集は別途必要',
  },
];

const relatedLinks = [
  { href: '/tools/dalle/', label: 'DALL·E詳細' },
  { href: '/tools/midjourney/', label: 'Midjourney詳細' },
  { href: '/conditions/commercial-use/', label: '商用利用確認しやすいAIツール' },
  { href: '/conditions/free/', label: '無料枠ありAIツール' },
  { href: '/conditions/japanese/', label: '日本語対応AIツール' },
  { href: '/conditions/no-watermark/', label: '透かしなしAIツール' },
  { href: '/comparisons/', label: 'AI画像・動画ツール比較表' },
  { href: '/comparisons/midjourney-vs-adobe-firefly/', label: 'Midjourney vs Adobe Firefly比較' },
  { href: '/guides/commercial-use-copyright/', label: '商用利用・著作権ガイド' },
];

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "DALL·EとMidjourneyを比較：料金・商用利用・日本語対応・用途の違い",
  "description": "DALL·EとMidjourneyを料金・無料枠・商用利用条件・日本語対応・ChatGPT連携・透かし・向いている用途の観点で比較。YouTubeサムネ・SNS・広告・初心者利用など用途別のおすすめも整理しています。",
  "url": "https://aicreative-db.com/comparisons/dalle-vs-midjourney/",
  "mainEntityOfPage": "https://aicreative-db.com/comparisons/dalle-vs-midjourney/",
  "author": {
    "@type": "Organization",
    "name": "AIクリエイティブナビ編集部"
  },
  "publisher": {
    "@type": "Organization",
    "name": "AIクリエイティブナビ",
    "url": "https://aicreative-db.com/"
  },
  ...(latestDate ? { "dateModified": latestDate } : {}),
});
---

<BaseLayout
  title="DALL·EとMidjourneyを比較：料金・商用利用・日本語対応・用途の違い | AIクリエイティブナビ"
  description="DALL·EとMidjourneyを料金・無料枠・商用利用条件・日本語対応・ChatGPT連携・透かし・向いている用途の観点で比較。YouTubeサムネ・SNS・広告・初心者利用など用途別のおすすめも整理しています。"
  canonicalPath="/comparisons/dalle-vs-midjourney/"
  jsonLd={articleJsonLd}
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <!-- パンくずナビ -->
    <nav class="mb-6 text-sm text-slate-500" aria-label="パンくずリスト">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/comparisons/" class="hover:underline">比較表</a>
      <span class="mx-1">/</span>
      <span>DALL·EとMidjourney比較</span>
    </nav>

    <!-- H1 -->
    <h1 class="mb-4 text-3xl font-bold text-slate-900">
      DALL·EとMidjourneyを比較：料金・商用利用・日本語対応・用途の違い
    </h1>

    <!-- 掲載ツール情報の最終確認日 -->
    <p class="mb-6 text-xs text-slate-400">掲載ツール情報の最終確認：{latestDate ? formatDate(latestDate) : '要確認'} ／ 掲載情報は変更される場合があります</p>

    <!-- 注意ボックス -->
    <div class="mb-8 rounded-lg border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800 leading-relaxed">
      <p class="mb-1 font-semibold">ご確認ください</p>
      <ul class="mt-2 space-y-1.5 list-disc list-inside">
        <li>料金・無料枠・商用利用条件・透かし条件は変更される場合があります。</li>
        <li>最新情報は各ツールの<strong>公式サイト・料金ページ・利用規約</strong>をご確認ください。</li>
        <li><strong>OpenAI側の利用条件とMidjourney側の利用条件は別々にご確認ください</strong>（条件は独立しています）。</li>
        <li>人物・著名人・ブランドロゴ・第三者素材を扱う場合は<strong>特に注意</strong>が必要です。</li>
        <li>本記事は情報提供を目的としており、<strong>法的助言ではありません</strong>。</li>
      </ul>
    </div>

    <!-- ============================================================ -->
    <!-- 結論サマリー                                                  -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <div class="rounded-xl border border-blue-100 bg-blue-50 px-6 py-5">
        <h2 class="mb-3 text-lg font-bold text-blue-900">結論：どちらを選ぶべきか</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="rounded-lg bg-white border border-blue-100 px-5 py-4">
            <p class="mb-2 text-sm font-bold text-slate-800">手軽さ・ChatGPT連携重視 → <a href="/tools/dalle/" class="text-blue-600 hover:underline">DALL·E</a></p>
            <p class="text-xs leading-relaxed text-slate-600">
              ChatGPTと統合されており、追加設定なしで日本語UIから利用できます。
              ChatGPTの無料プランでも制限付きで試せる場合があり、初心者や既存のChatGPTユーザーに取り組みやすい選択肢です。
              OpenAI公式情報上、商用利用が案内されています（条件あり）。
            </p>
          </div>
          <div class="rounded-lg bg-white border border-blue-100 px-5 py-4">
            <p class="mb-2 text-sm font-bold text-slate-800">高品質なビジュアル表現重視 → <a href="/tools/midjourney/" class="text-blue-600 hover:underline">Midjourney</a></p>
            <p class="text-xs leading-relaxed text-slate-600">
              アート・イラスト・写真風など幅広いスタイルで高品質な画像生成に定評があります。
              英語UIのみで有料プランのみの提供ですが、クリエイティブな表現を追求したい方に向いています。
              商用利用条件は最新の公式規約をご確認ください。
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 基本比較表                                                    -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">DALL·EとMidjourneyの基本比較表</h2>
      <p class="mb-4 text-sm text-slate-500">
        以下は参考情報です。内容は変更される場合があります。最新情報は各公式サイトでご確認ください。
      </p>
      <div class="overflow-x-auto rounded-xl border border-slate-100 shadow-sm">
        <table class="w-full min-w-[560px] text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">
              <th class="px-4 py-3 w-1/3">比較項目</th>
              <th class="px-4 py-3 w-1/3">DALL·E</th>
              <th class="px-4 py-3 w-1/3">Midjourney</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map(({ item, dalle, mj }, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                <td class="px-4 py-3 font-medium text-slate-700 text-xs">{item}</td>
                <td class="px-4 py-3 text-slate-600 text-xs leading-relaxed">{dalle}</td>
                <td class="px-4 py-3 text-slate-600 text-xs leading-relaxed">{mj}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-slate-400">
        情報は確認時点のものです。最新の料金・条件は各公式サイトをご参照ください。
      </p>
    </section>

    <!-- ============================================================ -->
    <!-- 料金・無料枠の違い                                            -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">料金・無料枠の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-5">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">DALL·E</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed">
            <li><span class="font-medium">無料プラン：</span>ChatGPT無料プランで制限付き利用できる場合あり</li>
            <li><span class="font-medium">有料プラン：</span>ChatGPT Plus等の有料プランで利用枠が拡大する場合あり</li>
            <li><span class="font-medium">API：</span>別途従量課金（詳細はOpenAI公式参照）</li>
          </ul>
          <p class="mt-3 text-xs text-slate-400">最新情報は<a href="https://openai.com/pricing" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">OpenAI公式料金ページ</a>でご確認ください。</p>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed">
            <li><span class="font-medium">無料プラン：</span>なし（2024年末に廃止されたとされています）</li>
            <li><span class="font-medium">最低プラン：</span>Basicプラン $10/月（年払いで$8/月）</li>
            <li><span class="font-medium">上位プラン：</span>Standard $30/月〜、Pro $60/月〜、Mega $120/月〜</li>
          </ul>
          <p class="mt-3 text-xs text-slate-400">最新料金は<a href="https://www.midjourney.com" class="text-blue-600 hover:underline" target="_blank" rel="noopener noreferrer">Midjourney公式サイト</a>でご確認ください。</p>
        </div>
      </div>

      <div class="rounded-lg border border-slate-100 bg-slate-50 px-5 py-4 text-sm text-slate-600 leading-relaxed">
        <p>
          <strong>まず試したい方：</strong>DALL·EはChatGPTの無料プランで制限付きながら試せる場合があります。
          Midjourneyは有料プランのみですが、品質を重視するユーザーから高い評価を受けています。
          <a href="/conditions/free/" class="text-blue-600 hover:underline ml-1">無料枠があるAIツール一覧も参考にしてください →</a>
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 商用利用条件の違い                                            -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">商用利用条件の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 mb-5">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">DALL·E</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            OpenAI公式情報上、DALL·E 3で生成した画像の商用利用ができる場合があります。
            ただし、<strong>用途・生成内容・第三者の権利・OpenAIポリシー</strong>により制限される場合があります。
            条件・規約は変更される可能性があるため、利用前に最新の公式利用規約をご確認ください。
          </p>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            公式情報上、有料プランでは商用利用ができる場合があります。ただし、<strong>年間総収益が100万ドル超の企業はPro/Megaプランへのアップグレードが利用規約上必要</strong>とされています。
            条件・規約は変更される可能性があるため、利用前に最新の公式利用規約をご確認ください。
          </p>
        </div>
      </div>

      <div class="rounded-lg border border-amber-100 bg-amber-50 px-5 py-4 text-sm text-amber-800 leading-relaxed">
        <p class="font-semibold mb-1">商用利用を前提にする場合は</p>
        <p>
          どちらのツールも「絶対に商用利用できる」とは断言できません。プランや用途によって条件が異なる可能性があります。
          商用利用前は必ず最新の公式規約をご確認ください。本記事は法的助言ではありません。
          <a href="/conditions/commercial-use/" class="text-blue-600 hover:underline ml-1">商用利用を確認しやすいAIツール一覧も参考に →</a>
        </p>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 生成品質・表現の自由度                                        -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">生成品質・表現の自由度の違い</h2>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">DALL·E</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>プロンプトへの忠実度が高く、指示通りの画像を生成しやすい傾向</li>
            <li>ChatGPTとの対話形式で細かい調整が可能</li>
            <li>インペインティング（部分修正）に対応</li>
            <li>スタイルの自由度・表現の幅は限定的な傾向</li>
          </ul>
        </div>
        <div class="rounded-xl border border-slate-100 bg-white p-5 shadow-sm">
          <h3 class="mb-3 font-bold text-slate-900">Midjourney</h3>
          <ul class="text-sm text-slate-600 space-y-2 leading-relaxed list-disc list-inside">
            <li>アート・イラスト・写真風など幅広いスタイルに対応</li>
            <li>業界トップクラスの画像品質と評される場合が多い</li>
            <li>v6以降、プロンプト精度が向上しているとされる</li>
            <li>スタイル指定の自由度が高い</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 日本語対応                                                    -->
    <!-- ============================================================ -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-bold text-slate-900">日本語対応・使いやすさの違い</h2>

      <div class="overflow-x-auto rounded-xl border border-slate-100 shadow-sm mb-4">
        <table class="w-full min-w-[400px] text-sm">
          <thead>
            <tr class="bg-slate-50 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">
              <th class="px-4 py-3">項目</th>
              <th class="px-4 py-3">DALL·E</th>
              <th class="px-4 py-3">Midjourney</th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-white">
              <td class="px-4 py-3 font-medium text-slate-700 text-xs">日本語UI</td>
              <td class="px-4 py-3 text-xs"><span class="text-emerald-700 font-medium">対応（ChatGPTに準拠）</span></td>
              <td class="px-4 py-3 text-slate-600 text-xs">非対応（英語のみ）</td>
            </tr>
            <tr class="bg-slate-50">
              <td class="px-4 py-3 font-medium text-slate-700 text-xs">日本語プロンプト</td>
              <td class="px-4 py-3 text-xs"><span class="text-amber-700 font-medium">一部対応（画像内テキストは精度低め）</span></td>
