---
import ComparisonVsArticle from '../../../components/ComparisonVsArticle.astro';
import { getEntry } from 'astro:content';

const [toolDalle, toolMidjourney] = await Promise.all([
  getEntry('tools', 'dalle'),
  getEntry('tools', 'midjourney'),
]);
const toolDates = [toolDalle?.data.lastReviewed, toolMidjourney?.data.lastReviewed].filter(Boolean) as string[];
const latestDate = toolDates.length ? toolDates.sort().at(-1)! : null;

const faqs = [
  {
    q: 'DALL·EとMidjourneyはどちらが画質が良いですか？',
    a: 'Midjourneyはアート・イラスト・写真風など幅広いスタイルで高い表現力が評価されています。DALL·Eはプロンプトへの忠実度が高く、ChatGPTと組み合わせた指示通りの生成に向いているとされています。用途や好みによって評価が分かれますので、両方試して比較することをおすすめします。',
  },
  {
    q: 'DALL·Eは無料で使えますか？',
    a: 'ChatGPTの無料プランで制限付きの利用ができる場合があります。利用可能回数はプランや時期により変わる可能性があるため、最新の状況はOpenAI公式ヘルプをご確認ください。',
  },
  {
    q: 'DALL·EとMidjourneyは商用利用できますか？',
    a: 'DALL·EはOpenAI公式情報上、生成画像の商用利用ができる場合があります。Midjourneyは公式情報上、有料プランで商用利用できる場合があります（年間総収益100万ドル超の企業はPro/Megaプランへのアップグレードが必要とされています）。どちらも用途・生成内容・プランによって条件が異なる可能性があります。商用利用前は必ず最新の公式規約をご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'DALL·Eは日本語で使えますか？',
    a: 'ChatGPT経由のため、ChatGPTの日本語UIに準拠して利用できる場合があります。日本語プロンプトも一部対応していますが、画像内への日本語テキスト生成は精度が低い傾向があります。Midjourneyは英語UIのみです。',
  },
  {
    q: 'DALL·Eに透かしは入りますか？',
    a: '従来型の可視透かしは付与されませんが、C2PA標準の不可視メタデータが埋め込まれる場合があります。Midjourneyは有料プランでは透かしが入らない場合があります。最新の条件は各公式サイトでご確認ください。',
  },
  {
    q: 'ChatGPTを使っていますが、DALL·EとMidjourneyどちらが使いやすいですか？',
    a: 'ChatGPTをすでに利用している場合、DALL·EはChatGPT上で追加設定なしに利用できます。日本語UIで操作でき、チャット形式での指示も可能です。Midjourneyは別途サービスへの登録とDiscordまたはWeb版の操作が必要です。手軽さではDALL·Eが向いています。',
  },
  {
    q: 'ブログアイキャッチやSNS画像にはどちらが向いていますか？',
    a: 'ブログアイキャッチでは、記事内容に沿った説明的な画像案を作りたい場合はDALL·E（ChatGPT経由）が取り組みやすい選択肢です。雰囲気のあるビジュアルやアート調の画像案を作りたい場合はMidjourneyが候補になります。SNS投稿画像も同様に、用途・求めるクオリティ・費用の観点で検討してください。',
  },
  {
    q: '商用利用前に何を確認すべきですか？',
    a: '利用するプランの規約・生成物の扱いに関する条件・人物画像やブランドロゴ・第三者素材が含まれる場合の条件を、OpenAIとMidjourney各々の公式規約で別々に確認してください。透かし、生成回数、出力サイズの条件もプランによって異なる場合があります。本記事は法的助言ではありません。',
  },
];

const comparisonRows = [
  { item: '料金（最低プラン）', toolA: 'ChatGPT Plus等の有料プランで利用枠拡大（詳細は公式参照）', toolB: '$10/月（Basicプラン・月払い）' },
  { item: '無料プラン', toolA: 'ChatGPT無料プランで制限付き利用できる場合あり', toolB: 'なし（2024年末廃止とされる）' },
  { item: '商用利用', toolA: 'OpenAI公式情報上、商用利用できる場合あり（条件あり）', toolB: '有料プランで可能な場合あり（条件・大企業は上位プランが必要）' },
  { item: '日本語UI', toolA: 'ChatGPTに準拠（対応）', toolB: '非対応（英語のみ）' },
  { item: '日本語プロンプト', toolA: '一部対応（画像内テキストは精度低め）', toolB: '一部対応（英語より精度低め）' },
  { item: '透かし', toolA: '可視透かしなし。C2PAメタデータ（不可視）が埋め込まれる場合あり', toolB: '有料プランでは透かしなし（要確認）' },
  { item: 'ChatGPT連携', toolA: 'ChatGPT上で追加設定なしに利用可能', toolB: '非対応（別サービス）' },
  { item: '対応環境', toolA: 'Web（ChatGPT）・API', toolB: 'Discord・Web' },
  { item: '表現の自由度', toolA: 'プロンプト忠実度が高い・スタイルの幅は限定的傾向', toolB: 'スタイルの幅が広い・アート表現に強み' },
  { item: '初心者向けか', toolA: 'ChatGPTの日本語UIで操作しやすい', toolB: '英語UI・要習熟' },
  { item: '生成後の編集しやすさ', toolA: 'ChatGPT上でインペインティング・テキスト指示での再生成に対応', toolB: 'Vary・Zoom Out・パン等に対応。外部ツールでの編集は別途必要' },
];

const relatedLinks = [
  { href: '/tools/dalle/', label: 'DALL·E詳細' },
  { href: '/tools/midjourney/', label: 'Midjourney詳細' },
  { href: '/categories/image-generation/', label: 'AI画像生成ツール一覧' },
  { href: '/guides/commercial-use-copyright/', label: '商用利用・著作権ガイド' },
  { href: '/conditions/commercial-use/', label: '商用利用確認しやすいAIツール' },
  { href: '/conditions/free/', label: '無料枠ありAIツール' },
  { href: '/conditions/japanese/', label: '日本語対応AIツール' },
  { href: '/conditions/no-watermark/', label: '透かしなしAIツール' },
  { href: '/comparisons/', label: 'AI画像・動画ツール比較表' },
  { href: '/comparisons/midjourney-vs-adobe-firefly/', label: 'Midjourney vs Adobe Firefly比較' },
];

const sources = [
  { href: 'https://openai.com/dall-e-3', label: 'DALL·E 3公式ページ（OpenAI）' },
  { href: 'https://openai.com/policies/usage-policies', label: 'OpenAI利用規約（公式）' },
  { href: 'https://openai.com/pricing', label: 'OpenAI API料金（公式）' },
  { href: 'https://docs.midjourney.com/hc/en-us/articles/27870484040333-Comparing-Midjourney-Plans', label: 'Midjourneyプラン比較（公式）' },
  { href: 'https://docs.midjourney.com/docs/terms-of-service', label: 'Midjourney利用規約（公式）' },
];

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "DALL·EとMidjourneyを比較：料金・商用利用・日本語対応・用途の違い",
  "description": "DALL·EとMidjourneyを料金・無料枠・商用利用条件・日本語対応・ChatGPT連携・透かし・向いている用途の観点で比較。",
  "url": "https://aicreative-db.com/comparisons/dalle-vs-midjourney/",
  "mainEntityOfPage": "https://aicreative-db.com/comparisons/dalle-vs-midjourney/",
  "author": { "@type": "Organization", "name": "AIクリエイティブナビ編集部" },
  "publisher": { "@type": "Organization", "name": "AIクリエイティブナビ", "url": "https://aicreative-db.com/" },
  ...(latestDate ? { "dateModified": latestDate } : {}),
});
---

<ComparisonVsArticle
  title="DALL·EとMidjourneyを比較：料金・商用利用・日本語対応・用途の違い | AIクリエイティブナビ"
  description="DALL·EとMidjourneyを料金・無料枠・商用利用条件・日本語対応・ChatGPT連携・透かし・向いている用途の観点で比較。YouTubeサムネ・SNS・広告・初心者利用など用途別のおすすめも整理しています。"
  canonicalPath="/comparisons/dalle-vs-midjourney/"
  jsonLd={articleJsonLd}
  breadcrumbLabel="DALL·EとMidjourney比較"
  h1="DALL·EとMidjourneyを比較"
  lead="ChatGPT連携・日本語UI・料金・商用利用条件・表現の自由度の観点から2ツールを整理します。初心者・SNS・広告・ブログアイキャッチなど用途別の判断ポイントを確認してください。"
  category="AI画像生成ツール比較"
  latestDate={latestDate}
  toolAName="DALL·E"
  toolASlug="dalle"
  toolBName="Midjourney"
  toolBSlug="midjourney"
  conclusionA={{
    label: 'ChatGPT連携・手軽さ重視 →',
    toolName: 'DALL·E',
    toolHref: '/tools/dalle/',
    body: 'ChatGPTと統合されており、追加設定なしで日本語UIから利用できます。ChatGPT無料プランで制限付きに試せる場合があり、初心者や既存のChatGPTユーザーに取り組みやすい選択肢です。OpenAI公式情報上、商用利用が案内されています（条件あり・最新規約要確認）。',
  }}
  conclusionB={{
    label: '高品質ビジュアル・アート重視 →',
    toolName: 'Midjourney',
    toolHref: '/tools/midjourney/',
    body: 'アート・イラスト・写真風など幅広いスタイルで高品質な画像生成に定評があります。英語UIのみで有料プランのみの提供ですが、クリエイティブな表現を追求したい方に向いています。商用利用条件は最新の公式規約をご確認ください。',
  }}
  conclusionNote="用途・求めるクオリティ・費用感によって最適なツールが変わります。料金・商用利用条件・無料枠は変更される場合があります。最新情報は公式サイトをご確認ください。本記事は法的助言ではありません。"
  comparisonRows={comparisonRows}
  faqs={faqs}
  relatedLinks={relatedLinks}
  sources={sources}
  noticeItems={[
    '料金・無料枠・商用利用条件・透かし条件は変更される場合があります。',
    '最新情報は各ツールの<strong>公式サイト・料金ページ・利用規約</strong>をご確認ください。',
    '<strong>OpenAI側の利用条件とMidjourney側の利用条件は別々にご確認ください</strong>（条件は独立しています）。',
    '人物・著名人・ブランドロゴ・第三者素材を扱う場合は<strong>特に注意</strong>が必要です。',
    '本記事は情報提供を目的としており、<strong>法的助言ではありません</strong>。',
  ]}
>
  <!-- ===== ChatGPT連携 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">ChatGPT連携の違い</h2>
    <div class="cp-2col">
      <div class="cp-card">
        <h3 class="cp-card-h3">DALL·E（ChatGPT経由）</h3>
        <ul>
          <li>ChatGPTに統合されており、追加登録なしで利用可能</li>
          <li>日本語UIでチャット形式の指示が可能</li>
          <li>インペインティング（部分修正）・テキスト指示での再生成に対応</li>
          <li>ChatGPTの文脈を活かした画像生成ができる</li>
        </ul>
      </div>
      <div class="cp-card">
        <h3 class="cp-card-h3">Midjourney</h3>
        <ul>
          <li>ChatGPTとは独立した別サービス</li>
          <li>Discord操作またはWeb版の習熟が必要</li>
          <li>英語UIのみ（英語プロンプト推奨）</li>
          <li>Vary・Zoom Out・パン等の独自編集機能あり</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== 用途別 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">用途別おすすめ</h2>
    <div class="cp-usecase-grid">
      {[
        { useCase: 'YouTubeサムネイル', a: 'プロンプト忠実度が高く、指定の内容で生成しやすい。日本語で指示できる', b: '高品質なビジュアルが得られやすく印象的なサムネに向く。商用利用条件（公式規約）を要確認', note: 'どちらも利用規約の確認が必要' },
        { useCase: 'SNS画像', a: 'ChatGPTの文脈に沿った画像生成が可能。日本語プロンプトで手軽に作成', b: 'スタイルの幅が広く、個性的・高品質なビジュアル生成に向く', note: '用途・頻度・求めるクオリティによって判断' },
        { useCase: '広告バナー・商用素材', a: 'OpenAI公式情報上、商用利用案内あり。指定の内容で生成しやすい', b: '有料プランで商用利用可能な場合あり。規約条件あり', note: '商用利用前に最新規約を必ず確認。本記事は法的助言ではありません' },
        { useCase: 'ブログアイキャッチ', a: '記事内容に合わせた画像生成が取り組みやすい。日本語指示で操作しやすい', b: '高品質なビジュアルで読者の目を引きやすい', note: '手軽さ重視ならDALL·E、品質重視ならMidjourney' },
        { useCase: 'コンセプトアート・イラスト', a: 'スタイルの幅はMidjourneyより狭い傾向。指示通りの生成向き', b: 'アート表現・スタイル探索に強み。クリエイティブな表現に向く', note: 'Midjourneyが向いている傾向' },
        { useCase: '初心者利用', a: 'ChatGPTの日本語UIで操作可能。無料枠で試せる場合あり', b: '英語UIのみ・Discord操作またはWeb版の習熟が必要', note: 'DALL·E（ChatGPT経由）が取り組みやすい' },
      ].map(({ useCase, a, b, note }) => (
        <div class="cp-usecase-item">
          <p class="cp-usecase-h">{useCase}</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
            <div style="background:var(--surface-2);border-radius:8px;padding:10px 12px;">
              <p style="font-size:11px;font-weight:700;color:var(--ink-soft);margin-bottom:4px;">DALL·E</p>
              <p style="font-size:12px;line-height:1.6;color:var(--ink-body);">{a}</p>
            </div>
            <div style="background:var(--brand-tint);border-radius:8px;padding:10px 12px;">
              <p style="font-size:11px;font-weight:700;color:var(--brand-ink);margin-bottom:4px;">Midjourney</p>
              <p style="font-size:12px;line-height:1.6;color:var(--ink-body);">{b}</p>
            </div>
          </div>
          <p style="font-size:11.5px;color:var(--faint);"><span style="font-weight:600;">判断のポイント：</span>{note}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 向いている人 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">向いている人・向いていない人</h2>
    <div class="cp-suited-grid">
      <div class="cp-suited-card">
        <p class="cp-suited-h">DALL·Eが向いている人</p>
        <ul class="cp-suited-list">
          <li>ChatGPTをすでに利用しており、追加設定なしで画像生成を試したい</li>
          <li>日本語UIで手軽に操作したい</li>
          <li>テキストの指示通りに忠実な画像を生成したい</li>
          <li>まず無料枠で試したい（ChatGPT無料プランで制限付き利用できる場合あり）</li>
          <li>初心者でプロンプト操作に慣れていない</li>
        </ul>
        <p style="margin-top:10px;"><a href="/tools/dalle/" style="color:var(--brand-ink);font-size:13px;font-weight:600;">DALL·E詳細ページを見る →</a></p>
      </div>
      <div class="cp-suited-card">
        <p class="cp-suited-h">Midjourneyが向いている人</p>
        <ul class="cp-suited-list">
          <li>高品質なアート・イラスト・写真風ビジュアルを生成したい</li>
          <li>英語プロンプトに慣れている・英語UIで問題ない</li>
          <li>スタイルの幅が広い表現を追求したい</li>
          <li>有料プランへの課金を前提にしている</li>
          <li>クリエイター・デザイナーとして高品質な素材が必要</li>
        </ul>
        <p style="margin-top:10px;"><a href="/tools/midjourney/" style="color:var(--brand-ink);font-size:13px;font-weight:600;">Midjourney詳細ページを見る →</a></p>
      </div>
    </div>
    <div class="cp-not-suited">
      <p class="cp-not-suited-h">どちらも向いていないケース</p>
      <ul>
        <li>毎回同じ人物・構図を完全に再現したい場合</li>
        <li>公式利用条件を確認せずに商用案件へ使いたい場合</li>
        <li>入稿用デザインデータまで画像生成だけで完結させたい場合</li>
        <li>人物・著名人・ブランドロゴ・第三者素材を含む画像を商用利用したい場合（別途確認が必要）</li>
      </ul>
    </div>
  </section>

  <!-- ===== 他ツール ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">他のAI画像生成ツールも比較したい場合</h2>
    <div class="cp-other-grid">
      <div class="cp-other-card">
        <p class="cp-other-h"><a href="/tools/adobe-firefly/">Adobe Firefly</a></p>
        <p>日本語UI対応。商用利用を想定した設計（β機能は対象外）。Photoshop・Illustrator連携可。無料枠あり。</p>
      </div>
      <div class="cp-other-card">
        <p class="cp-other-h"><a href="/tools/leonardo-ai/">Leonardo AI</a></p>
        <p>無料枠あり。スタイルの幅が広く、ゲームグラフィック・キャラクターイラストなどに向いているとされています。</p>
      </div>
      <div class="cp-other-card">
        <p class="cp-other-h"><a href="/tools/stable-diffusion/">Stable Diffusion</a></p>
        <p>オープンソース。ローカル環境での動作が可能で、カスタマイズ性が高い。技術的な知識が必要な場合があります。</p>
      </div>
    </div>
    <p style="margin-top:12px;font-size:12px;color:var(--faint);">各ツールの料金・商用利用条件・機能は変更される場合があります。利用前に各公式サイトをご確認ください。</p>
  </section>
</ComparisonVsArticle>
