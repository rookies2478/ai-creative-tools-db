---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NoticeBox from '../../../components/NoticeBox.astro';
import { getEntry } from 'astro:content';

const toolEntries = await Promise.all([
  getEntry('tools', 'canva-ai-image-generator'),
  getEntry('tools', 'adobe-firefly'),
  getEntry('tools', 'dalle'),
  getEntry('tools', 'stable-diffusion'),
  getEntry('tools', 'leonardo-ai'),
  getEntry('tools', 'midjourney'),
]);
const toolDates = toolEntries.map(t => t?.data.lastReviewed).filter(Boolean) as string[];
const latestDate = toolDates.length ? toolDates.sort().at(-1)! : null;
function formatDate(iso: string): string {
  const [y, m, d] = iso.split('-');
  return `${y}年${Number(m)}月${Number(d)}日`;
}

const tools = [
  {
    name: 'Canva AI画像生成',
