---
import ComparisonVsArticle from '../../../components/ComparisonVsArticle.astro';
import SamePromptImageComparison from '../../../components/SamePromptImageComparison.astro';
import { generatedImages } from '../../../data/generatedImages';
import { getEntry } from 'astro:content';

const imgFirefly = generatedImages.find(
  (i) => i.sourceToolSlug === 'adobe-firefly' && i.sampleType === 'tool-output' && i.comparisonEligible === true && i.promptVersion === 'image-tool-benchmark-v1'
)!;
const imgMidjourney = generatedImages.find(
  (i) => i.sourceToolSlug === 'midjourney' && i.sampleType === 'tool-output' && i.comparisonEligible === true && i.promptVersion === 'image-tool-benchmark-v1'
)!;

const [toolMidjourney, toolFirefly] = await Promise.all([
  getEntry('tools', 'midjourney'),
  getEntry('tools', 'adobe-firefly'),
]);
const toolDates = [toolMidjourney?.data.lastReviewed, toolFirefly?.data.lastReviewed].filter(Boolean) as string[];
const latestDate = toolDates.length ? toolDates.sort().at(-1)! : null;

const faqs = [
  {
    q: 'MidjourneyとAdobe Fireflyはどちらが画質が良いですか？',
    a: 'Midjourneyはアート・イラスト・写真風など幅広いスタイルで高い表現力が評価されています。Adobe Fireflyは写実的・実用的な素材生成に向いているとされています。用途や好みによって評価が分かれますので、両方試して比較することをおすすめします。',
  },
  {
    q: 'Adobe Fireflyは無料で商用利用できますか？',
    a: 'Adobe公式情報上、Fireflyは商用利用を想定したサービスとして案内されています。ただしβ（ベータ）表示の機能は商用利用対象外とされています。プランや用途によって条件が異なる可能性があるため、利用前にAdobe公式のユーザーガイドラインをご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'Midjourneyは日本語プロンプトで使えますか？',
    a: '日本語プロンプトを一部理解する場合がありますが、英語プロンプトと比べて精度が低い傾向があります。UIは英語のみです。日本語環境での使いやすさを重視する場合はAdobe Fireflyが有利です。',
  },
  {
    q: 'MidjourneyはYouTubeサムネイルに使えますか？',
    a: '公式情報上、有料プランでは商用利用ができる場合があります。ただし、YouTubeサムネイルへの利用が商用利用に該当するかは最新の公式利用規約をご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'Adobe Fireflyの透かしはどのプランで消えますか？',
    a: 'プランによっては可視透かしが入る場合があります。また全プラン共通でC2PAの不可視メタデータが埋め込まれる場合があります。具体的な条件はAdobe公式サイトでご確認ください。',
  },
  {
    q: 'どちらが初心者に使いやすいですか？',
    a: 'Adobe Fireflyは日本語UI対応、プロンプト補助機能があり、初心者に取り組みやすい設計です。Midjourneyは英語UIのみで、操作にDiscordまたはWebアプリの習熟が必要ですが、短いプロンプトでも高品質な画像を生成できるとされています。',
  },
  {
    q: '無料で試しやすいのはMidjourneyとAdobe Fireflyのどちらですか？',
    a: 'Adobe Fireflyには無料枠があり、費用をかけずに試すことができます（生成回数・条件は変更される場合があります）。Midjourneyは現時点で無料プランがなく、有料プランへの加入が必要です。最新の料金・利用条件はそれぞれの公式サイトをご確認ください。',
  },
  {
    q: '商用利用前に何を確認すべきですか？',
    a: '利用するツールの最新利用規約、生成物の取り扱い条件、プランによる商用利用の可否をご確認ください。人物・著名人・ブランドロゴ・第三者素材を含む場合は別途確認が必要です。Adobe製品や外部素材と組み合わせる場合は、それぞれの条件も合わせてご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'SNS画像や広告バナーにはどちらが向いていますか？',
    a: '雰囲気のある画像案を作るならMidjourneyが候補になります。生成後にAdobe製品（PhotoshopやExpress）で編集・加工したい場合はAdobe Fireflyが候補になります。SNS投稿や広告への利用を前提にする場合は、商用利用条件を利用前に公式規約でご確認ください。',
  },
];

const comparisonRows = [
  { item: '料金（最低プラン）', toolA: '$10/月（Basicプラン・月払い）', toolB: '1,580円/月（税込）〜（Firefly Standardプラン・日本語公式料金ページ確認）' },
  { item: '無料プラン', toolA: 'なし（2024年末廃止）', toolB: 'あり（クレジット数・条件は要確認）' },
  { item: '商用利用', toolA: '有料プランで可能な場合あり（条件あり）', toolB: '商用利用を想定した設計（β機能は対象外）' },
  { item: '日本語UI', toolA: '非対応（英語のみ）', toolB: '対応' },
  { item: '日本語プロンプト', toolA: '一部対応（英語より精度低め）', toolB: '対応' },
  { item: '透かし', toolA: '有料プランでは透かしなし（要確認）', toolB: 'プランによっては可視透かしあり。全プランでC2PAメタデータ埋め込み' },
  { item: '対応環境', toolA: 'Discord・Web', toolB: 'Web（Photoshop・Illustrator連携可）' },
  { item: '表現の自由度', toolA: 'スタイルの幅が広い・アート表現に強み', toolB: '実用的な素材向け・スタイルの幅は狭め' },
  { item: '初心者向けか', toolA: '英語UI・要習熟', toolB: '日本語UI・プロンプト補助あり' },
  { item: '生成後の編集しやすさ', toolA: '外部エディタで加工が前提', toolB: 'Photoshop・Expressとの連携で加工しやすい' },
  { item: 'Adobe製品連携', toolA: 'なし', toolB: 'Photoshop・Illustrator・Express連携可' },
];

const relatedLinks = [
  { href: '/tools/midjourney/', label: 'Midjourney詳細' },
  { href: '/tools/adobe-firefly/', label: 'Adobe Firefly詳細' },
  { href: '/categories/image-generation/', label: 'AI画像生成ツール一覧' },
  { href: '/categories/design/', label: 'AIデザインツール一覧' },
  { href: '/comparisons/canva-ai-vs-adobe-firefly/', label: 'Canva AI vs Adobe Firefly比較' },
  { href: '/guides/commercial-use-copyright/', label: '商用利用・著作権ガイド' },
  { href: '/conditions/commercial-use/', label: '商用利用確認しやすいAIツール' },
  { href: '/conditions/free/', label: '無料枠ありAIツール' },
  { href: '/conditions/japanese/', label: '日本語対応AIツール' },
  { href: '/conditions/no-watermark/', label: '透かしなしAIツール' },
  { href: '/use-cases/sns-post-image/', label: 'SNS投稿画像向けAIツール' },
  { href: '/use-cases/ad-banner/', label: '広告バナー向けAIツール' },
  { href: '/use-cases/blog-eyecatch/', label: 'ブログアイキャッチ向けAIツール' },
  { href: '/comparisons/', label: 'AI画像・動画ツール比較表' },
];

const sources = [
  { href: 'https://docs.midjourney.com/hc/en-us/articles/27870484040333-Comparing-Midjourney-Plans', label: 'Midjourneyプラン比較（公式）' },
  { href: 'https://docs.midjourney.com/docs/terms-of-service', label: 'Midjourney利用規約（公式）' },
  { href: 'https://www.adobe.com/products/firefly/plans.html', label: 'Adobe Firefly料金プラン（公式）' },
  { href: 'https://www.adobe.com/legal/licenses-terms/adobe-gen-ai-user-guidelines.html', label: 'Adobe生成AIユーザーガイドライン（公式）' },
];

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "MidjourneyとAdobe Fireflyを比較：商用利用・料金・日本語対応・用途の違い",
  "description": "MidjourneyとAdobe Fireflyを料金・無料枠・商用利用条件・日本語対応・透かし・向いている用途の観点で比較。YouTubeサムネ・SNS・広告・企業利用など用途別のおすすめも整理しています。",
  "url": "https://aicreative-db.com/comparisons/midjourney-vs-adobe-firefly/",
  "mainEntityOfPage": "https://aicreative-db.com/comparisons/midjourney-vs-adobe-firefly/",
  "author": { "@type": "Organization", "name": "AIクリエイティブナビ編集部" },
  "publisher": { "@type": "Organization", "name": "AIクリエイティブナビ", "url": "https://aicreative-db.com/" },
  ...(latestDate ? { "dateModified": latestDate } : {}),
});
---

<ComparisonVsArticle
  title="MidjourneyとAdobe Fireflyを比較：商用利用・料金・日本語対応・用途の違い | AIクリエイティブナビ"
  description="MidjourneyとAdobe Fireflyを料金・無料枠・商用利用条件・日本語対応・透かし・向いている用途の観点で比較。YouTubeサムネ・SNS・広告・企業利用など用途別のおすすめも整理しています。"
  canonicalPath="/comparisons/midjourney-vs-adobe-firefly/"
  jsonLd={articleJsonLd}
  breadcrumbLabel="MidjourneyとAdobe Firefly比較"
  h1="MidjourneyとAdobe Fireflyを比較"
  lead="商用利用・料金・日本語対応・表現の自由度の観点から2ツールを整理します。SNS・広告・ブログアイキャッチなどの用途で向いているツールを確認してください。"
  category="AI画像生成ツール比較"
  latestDate={latestDate}
  toolAName="Midjourney"
  toolASlug="midjourney"
  toolBName="Adobe Firefly"
  toolBSlug="adobe-firefly"
  quickDecisionRows={[
    { purpose: 'まず無料で試したい人', candidate: 'Adobe Firefly', checkPoint: '無料枠の上限・条件は変更される場合あり。公式で要確認' },
    { purpose: '日本語UIで操作したい人', candidate: 'Adobe Firefly', checkPoint: '日本語UI・日本語プロンプト対応。Midjourneyは英語のみ' },
    { purpose: 'アート調・高品質ビジュアル重視', candidate: 'Midjourney', checkPoint: '有料プランのみ（無料プランなし）。英語UIへの慣れが必要' },
    { purpose: '商用利用前提で確認したい人', candidate: '両方とも公式規約を確認', checkPoint: 'プラン・用途・β機能の有無によって条件が異なる場合あり' },
    { purpose: 'Adobe製品と連携したい人', candidate: 'Adobe Firefly', checkPoint: 'Photoshop・Illustrator連携可。利用条件は公式で確認' },
  ]}
  conclusionA={{
    label: 'アート調・雰囲気重視 →',
    toolName: 'Midjourney',
    toolHref: '/tools/midjourney/',
    body: 'スタイルの幅が広く、アート・イラスト・世界観のあるビジュアル生成に定評があります。SNS画像やアイキャッチの背景素材、コンセプトビジュアルを複数試したい方に向いています。有料プランのみ（無料プランなし）。英語UI・英語プロンプトが基本です。',
  }}
  conclusionB={{
    label: 'Adobe連携・実務素材重視 →',
    toolName: 'Adobe Firefly',
    toolHref: '/tools/adobe-firefly/',
    body: '日本語UIに対応し、生成後にPhotoshopやExpressで編集・加工しやすい設計です。広告バナー・SNS画像・ブログアイキャッチなど実務用素材を作りたい場合の候補になります。無料枠あり。商用利用条件の詳細は公式規約をご確認ください。',
  }}
  conclusionNote="SNS投稿画像・広告バナー・ブログアイキャッチなど実務用途では、生成後の編集しやすさや商用利用条件も比較ポイントになります。無料枠・生成回数・商用利用条件は変更される場合があります。最新情報は公式サイトをご確認ください。本記事は法的助言ではありません。"
  comparisonRows={comparisonRows}
  faqs={faqs}
  relatedLinks={relatedLinks}
  sources={sources}
  noticeItems={[
    '料金・無料枠・商用利用条件・透かし条件は変更される場合があります。',
    '最新情報は各ツールの<strong>公式サイト・料金ページ・利用規約</strong>をご確認ください。',
    '人物・著名人・ブランドロゴ・第三者素材を扱う場合は、特に注意が必要です。',
    'Adobe Stock素材や外部素材と組み合わせる場合は、それぞれの利用条件を別途ご確認ください。',
    '本記事は情報提供を目的としており、<strong>法的助言ではありません</strong>。',
  ]}
>
  <!-- ===== 生成品質 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">生成品質・表現の自由度の違い</h2>
    <div class="cp-2col">
      <div class="cp-card">
        <h3 class="cp-card-h3">Midjourney</h3>
        <ul>
          <li>アート・イラスト・写真風など幅広いスタイルに対応</li>
          <li>業界トップクラスの画像品質と評される場合が多い</li>
          <li>v6以降、プロンプト精度が向上しているとされる</li>
          <li>スタイル指定の自由度が高い</li>
        </ul>
      </div>
      <div class="cp-card">
        <h3 class="cp-card-h3">Adobe Firefly</h3>
        <ul>
          <li>写実的・実用的な素材生成に向いているとされる</li>
          <li>スタイルの幅はMidjourneyより狭い傾向</li>
          <li>Photoshop連携でのインペイント・アウトペインティングが可能</li>
          <li>プロンプト補助機能あり（初心者向け）</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== 日本語対応 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">日本語対応の違い</h2>
    <div style="overflow-x:auto;border-radius:14px;border:1px solid var(--line);box-shadow:var(--shadow-sm);margin-bottom:12px;">
      <table style="width:100%;min-width:400px;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:var(--brand-tint);">
            <th style="text-align:left;padding:12px 16px;font-weight:700;color:var(--brand-ink);border-bottom:1px solid var(--line);">項目</th>
            <th style="text-align:left;padding:12px 16px;font-weight:700;color:var(--brand-ink);border-bottom:1px solid var(--line);">Midjourney</th>
            <th style="text-align:left;padding:12px 16px;font-weight:700;color:var(--brand-ink);border-bottom:1px solid var(--line);">Adobe Firefly</th>
          </tr>
        </thead>
        <tbody>
          <tr style="background:var(--surface);">
            <td style="padding:11px 16px;font-weight:600;font-size:12.5px;border-bottom:1px solid var(--line);">日本語UI</td>
            <td style="padding:11px 16px;font-size:12.5px;color:var(--ink-soft);border-bottom:1px solid var(--line);">非対応（英語のみ）</td>
            <td style="padding:11px 16px;font-size:12.5px;color:#15803d;font-weight:600;border-bottom:1px solid var(--line);">対応</td>
          </tr>
          <tr style="background:var(--surface-2);">
            <td style="padding:11px 16px;font-weight:600;font-size:12.5px;border-bottom:1px solid var(--line);">日本語プロンプト</td>
            <td style="padding:11px 16px;font-size:12.5px;color:var(--ink-soft);border-bottom:1px solid var(--line);">一部対応（精度は英語より低め）</td>
            <td style="padding:11px 16px;font-size:12.5px;color:#15803d;font-weight:600;border-bottom:1px solid var(--line);">対応</td>
          </tr>
          <tr style="background:var(--surface);">
            <td style="padding:11px 16px;font-weight:600;font-size:12.5px;">日本語ドキュメント</td>
            <td style="padding:11px 16px;font-size:12.5px;color:var(--ink-soft);">非対応</td>
            <td style="padding:11px 16px;font-size:12.5px;color:#15803d;font-weight:600;">対応</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p style="font-size:13px;color:var(--ink-soft);">日本語環境での使いやすさはAdobe Fireflyが優位です。<a href="/conditions/japanese/" style="color:var(--brand-ink);">日本語対応AIツール一覧も参考に →</a></p>
  </section>

  <!-- ===== 向いている人 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">向いている人・向いていない人</h2>
    <div class="cp-suited-grid">
      <div class="cp-suited-card">
        <p class="cp-suited-h">Midjourneyが向いている人</p>
        <ul class="cp-suited-list">
          <li>高品質なアート・イラスト・写真風ビジュアルを生成したい</li>
          <li>英語プロンプトに慣れている・英語UIで問題ない</li>
          <li>スタイルの幅が広い表現を追求したい</li>
          <li>有料プランへの課金を前提にしている</li>
        </ul>
        <p style="margin-top:10px;"><a href="/tools/midjourney/" style="color:var(--brand-ink);font-size:13px;font-weight:600;">Midjourney詳細ページを見る →</a></p>
      </div>
      <div class="cp-suited-card">
        <p class="cp-suited-h">Adobe Fireflyが向いている人</p>
        <ul class="cp-suited-list">
          <li>日本語UIで使いたい・日本語プロンプトで生成したい</li>
          <li>まず無料枠で試してみたい</li>
          <li>Adobe Creative Cloud（Photoshop・Illustrator）を使っている</li>
          <li>商用利用を前提にした設計のツールを使いたい（最新規約の確認は必要）</li>
          <li>初心者でプロンプト補助機能を使いたい</li>
        </ul>
        <p style="margin-top:10px;"><a href="/tools/adobe-firefly/" style="color:var(--brand-ink);font-size:13px;font-weight:600;">Adobe Firefly詳細ページを見る →</a></p>
      </div>
    </div>
    <div class="cp-not-suited">
      <p class="cp-not-suited-h">どちらも向いていないケース</p>
      <ul>
        <li>毎回同じ人物・構図を完全に再現したい場合（AI画像生成は再現性が低い）</li>
        <li>公式条件を確認せずに商用案件へ使いたい場合</li>
        <li>入稿用デザインデータまでAI画像生成だけで完結させたい場合</li>
        <li>人物・著名人・ブランドロゴ・第三者素材を含む画像を商用利用したい場合（別途確認が必要）</li>
      </ul>
    </div>
  </section>

  <!-- ===== 同一プロンプト比較 ===== -->
  <SamePromptImageComparison
    imageA={imgMidjourney}
    imageB={imgFirefly}
    toolAName="Midjourney"
    toolBName="Adobe Firefly"
  />

  <!-- ===== 他ツール ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">他のAI画像生成ツールも比較したい場合</h2>
    <div class="cp-other-grid">
      <div class="cp-other-card">
        <p class="cp-other-h"><a href="/tools/leonardo-ai/">Leonardo AI</a></p>
        <p>無料枠あり。スタイルの幅が広く、ゲームグラフィック・キャラクターイラストなどに向いているとされています。商用利用条件は公式規約をご確認ください。</p>
      </div>
      <div class="cp-other-card">
        <p class="cp-other-h"><a href="/tools/canva-ai-image-generator/">Canva AI画像生成</a></p>
        <p>Canvaのデザイン編集と一体化した生成機能。日本語対応。SNS画像・プレゼン素材など既存デザインへの組み込みに向いています。</p>
      </div>
      <div class="cp-other-card">
        <p class="cp-other-h"><a href="/tools/stable-diffusion/">Stable Diffusion</a></p>
        <p>オープンソース。ローカル環境での動作が可能で、カスタマイズ性が高い。技術的な知識が必要な場合があります。商用利用条件はモデル・利用形態によって異なります。</p>
      </div>
      <div class="cp-other-card">
        <p class="cp-other-h"><a href="/tools/dalle/">DALL·E</a></p>
        <p>OpenAI提供。ChatGPTとの連携で使いやすく、テキスト内容の正確な反映に強みがあるとされます。商用利用条件は公式規約をご確認ください。</p>
      </div>
    </div>
    <p style="margin-top:12px;font-size:12px;color:var(--faint);">各ツールの料金・商用利用条件・機能は変更される場合があります。利用前に各公式サイトをご確認ください。</p>
  </section>
</ComparisonVsArticle>
