---
import ComparisonVsArticle from '../../../components/ComparisonVsArticle.astro';
import { getEntry } from 'astro:content';

const [toolSD, toolMidjourney] = await Promise.all([
  getEntry('tools', 'stable-diffusion'),
  getEntry('tools', 'midjourney'),
]);
const toolDates = [toolSD?.data.lastReviewed, toolMidjourney?.data.lastReviewed].filter(Boolean) as string[];
const latestDate = toolDates.length ? toolDates.sort().at(-1)! : null;

const faqs = [
  {
    q: 'Stable DiffusionとMidjourneyはどちらが無料で使えますか？',
    a: 'Stable Diffusionはローカル環境（自分のPC）で無料実行できます。ただしGPU搭載PCと環境構築が必要です。Midjourneyは現在無料プランが提供されていない場合があります（2024年末に廃止されたとされています）。クラウド経由で手軽に試したい場合は、別途無料枠があるツールも参考にしてください。',
  },
  {
    q: 'Stable Diffusionは商用利用できますか？',
    a: '利用するモデルのバージョンによってライセンスが異なります。SD 1.x/2.x（CreativeML Open RAIL-M）は条件付きで商用利用できる場合があります。SD 3.x以降（Stability AI Community License）は年間総収益100万ドル未満の場合に商用利用できる場合があるとされています。コミュニティ配布のカスタムモデル・LoRAはそれぞれ独自のライセンスを持つ場合があり、個別確認が必要です。本記事は法的助言ではありません。',
  },
  {
    q: 'Midjourneyは商用利用できますか？',
    a: '公式情報上、有料プランでは商用利用ができる場合があります。ただし年間総収益が100万ドル超の企業はPro/Megaプランへのアップグレードが利用規約上必要とされています。条件・規約は変更される可能性があるため、利用前に最新の公式利用規約をご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'Stable Diffusionは日本語で使えますか？',
    a: 'AUTOMATIC1111 Web UIなど一部の実装では日本語化拡張機能を導入することで日本語UIにできる場合があります。日本語プロンプトは一部対応ですが、英語プロンプトの方が精度が高い傾向があります。MidjourneyはUIが英語のみです。日本語環境での利用を重視する場合はどちらも追加の対応が必要になる点に注意してください。',
  },
  {
    q: '初心者にはStable DiffusionとMidjourneyのどちらが向いていますか？',
    a: 'Midjourneyはブラウザ（Web版）またはDiscordから比較的手軽に高品質な画像を生成できるとされています。ただし英語UIのみです。Stable Diffusionはローカル環境構築（GPU・依存ライブラリ等）の知識が必要で、初心者には難易度が高い場合があります。クラウド経由のサービスを使えば環境構築は不要ですが、別途費用が発生する場合があります。',
  },
  {
    q: 'Stable DiffusionはYouTubeサムネイルや広告に使えますか？',
    a: '利用するモデルのライセンスによって条件が異なります。商用利用を前提にする場合は、使用するモデルのライセンス（SD 3.x以降はStability AI Community License等）を必ずご確認ください。また、コミュニティ配布のモデル・LoRAはそれぞれ独自のライセンスを持つ場合があり、個別確認が必要です。本記事は法的助言ではありません。',
  },
  {
    q: '商用利用前に何を確認すべきですか？',
    a: 'ツールの利用規約、利用するモデルの条件（バージョン・配布元・ライセンス）、生成物の扱い、そして人物画像・ブランドロゴ・第三者素材を含む場合の追加条件を確認してください。プラン・用途によっても条件が異なる場合があります。最新情報は公式サイトをご確認ください。本記事は法的助言ではありません。',
  },
  {
    q: 'ブログやSNS画像にはどちらが向いていますか？',
    a: '画風や設定を細かく調整したい場合はStable Diffusion系が候補になります。雰囲気のあるビジュアルを環境構築なしで手軽に作りたい場合はMidjourneyが候補になります。どちらも商用利用条件は利用前に公式規約をご確認ください。',
  },
];

const comparisonRows = [
  { item: '料金', toolA: 'ローカル実行は無料（GPU搭載PC・環境構築が必要）。クラウドサービス経由は別途課金', toolB: '$10/月（Basicプラン・月払い）。無料プランなし' },
  { item: '無料プラン', toolA: 'ローカル実行は無料（要環境構築）', toolB: 'なし（2024年末廃止とされる）' },
  { item: '利用形態', toolA: 'ローカル実行・API・クラウドサービス', toolB: 'Discord・Web版（クラウドのみ）' },
  { item: '商用利用', toolA: 'モデル・バージョン・ライセンスによって異なる（要個別確認）', toolB: '有料プランで可能な場合あり（条件あり。大企業は上位プランが必要とされる）' },
  { item: '日本語UI', toolA: '一部対応（実装・拡張機能による）', toolB: '非対応（英語のみ）' },
  { item: '日本語プロンプト', toolA: '一部対応（英語より精度低め。翻訳拡張機能の利用が推奨される場合あり）', toolB: '一部対応（英語より精度低め）' },
  { item: '透かし', toolA: '一部バージョンで不可視透かしが埋め込まれる場合あり', toolB: '有料プランでは透かしなし（要確認）' },
  { item: 'カスタマイズ性', toolA: 'モデル選択・LoRA・拡張機能など高度なカスタマイズが可能', toolB: 'スタイルプリセット・パラメータ調整（カスタムモデル不可）' },
  { item: 'オープンソース', toolA: 'あり（モデルウェイトが公開）', toolB: 'なし（クローズドサービス）' },
  { item: '初心者向けか', toolA: '環境構築・知識が必要。難易度高め', toolB: 'Web版で比較的手軽。英語UIへの慣れが必要' },
  { item: '生成後の編集しやすさ', toolA: 'インペインティング・アウトペインティング対応。画像→画像変換も可能', toolB: 'Vary・Zoom Out・リミックスなどで一定の編集が可能。外部ツールとの連携は別途必要' },
];

const relatedLinks = [
  { href: '/tools/stable-diffusion/', label: 'Stable Diffusion詳細' },
  { href: '/tools/midjourney/', label: 'Midjourney詳細' },
  { href: '/categories/image-generation/', label: 'AI画像生成ツール一覧' },
  { href: '/guides/commercial-use-copyright/', label: '商用利用・著作権ガイド' },
  { href: '/conditions/commercial-use/', label: '商用利用確認しやすいAIツール' },
  { href: '/conditions/free/', label: '無料枠ありAIツール' },
  { href: '/conditions/japanese/', label: '日本語対応AIツール' },
  { href: '/conditions/no-watermark/', label: '透かしなしAIツール' },
  { href: '/comparisons/dalle-vs-midjourney/', label: 'DALL·E vs Midjourney比較' },
  { href: '/comparisons/midjourney-vs-adobe-firefly/', label: 'Midjourney vs Adobe Firefly比較' },
  { href: '/comparisons/midjourney-vs-leonardo-ai/', label: 'Midjourney vs Leonardo AI比較' },
  { href: '/comparisons/', label: 'AI画像・動画ツール比較表' },
];

const sources = [
  { href: 'https://stability.ai/license', label: 'Stability AIライセンスページ（公式）' },
  { href: 'https://stability.ai', label: 'Stability AI公式サイト' },
  { href: 'https://github.com/CompVis/stable-diffusion', label: 'Stable Diffusion GitHub（CompVis）' },
  { href: 'https://github.com/AUTOMATIC1111/stable-diffusion-webui', label: 'AUTOMATIC1111 Web UI（GitHub）' },
  { href: 'https://docs.midjourney.com/hc/en-us/articles/27870484040333-Comparing-Midjourney-Plans', label: 'Midjourneyプラン比較（公式）' },
  { href: 'https://docs.midjourney.com/docs/terms-of-service', label: 'Midjourney利用規約（公式）' },
];

const articleJsonLd = JSON.stringify([{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Stable DiffusionとMidjourneyを比較：無料・商用利用・画質・自由度の違い",
  "description": "Stable DiffusionとMidjourneyを料金・無料枠・ローカル利用・商用利用条件・カスタマイズ性・日本語対応・透かし・用途の観点で比較。",
  "url": "https://aicreative-db.com/comparisons/stable-diffusion-vs-midjourney/",
  "mainEntityOfPage": "https://aicreative-db.com/comparisons/stable-diffusion-vs-midjourney/",
  "author": { "@type": "Organization", "name": "AIクリエイティブナビ編集部" },
  "publisher": { "@type": "Organization", "name": "AIクリエイティブナビ", "url": "https://aicreative-db.com/" },
  ...(latestDate ? { "dateModified": latestDate } : {}),
}, {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://aicreative-db.com/" },
    { "@type": "ListItem", "position": 2, "name": "比較記事", "item": "https://aicreative-db.com/comparisons/" },
    { "@type": "ListItem", "position": 3, "name": "Stable DiffusionとMidjourney比較", "item": "https://aicreative-db.com/comparisons/stable-diffusion-vs-midjourney/" },
  ],
}]);
---

<ComparisonVsArticle
  title="Stable DiffusionとMidjourneyを比較：無料・商用利用・画質・自由度の違い | AIクリエイティブナビ"
  description="Stable DiffusionとMidjourneyを料金・無料枠・ローカル利用・商用利用条件・カスタマイズ性・日本語対応・透かし・用途の観点で比較。YouTubeサムネ・SNS・広告・コンセプトアートなど用途別のおすすめも整理しています。"
  canonicalPath="/comparisons/stable-diffusion-vs-midjourney/"
  jsonLd={articleJsonLd}
  breadcrumbLabel="Stable DiffusionとMidjourney比較"
  h1="Stable DiffusionとMidjourneyを比較"
  lead="環境構築やモデル選択まで自分で調整したいならStable Diffusionが、ブラウザやDiscord上で高品質な画像をすぐ作りたいならMidjourneyが候補になります。Stable Diffusionは使うモデルごとにライセンス条件が異なり、Midjourneyはプラン条件の確認が必要です。商用利用や著作権まわりはツール名だけで判断せず、使うモデル・プラン・公式規約を確認してください。"
  category="AI画像生成ツール比較"
  latestDate={latestDate}
  toolAName="Stable Diffusion"
  toolASlug="stable-diffusion"
  toolBName="Midjourney"
  toolBSlug="midjourney"
  quickDecisionRows={[
    { purpose: '完全無料・ローカルで試したい人', candidate: 'Stable Diffusion', checkPoint: 'GPU搭載PCと環境構築の知識が必要' },
    { purpose: '環境構築なしで手軽に始めたい人', candidate: 'Midjourney', checkPoint: '有料プランのみ（無料プランなし）。英語UIへの慣れが必要' },
    { purpose: '高度なカスタマイズ・LoRAを活用したい人', candidate: 'Stable Diffusion', checkPoint: 'モデルのライセンスを個別に確認。LoRAはそれぞれ独自条件あり' },
    { purpose: 'アート調高品質画像を手軽に生成したい人', candidate: 'Midjourney', checkPoint: '英語プロンプト推奨。有料プランのみ' },
    { purpose: '商用利用前提で確認したい人', candidate: '両方とも公式規約・ライセンスを確認', checkPoint: 'SDはモデルバージョンごとにライセンスが異なる。個別確認が必須' },
  ]}
  conclusionA={{
    label: '無料・ローカル・自由度重視 →',
    toolName: 'Stable Diffusion',
    toolHref: '/tools/stable-diffusion/',
    body: 'オープンソースでモデルウェイトが公開されており、GPU搭載PCがあればローカル環境で無料実行できます。カスタムモデル・LoRAを活用した高度な生成が可能で、自由度・カスタマイズ性を重視する方に向いています。商用利用条件は利用するモデル・配布元・ライセンスによって異なるため個別確認が必要です。',
  }}
  conclusionB={{
    label: '高品質ビジュアル・手軽さ重視 →',
    toolName: 'Midjourney',
    toolHref: '/tools/midjourney/',
    body: 'アート調・雰囲気重視の画像を手軽に作りたい方に向いています。アート・イラスト・写真風など幅広いスタイルで高品質な画像生成に定評があります。Web版またはDiscordから環境構築不要で利用できます。英語UIのみで有料プランのみの提供。商用利用条件は最新の公式規約をご確認ください。',
  }}
  conclusionNote="Stable Diffusionはモデルのバージョン・ライセンスによって条件が大きく異なります。商用利用前は必ず利用するモデルのライセンスと最新の公式規約をご確認ください。本記事は法的助言ではありません。"
  comparisonRows={comparisonRows}
  faqs={faqs}
  relatedLinks={relatedLinks}
  sources={sources}
  noticeItems={[
    '料金・無料枠・商用利用条件・透かし条件は変更される場合があります。',
    '<strong>Stable Diffusionは利用するモデル・配布元・ライセンスによって条件が異なる</strong>場合があります。',
    '最新情報は各ツールの<strong>公式サイト・料金ページ・利用規約・モデルライセンス</strong>をご確認ください。',
    '人物・著名人・ブランドロゴ・第三者素材を扱う場合は、別途確認が必要です。',
    '本記事は情報提供を目的としており、<strong>法的助言ではありません</strong>。',
  ]}
>
  <!-- ===== ローカル利用・Web利用 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">ローカル利用・Web利用の違い</h2>
    <div class="cp-2col">
      <div class="cp-card">
        <h3 class="cp-card-h3">Stable Diffusion</h3>
        <ul>
          <li>ローカル環境（Windows/Mac/Linux）で実行可能</li>
          <li>AUTOMATIC1111 Web UI・ComfyUIなどで操作</li>
          <li>標準的な構成では生成データが外部に送信されにくい</li>
          <li>GPU搭載PCと環境構築の知識が必要</li>
          <li>API経由でのクラウド利用も可能</li>
        </ul>
      </div>
      <div class="cp-card">
        <h3 class="cp-card-h3">Midjourney</h3>
        <ul>
          <li>クラウドのみ（ローカル実行不可）</li>
          <li>Discord経由またはWeb版で利用</li>
          <li>環境構築不要で手軽に使い始められる</li>
          <li>生成データはMidjourneyのサーバーに送信される</li>
        </ul>
      </div>
    </div>
    <p style="font-size:13px;color:var(--ink-soft);margin-top:8px;">プライバシーを重視する場合や、インターネット環境がない場所での利用を想定している場合は、ローカル実行が可能なStable Diffusionが候補になります（標準的な構成での傾向です）。</p>
  </section>

  <!-- ===== カスタマイズ性 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">カスタマイズ性の違い</h2>
    <div class="cp-2col">
      <div class="cp-card">
        <h3 class="cp-card-h3">Stable Diffusion</h3>
        <ul>
          <li>モデルウェイトが公開されており、モデルを自由に選択・切り替え可能</li>
          <li>LoRA・Embedding・Hypernetworkなどファインチューニング手法に対応</li>
          <li>AUTOMATIC1111・ComfyUIなど多様なフロントエンドが存在</li>
          <li>拡張機能による機能追加が可能</li>
        </ul>
      </div>
      <div class="cp-card">
        <h3 class="cp-card-h3">Midjourney</h3>
        <ul>
          <li>プロンプトパラメータ（スタイル・アスペクト比・カオス値等）での調整が可能</li>
          <li>スタイルプリセット対応</li>
          <li>カスタムモデルの追加・LoRA利用は非対応</li>
          <li>クローズドサービスのため拡張機能によるカスタマイズ不可</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== 商用利用・モデルライセンス ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">商用利用条件・モデルライセンス</h2>
    <div class="cp-caution-box">
      <p style="font-weight:700;margin-bottom:8px;">Stable Diffusionのモデルライセンスは個別に確認が必要です</p>
      <ul>
        <li>SD 1.x/2.x（CreativeML Open RAIL-M）：条件付きで商用利用できる場合あり</li>
        <li>SD 3.x以降（Stability AI Community License）：年間総収益100万ドル未満は商用利用できる場合があるとされている。100万ドル以上はエンタープライズ契約が必要とされている</li>
        <li>コミュニティ配布のカスタムモデル・LoRAは独自のライセンスを持つ場合があり、<strong>個別確認が必要</strong></li>
      </ul>
    </div>
    <p style="font-size:13px;color:var(--ink-soft);margin-top:8px;">Midjourneyは公式情報上、有料プランで商用利用可能な場合があります（年間総収益100万ドル超の企業は上位プランが必要）。条件は変更される場合があります。<a href="/conditions/commercial-use/" style="color:var(--brand-ink);">商用利用確認しやすいAIツール一覧 →</a></p>
  </section>

  <!-- ===== 用途別 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">用途別おすすめ</h2>
    <div class="cp-check-grid">
      {[
        { useCase: 'YouTubeサムネイル', a: '高品質なカスタムモデルで独自スタイルのサムネ制作が可能。商用利用条件はモデルライセンスの確認が必要', b: '高品質なビジュアルが得られやすく印象的なサムネに向く。商用利用条件（公式規約）を要確認', note: 'どちらも商用利用条件の確認が必要' },
        { useCase: 'SNS画像', a: 'カスタムモデルで独自スタイルの確立が可能。LoRAで特定スタイルに特化', b: 'スタイルの幅が広く、高品質なビジュアル生成に向く。環境構築不要', note: '手軽さ重視ならMidjourney、カスタマイズ重視ならStable Diffusion' },
        { useCase: '広告バナー・商用素材', a: '利用するモデルのライセンスによって条件が異なる。個別確認が必要', b: '有料プランで商用利用可能な場合あり。規約条件あり', note: '商用利用前に最新規約・モデルライセンスを必ず確認' },
        { useCase: 'ブログアイキャッチ', a: 'ローカル生成で大量制作に向く。生成コストがかからない', b: '高品質なビジュアル。Webから手軽に生成', note: 'コスト重視ならStable Diffusion、品質・手軽さ重視ならMidjourney' },
        { useCase: 'コンセプトアート・イラスト', a: 'カスタムモデル・LoRAで特定スタイルへの特化が可能', b: 'アート表現・スタイル探索に強み。短いプロンプトでも高品質', note: 'どちらも強みがあり用途・スキルによって判断' },
        { useCase: 'キャラクター画像・特定スタイル', a: 'LoRAで特定キャラクター・スタイルへの特化が可能', b: 'スタイルプリセット対応。カスタムモデル・LoRAの追加は非対応', note: '特定キャラ・スタイルへの特化はStable Diffusionが向いている' },
        { useCase: 'プロンプト検証・研究用途', a: 'ローカル実行でAPIコストなしに検証可能', b: 'プロンプト毎に生成クレジットを消費', note: 'コスト効率重視の検証はStable Diffusionが向いている' },
        { useCase: '初心者', a: 'GPU搭載PCと環境構築が必要で難易度高め', b: 'Web版で比較的手軽。英語UIのみのため慣れが必要', note: '環境構築なしで始めるならMidjourney（または他の日本語対応ツール）' },
      ].map(({ useCase, a, b, note }) => (
        <div class="cp-check-item">
          <p class="cp-check-h">{useCase}</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">
            <div style="background:var(--surface-2);border-radius:8px;padding:10px 12px;">
              <p style="font-size:11px;font-weight:700;color:var(--ink-soft);margin-bottom:4px;">Stable Diffusion</p>
              <p style="font-size:12px;line-height:1.6;color:var(--ink-body);">{a}</p>
            </div>
            <div style="background:var(--brand-tint);border-radius:8px;padding:10px 12px;">
              <p style="font-size:11px;font-weight:700;color:var(--brand-ink);margin-bottom:4px;">Midjourney</p>
              <p style="font-size:12px;line-height:1.6;color:var(--ink-body);">{b}</p>
            </div>
          </div>
          <p style="font-size:11.5px;color:var(--faint);"><span style="font-weight:600;">判断のポイント：</span>{note}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== 向いている人 ===== -->
  <section class="cp-body-sec">
    <h2 class="cp-body-h2">向いている人・向いていない人</h2>
    <div class="cp-suited-grid">
      <div class="cp-suited-card">
        <p class="cp-suited-h">Stable Diffusionが向いている人</p>
        <ul class="cp-suited-list">
          <li>GPU搭載PCがあり、ローカルで無料実行したい</li>
          <li>カスタムモデル・LoRAを活用した高度な生成を行いたい</li>
          <li>特定のキャラクターや独自スタイルへの特化が必要</li>
          <li>オープンソースの自由度・拡張性を重視する</li>
          <li>プロンプト検証や研究目的での大量生成を行いたい</li>
          <li>プライバシーを重視してデータをローカルに留めたい</li>
        </ul>
        <p style="margin-top:10px;"><a href="/tools/stable-diffusion/" style="color:var(--brand-ink);font-size:13px;font-weight:600;">Stable Diffusion詳細ページを見る →</a></p>
      </div>
      <div class="cp-suited-card">
        <p class="cp-suited-h">Midjourneyが向いている人</p>
        <ul class="cp-suited-list">
          <li>環境構築なしで高品質な画像をすぐに生成したい</li>
          <li>アート・イラスト・写真風など幅広いスタイルの表現を追求したい</li>
          <li>SNS画像やアイキャッチの背景素材を作りたい</li>
          <li>英語プロンプトに慣れている・英語UIで問題ない</li>
          <li>有料プランへの課金を前提にしている</li>
        </ul>
        <p style="margin-top:10px;"><a href="/tools/midjourney/" style="color:var(--brand-ink);font-size:13px;font-weight:600;">Midjourney詳細ページを見る →</a></p>
      </div>
    </div>
    <div class="cp-not-suited">
      <p class="cp-not-suited-h">どちらも向いていないケース</p>
      <ul>
        <li>公式条件やモデルのライセンスを確認せずに商用案件で使いたい場合</li>
        <li>毎回同じ人物・構図を完全に再現したい場合</li>
        <li>入稿用デザインデータまでAI画像生成だけで完結させたい場合</li>
        <li>人物・著名人・ブランドロゴ・第三者素材を含む画像を商用利用したい場合（別途確認が必要）</li>
      </ul>
    </div>
  </section>
</ComparisonVsArticle>
