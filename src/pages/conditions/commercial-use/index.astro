---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ConditionChips from '../../../components/ConditionChips.astro';
import CommercialUse, { type Status } from '../../../components/CommercialUse.astro';

const entries = await getCollection('tools');
const toolsData = entries.map((e) => {
  const commercial = (e.data.commercialUse === 'paid-only' ? 'paid' : e.data.commercialUse) as Status;
  const freeVal = e.data.freePlan;
  const free = freeVal === true ? 'あり' : freeVal === false ? 'なし' : '要確認';
  const jaVal = e.data.japaneseUi;
  const ja = jaVal === true ? '対応' : jaVal === false ? '非対応' : '要確認';
  const wmVal = e.data.watermark;
  const wm = wmVal === 'no' ? 'なし' : wmVal === 'yes' ? 'あり' : '要確認';
  return {
    name: e.data.name,
    slug: e.slug,
    initial: e.data.name.charAt(0),
    free,
    ja,
    wm,
    commercial,
    note: e.data.commercialUseNote,
  };
});

const toolCount = toolsData.length.toString();
---

<BaseLayout
  title="AI画像・動画生成ツールの商用利用条件比較｜公式規約・料金・透かしを整理"
  description="AI画像・動画生成ツールの商用利用条件を比較。ok／paid-only／limited の違い、無料・有料プランの条件差、透かし、日本語対応を整理。実務利用前に公式規約を必ずご確認ください。本記事は法的助言ではありません。"
  canonicalPath="/conditions/commercial-use/"
>
  <div class="mx-auto max-w-5xl px-6 pt-8 pb-2">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>条件別：商用利用条件を確認したいAIクリエイティブツール</span>
    </nav>
    <ConditionChips currentPath="/conditions/commercial-use/" />
  </div>
  <div class="mx-auto max-w-5xl px-6 pb-16">
    <CommercialUse
      tools={toolsData}
      stats={[
        { n: toolCount, label: '対象ツール' },
        { n: '5', label: 'ステータス段階' },
        { n: '7', label: 'よくある質問' },
      ]}
    />
  </div>
</BaseLayout>
