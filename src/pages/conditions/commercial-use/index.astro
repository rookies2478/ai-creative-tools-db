---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ConditionChips from '../../../components/ConditionChips.astro';
import CommercialUse, { type Status } from '../../../components/CommercialUse.astro';

const entries = await getCollection('tools');
const toolsData = entries.map((e) => {
  const commercial = (e.data.commercialUse === 'paid-only' ? 'paid' : e.data.commercialUse) as Status;
  const freeVal = e.data.freePlan;
  const free = freeVal === true ? 'あり' : freeVal === false ? 'なし' : '要確認';
  const jaVal = e.data.japaneseUi;
  const ja = jaVal === true ? '対応' : jaVal === false ? '非対応' : '要確認';
  const wmVal = e.data.watermark;
  const wm = wmVal === 'no' ? 'なし' : wmVal === 'yes' ? 'あり' : '要確認';
  return {
    name: e.data.name,
    slug: e.slug,
    initial: e.data.name.charAt(0),
    free,
    ja,
    wm,
    commercial,
    note: e.data.commercialUseNote,
    verifiedAt: e.data.verifiedAt ?? '',
  };
});

const toolCount = toolsData.length.toString();

const stripHtml = (s: string) => s.replace(/<[^>]+>/g, '');

const pageFaqs = [
  { q:'商用利用できるAI画像生成ツールはどう選べばいいですか？', a:'まず公式規約で商用利用がどう案内されているかを確認し、次にプラン（無料・有料）、透かしの有無、用途ごとの制限を確認するのが基本の流れです。GeminiやChatGPT系の画像生成も検討する場合は、<a href="/tools/gemini-image-generation/">Gemini画像生成の商用利用・無料枠</a>もあわせて確認してください。用途やプランによって条件が異なる可能性があるため、実務利用前には必ず最新の公式規約をご確認ください。本記事は法的助言ではありません。' },
  { q:'無料プランでも商用利用できますか？', a:'ツールによって異なります。無料プランでも商用利用が案内されているツールがある一方、無料プランでは商用利用が制限され有料プランへの移行が必要なツールもあります。また、無料プランでは透かしが入る場合があり、成果物の実務利用が難しい場面もあります。本記事は法的助言ではありません。' },
  { q:'有料プランなら必ず商用利用できますか？', a:'必ずしもそうとは限りません。有料プランでも生成内容・用途・入力素材によって制限が生じる場合があります。公式規約では利用禁止コンテンツや特定用途の制限が別途定められているケースがあります。用途やプランによって条件が異なる可能性があるため、最新の公式規約をご確認ください。Stable Diffusion系の公式寄りサービスを確認したい場合は、<a href="/tools/dreamstudio/">DreamStudioの料金・商用利用条件</a>も参考になります。' },
  { q:'AI生成画像の著作権は誰にありますか？', a:'AI生成画像の著作権の帰属は、ツールの利用規約・国・法律によって解釈が異なる場合があります。一部ツールは「ユーザーに権利を付与する」旨を規約に明記していますが、これは法的な著作権の確定を意味しない場合もあります。著作権に関しては法的断定を避け、必要に応じて専門家にご相談ください。本記事は法的助言ではありません。' },
  { q:'YouTubeサムネや広告バナーに使う場合の注意点は？', a:'収益化を伴うYouTubeチャンネルのサムネイルや広告バナーは、商用利用と判断される場合があります。プランごとの商用利用条件・透かし条件・クレジット表記義務を各ツールの公式規約で事前に確認することを推奨します。本記事は法的助言ではありません。' },
  { q:'商用利用前に確認すべき公式情報は何ですか？', a:'主に以下の3点を確認することを推奨します：①利用規約（Terms of Service）における商用利用の定義と許可範囲、②プランごとの料金ページにおける商用利用の記載、③コンテンツポリシー（禁止コンテンツ・用途）。本記事は法的助言ではありません。' },
  { q:'「条件あり」と表示されていれば商用利用できますか？', a:'利用できる場合がありますが、プラン・用途・生成コンテンツの内容・利用規約によって条件が変わります。実際に使う前に、必ず各ツールの最新公式情報をご確認ください。' },
  { q:'商用利用の可否だけ確認すれば十分ですか？', a:'商用利用条件の確認に加えて、入力素材・第三者素材・人物・ロゴ・商標の扱い、透かしの有無、クレジット表記義務も別途確認が必要です。用途によってはプランの変更が必要な場合もあります。本記事は法的助言ではありません。' },
  { q:'Stable Diffusionで作った画像は商用利用できますか？', a:'Stable Diffusionは、利用するモデル、配布元、ライセンス、実行環境によって確認すべき条件が変わります。商用利用を検討する場合は、利用しているモデルのライセンス、配布元の規約、生成物の用途、素材や人物・ブランドの権利を確認してください。詳しくは<a href="/tools/stable-diffusion/">Stable Diffusionページ</a>と<a href="/guides/commercial-use-copyright/">著作権・肖像権の確認ガイド</a>も参照してください。' },
];

const faqSchemaObj = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pageFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.a) },
  })),
};

const breadcrumbSchemaObj = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
    { '@type': 'ListItem', position: 2, name: '商用利用条件を確認したいAIクリエイティブツール', item: 'https://aicreative-db.com/conditions/commercial-use/' },
  ],
};

const combinedSchema = JSON.stringify([faqSchemaObj, breadcrumbSchemaObj]);
---

<BaseLayout
  title="AI画像・動画生成ツールの商用利用条件まとめ｜確認すべき権利・規約"
  description="AI画像生成・動画生成ツールを商用利用する前に確認したい、利用規約・ライセンス・著作権・肖像権・透かし・無料プランの注意点を整理。Stable Diffusion、Midjourney、Adobe Firefly、Runwayなど主要ツールの確認導線もまとめます。"
  canonicalPath="/conditions/commercial-use/"
  jsonLd={combinedSchema}
>
  <div class="mx-auto max-w-5xl px-6 pt-8 pb-2">
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>条件別：商用利用条件を確認したいAIクリエイティブツール</span>
    </nav>
    <ConditionChips currentPath="/conditions/commercial-use/" />
  </div>
  <div class="mx-auto max-w-5xl px-6 pb-16">
    <CommercialUse
      lead="このページでは、主要なAI画像・動画生成ツールの商用利用条件を一覧で比較できます。用途・プラン・生成内容によって条件は異なる場合があり、規約はツール側の判断で随時変更されることがあります。"
      tools={toolsData}
      stats={[
        { n: toolCount, label: '対象ツール' },
        { n: '5', label: 'ステータス段階' },
        { n: '9', label: 'よくある質問' },
      ]}
    />
    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">ツール別に商用利用条件を確認する</h2>
      <p class="mt-3 text-slate-600 leading-relaxed">
        AI画像・動画生成ツールは、ツール名だけで商用利用可否を判断できない場合があります。生成に使うサービス、契約プラン、モデルや素材の権利、利用先の広告媒体・ECモール・SNSポリシーによって確認点が変わるため、個別ツールページの注意点もあわせて確認してください。
      </p>
      <ul class="mt-4 list-disc list-inside space-y-1 text-slate-700">
        <li><a href="/tools/gemini-image-generation/" class="hover:underline">Gemini画像生成の商用利用確認</a></li>
        <li><a href="/tools/stable-diffusion/" class="hover:underline">Stable Diffusionのモデルライセンス確認</a></li>
        <li><a href="/tools/runway/" class="hover:underline">Runwayの動画・画像利用時の権利確認</a></li>
        <li><a href="/tools/midjourney/" class="hover:underline">Midjourneyの商用利用・料金確認</a></li>
        <li><a href="/tools/adobe-firefly/" class="hover:underline">Adobe Fireflyの商用利用・ライセンス確認</a></li>
        <li><a href="/tools/kling-ai/" class="hover:underline">Kling AIの商用利用・プラン確認</a></li>
        <li><a href="/tools/canva-ai-image-generator/" class="hover:underline">Canva AI画像生成の商用利用確認</a></li>
        <li><a href="/tools/leonardo-ai/" class="hover:underline">Leonardo AIの商用利用・料金確認</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="hover:underline">生成AI画像・動画の著作権確認ガイド</a></li>
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">主要AIツール別に商用利用条件を確認する</h2>
      <p class="mt-3 text-slate-600 leading-relaxed">
        AI画像・動画生成ツールは、同じ「商用利用」といっても、無料プラン・有料プラン・生成モデル・素材・出力形式によって条件が変わる場合があります。特にStable Diffusionのように利用するモデルや配布元によって条件が変わるもの、MidjourneyやRunway、Kling AIのようにプラン・規約確認が重要なものは、各ツールページと公式規約をあわせて確認してください。
      </p>
    </section>
  </div>
</BaseLayout>
