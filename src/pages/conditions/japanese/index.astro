---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ConditionChips from '../../../components/ConditionChips.astro';
import Japanese, { type JaStatus, type Mark, type Tool } from '../../../components/Japanese.astro';

const entries = await getCollection('tools');

function mapJa(
  ui: boolean | 'partial' | 'unknown',
  prompt: boolean | 'partial' | 'unknown',
): JaStatus {
  if (ui === true) return 'ok';
  if (ui === 'partial') return 'partial';
  if (ui === false && (prompt === true || prompt === 'partial')) return 'partial';
  return 'unknown';
}

function triMark(val: boolean | 'partial' | 'unknown' | undefined): Mark {
  if (val === true) return '○';
  if (val === 'partial') return '△';
  if (val === false) return '×';
  return '?';
}

const tools: Tool[] = entries.map((e) => {
  const ui      = e.data.japaneseUi;
  const prompt  = e.data.japanesePrompt;
  const docs    = e.data.japaneseDocs;
  const free    = e.data.freePlan;
  const cu      = e.data.commercialUse;
  const wm      = e.data.watermark;
  return {
    name:       e.data.name,
    slug:       e.slug,
    initial:    e.data.name.charAt(0),
    ja:         mapJa(ui, prompt),
    ui:         triMark(ui),
    prompt:     triMark(prompt),
    docs:       docs === true ? '○' : docs === false ? '×' : '?',
    free:       (free === true || free === 'limited') ? 'あり' : free === false ? 'なし' : '要確認',
    commercial: cu === 'ok' ? '案内あり' : cu === 'no' ? '不可' : '要確認',
    wm:         wm === 'no' ? 'なし' : wm === 'yes' ? 'あり' : '要確認',
    verifiedAt: e.data.verifiedAt ?? '',
  };
});

const toolCount = tools.length.toString();

const stripHtml = (s: string) => s.replace(/<[^>]+>/g, '');

const pageFaqs = [
  { q:'日本語対応AI画像生成ツールとは何ですか？', a:'日本語UIや日本語プロンプトに対応しているAI画像生成ツールの総称です。ただし「日本語対応」の範囲はツールによって異なり、操作画面だけが日本語化されているもの、日本語の指示（プロンプト）で画像を生成できるもの、画像内に日本語文字を描画できるものなど、対応の種類は様々です。詳細は各ツールの詳細ページでご確認ください。' },
  { q:'日本語プロンプトだけで画像生成できますか？', a:'多くのツールで日本語プロンプトを受け付けますが、精度はツールやモデルによって異なります。細かいニュアンス・スタイル指定・専門用語などは英語プロンプトの方が意図が通りやすい場合があります。「一部対応（△）」と表示されているツールでは特に、英語プロンプトも試すことをおすすめします。' },
  { q:'画像内に日本語文字を入れられますか？', a:'画像内への日本語文字の描画は、ほとんどのAI画像生成ツールで安定しない場合があります。日本語プロンプトに対応していても、生成画像の中に正確な日本語テキストを挿入することは技術的に難しく、文字が崩れたり読めなかったりすることがあります。SNS画像やバナーにテキストを入れる場合は、別途画像編集ツールでテキストを追加することを検討してください。' },
  { q:'日本語UIがないツールでも使えますか？', a:'日本語UIがなくても、日本語プロンプトに対応しているツールであれば指示を日本語で書いて画像生成できます。ただし設定や料金ページが英語のみの場合、初心者には操作ハードルが上がります。英語が苦手な方は、日本語UIに対応したツールか、日本語ドキュメントが整備されているツールから始めるのが安心です。' },
  { q:'商用利用時に日本語対応以外で確認すべきことは？', a:'SNS画像・YouTubeサムネイル・広告バナーなど収益化を伴う用途では、商用利用条件・透かしの有無・クレジット表記義務を各ツールの公式規約で確認することが重要です。日本語UIや日本語プロンプトへの対応とは別に、商用利用可否はプランや生成内容によって変わる場合があります。最新の公式規約を必ずご確認ください。本記事は法的助言ではありません。' },
  { q:'初心者にはどのタイプの日本語対応ツールが向いていますか？', a:'操作に慣れていない方には、日本語UIと日本語ドキュメントの両方に対応しているツールが向いています。設定・料金・ヘルプを日本語で確認できると、疑問が出たときに対処しやすくなります。まず無料で使えるツールで試してみることも選択肢の一つです。' },
  { q:'日本語対応なら画像内の日本語文字も得意ですか？', a:'日本語UIや日本語プロンプトに対応していても、画像内に日本語テキストを正確に描画する機能は別問題です。ほとんどのAI画像生成ツールで文字が崩れたり読めない状態になったりすることがあります。SNS画像やバナーにテキストを入れる場合は、別途画像編集ツールでテキストを追加する方法が安定します。' },
];

const faqSchemaObj = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pageFaqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.a) },
  })),
};

const breadcrumbSchemaObj = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
    { '@type': 'ListItem', position: 2, name: '日本語対応AIツール', item: 'https://aicreative-db.com/conditions/japanese/' },
  ],
};

const combinedSchema = JSON.stringify([faqSchemaObj, breadcrumbSchemaObj]);
---

<BaseLayout
  title="日本語対応AI画像生成ツール比較｜日本語UI・プロンプト・ドキュメントを確認"
  description="画像生成AI・動画生成AIの日本語対応を「日本語UI / 日本語プロンプト / 日本語ドキュメント」の3種類に分けて比較。無料枠・透かし・商用利用条件もあわせて確認できます。最新情報は公式サイトをご確認ください。"
  canonicalPath="/conditions/japanese/"
  jsonLd={combinedSchema}
>
  <div class="mx-auto max-w-5xl px-6 py-12">

    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>条件別：日本語対応</span>
    </nav>

    <ConditionChips currentPath="/conditions/japanese/" />

    <Japanese
      {tools}
      stats={[
        { n: toolCount, label: '対象ツール' },
        { n: '3',       label: '対応の種類' },
        { n: '7',       label: 'よくある質問' },
      ]}
    />

  </div>
</BaseLayout>
