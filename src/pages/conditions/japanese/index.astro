---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ConditionChips from '../../../components/ConditionChips.astro';
import Japanese from '../../../components/Japanese.astro';
---

<BaseLayout
  title="日本語対応AI画像生成ツール比較｜日本語UI・日本語プロンプト対応を確認"
  description="本サイトDBに登録されたAI画像・動画生成ツールを日本語対応で絞り込むDB一覧ページです。日本語UI・日本語プロンプト・日本語資料の3区分の違いや選び方の手順は /guides/japanese-ai-image-tools/ をご参照ください。最新情報は公式サイトをご確認ください。"
  canonicalPath="/conditions/japanese/"
>
  <div class="mx-auto max-w-5xl px-6 py-12">

    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>条件別：日本語対応</span>
    </nav>

    <ConditionChips currentPath="/conditions/japanese/" />

    <Japanese />

  </div>
</BaseLayout>
