---
import { getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const entry = await getEntry('guides', 'commercial-use-copyright');
if (!entry) throw new Error('guide not found: commercial-use-copyright');

const { data } = entry;
const { Content } = await entry.render();
---

<BaseLayout
  title={`${data.title} | AI画像生成・動画生成ツール比較DB`}
  description={data.description}
  canonicalPath="/guides/commercial-use-copyright/"
  ogType="article"
>
  <div class="mx-auto max-w-3xl px-6 py-12">

    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <span>{data.title}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">{data.title}</h1>
      <p class="mt-2 text-gray-500">{data.description}</p>
    </header>

    <div class="prose prose-gray mb-10 max-w-none text-sm leading-relaxed">
      <Content />
    </div>

    <section class="mb-8 rounded-lg border border-yellow-200 bg-yellow-50 px-5 py-4 text-sm text-yellow-800">
      <p>
        <strong>情報の鮮度：</strong>最終確認日 {data.lastReviewed}（次回確認予定 {data.nextReviewDue}）
      </p>
      <p class="mt-1">
        このガイドは情報提供を目的としており、法的アドバイスではありません。商用利用の判断は各ツールの最新利用規約と専門家への相談に基づいて行ってください。
      </p>
    </section>

    <!-- 関連ページ -->
    <section class="mb-8 space-y-6">
      <div>
        <h2 class="mb-3 text-sm font-semibold text-gray-600">関連カテゴリ</h2>
        <ul class="flex flex-wrap gap-3 text-sm">
          <li><a href="/tools/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">ツール一覧</a></li>
          <li><a href="/categories/commercial-use/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用OKのツール</a></li>
          <li><a href="/categories/free/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">無料で使えるツール</a></li>
          <li><a href="/categories/japanese/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">日本語対応ツール</a></li>
          <li><a href="/categories/no-watermark/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">透かしなしツール</a></li>
        </ul>
      </div>

      <div>
        <h2 class="mb-3 text-sm font-semibold text-gray-600">主要ツール詳細</h2>
        <ul class="flex flex-wrap gap-3 text-sm">
          <li><a href="/tools/midjourney/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">Midjourney</a></li>
          <li><a href="/tools/adobe-firefly/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">Adobe Firefly</a></li>
          <li><a href="/tools/stable-diffusion/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">Stable Diffusion</a></li>
          <li><a href="/tools/dalle/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">DALL·E</a></li>
          <li><a href="/tools/canva-ai-image-generator/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">Canva AI画像生成</a></li>
          <li><a href="/tools/leonardo-ai/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">Leonardo AI</a></li>
          <li><a href="/tools/runway/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">Runway</a></li>
          <li><a href="/tools/pika/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">Pika</a></li>
          <li><a href="/tools/kling-ai/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">Kling AI</a></li>
        </ul>
      </div>
    </section>

    <nav class="border-t border-gray-200 pt-6 text-sm">
      <a href="/" class="text-blue-600 hover:underline">← トップに戻る</a>
    </nav>

  </div>
</BaseLayout>
