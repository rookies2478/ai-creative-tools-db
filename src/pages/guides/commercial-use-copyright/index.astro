---
import { getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideWarningBox from '../../../components/GuideWarningBox.astro';
import GuideSummaryBox from '../../../components/GuideSummaryBox.astro';
import GuideCheckList from '../../../components/GuideCheckList.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';
import GuideComparisonTable from '../../../components/GuideComparisonTable.astro';
import GuidePageHeader from '../../../components/GuidePageHeader.astro';
import GuideFreshnessBox from '../../../components/GuideFreshnessBox.astro';

const entry = await getEntry('guides', 'commercial-use-copyright');
if (!entry) throw new Error('guide not found: commercial-use-copyright');
const { data } = entry;

// ── 画像生成ツール比較 ──────────────────────────────────
const imageToolHeaders = ['ツール名', '商用利用', '主な注意点', '確認日', '詳細'];
const imageToolRows = [
  [
    { text: 'Adobe Firefly' },
    { text: '〇（条件あり）' },
    { text: 'ベータ機能（β表示）は商用利用対象外。プランによっては可視透かしあり' },
    { text: '2026-05-04', muted: true },
    { text: '詳細を見る', href: '/tools/adobe-firefly/' },
  ],
  [
    { text: 'DALL·E' },
    { text: '〇（条件あり）' },
    { text: 'ChatGPT経由。C2PA不可視メタデータが埋め込まれる場合あり' },
    { text: '2026-05-04', muted: true },
    { text: '詳細を見る', href: '/tools/dalle/' },
  ],
  [
    { text: 'Midjourney' },
    { text: '△（プランにより異なる）' },
    { text: '有料プランで商用利用可。年間総収益100万ドル超の企業はPro/Megaプランへのアップグレードが必要とされている' },
    { text: '2026-05-04', muted: true },
    { text: '詳細を見る', href: '/tools/midjourney/' },
  ],
  [
    { text: 'Canva AI画像生成' },
    { text: '△（プランにより異なる）' },
    { text: 'AI生成コンテンツであることの明示が条件とされる場合あり' },
    { text: '2026-05-04', muted: true },
    { text: '詳細を見る', href: '/tools/canva-ai-image-generator/' },
  ],
  [
    { text: 'Leonardo AI' },
    { text: '△（プランにより異なる）' },
    { text: '有料プラン＋Private設定が商用利用の条件。無料プランでは画像の権利がLeonardo.AIに帰属する場合あり' },
    { text: '2026-05-04', muted: true },
    { text: '詳細を見る', href: '/tools/leonardo-ai/' },
  ],
  [
    { text: 'Stable Diffusion' },
    { text: '△（モデル・ライセンスにより異なる）' },
    { text: 'SD 3.x以降は年間収益100万ドル未満が条件とされている。モデルごとに個別のライセンス確認が必要' },
    { text: '2026-05-04', muted: true },
    { text: '詳細を見る', href: '/tools/stable-diffusion/' },
  ],
];

// ── 動画生成ツール比較 ──────────────────────────────────
const videoToolHeaders = ['ツール名', '商用利用', '主な注意点', '確認日', '詳細'];
const videoToolRows = [
  [
    { text: 'Runway' },
    { text: '〇（条件あり）' },
    { text: '全プランで商用利用可とされているが、無料プランでは透かしあり・クレジット一度限りのため実用に制限がある' },
    { text: '2026-05-05', muted: true },
    { text: '詳細を見る', href: '/tools/runway/' },
  ],
  [
    { text: 'Pika' },
    { text: '△（プランにより異なる）' },
    { text: '無料プランでは商用利用不可。有料プランで可能とされている' },
    { text: '2026-05-05', muted: true },
    { text: '詳細を見る', href: '/tools/pika/' },
  ],
  [
    { text: 'Kling AI' },
    { text: '△（プランにより異なる）' },
    { text: '無料プランでは商用利用不可。プラットフォームが生成コンテンツへの永続的なライセンスを保持する条項あり。中国系サービスのためデータポリシーも要確認' },
    { text: '2026-05-05', muted: true },
    { text: '詳細を見る', href: '/tools/kling-ai/' },
  ],
];

// ── 無料プラン制限 ──────────────────────────────────────
const freePlanHeaders = ['ツール名', '無料プランの主な制限（確認時点）'];
const freePlanRows = [
  [{ text: 'Midjourney' }, { text: '無料プランなし（2024年末に廃止されたとされている）' }],
  [{ text: 'DALL·E' }, { text: 'ChatGPT無料プランで制限付き利用可。商用利用できる場合あり' }],
  [{ text: 'Adobe Firefly' }, { text: '一定数の生成クレジットあり。商用利用できる場合あり（β機能を除く）' }],
  [{ text: 'Stable Diffusion' }, { text: 'ローカル実行は無料。モデルごとにライセンスを個別確認' }],
  [{ text: 'Canva AI画像生成' }, { text: '一定回数まで生成可。商用利用できる場合があるが明示条件あり' }],
  [{ text: 'Leonardo AI' }, { text: '1日150トークン程度（変更の可能性あり）。無料プランでは画像の権利がLeonardo.AIに帰属し商用利用不可とされている' }],
  [{ text: 'Runway' }, { text: '125クレジット（初回のみ・更新なし）。商用利用できる場合があるが透かしあり' }],
  [{ text: 'Pika' }, { text: '月80クレジット程度（毎月更新）。商用利用不可' }],
  [{ text: 'Kling AI' }, { text: '1日66クレジット程度（翌日繰越なし・透かしあり）。商用利用不可' }],
];

// ── 透かし条件 ─────────────────────────────────────────
const watermarkHeaders = ['ツール名', '透かしの条件（確認時点）'];
const watermarkRows = [
  [{ text: 'Midjourney' }, { text: '有料プランでは透かしなし' }],
  [{ text: 'DALL·E' }, { text: '可視透かしなし。C2PA標準の不可視メタデータが埋め込まれる場合あり' }],
  [{ text: 'Adobe Firefly' }, { text: 'プランによっては可視透かしあり。全プランでC2PAメタデータ（コンテンツクレデンシャル）埋め込み' }],
  [{ text: 'Stable Diffusion' }, { text: '一部バージョン・実装で不可視透かし（invisible watermark）が埋め込まれる場合あり' }],
  [{ text: 'Canva AI画像生成' }, { text: '公式情報から未確認' }],
  [{ text: 'Leonardo AI' }, { text: '通常は透かしなしとされているが公式情報からの詳細は未確認' }],
  [{ text: 'Runway' }, { text: '無料プランでは透かしあり。有料プランでは透かしなし' }],
  [{ text: 'Pika' }, { text: '無料プランでは透かしあり。有料プランでは透かしなし' }],
  [{ text: 'Kling AI' }, { text: '無料プランでは透かしあり。有料プランでは透かしなし' }],
];

// ── チェックリスト ─────────────────────────────────────
const checklistItems = [
  '使用するツールの公式利用規約（Terms of Service）を確認した',
  '利用するプランが商用利用を許可していることを確認した',
  '透かし・クレジット表記の条件を確認した',
  '生成コンテンツに既存の著作物・商標・肖像が含まれていないことを確認した',
  '組み合わせる素材・テンプレートそれぞれのライセンスを確認した（Canva等）',
  '利用規約の最終更新日を確認し、最新版を参照した',
  '大企業（年間収益100万ドル超）に該当する場合はMidjourney・Stable Diffusionの条件を別途確認した',
  '重要な商用利用の場合、法律の専門家に相談した',
];

// ── FAQ ────────────────────────────────────────────────
const faqItems = [
  {
    q: '無料プランで生成した画像・動画は商用利用できますか？',
    a: 'ツールとプランによって大きく異なります。Pika・Kling AIの無料プランは商用利用不可とされています（確認時点）。Leonardo AIの無料プランでも画像の権利がLeonardo.AIに帰属し商用利用不可とされています。一方、Runway・DALL·E・Adobe Fireflyは全プランで商用利用できる場合があるとされています（確認時点）。いずれも条件は変更される可能性があるため、利用前に各ツールの最新利用規約とプラン条件を必ずご確認ください。',
  },
  {
    q: '透かし（ウォーターマーク）が入っていても商用利用できますか？',
    a: '透かしの有無と商用利用の可否は、別の問題として扱われる場合があります。透かしが入っていても利用規約上は商用利用が許可されている場合がありますが、透かし入りコンテンツの実用的な商用利用は困難な場合がほとんどです。また、透かしを無断で除去することがツールの利用規約に違反する可能性があります。各ツールの規約をご確認ください。',
  },
  {
    q: '生成コンテンツの著作権は自分に帰属しますか？',
    a: 'ツールの利用規約と日本の著作権法の両面から確認が必要です。多くのツールでは「ユーザーに権利が帰属する」または「ユーザーに商用利用ライセンスを付与する」としていますが、Kling AIなどプラットフォームが生成コンテンツへの永続的なライセンスを保持する条項を設けているツールもあります。AI生成コンテンツの著作権の法的扱いは日本でも整備・議論中のため、重要な商用利用の場面では専門家への相談を推奨します。',
  },
  {
    q: 'SNS広告に使っても問題ありませんか？',
    a: '利用するツールの商用利用許可の有無に加えて、以下の点も個別に確認することを推奨します。生成コンテンツに第三者の著作権・商標・肖像権等に関わる要素が含まれていないか、ツールの利用規約で広告利用が制限されていないか、掲載するプラットフォームのポリシーに抵触しないか。これらは各ツールの最新公式情報と必要に応じて専門家への確認に基づいて判断することを推奨します。',
  },
  {
    q: '生成した画像・動画を素材として販売できますか？',
    a: '素材集・テンプレートとしての販売（再頒布）は、ツールによって明示的に禁止または制限されている場合があります。利用規約の「再頒布」「再販」「サブライセンス」に関する条項を事前に確認してください。ツールによって扱いが異なるため、各ツールの最新公式情報でご確認ください。',
  },
  {
    q: 'クライアントへの納品物に使っても問題ありませんか？',
    a: '商用利用を許可しているツールでは、クライアントへの成果物納品は一般的に想定される商用利用の範囲に含まれる場合があります。ただし、納品物に含まれる生成コンテンツへの第三者の権利侵害リスク、ツールの利用規約上の制限の有無、クライアントが求めるコンプライアンス要件等を確認した上で使用することを推奨します。',
  },
];
---

<BaseLayout
  title={`${data.title} | AIクリエイティブツール比較DB`}
  description={data.description}
  canonicalPath="/guides/commercial-use-copyright/"
  ogType="article"
>
  <div class="mx-auto max-w-3xl px-6 py-12">

    <GuidePageHeader
      title={data.title}
      description={data.description}
      lastReviewed={data.lastReviewed}
    />

    <!-- 結論サマリー -->
    <GuideSummaryBox title="このガイドの結論">
      <p>
        商用利用の可否は<strong class="font-semibold text-slate-900">ツールとプランの組み合わせ</strong>によって異なります。
        無料プランでは商用利用不可、有料プランでは可能という構造が多く、「商用利用可」でも透かしの除去・クレジット表記・大企業向け収益条件など追加の要件がある場合があります。
        利用前に各ツールの公式利用規約を必ず確認してください。
      </p>
    </GuideSummaryBox>

    <!-- 免責事項 -->
    <GuideWarningBox variant="warning" title="免責事項">
      このガイドは情報提供を目的としており、法的アドバイスではありません。商用利用の判断は各ツールの最新利用規約を必ず確認し、重要な場面では専門家（弁護士等）への相談に基づいて行ってください。
    </GuideWarningBox>

    <!-- ── 確認すべきポイント ── -->
    <section class="my-10" aria-labelledby="check-points-heading">
      <h2 class="mb-6 text-lg font-semibold text-slate-900" id="check-points-heading">
        商用利用で確認すべきポイント
      </h2>

      <ol class="space-y-5">
        <li class="flex gap-4">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white" aria-hidden="true">1</span>
          <div>
            <h3 class="mb-1 text-sm font-semibold text-slate-900">公式規約で商用利用が認められているか</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              各AIツールの利用規約（Terms of Service）が商用利用を認めているかが最優先の確認事項です。規約は予告なく変更される場合があるため、利用前に最終更新日も確認することを推奨します。
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white" aria-hidden="true">2</span>
          <div>
            <h3 class="mb-1 text-sm font-semibold text-slate-900">無料プランと有料プランで条件が違うか</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              多くのAIツールでは、無料プランと有料プランで商用利用の条件が異なります。無料プランでは透かし・解像度・クレジット表記・利用可能な用途などに制限がある場合があります。Pika・Kling AIの無料プランは商用利用不可とされています（確認時点）。
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white" aria-hidden="true">3</span>
          <div>
            <h3 class="mb-1 text-sm font-semibold text-slate-900">透かしやクレジット表記の条件があるか</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              透かしを除去できることと、商用利用が認められていることは別の問題です。有料プランで透かしを消せても、利用規約上の商用利用条件を別途満たす必要がある場合があります。ツール名のクレジット表記を求める規約があるかどうかも事前に確認してください。
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white" aria-hidden="true">4</span>
          <div>
            <h3 class="mb-1 text-sm font-semibold text-slate-900">生成物に第三者の権利が含まれていないか</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              AIが生成したコンテンツに既存のキャラクター・ロゴ・商標・著名人の肖像・第三者の著作物の特徴が含まれている場合、著作権・商標権・肖像権等を侵害する可能性があります。このリスクはどのツールを使用した場合にも生じる可能性があり、ツールの利用規約上の商用利用許可とは別に対応が必要です。
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white" aria-hidden="true">5</span>
          <div>
            <h3 class="mb-1 text-sm font-semibold text-slate-900">素材・テンプレート・アップロード画像の権利に問題がないか</h3>
            <p class="text-sm leading-relaxed text-slate-600">
              Canvaのように素材・テンプレート・アップロード画像を組み合わせるツールでは、AI生成部分だけでなく、組み合わせた各素材それぞれの権利条件を個別に確認する必要があります。
            </p>
          </div>
        </li>
      </ol>
    </section>

    <!-- ── ツール別比較 ── -->
    <section class="my-10" aria-labelledby="tool-comparison-heading">
      <h2 class="mb-2 text-lg font-semibold text-slate-900" id="tool-comparison-heading">
        ツール別の商用利用条件
      </h2>
      <p class="mb-6 text-sm text-slate-500">
        以下は各確認日時点の情報です。<strong class="font-medium text-slate-700">実際の条件はプラン・時期によって変更される場合があります。</strong>
        詳細は各ツールの詳細ページおよび公式利用規約でご確認ください。
      </p>

      <h3 class="mb-3 text-sm font-semibold text-slate-700">画像生成ツール</h3>
      <GuideComparisonTable
        caption="画像生成ツール商用利用比較"
        headers={imageToolHeaders}
        rows={imageToolRows}
        statusColIndex={1}
      />

      <h3 class="mb-3 mt-8 text-sm font-semibold text-slate-700">動画生成ツール</h3>
      <GuideComparisonTable
        caption="動画生成ツール商用利用比較"
        headers={videoToolHeaders}
        rows={videoToolRows}
        statusColIndex={1}
      />

      <!-- 凡例 -->
      <div class="mt-4 rounded-lg border border-slate-100 bg-slate-50 px-4 py-3 text-xs text-slate-600">
        <p class="mb-1 font-semibold text-slate-700">凡例</p>
        <ul class="space-y-1">
          <li><span class="inline-block rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-800 mr-2">〇（条件あり）</span>確認時点の公式情報で商用利用できる場合があるとされています。利用規約・プラン・コンテンツ内容等により制限される可能性があります。</li>
          <li><span class="inline-block rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800 mr-2">△（プランにより異なる）</span>無料プランでは商用利用不可、有料プランでは商用利用できる場合があるとされています。</li>
        </ul>
        <p class="mt-2 text-slate-500">この表は法的判断の根拠ではありません。必ず各ツールの最新公式情報をご確認ください。</p>
      </div>
    </section>

    <!-- ── 無料プランの注意 ── -->
    <section class="my-10" aria-labelledby="free-plan-heading">
      <h2 class="mb-3 text-lg font-semibold text-slate-900" id="free-plan-heading">
        無料プラン利用時の注意
      </h2>
      <p class="mb-4 text-sm text-slate-500">
        無料プランで生成したコンテンツを商用利用する際は特に注意が必要です。
      </p>

      <GuideWarningBox variant="danger" title="無料プランで商用利用が明確に不可とされているツール（確認時点）">
        <strong>Pika・Kling AI・Leonardo AI</strong> の無料プランは商用利用不可とされています。
      </GuideWarningBox>

      <GuideComparisonTable
        caption="無料プランの商用利用制限"
        headers={freePlanHeaders}
        rows={freePlanRows}
        statusColIndex={-1}
      />
    </section>

    <!-- ── 透かし・クレジット ── -->
    <section class="my-10" aria-labelledby="watermark-heading">
      <h2 class="mb-3 text-lg font-semibold text-slate-900" id="watermark-heading">
        透かし・クレジット・ライセンスの違い
      </h2>
      <p class="mb-4 text-sm font-medium text-slate-700">
        「透かしなし＝商用利用可」ではありません。透かしの有無、クレジット表記の要否、商用ライセンスの付与はそれぞれ別の問題です。
      </p>

      <GuideComparisonTable
        caption="ツール別透かし条件"
        headers={watermarkHeaders}
        rows={watermarkRows}
        statusColIndex={-1}
      />
    </section>

    <!-- ── チェックリスト ── -->
    <section class="my-10">
      <GuideCheckList
        title="実務利用前のチェックリスト"
        items={checklistItems}
      />
    </section>

    <!-- ── FAQ ── -->
    <section class="my-10">
      <GuideFAQ items={faqItems} title="よくある質問（FAQ）" />
    </section>

    <!-- ── 注意事項 ── -->
    <section class="my-10" aria-labelledby="notes-heading">
      <h2 class="mb-4 text-base font-semibold text-slate-900" id="notes-heading">注意事項</h2>
      <GuideWarningBox variant="info">
        <ul class="space-y-1.5 list-disc list-inside">
          <li>各ツールの利用規約は予告なく変更されます。定期的に公式規約を確認してください</li>
          <li>このサイトの情報は各ページの確認日時点のものです。最新情報は必ず公式サイトでご確認ください</li>
          <li>AI生成コンテンツに関する著作権・知的財産の法的解釈は、日本を含む各国で整備・更新中です</li>
          <li>重要な商用利用の場面では、法律の専門家（弁護士等）への相談を推奨します</li>
        </ul>
