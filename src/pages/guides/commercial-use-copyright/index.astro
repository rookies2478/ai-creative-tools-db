---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CommercialUseCopyright from '../../../components/CommercialUseCopyright.astro';
---

<BaseLayout
  title="AI画像・動画生成の商用利用と著作権ガイド｜規約・肖像権・商標の確認ポイント"
  description="AI画像生成・AI動画生成ツールを仕事や副業で使う前に確認したい、商用利用条件・著作権・肖像権・商標・第三者素材の注意点を整理します。本記事は法的助言ではありません。"
  canonicalPath="/guides/commercial-use-copyright/"
  ogType="article"
>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <CommercialUseCopyright
      related={[
        { label: '商用利用前の確認チェックリスト', href: '/guides/ai-image-commercial-use-checklist/' },
        { label: '商用利用を確認しやすいツール', href: '/conditions/commercial-use/' },
        { label: '無料で使えるツール', href: '/conditions/free/' },
        { label: '日本語対応ツール', href: '/conditions/japanese/' },
        { label: '透かしなしツール', href: '/conditions/no-watermark/' },
      ]}
      relatedSolid={[
        { label: 'すべてのツールを見る', href: '/tools/' },
        { label: '全ツール比較表', href: '/comparisons/' },
      ]}
    />
  </div>
</BaseLayout>
