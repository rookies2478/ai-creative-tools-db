---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuidePageHeader from '../../../components/GuidePageHeader.astro';
import GuideSummaryBox from '../../../components/GuideSummaryBox.astro';
import GuideWarningBox from '../../../components/GuideWarningBox.astro';
import GuideCheckList from '../../../components/GuideCheckList.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';
import GuideComparisonTable from '../../../components/GuideComparisonTable.astro';
import GuideFreshnessBox from '../../../components/GuideFreshnessBox.astro';

const entry = await getEntry('guides', 'free-ai-image-tools');
if (!entry) throw new Error('guide not found: free-ai-image-tools');
const { data } = entry;

const allTools = await getCollection('tools');
const freeTools = allTools
  .filter((t) => t.data.freePlan === true || t.data.freePlan === 'limited')
  .sort((a, b) => a.data.name.localeCompare(b.data.name, 'ja'));

type FreePlan = boolean | 'limited' | 'unknown';
type FourState = 'yes' | 'no' | 'limited' | 'unknown';

function freePlanLabel(val: FreePlan): string {
  if (val === true)      return '〇 無料プランあり';
  if (val === 'limited') return '△ 制限付き無料';
                         return '不明';
}

function commercialLabel(val: FourState): string {
  if (val === 'yes')     return '〇 可';
  if (val === 'no')      return '× 不可';
  if (val === 'limited') return '△ 条件付き';
                         return '不明';
}

function watermarkLabel(val: FourState): string {
  if (val === 'yes')     return '× あり';
  if (val === 'no')      return '〇 なし';
  if (val === 'limited') return '△ 条件付き';
                         return '確認中';
}

const freeToolRows = freeTools.map((tool) => [
  { text: tool.data.name, href: `/tools/${tool.slug}/` },
  { text: freePlanLabel(tool.data.freePlan) },
  { text: commercialLabel(tool.data.commercialUse) },
  { text: watermarkLabel(tool.data.watermark) },
  { text: tool.data.lastReviewed, muted: true },
]);

const freePlanTypeRows = [
  [{ text: '無料プラン（Free Plan）' }, { text: '毎月一定量のクレジットが継続的に付与されるプラン' }],
  [{ text: '無料トライアル（Free Trial）' }, { text: '一定期間または一定量だけ有料機能を試せる仕組み' }],
  [{ text: '無料クレジット（Free Credits）' }, { text: '新規登録時に付与される初回限りのポイント' }],
];

const useCaseRows = [
  [{ text: '手軽にWebで試したい・日本語対応が必要' }, { text: 'Canva AI画像生成 / Adobe Firefly' }, { text: '日本語UI・プロンプト対応。登録後すぐ使える' }],
  [{ text: 'ChatGPTと一緒に使いたい' }, { text: 'DALL·E', href: '/tools/dalle/' }, { text: 'ChatGPT統合。日本語UIはChatGPTに準拠' }],
  [{ text: '商用素材として使いたい' }, { text: 'Adobe Firefly', href: '/tools/adobe-firefly/' }, { text: '商用利用を想定した設計とされている（条件要確認）' }],
  [{ text: 'プライバシー重視・ローカルで使いたい' }, { text: 'Stable Diffusion', href: '/tools/stable-diffusion/' }, { text: 'ローカル実行。標準的な構成ではデータが外部に送られにくい' }],
  [{ text: 'ゲーム・イラスト向けに無料枠での試作' }, { text: 'Leonardo AI', href: '/tools/leonardo-ai/' }, { text: '1日150トークン程度の無料枠（変更の可能性あり）' }],
];

const checklistItems = [
  '無料プランの形式を確認した（継続型か、初回のみか）',
  '月あたりの生成可能枚数・クレジット数を確認した',
  '透かしの有無・条件を確認した',
  '商用利用する場合、公式規約で条件を確認した',
  'クレジット表記の義務の有無を確認した',
  '使いたいデバイス・環境に対応しているか確認した',
  '日本語UI・プロンプト対応が必要な場合、対応状況を確認した',
];

const faqItems = [
  {
    q: '無料で使えるAI画像生成ツールはありますか？',
    a: 'あります。Stable Diffusion（ローカル実行）・Adobe Firefly・Canva AI画像生成・DALL·E（ChatGPT経由）・Leonardo AIなどで無料プランまたは無料枠が提供されています（確認時点）。ただし生成枚数・機能・商用利用条件はツールによって異なります。最新の提供状況は各ツールの公式サイトでご確認ください。',
  },
  {
    q: '無料プランでも商用利用できますか？',
    a: 'ツールによって異なります。Adobe Firefly・DALL·E（ChatGPT経由）は公式情報上、商用利用が案内されていますが、条件があります。Leonardo AIの無料プランでは生成画像の権利がLeonardo.AIに帰属する場合があるとされています。Stable Diffusionはモデルバージョンごとにライセンスが異なります。商用利用前は必ず各ツールの公式利用規約の最新版をご確認ください。このページは法的アドバイスではありません。',
  },
  {
    q: '無料プランでは透かしが入りますか？',
    a: 'ツールやプランによって異なります。無料プランで可視透かしが付与されるツールもあれば、透かしなしで利用できるツールもあります。また可視透かしがない場合でも、C2PAなどの不可視メタデータが埋め込まれる場合があります（Adobe Firefly・DALL·E 3など）。最新の条件は各ツールの公式サイトでご確認ください。',
  },
  {
    q: '日本語で使える無料AI画像生成ツールはありますか？',
    a: '日本語UIに対応しているツールとして、Adobe Firefly・Canva AI画像生成（いずれも確認時点）が挙げられます。DALL·EはChatGPT経由のためChatGPTの日本語UIに準拠します。最新の対応状況は各ツールの公式サイトでご確認ください。',
  },
  {
    q: '無料プランから有料プランに切り替える目安はありますか？',
    a: '月あたりの生成回数・クレジットが不足している場合、透かしが商用利用・納品物に支障をきたす場合、商用利用条件を満たすために有料プランが必要とされている場合、出力解像度が用途に対して不足している場合に有料プランの検討が現実的です。料金・機能・商用利用条件を公式サイトで比較してください。',
  },
];
---

<BaseLayout
  title={`${data.title} | AIクリエイティブツール比較DB`}
  description={data.description}
  canonicalPath="/guides/free-ai-image-tools/"
  ogType="article"
>
  <div class="mx-auto max-w-3xl px-6 py-12">

    <GuidePageHeader
      title={data.title}
      description={data.description}
      lastReviewed={data.lastReviewed}
    />

    <GuideSummaryBox title="このガイドの結論">
      <p>
        無料で試せるAI画像生成ツールはいくつかありますが、<strong class="font-semibold text-slate-900">「無料で使える」＝「制限なく使える」ではありません</strong>。
        クレジット数・透かし・商用利用条件・対応環境はツールごとに大きく異なります。用途に合わせた事前確認が重要です。
      </p>
    </GuideSummaryBox>

    <GuideWarningBox variant="warning" title="免責事項">
      このガイドは情報提供を目的としており、法的アドバイスではありません。商用利用の可否判断は各ツールの最新利用規約を必ずご確認ください。
    </GuideWarningBox>

    <!-- 選ぶポイント -->
    <section class="my-10" aria-labelledby="points-heading">
      <h2 class="mb-5 text-lg font-semibold text-slate-900" id="points-heading">
        無料AI画像生成ツールを選ぶポイント
      </h2>
      <ol class="space-y-3">
        {[
          ['無料プランの形式', '継続的に使えるか、初回のみか'],
          ['生成できる枚数・クレジット数', '月あたりの上限を確認する'],
          ['透かし（ウォーターマーク）の有無と条件', 'SNS投稿や商用利用で問題にならないか'],
          ['商用利用の可否', '無料プランでの商用利用条件を確認する'],
          ['対応環境', 'Webブラウザ・スマートフォン・ローカル実行など'],
          ['日本語対応', 'UI・プロンプトの対応状況'],
        ].map(([title, desc], i) => (
          <li class="flex gap-4">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white" aria-hidden="true">{i + 1}</span>
            <div>
              <p class="text-sm font-semibold text-slate-900">{title}</p>
              <p class="text-sm text-slate-600">{desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- 無料枠の種類 -->
    <section class="my-10" aria-labelledby="plan-types-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="plan-types-heading">
        無料枠で比較すべき項目
      </h2>

      <h3 class="mb-3 text-sm font-semibold text-slate-700">無料プランの種類を把握する</h3>
      <p class="mb-4 text-sm leading-relaxed text-slate-600">
        「無料で使える」という表現には異なる意味が含まれている場合があります。「初回無料クレジット」は継続的に使える「無料プラン」とは別物です。各ツールの公式サイトで、どの形式の「無料」かを確認してください。
      </p>

      <GuideComparisonTable
        caption="無料プランの種類"
        headers={['種類', '内容']}
        rows={freePlanTypeRows}
        statusColIndex={-1}
      />

      <h3 class="mb-3 mt-8 text-sm font-semibold text-slate-700">透かし（ウォーターマーク）について</h3>
      <p class="mb-4 text-sm leading-relaxed text-slate-600">
        生成画像に透かしが入る場合、SNS・個人利用では問題ないこともありますが、商業素材・納品物・広告への使用は困難な場合があります。
        また可視透かしがなくても、C2PA（Content Authenticity Initiative）などの標準に基づく不可視メタデータが埋め込まれる場合があります。<strong class="font-medium text-slate-700">透かしを消せることと商用利用できることは別問題です。</strong>
      </p>

      <h3 class="mb-3 mt-8 text-sm font-semibold text-slate-700">商用利用条件のパターン</h3>
      <ul class="space-y-2 text-sm text-slate-600">
        <li class="flex gap-2"><span class="text-slate-400 shrink-0">—</span><span><strong class="font-medium text-slate-700">無料プランでも商用利用できる場合がある：</strong>条件・注意事項を確認の上で利用する（Adobe Firefly・DALL·Eなど）</span></li>
        <li class="flex gap-2"><span class="text-slate-400 shrink-0">—</span><span><strong class="font-medium text-slate-700">有料プランへのアップグレードが必要な場合：</strong>無料プランでは商用利用に制限がある（Leonardo AIなど）</span></li>
        <li class="flex gap-2"><span class="text-slate-400 shrink-0">—</span><span><strong class="font-medium text-slate-700">追加の条件がある場合：</strong>AI生成コンテンツであることの明示が求められる場合がある（Canva AIなど）</span></li>
        <li class="flex gap-2"><span class="text-slate-400 shrink-0">—</span><span><strong class="font-medium text-slate-700">モデルバージョンによって条件が異なる場合：</strong>利用するモデルごとに確認が必要（Stable Diffusionなど）</span></li>
      </ul>
    </section>

    <!-- 動的ツール一覧 -->
    <section class="my-10" aria-labelledby="tool-list-heading">
      <h2 class="mb-2 text-lg font-semibold text-slate-900" id="tool-list-heading">
        無料プランがあるツール（確認時点）
      </h2>
      <p class="mb-4 text-sm text-slate-500">
        以下は <strong class="font-medium text-slate-700">{data.lastReviewed}</strong> 時点の調査に基づく目安です。プランや時期によって変更される可能性があります。詳細は各ツールの詳細ページおよび公式サイトでご確認ください。
      </p>

      {freeTools.length === 0 ? (
        <p class="rounded-xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-600">
          現在、公式情報確認前のため、この条件に該当するツールは未確定です。確認が完了したツールから順次掲載します。
        </p>
      ) : (
        <GuideComparisonTable
          caption="無料プランがあるツール一覧"
          headers={['ツール名', '無料プラン', '商用利用', '透かし', '最終確認日']}
          rows={freeToolRows}
          statusColIndexes={[1, 2, 3]}
        />
      )}

      <!-- 凡例 -->
      <div class="mt-4 rounded-lg border border-slate-100 bg-slate-50 px-4 py-3 text-xs text-slate-600">
        <p class="mb-1 font-semibold text-slate-700">凡例</p>
        <ul class="space-y-1">
          <li><span class="inline-block rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-800 mr-2">〇</span>可能または無料プランあり（確認時点。条件あり）</li>
          <li><span class="inline-block rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800 mr-2">△</span>条件付き・制限付き</li>
          <li><span class="inline-block rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-800 mr-2">×</span>不可または透かしあり</li>
        </ul>
        <p class="mt-2 text-slate-500">この表は法的判断の根拠ではありません。必ず各ツールの最新公式情報をご確認ください。</p>
      </div>
    </section>

    <!-- 用途別おすすめ -->
    <section class="my-10" aria-labelledby="usecase-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="usecase-heading">用途別おすすめ</h2>
      <p class="mb-4 text-sm text-slate-500">目的に応じて、以下を参考に選ぶことができます。各ツールの詳細条件・最新情報は各ツールの詳細ページおよび公式サイトでご確認ください。</p>

      <GuideComparisonTable
        caption="用途別おすすめツール"
        headers={['用途', 'ツール', '理由']}
        rows={useCaseRows}
        statusColIndex={-1}
      />
    </section>

    <!-- 無料プラン利用時の注意点 -->
    <section class="my-10">
      <GuideWarningBox variant="info" title="無料プラン利用時の注意点">
        <ul class="space-y-1.5 list-disc list-inside">
          <li><strong>無料枠は変更・終了される可能性があります。</strong>今日確認した内容が数週間後に変わっている場合があります。</li>
          <li><strong>「永久無料」という表現は保証ではありません。</strong>サービス方針の変更により、無料プランが縮小・廃止される可能性があります。</li>
          <li><strong>「初回のみ無料」と「毎月継続して無料」は別物です。</strong>生成前に無料プランの形式を確認してください。</li>
          <li><strong>無料プランのコンテンツがプラットフォームに利用される場合があります。</strong>一部のツールでは生成コンテンツがモデル学習等に使用される可能性があります。</li>
          <li><strong>商用利用前には必ず公式規約を確認してください。</strong></li>
        </ul>
      </GuideWarningBox>
    </section>

    <!-- チェックリスト -->
    <section class="my-10">
      <GuideCheckList
        id="free-tools-checklist"
        title="実際に使う前のチェックリスト"
        items={checklistItems}
      />
    </section>

    <!-- FAQ -->
    <section class="my-10">
      <GuideFAQ items={faqItems} title="よくある質問（FAQ）" />
    </section>

    <!-- 注意事項 -->
    <section class="my-10">
      <GuideWarningBox variant="info">
        <ul class="space-y-1.5 list-disc list-inside">
          <li>各ツールの料金・利用規約は予告なく変更されます。利用前に必ず公式サイトの最新情報をご確認ください</li>
          <li>本ページは法的アドバイスではありません。重要な商用利用の場面では、専門家（弁護士等）への相談を推奨します</li>
        </ul>
      </GuideWarningBox>
    </section>

    <GuideFreshnessBox lastReviewed={data.lastReviewed} nextReviewDue={data.nextReviewDue} />

    <!-- 関連ページ -->
    <section class="mb-8 space-y-6">
      <div>
        <h2 class="mb-3 text-sm font-semibold text-slate-600">関連ページ</h2>
        <ul class="flex flex-wrap gap-3 text-sm">
          <li><a href="/tools/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">ツール一覧</a></li>
          <li><a href="/categories/free/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">無料で使えるツール</a></li>
          <li><a href="/categories/commercial-use/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">商用利用を確認しやすいツール</a></li>
          <li><a href="/categories/no-watermark/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">透かしなしツール</a></li>
          <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">商用利用・著作権ガイド</a></li>
          <li><a href="/guides/watermark-credit-guide/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">透かし・クレジット表記ガイド</a></li>
        </ul>
      </div>
    </section>

    <nav class="border-t border-slate-200 pt-6 text-sm" aria-label="ページナビゲーション">
      <a href="/" class="text-blue-600 hover:underline focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-sm">← トップに戻る</a>
    </nav>

  </div>
</BaseLayout>
