---
import { getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import JapaneseAiToolsGuide from '../../../components/JapaneseAiToolsGuide.astro';

const entry = await getEntry('guides', 'japanese-ai-image-tools');
if (!entry) throw new Error('guide not found: japanese-ai-image-tools');
const { data } = entry;

const breadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://aicreative-db.com/" },
    { "@type": "ListItem", "position": 2, "name": "ガイド一覧", "item": "https://aicreative-db.com/guides/" },
    { "@type": "ListItem", "position": 3, "name": "日本語対応AI画像生成ツール比較" }
  ]
});
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonicalPath="/guides/japanese-ai-image-tools/"
  ogType="article"
  jsonLd={breadcrumb}
>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <JapaneseAiToolsGuide
      checkedDate={data.lastReviewed}
      nextCheckDate={data.nextReviewDue}
      statusAsOf={data.lastReviewed}
      related={[
        { label: 'ツール一覧', href: '/tools/' },
        { label: '日本語対応ツール', href: '/conditions/japanese/' },
        { label: '無料で使えるツール', href: '/conditions/free/' },
        { label: '商用利用を確認しやすいツール', href: '/conditions/commercial-use/' },
        { label: '無料ツールの選び方', href: '/guides/free-ai-image-tools/' },
        { label: '透かし・クレジット表記ガイド', href: '/guides/watermark-credit-guide/' },
        { label: '日本語対応の3区分ガイド', href: '/guides/japanese-support-three-types/' },
      ]}
    />
  </div>
</BaseLayout>
