---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const entry = await getEntry('guides', 'japanese-ai-image-tools');
if (!entry) throw new Error('guide not found: japanese-ai-image-tools');

const { data } = entry;
const { Content } = await entry.render();

const allTools = await getCollection('tools');
const japaneseTools = allTools.filter(
  (t) =>
    t.data.japaneseUi === true ||
    t.data.japaneseUi === 'partial' ||
    t.data.japanesePrompt === true ||
    t.data.japanesePrompt === 'partial'
);

type FreePlan = boolean | 'limited' | 'unknown';
type TriState = boolean | 'partial' | 'unknown';
type FourState = 'yes' | 'no' | 'limited' | 'unknown';

function triLabel(val: TriState) {
  if (val === true)      return { text: '対応',    cls: 'bg-green-100 text-green-800' };
  if (val === false)     return { text: '非対応',  cls: 'bg-red-100 text-red-800' };
  if (val === 'partial') return { text: '一部対応', cls: 'bg-yellow-100 text-yellow-800' };
                         return { text: '確認中',  cls: 'bg-gray-100 text-gray-600' };
}

function freePlanLabel(val: FreePlan) {
  if (val === true)      return { text: '無料プランあり', cls: 'bg-green-100 text-green-800' };
  if (val === false)     return { text: '無料プランなし', cls: 'bg-red-100 text-red-800' };
  if (val === 'limited') return { text: '制限付き無料',  cls: 'bg-yellow-100 text-yellow-800' };
                         return { text: '不明',          cls: 'bg-gray-100 text-gray-600' };
}

function commercialUseLabel(val: FourState) {
  if (val === 'yes')     return { text: '可',      cls: 'bg-green-100 text-green-800' };
  if (val === 'no')      return { text: '不可',    cls: 'bg-red-100 text-red-800' };
  if (val === 'limited') return { text: '条件付き', cls: 'bg-yellow-100 text-yellow-800' };
                         return { text: '不明',    cls: 'bg-gray-100 text-gray-600' };
}
---

<BaseLayout
  title={`${data.title} | AI画像生成・動画生成ツール比較DB`}
  description={data.description}
  canonicalPath="/guides/japanese-ai-image-tools/"
  ogType="article"
>
  <div class="mx-auto max-w-3xl px-6 py-12">

    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <span>{data.title}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">{data.title}</h1>
      <p class="mt-2 text-gray-500">{data.description}</p>
    </header>

    <div class="prose prose-gray mb-10 max-w-none text-sm leading-relaxed">
      <Content />
    </div>

    <!-- 日本語対応ツール表 -->
    <section class="mb-10">
      <h2 class="mb-4 text-lg font-semibold text-gray-800">日本語対応ツール一覧（確認時点）</h2>
      <p class="mb-4 text-xs text-gray-500">
        以下は <strong>{data.lastReviewed}</strong> 時点の調査に基づく目安です。アップデートや方針変更により変わる可能性があります。詳細は各ツールの詳細ページおよび公式サイトでご確認ください。
      </p>

      <div class="mb-3 flex flex-wrap gap-3 text-xs text-gray-600">
        <span>凡例：</span>
        <span class="rounded bg-green-100 px-2 py-0.5 text-green-800">対応</span>
        <span class="rounded bg-yellow-100 px-2 py-0.5 text-yellow-800">一部対応</span>
        <span class="rounded bg-red-100 px-2 py-0.5 text-red-800">非対応</span>
        <span class="rounded bg-gray-100 px-2 py-0.5 text-gray-600">確認中</span>
      </div>

      {japaneseTools.length === 0 ? (
        <p class="rounded-lg border border-gray-200 bg-gray-50 px-5 py-4 text-sm text-gray-600">
          現在、公式情報確認前のため、この条件に該当するツールは未確定です。確認が完了したツールから順次掲載します。
        </p>
      ) : (
        <div class="overflow-x-auto rounded-lg border border-gray-200">
          <table class="w-full text-sm">
            <thead class="bg-gray-50 text-left text-xs font-medium text-gray-600">
              <tr>
                <th class="px-4 py-3">ツール名</th>
                <th class="px-4 py-3">日本語UI</th>
                <th class="px-4 py-3">日本語プロンプト</th>
                <th class="px-4 py-3">無料プラン</th>
                <th class="px-4 py-3">商用利用</th>
                <th class="px-4 py-3">最終確認日</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {japaneseTools.map((tool) => {
                const jui = triLabel(tool.data.japaneseUi);
                const jpr = triLabel(tool.data.japanesePrompt);
                const fp  = freePlanLabel(tool.data.freePlan);
                const cu  = commercialUseLabel(tool.data.commercialUse);
                return (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium">
                      <a href={`/tools/${tool.slug}/`} class="text-blue-600 hover:underline">
                        {tool.data.name}
                      </a>
                    </td>
                    <td class="px-4 py-3">
                      <span class={`rounded px-2 py-0.5 text-xs font-medium ${jui.cls}`}>{jui.text}</span>
                    </td>
                    <td class="px-4 py-3">
                      <span class={`rounded px-2 py-0.5 text-xs font-medium ${jpr.cls}`}>{jpr.text}</span>
                    </td>
                    <td class="px-4 py-3">
                      <span class={`rounded px-2 py-0.5 text-xs font-medium ${fp.cls}`}>{fp.text}</span>
                    </td>
                    <td class="px-4 py-3">
                      <span class={`rounded px-2 py-0.5 text-xs font-medium ${cu.cls}`}>{cu.text}</span>
                    </td>
                    <td class="px-4 py-3 text-gray-500">{tool.data.lastReviewed}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- FAQ -->
    <section class="mb-10">
      <h2 class="mb-4 text-lg font-semibold text-gray-800">よくある質問</h2>
      <div class="space-y-5">
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">日本語UIに対応していれば使いやすいですか？</p>
          <p class="mt-2 text-sm text-gray-600">
            日本語UIに対応していると操作しやすい場合があります。ただし、AI生成の品質や商用利用条件はUI言語だけでは判断できません。料金、利用規約、出力品質も確認してください。
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">英語UIのツールでも日本語プロンプトは使えますか？</p>
          <p class="mt-2 text-sm text-gray-600">
            使える場合があります。ただし、ツールやモデルによって日本語の理解度や出力精度は異なる可能性があります。重要な用途では、複数回確認し、必要に応じて英語プロンプトも検討してください。
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 px-5 py-4">
          <p class="font-medium text-gray-800">日本語プロンプトで作った画像や動画は商用利用できますか？</p>
          <p class="mt-2 text-sm text-gray-600">
            プロンプトの言語だけでは商用利用可否は決まりません。商用利用の可否は、ツールの利用規約、プラン、生成内容、用途によって変わる場合があります。必ず公式情報をご確認ください。
          </p>
        </div>
      </div>
    </section>

    <!-- 情報鮮度・免責 -->
    <section class="mb-8 rounded-lg border border-yellow-200 bg-yellow-50 px-5 py-4 text-sm text-yellow-800">
      <p>
        <strong>情報の鮮度：</strong>最終確認日 {data.lastReviewed}（次回確認予定 {data.nextReviewDue}）
      </p>
      <p class="mt-1">
        各ツールの機能・対応状況・料金・利用規約は予告なく変更されます。利用前に必ず公式サイトの最新情報をご確認ください。本ページは法的アドバイスではありません。
      </p>
    </section>

    <!-- 関連ページ -->
    <section class="mb-8">
      <h2 class="mb-3 text-sm font-semibold text-gray-600">関連ページ</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/tools/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">ツール一覧</a></li>
        <li><a href="/categories/japanese/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">日本語対応ツール</a></li>
        <li><a href="/categories/free/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">無料で使えるツール</a></li>
        <li><a href="/categories/commercial-use/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用OKのツール</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用・著作権ガイド</a></li>
        <li><a href="/guides/free-ai-image-tools/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">無料ツールの選び方</a></li>
        <li><a href="/guides/watermark-credit-guide/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">透かし・クレジット表記ガイド</a></li>
      </ul>
    </section>

    <nav class="border-t border-gray-200 pt-6 text-sm">
      <a href="/" class="text-blue-600 hover:underline">← トップに戻る</a>
    </nav>

  </div>
</BaseLayout>
