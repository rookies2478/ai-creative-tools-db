---
import { getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuideWarningBox from '../../../components/GuideWarningBox.astro';
import GuideSummaryBox from '../../../components/GuideSummaryBox.astro';
import GuideCheckList from '../../../components/GuideCheckList.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';
import GuideComparisonTable from '../../../components/GuideComparisonTable.astro';
import GuideFreshnessBox from '../../../components/GuideFreshnessBox.astro';

const entry = await getEntry('guides', 'japanese-support-three-types');
if (!entry) throw new Error('guide not found: japanese-support-three-types');
const { data } = entry;

// ── 比較表：3区分の確認表 ─────────────────────────────
const crossHeaders = ['ツール名', '日本語UI', '日本語プロンプト', '日本語文字生成', '日本語公式ページ', '注意点'];
const crossRows = [
  [
    { text: 'Adobe Firefly', href: '/tools/adobe-firefly/' },
    { text: '〇 対応' },
    { text: '〇 対応' },
    { text: '要実テスト' },
    { text: 'あり' },
    { text: 'UI・プロンプトは日本語対応とされるが、画像内文字生成の精度は未検証' },
  ],
  [
    { text: 'Canva AI画像生成', href: '/tools/canva-ai-image-generator/' },
    { text: '〇 対応' },
    { text: '〇 対応' },
    { text: '要実テスト' },
    { text: 'あり' },
    { text: 'デザインツールと一体化。文字入れはCanvaのテキスト編集機能で代替可能' },
  ],
  [
    { text: 'Gemini画像生成', href: '/tools/gemini-image-generation/' },
    { text: '〇 対応' },
    { text: '〇 対応' },
    { text: '要実テスト' },
    { text: 'あり' },
    { text: 'UI・プロンプトは日本語対応とされる。画像内文字生成は未検証' },
  ],
  [
    { text: 'Microsoft Designer', href: '/tools/microsoft-designer/' },
    { text: '〇 対応' },
    { text: '〇 対応' },
    { text: '要実テスト' },
    { text: '？ 未確認' },
    { text: 'UI・プロンプトは日本語対応。日本語公式資料の有無は要確認' },
  ],
  [
    { text: 'Ideogram', href: '/tools/ideogram/' },
    { text: '× 非対応' },
    { text: '？ 要確認' },
    { text: '要実テスト' },
    { text: '？ 未確認' },
    { text: 'UIは日本語非対応とされる。日本語プロンプトの精度は要確認' },
  ],
  [
    { text: 'Midjourney', href: '/tools/midjourney/' },
    { text: '× 非対応' },
    { text: '△ 一部対応' },
    { text: '要実テスト' },
    { text: '？ 未確認' },
    { text: 'UIは英語のみ。日本語プロンプトは一部使えるが英語より精度が下がる傾向' },
  ],
  [
    { text: 'Runway', href: '/tools/runway/' },
    { text: '× 非対応' },
    { text: '△ 一部対応' },
    { text: '要実テスト' },
    { text: '？ 未確認' },
    { text: 'UIは英語のみ。日本語プロンプトは一部対応とされる' },
  ],
  [
    { text: 'Kling AI', href: '/tools/kling-ai/' },
    { text: '△ 一部対応' },
    { text: '〇 対応' },
    { text: '要実テスト' },
    { text: '？ 未確認' },
    { text: 'UIは一部日本語表示。日本語プロンプトは対応とされる' },
  ],
  [
    { text: 'Vidu AI', href: '/tools/vidu-ai/' },
    { text: '× 非対応' },
    { text: '？ 要確認' },
    { text: '要実テスト' },
    { text: '？ 未確認' },
    { text: 'UI・プロンプトともに公式情報から未確認の部分あり' },
  ],
  [
    { text: 'HeyGen', href: '/tools/heygen/' },
    { text: '？ 要確認' },
    { text: '〇 対応' },
    { text: '要実テスト' },
    { text: '？ 未確認' },
    { text: '日本語プロンプト・音声ナレーションは対応とされるが、UI対応状況は要確認' },
  ],
];

// ── チェックリスト ─────────────────────────────────────────
const checklistItems = [
  '「日本語対応」が、UI・プロンプト・文字生成のどの意味で使われているか確認した',
  '操作画面を日本語で使いたいか、指示文だけ日本語でよいかを区別した',
  '画像・動画内に日本語文字を入れる必要がある場合、実際に生成テストを行う（または編集ツールでの追加を検討する）予定にした',
  '日本語ページの有無と、日本円決済の可否は別問題であることを理解した',
  '商用利用条件は日本語対応の3区分とは別に確認する必要があることを理解した',
  '公式サイト・実際の編集画面で最新の対応状況を確認する予定にした',
];

// ── FAQ ────────────────────────────────────────────────────
const faqItems = [
  {
    q: 'AIツールの日本語対応とは何ですか？',
    a: '「日本語対応」は1つの意味ではなく、少なくとも日本語UI（管理画面表示）、日本語プロンプト（指示文の入力）、日本語文字生成（画像・動画内の文字描画）の3つに分解できます。ツール紹介で「日本語対応」とだけ書かれている場合、どの軸を指しているか確認することをおすすめします。',
  },
  {
    q: '日本語UIがあれば日本語プロンプトも使えますか？',
    a: '必ずしもそうとは限りません。日本語UIと日本語プロンプトの精度は別の機能・技術領域です。UIが日本語でもプロンプトの理解精度が低い場合や、逆にUIが英語のみでも日本語プロンプトが使える場合があります。',
  },
  {
    q: '日本語プロンプトが使えれば、画像内の日本語文字も正しく生成できますか？',
    a: '別の話です。プロンプトを日本語で理解できることと、画像内に日本語の文字を正確に描画できることは異なる技術的課題です。実際に生成テストを行わない限り、文字生成の精度を断定することはできません。',
  },
  {
    q: '日本語ページがあるツールは日本円で支払えますか？',
    a: '日本語ページの有無と日本円決済の可否は別の条件です。日本語UIや紹介ページが日本語であっても、決済は外貨建てでカード会社が円換算する場合があります。詳しくは料金表の見方ガイドをご参照ください。',
  },
  {
    q: '日本語の文字入り画像を作るにはどうすればよいですか？',
    a: '生成モデルの自動描画だけに頼らず、実際に同じ用途で生成テストを行い、誤字・文字化けの有無を確認することをおすすめします。正確さが求められる用途では、生成後にCanvaなどの編集ツールでテキストを追加する方法もあります。',
  },
  {
    q: '日本語対応ツールを選ぶときに何を確認すべきですか？',
    a: 'まず自分が必要とする軸（操作画面か、指示文か、画像内の文字か）を明確にした上で、該当する軸の対応状況を公式サイトや実際の編集画面で確認してください。商用利用条件・日本円決済の可否は、日本語対応とは別に確認が必要です。',
  },
];

const breadcrumb = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "トップ", "item": "https://aicreative-db.com/" },
    { "@type": "ListItem", "position": 2, "name": "ガイド一覧", "item": "https://aicreative-db.com/guides/" },
    { "@type": "ListItem", "position": 3, "name": "AIツールの日本語対応とは？日本語UI・日本語プロンプト・日本語文字生成の違い" }
  ]
});
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonicalPath="/guides/japanese-support-three-types/"
  ogType="article"
  jsonLd={breadcrumb}
>
  <div class="mx-auto max-w-3xl px-6 py-12">

    <div class="gh-hero">
      <nav class="gh-bc" aria-label="パンくずリスト">
        <a href="/">トップ</a><span aria-hidden="true"> / </span><a href="/guides/">ガイド一覧</a><span aria-hidden="true"> / </span><span aria-current="page">日本語対応の3区分ガイド</span>
      </nav>
      <div class="gh-meta">
        <span class="gh-pill">ガイド</span>
        <span class="gh-date">最終確認: {data.lastReviewed}</span>
      </div>
      <h1 class="gh-h1">{data.title}</h1>
      <p class="gh-lead">{data.description}</p>
    </div>

    <style>
      .gh-hero { padding: 8px 0 32px; border-bottom: 1px solid #E3E2D9; margin-bottom: 32px; }
      .gh-bc { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; font-size: 13px; color: #6A7180; margin-bottom: 18px; }
      .gh-bc a { color: #6A7180; text-decoration: none; }
      .gh-bc a:hover { color: #4B3FE4; text-decoration: underline; }
      .gh-meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; }
      .gh-pill { font-size: 12px; font-weight: 700; color: #2E25A6; background: #ECEBFB; padding: 4px 13px; border-radius: 999px; font-family: "Noto Sans JP", system-ui, sans-serif; }
      .gh-date { font-size: 12px; color: #6A7180; font-family: "Space Mono", monospace; }
      .gh-h1 { font-size: clamp(22px, 3vw, 36px); font-weight: 900; line-height: 1.22; letter-spacing: -0.01em; color: #16181D; text-wrap: balance; margin: 0 0 14px; font-family: "Zen Kaku Gothic New", "Noto Sans JP", system-ui, sans-serif; }
      .gh-lead { font-size: 15px; color: #3A3E47; line-height: 1.75; max-width: 620px; margin: 0; }
    </style>

    <!-- この記事で分かること -->
    <GuideSummaryBox title="この記事で分かること">
      <p>
        「日本語対応」という言葉には、<strong class="font-semibold text-slate-900">日本語UI・日本語プロンプト・日本語文字生成</strong>という3つの異なる意味が混在しています。
        本記事では、それぞれの違いと確認方法を整理します。ツールごとのおすすめ・ランキングは扱いません。個別ツールの一覧比較は関連ページをご参照ください。
      </p>
    </GuideSummaryBox>

    <GuideWarningBox variant="warning" title="免責事項・重要事項">
      本記事における日本語文字生成（画像・動画内への日本語テキスト描画）の対応状況は、実際に生成テストを行っていないツールについて「対応している」と断定していません。対応状況はモデルのアップデートにより変わる可能性があるため、必要な用途では実際に生成テストを行うか、公式サイトで最新情報を確認してください。
    </GuideWarningBox>

    <!-- ── 1種類ではない ── -->
    <section class="my-10" aria-labelledby="not-one-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="not-one-heading">
        AIツールの「日本語対応」は1種類ではない
      </h2>
      <div class="rounded-xl border border-slate-100 bg-white px-6 py-5 shadow-sm text-sm text-slate-700 space-y-3">
        <p>
          AI画像・動画生成ツールの紹介記事や公式サイトで見かける「日本語対応」は、少なくとも次の3つに分解できます。
        </p>
        <ul class="list-disc list-inside space-y-1">
          <li><strong>日本語UI</strong> — 管理画面やメニューが日本語で表示されるか</li>
          <li><strong>日本語プロンプト</strong> — 日本語の文章で生成指示を出せるか</li>
          <li><strong>日本語文字生成</strong> — 画像・動画の中に日本語の文字を正しく描画できるか</li>
        </ul>
        <p>
          この3つは互いに独立しています。日本語UIがあっても日本語プロンプトの精度が高いとは限らず、日本語プロンプトが通っても画像内に正しい日本語文字を描けるとは限りません。「日本語対応」という一言だけで判断せず、目的に応じてどの軸を確認すべきかを知ることが重要です。
        </p>
      </div>
    </section>

    <!-- ── 日本語UIとは ── -->
    <section class="my-10" aria-labelledby="ui-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="ui-heading">
        日本語UIとは
      </h2>
      <div class="rounded-xl border border-slate-100 bg-white px-6 py-5 shadow-sm text-sm text-slate-700 space-y-3">
        <p>
          日本語UIとは、管理画面のメニュー・ボタン・設定画面が日本語で表示されることを指します。料金ページやヘルプページが日本語で読める場合もこれに含まれます。
        </p>
        <p>
          日本語UIがあると操作を直感的に理解しやすくなりますが、<strong>日本語UIであることと、日本語プロンプトの精度・画像内の日本語文字生成の精度は別の話</strong>です。UIの翻訳と、生成モデルが日本語をどれだけ理解し描画できるかは、技術的に異なる領域です。
        </p>
      </div>
    </section>

    <!-- ── 日本語プロンプトとは ── -->
    <section class="my-10" aria-labelledby="prompt-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="prompt-heading">
        日本語プロンプトとは
      </h2>
      <div class="rounded-xl border border-slate-100 bg-white px-6 py-5 shadow-sm text-sm text-slate-700 space-y-3">
        <p>
          日本語プロンプトとは、画像・動画生成の指示（プロンプト）を日本語の文章で入力できることを指します。ツールや生成モデルが日本語の指示を理解し、生成結果に反映できる場合を指します。
        </p>
        <p>
          ただし、日本語プロンプトが「入力できる」ことと「英語プロンプトと同等の精度で意図が反映される」ことは別です。モデルによっては英語プロンプトの方が意図通りの結果が得やすい場合があります。また、対応の深さはツール・モデル・プロンプトの内容（固有名詞、複雑な構文、文化的表現など）によって変わります。
        </p>
      </div>
    </section>

    <!-- ── 日本語文字生成とは ── -->
    <section class="my-10" aria-labelledby="text-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="text-heading">
        日本語文字生成とは
      </h2>
      <div class="rounded-xl border border-slate-100 bg-white px-6 py-5 shadow-sm text-sm text-slate-700 space-y-3">
        <p>
          日本語文字生成とは、画像や動画の中に日本語の文字（看板の文字、テキスト入りバナーなど）を正しく描画できることを指します。
        </p>
        <p>
          これは日本語UI対応・日本語プロンプト対応とは<strong>別の難しさ</strong>を持つ領域です。プロンプトが日本語で正しく理解されても、画像内に文字として描画する処理は生成モデルごとに精度が大きく異なり、文字化けや誤字が発生することも珍しくありません。
        </p>
        <p>
          <strong>本記事および当サイトのツールDBでは、実際に日本語文字生成のテストを行っていないツールについて、「対応している」と断定することはしていません。</strong> 日本語文字を含む画像・動画が必要な場合は、実際に生成テストを行うか、生成後にCanvaなどの編集ツールで文字を追加する方法も選択肢になります。
        </p>
      </div>
    </section>

    <!-- ── 日本語ページ・日本円決済は別 ── -->
    <section class="my-10" aria-labelledby="billing-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="billing-heading">
        日本語ページ・日本語UI・日本円決済は別
      </h2>
      <div class="rounded-xl border border-slate-100 bg-white px-6 py-5 shadow-sm text-sm text-slate-700 space-y-3">
        <p>
          もう一つ混同されやすい点として、「日本語ページがある」ことと「日本円で決済できる」ことも別の条件です。日本語UIや日本語の紹介ページが用意されていても、決済自体は外貨建てでカード会社が円換算する場合があります。料金・通貨の確認方法は<a href="/guides/ai-tool-pricing-currency-japan/" class="text-blue-600 hover:underline">AI画像・動画生成ツールの料金表の見方</a>で解説しています。
        </p>
      </div>
    </section>

    <!-- ── 画像生成ツールで確認したいポイント ── -->
    <section class="my-10" aria-labelledby="image-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="image-heading">
        画像生成ツールで確認したいポイント
      </h2>
      <div class="rounded-xl border border-slate-100 bg-white px-6 py-5 shadow-sm text-sm text-slate-700 space-y-3">
        <ul class="list-disc list-inside space-y-1">
          <li>管理画面・生成画面のメニューが日本語表示かどうか（日本語UI）</li>
          <li>日本語の文章でプロンプトを入力したとき、意図通りの構図・スタイルが反映されるか（日本語プロンプト）</li>
          <li>看板・ロゴ・テキスト入りバナーなど、画像内に日本語文字を含める必要がある場合は、実際に生成テストを行い精度を確認する（日本語文字生成）</li>
          <li>公式ヘルプ・利用規約が日本語で読めるか（別途、商用利用条件の確認とあわせて実施）</li>
        </ul>
        <p>
          画像生成ツールの日本語対応の詳細な比較は、<a href="/guides/japanese-ai-image-tools/" class="text-blue-600 hover:underline">日本語対応AI画像生成ツール比較</a>をご参照ください。
        </p>
      </div>
    </section>

    <!-- ── 動画生成ツールで確認したいポイント ── -->
    <section class="my-10" aria-labelledby="video-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="video-heading">
        動画生成ツールで確認したいポイント
      </h2>
      <div class="rounded-xl border border-slate-100 bg-white px-6 py-5 shadow-sm text-sm text-slate-700 space-y-3">
        <ul class="list-disc list-inside space-y-1">
          <li>管理画面が日本語表示かどうか（日本語UI）</li>
          <li>動画生成の指示を日本語プロンプトで出したとき、意図通りの動きやカット割りになるか</li>
          <li>テロップ・字幕・画面内テキストとして日本語文字を使う場合は、生成モデルによる自動描画に頼らず、CapCutなどの編集ツールで別途テキストを追加する方法も検討する</li>
          <li>音声ナレーション・吹き替え機能がある場合、日本語音声への対応状況は文字生成とは別に確認する</li>
        </ul>
      </div>
    </section>

    <!-- ── 3区分の確認表 ── -->
    <section class="my-10" aria-labelledby="table-heading">
      <h2 class="mb-2 text-lg font-semibold text-slate-900" id="table-heading">
        3区分の確認表
      </h2>
      <p class="mb-4 text-sm text-slate-500">
        以下は、代表的なツールについて、当サイトのツールDB（lastReviewed時点の調査）に基づく日本語UI・日本語プロンプトの対応状況です。<strong>日本語文字生成は実テストを行っていないため「要実テスト」としています。</strong>対応状況はアップデートにより変わる可能性があるため、最新情報は公式サイトでご確認ください。
      </p>
      <GuideComparisonTable
        caption="日本語対応3区分の確認表"
        headers={crossHeaders}
        rows={crossRows}
        statusColIndexes={[1, 2, 3]}
        note="各ツールの対応状況は公式サイトでの最新確認を推奨します"
      />
    </section>

    <!-- ── 目的別の確認手順 ── -->
    <section class="my-10" aria-labelledby="steps-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="steps-heading">
        目的別の確認手順
      </h2>
      <div class="rounded-xl border border-slate-100 bg-white px-6 py-5 shadow-sm text-sm text-slate-700 space-y-4">
        <div>
          <p class="font-semibold text-slate-900 mb-1">操作画面を日本語で使いたい場合</p>
          <p>管理画面・設定画面のメニューが日本語表示かどうかを確認します。上表で「日本語UI：〇」のツールが対象になります。ただし、料金ページやヘルプが日本語かどうかは別途確認が必要です。</p>
        </div>
        <div>
          <p class="font-semibold text-slate-900 mb-1">日本語の指示文で生成したい場合</p>
          <p>日本語プロンプトの対応状況を確認します。UIが英語でも日本語プロンプトが使えるツールがあります。複雑な指示や固有名詞を含む場合は、英語キーワードとの併用や翻訳ツール（DeepL等）の併用も検討してください。</p>
        </div>
        <div>
          <p class="font-semibold text-slate-900 mb-1">画像・動画内に日本語文字を入れたい場合</p>
          <p>生成モデルによる自動描画に頼る前に、実際に同じ用途のプロンプトで生成テストを行い、誤字・文字化けがないか確認することを推奨します。看板・ロゴ・商品パッケージなど正確さが求められる用途では、生成後にCanva・CapCutなどの編集ツールでテキストを追加する方法がより確実です。</p>
        </div>
        <div>
          <p class="font-semibold text-slate-900 mb-1">商用利用・日本円決済とあわせて確認したい場合</p>
          <p>日本語対応の3区分とは別に、商用利用条件は<a href="/conditions/commercial-use/" class="text-blue-600 hover:underline">商用利用対応ツール比較</a>、日本円決済の可否は<a href="/guides/ai-tool-pricing-currency-japan/" class="text-blue-600 hover:underline">料金表の見方ガイド</a>で確認してください。</p>
        </div>
      </div>
    </section>

