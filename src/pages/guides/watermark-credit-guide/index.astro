---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GuidePageHeader from '../../../components/GuidePageHeader.astro';
import GuideSummaryBox from '../../../components/GuideSummaryBox.astro';
import GuideWarningBox from '../../../components/GuideWarningBox.astro';
import GuideCheckList from '../../../components/GuideCheckList.astro';
import GuideFAQ from '../../../components/GuideFAQ.astro';
import GuideComparisonTable from '../../../components/GuideComparisonTable.astro';
import GuideFreshnessBox from '../../../components/GuideFreshnessBox.astro';

const entry = await getEntry('guides', 'watermark-credit-guide');
if (!entry) throw new Error('guide not found: watermark-credit-guide');
const { data } = entry;

const allTools = await getCollection('tools');
const sortedTools = [...allTools].sort((a, b) => a.data.name.localeCompare(b.data.name, 'ja'));

type FreePlan = boolean | 'limited' | 'unknown';
type FourState = 'yes' | 'no' | 'limited' | 'unknown';
type CommercialUse = 'ok' | 'paid-only' | 'limited' | 'no' | 'unknown';

function watermarkLabel(val: FourState): string {
  if (val === 'yes')     return '× あり';
  if (val === 'no')      return '〇 なし';
  if (val === 'limited') return '△ 条件付き';
                         return '確認中';
}

function freePlanLabel(val: FreePlan): string {
  if (val === true)      return '〇 無料プランあり';
  if (val === false)     return '× 無料プランなし';
  if (val === 'limited') return '△ 制限付き無料';
                         return '不明';
}

function commercialLabel(val: CommercialUse): string {
  if (val === 'ok')        return '〇 可能（公式情報）';
  if (val === 'paid-only') return '★ 有料プラン向け';
  if (val === 'no')        return '× 不可または非推奨';
  if (val === 'limited')   return '△ 条件付き';
                           return '要確認';
}

const platformDisplayMap: Record<string, string> = {
  web: 'Web', discord: 'Discord', ios: 'iOS', android: 'Android',
  desktop: 'Desktop', api: 'API', local: 'ローカル',
};

function platformLabel(platforms: string[] | undefined): string {
  if (!platforms || platforms.length === 0) return '—';
  return platforms.map(p => platformDisplayMap[p] ?? p).join('、');
}

function freePlanNoteText(freePlan: FreePlan, note: string | undefined): string {
  if (freePlan === false)     return '無料プランなし';
  if (freePlan === true)      return '無料プランあり';
  if (freePlan === 'limited') return note || '制限付き無料';
                               return '不明';
}

const toolTableRows = sortedTools.map((tool) => [
  { text: tool.data.name, href: `/tools/${tool.slug}/` },
  { text: watermarkLabel(tool.data.watermark) },
  { text: freePlanLabel(tool.data.freePlan) },
  { text: commercialLabel(tool.data.commercialUse) },
  { text: tool.data.lastReviewed, muted: true },
]);

// 透かし条件の比較表（ツールデータから動的生成）
const watermarkConditionRows = sortedTools.map((tool) => [
  { text: tool.data.name, href: `/tools/${tool.slug}/` },
  { text: tool.data.watermarkCondition || watermarkLabel(tool.data.watermark) },
  { text: freePlanNoteText(tool.data.freePlan, tool.data.freePlanNote) },
  { text: commercialLabel(tool.data.commercialUse) },
  { text: platformLabel(tool.data.platforms), muted: true },
]);

const useCaseCheckRows = [
  [{ text: 'SNS投稿' }, { text: '商用利用の可否、AI生成であることの開示、投稿プラットフォームのAI生成コンテンツポリシー' }],
  [{ text: 'ブログ記事' }, { text: '商用利用の可否（収益化の有無も影響する場合あり）' }],
  [{ text: '広告・広告素材' }, { text: '商用利用の可否、AI生成の明示、第三者の権利' }],
  [{ text: '納品物・製品画像' }, { text: '商用利用の可否、クレジット表記の有無、規約の最新版確認' }],
];

const checklistItems = [
  '使用するプランで透かしなし出力が可能か確認した',
  '可視透かしがない場合でも、不可視メタデータ（C2PA等）が埋め込まれるか確認した',
  '使用目的（SNS・ブログ・広告・納品物等）で商用利用が許可されているか確認した',
  '無料プランの場合、商用利用が可能か確認した',
  'AI生成コンテンツであることの開示・明示が必要か確認した',
  '第三者の著作権・肖像権に関わる内容が含まれていないか確認した',
  '最新の公式利用規約を確認した',
];

const faqItems = [
  {
    q: '透かしなしで使えるAI画像生成ツールはありますか？',
    a: '透かしなし出力が可能なツールは存在します。ただし多くの場合、有料プランへの移行が必要です。また「透かしなし」であっても、C2PAなどの不可視メタデータが埋め込まれる場合や、商用利用に別途条件が設けられている場合があります。最新の条件は各ツールの公式サイトでご確認ください。',
  },
  {
    q: '無料プランでも透かしなしで出力できますか？',
    a: 'ツールによって異なります。Runway、Pika、Kling AIなど多くの動画生成ツールでは、無料プランでは透かしが付与される場合があります。Adobe FireflyやLeonardo AIなど一部の画像生成ツールでは、無料プランでも透かしなし出力ができる場合がありますが、生成回数やクレジットに上限があります。最新の条件は各公式サイトでご確認ください。',
  },
  {
    q: '透かしがなければ商用利用できますか？',
    a: '透かしなし出力ができることと、商用利用が許可されていることは別の問題です。商用利用の可否はツールの利用規約で別に定められています。透かしがなくても商用利用に制限がある場合や、追加条件が設けられている場合があります。商用利用を検討する場合は、各ツールの最新利用規約を必ずご確認ください。このページは法的助言ではありません。',
  },
  {
    q: '透かしを消すために有料プランが必要ですか？',
    a: '多くのツールでは、有料プランに移行することで透かしなし出力が可能になります。ただし有料プランでも、出力形式・サイズ・用途によって条件が異なる場合があります。また公式に認められていない方法で透かしを削除することは、利用規約違反になる可能性があります。必ず公式のプランや方法で対応することを推奨します。',
  },
  {
    q: 'SNSやブログで使う前に何を確認すればよいですか？',
    a: '使用するプランで商用利用が許可されているか（ブログの収益化の有無も影響する場合があります）、AI生成コンテンツであることの開示・明示が必要かどうか、第三者の著作権・肖像権に関わる内容が含まれていないか、投稿するプラットフォームのAI生成コンテンツに関するポリシーを確認することを推奨します。',
  },
];
---

<BaseLayout
  title={`${data.title} | AIクリエイティブツール比較DB`}
  description={data.description}
  canonicalPath="/guides/watermark-credit-guide/"
  ogType="article"
>
  <div class="mx-auto max-w-3xl px-6 py-12">

    <GuidePageHeader
      title={data.title}
      description={data.description}
      lastReviewed={data.lastReviewed}
    />

    <GuideSummaryBox title="このガイドの結論">
      <p>
        AI画像生成ツールで「透かしなし」と記載があっても、<strong class="font-semibold text-slate-900">実際の条件はプラン・用途・出力形式によって異なります</strong>。
        透かしの有無だけで判断するのではなく、商用利用の可否・不可視メタデータ・プランごとの条件を合わせて確認することが重要です。
      </p>
    </GuideSummaryBox>

    <GuideWarningBox variant="warning" title="免責事項">
      このガイドは情報提供を目的としており、法的アドバイスではありません。商用利用の可否判断は各ツールの最新利用規約を必ずご確認ください。
    </GuideWarningBox>

    <!-- 選ぶときのポイント -->
    <section class="my-10" aria-labelledby="selection-points-heading">
      <h2 class="mb-5 text-lg font-semibold text-slate-900" id="selection-points-heading">
        透かしなしAI画像生成ツール選びのポイント
      </h2>
      <ol class="space-y-4">
        {[
          ['プランによる条件の違い', '多くのツールでは無料プランで透かしが入り、有料プランで透かしなし出力が可能になります'],
          ['可視透かしと不可視メタデータの違い', '目に見える透かしがなくても、C2PA（Coalition for Content Provenance and Authenticity）などの不可視メタデータが埋め込まれる場合があります'],
          ['商用利用条件の別途確認', '透かしなし出力ができても、商用利用の可否は利用規約で別に定められている場合があります'],
          ['無料プランの実用性', '無料プランでは生成回数・解像度・透かしなどに制限がある場合があります'],
        ].map(([title, desc], i) => (
          <li class="flex gap-4">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white" aria-hidden="true">{i + 1}</span>
            <div>
              <p class="text-sm font-semibold text-slate-900">{title}</p>
              <p class="mt-0.5 text-sm leading-relaxed text-slate-600">{desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- 透かし条件で確認すべきポイント -->
    <section class="my-10" aria-labelledby="check-points-heading">
      <h2 class="mb-6 text-lg font-semibold text-slate-900" id="check-points-heading">
        透かし条件で確認すべきポイント
      </h2>

      <div class="space-y-6">
        <div>
          <h3 class="mb-2 text-sm font-semibold text-slate-900">1. 使用するプランで透かしなし出力ができるか</h3>
          <p class="text-sm leading-relaxed text-slate-600">
            無料プランでは透かしが入り、有料プランに移行すると透かしなし出力が可能になるケースが多くあります。また有料プランでも、出力サイズや形式によって条件が異なる場合があります。
          </p>
        </div>

        <div>
          <h3 class="mb-2 text-sm font-semibold text-slate-900">2. 可視透かしと不可視メタデータの違いを理解する</h3>
          <ul class="space-y-2 text-sm text-slate-600">
            <li class="flex gap-2"><span class="text-slate-400 shrink-0">—</span><span><strong class="font-medium text-slate-700">可視透かし：</strong>生成画像・動画に直接表示されるロゴやテキスト</span></li>
            <li class="flex gap-2"><span class="text-slate-400 shrink-0">—</span><span><strong class="font-medium text-slate-700">不可視メタデータ（C2PA等）：</strong>目には見えないが画像ファイルに埋め込まれるAI生成情報</span></li>
          </ul>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">DALL·EやAdobe Fireflyなど一部のツールでは、可視透かしがなくてもC2PA標準のメタデータが埋め込まれる場合があります。</p>
        </div>

        <div>
          <h3 class="mb-2 text-sm font-semibold text-slate-900">3. 透かしなし出力と商用利用は別問題</h3>
          <p class="text-sm leading-relaxed text-slate-600">
            透かしなし出力ができても、商用利用が許可されているかどうかは利用規約で別に定められています。商用利用前は必ず公式の利用規約を確認してください。
          </p>
        </div>

        <div>
          <h3 class="mb-2 text-sm font-semibold text-slate-900">4. 条件はプランや時期によって変わる可能性がある</h3>
          <p class="text-sm leading-relaxed text-slate-600">
            透かしに関するルールはツールの方針変更やプラン改定により変更される可能性があります。利用前に最新の公式情報をご確認ください。
          </p>
        </div>
      </div>
    </section>

    <!-- 主要ツール透かし比較表（静的） -->
    <section class="my-10" aria-labelledby="tool-comparison-heading">
      <h2 class="mb-2 text-lg font-semibold text-slate-900" id="tool-comparison-heading">
        透かしなし・条件付き透かしの主要ツール比較
      </h2>
      <p class="mb-6 text-sm text-slate-500">
        以下は <strong class="font-medium text-slate-700">{data.lastReviewed}</strong> 時点の調査に基づいた目安です。プランや時期によって変更される可能性があります。
      </p>

      <GuideComparisonTable
        caption="主要ツール透かし条件・商用利用比較"
        headers={['ツール名', '透かし条件', '無料プランの注意', '商用利用', '対応プラットフォーム']}
        rows={watermarkConditionRows}
        statusColIndex={-1}
      />
    </section>

    <!-- 無料・有料の違い -->
    <section class="my-10" aria-labelledby="plan-diff-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="plan-diff-heading">
        無料プランと有料プランの違い
      </h2>

      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-red-200 bg-red-50 p-4">
          <h3 class="mb-3 text-sm font-semibold text-red-900">無料プランで注意すること</h3>
          <ul class="space-y-2 text-xs text-red-800">
            <li class="flex gap-2"><span class="shrink-0">—</span><span><strong>透かしあり：</strong>Runway、Pika、Kling AIなどは無料プランで透かしが入る場合があります</span></li>
            <li class="flex gap-2"><span class="shrink-0">—</span><span><strong>商用利用不可：</strong>Pika、Kling AIなどは無料プランでは商用利用不可とされています</span></li>
            <li class="flex gap-2"><span class="shrink-0">—</span><span><strong>権利の帰属：</strong>Leonardo AIの無料プランでは生成画像の権利がサービス側に帰属する場合があります</span></li>
          </ul>
        </div>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4">
          <h3 class="mb-3 text-sm font-semibold text-emerald-900">有料プランへの移行で変わること</h3>
          <ul class="space-y-2 text-xs text-emerald-800">
            <li class="flex gap-2"><span class="shrink-0">—</span><span><strong>透かし除去：</strong>多くのツールで有料プランに移行すると透かしなし出力が可能になります</span></li>
            <li class="flex gap-2"><span class="shrink-0">—</span><span><strong>商用利用許可：</strong>Pika、Kling AIなど、有料プランで初めて商用利用が許可されるツールがあります</span></li>
            <li class="flex gap-2"><span class="shrink-0">—</span><span><strong>生成量の拡大：</strong>クレジット数や生成回数の上限が緩和される場合があります</span></li>
          </ul>
        </div>
      </div>
      <p class="mt-3 text-xs text-slate-500">ただし有料プランでも、商用利用に追加条件がある場合があります。必ず公式情報をご確認ください。</p>
    </section>

    <!-- 商用利用時の確認ポイント -->
    <section class="my-10" aria-labelledby="commercial-check-heading">
      <h2 class="mb-4 text-lg font-semibold text-slate-900" id="commercial-check-heading">
        商用利用時の重要注意点
      </h2>

      <GuideWarningBox variant="warning" title="「透かしなし出力」と「商用利用の可否」は別の問題です">
        透かしなし出力ができても、ツールの利用規約が商用利用を制限する場合があります。プランによって条件が分かれることもあります。
      </GuideWarningBox>

      <h3 class="mb-3 mt-6 text-sm font-semibold text-slate-700">用途別の主な確認ポイント</h3>
      <GuideComparisonTable
        caption="用途別商用利用確認ポイント"
        headers={['用途', '主な確認ポイント']}
        rows={useCaseCheckRows}
        statusColIndex={-1}
      />
    </section>

    <!-- 全ツール透かし一覧（動的） -->
    <section class="my-10" aria-labelledby="all-tools-heading">
      <h2 class="mb-2 text-lg font-semibold text-slate-900" id="all-tools-heading">
        主要ツールの透かし状況（確認時点）
      </h2>
      <p class="mb-4 text-sm text-slate-500">
        以下は <strong class="font-medium text-slate-700">{data.lastReviewed}</strong> 時点の調査に基づく目安です。プランや時期によって変更される可能性があります。
      </p>

      <GuideComparisonTable
        caption="主要ツール透かし・無料プラン・商用利用一覧"
        headers={['ツール名', '透かし', '無料プラン', '商用利用', '最終確認日']}
        rows={toolTableRows}
        statusColIndexes={[1, 2, 3]}
      />

      <!-- 凡例 -->
      <div class="mt-4 rounded-lg border border-slate-100 bg-slate-50 px-4 py-3 text-xs text-slate-600">
        <p class="mb-1 font-semibold text-slate-700">凡例</p>
        <ul class="space-y-1">
          <li><span class="inline-block rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-800 mr-2">〇</span>なし（透かし）・可（商用利用）・あり（無料プラン）</li>
          <li><span class="inline-block rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800 mr-2">△</span>条件付き・制限付き</li>
          <li><span class="inline-block rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-800 mr-2">×</span>あり（透かし）・不可（商用利用）・なし（無料プラン）</li>
        </ul>
        <p class="mt-2 text-slate-500">この表は法的判断の根拠ではありません。必ず各ツールの最新公式情報をご確認ください。</p>
      </div>
    </section>

    <!-- チェックリスト -->
    <section class="my-10">
      <GuideCheckList
        id="watermark-checklist"
        title="ツール利用前のチェックリスト"
        items={checklistItems}
      />
    </section>

    <!-- FAQ -->
    <section class="my-10">
      <GuideFAQ items={faqItems} title="よくある質問（FAQ）" />
    </section>

    <!-- 注意事項 -->
    <section class="my-10">
      <GuideWarningBox variant="info">
        <ul class="space-y-1.5 list-disc list-inside">
          <li>各ツールの料金・利用規約・透かし条件は予告なく変更されます。利用前に必ず公式サイトの最新情報をご確認ください</li>
          <li>本ページは法的アドバイスではありません。重要な商用利用の場面では、専門家（弁護士等）への相談を推奨します</li>
          <li>透かし・商用利用の最終的な判断は、各ツールの最新の公式利用規約に基づいてください</li>
        </ul>
      </GuideWarningBox>
    </section>

    <GuideFreshnessBox lastReviewed={data.lastReviewed} nextReviewDue={data.nextReviewDue} />

    <!-- 関連ページ -->
    <section class="mb-8">
      <h2 class="mb-3 text-sm font-semibold text-slate-600">関連ページ</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/tools/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">ツール一覧</a></li>
        <li><a href="/categories/no-watermark/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">透かしなしツール</a></li>
        <li><a href="/categories/free/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">無料で使えるツール</a></li>
        <li><a href="/categories/commercial-use/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">商用利用を確認しやすいツール</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">商用利用・著作権ガイド</a></li>
        <li><a href="/guides/free-ai-image-tools/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100 focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-full transition-colors">無料ツールの選び方</a></li>
      </ul>
    </section>

    <nav class="border-t border-slate-200 pt-6 text-sm" aria-label="ページナビゲーション">
      <a href="/" class="text-blue-600 hover:underline focus-visible:outline-2 focus-visible:outline-blue-500 focus-visible:rounded-sm">← トップに戻る</a>
    </nav>

  </div>
</BaseLayout>
