---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHeroAnimated from '../components/HomeHeroAnimated.astro';
import HomePillarCards from '../components/HomePillarCards.astro';
import HomeCriteriaStrip from '../components/HomeCriteriaStrip.astro';
import HomePurposeCards from '../components/HomePurposeCards.astro';
import HomeGoalCards from '../components/HomeGoalCards.astro';
import HomeStartFinder from '../components/HomeStartFinder.astro';
import HomeComparisonInteractive from '../components/HomeComparisonInteractive.astro';
import type { CmpTool } from '../components/HomeComparisonInteractive.astro';
import HomeGuidesGrid from '../components/HomeGuidesGrid.astro';
import HomeEditorialPolicy from '../components/HomeEditorialPolicy.astro';
import HomeFaq from '../components/HomeFaq.astro';
import HomeCtaBanner from '../components/HomeCtaBanner.astro';

const FEATURED_IMAGE_SLUGS = [
  'midjourney',
  'adobe-firefly',
  'canva-ai-image-generator',
  'leonardo-ai',
  'stable-diffusion',
];

const FEATURED_VIDEO_SLUGS = [
  'runway',
  'kling-ai',
  'pika',
  'luma-ai',
  'capcut-ai',
];

const allTools = await getCollection('tools');

const imageTools = FEATURED_IMAGE_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

const videoTools = FEATURED_VIDEO_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

// --- CmpTool マッピング ---
type Mark = 'y' | 'c' | 'n';
const TOOL_META: Record<string, { initial: string; color: string; cat: string }> = {
  'runway':                   { initial: 'R', color: '#E1543A', cat: '動画生成' },
  'kling-ai':                 { initial: 'K', color: '#3A6FF0', cat: '動画生成' },
  'pika':                     { initial: 'P', color: '#10A4C8', cat: '動画生成' },
  'luma-ai':                  { initial: 'L', color: '#15897F', cat: '動画生成' },
  'capcut-ai':                { initial: 'C', color: '#111319', cat: '動画生成' },
  'midjourney':               { initial: 'M', color: '#7A5AE0', cat: '画像生成' },
  'adobe-firefly':            { initial: 'A', color: '#D8453A', cat: '画像生成' },
  'canva-ai-image-generator': { initial: 'C', color: '#0E8E84', cat: '画像生成' },
  'leonardo-ai':              { initial: 'L', color: '#E89B12', cat: '画像生成' },
  'stable-diffusion':         { initial: 'S', color: '#1F63E8', cat: '画像生成' },
};
function mapFree(v: boolean | 'limited' | 'unknown'): Mark {
  return v === true ? 'y' : v === false ? 'n' : 'c';
}
function mapWatermark(v: 'yes' | 'no' | 'limited' | 'unknown'): Mark {
  return v === 'no' ? 'y' : v === 'yes' ? 'n' : 'c';
}
function mapJapanese(v: boolean | 'partial' | 'unknown'): Mark {
  return v === true ? 'y' : v === false ? 'n' : 'c';
}
function mapCommercial(v: 'ok' | 'paid-only' | 'limited' | 'no' | 'unknown'): Mark {
  return v === 'ok' ? 'y' : v === 'no' ? 'n' : 'c';
}
function extractPrice(s?: string): number | null {
  if (!s) return null;
  const m = s.match(/(\d+\.?\d*)/);
  return m ? parseFloat(m[1]) : null;
}
function toCmpTool(t: (typeof allTools)[number]): CmpTool {
  const d = t.data;
  const meta = TOOL_META[t.slug] ?? { initial: d.name[0], color: '#888', cat: '' };
  const noLowest = !d.lowestPaidPlan;
  const isFreeOnly = d.freePlan === true && noLowest;
  const price = isFreeOnly ? 0 : extractPrice(d.lowestPaidPlan);
  const sym = d.lowestPaidPlan?.startsWith('¥') ? '¥' : '$';
  const priceLabel = isFreeOnly
    ? '<span class="cmp-free">無料〜</span>'
    : price !== null
      ? `${sym}${price}<small>/月〜</small>`
      : '要確認';
  return {
    name: d.name, initial: meta.initial, color: meta.color, cat: meta.cat,
    free: mapFree(d.freePlan),
    watermark: mapWatermark(d.watermark),
    japanese: mapJapanese(d.japaneseUi),
    commercial: mapCommercial(d.commercialUse),
    price, priceLabel,
    checked: d.lastReviewed,
    url: `/tools/${t.slug}/`,
  };
}
const cmpVideoTools: CmpTool[] = videoTools.map(toCmpTool);
const cmpImageTools: CmpTool[] = imageTools.map(toCmpTool);
// --- ここまで ---

const jsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "AIクリエイティブナビ",
    "url": "https://aicreative-db.com/"
  }
]);
---

<BaseLayout
  title="AIクリエイティブナビ｜動画生成・画像生成を中心に目的別で探せる"
  description="AI画像生成・AI動画生成ツールを商用利用・料金・無料枠・透かし・日本語対応で比較できるDBです。副業・SNS運用・仕事での利用前に条件を確認できます。最新情報は公式サイトをご確認ください。"
  canonicalPath="/"
  jsonLd={jsonLd}
  homePage={true}
>

  <HomeHeroAnimated
    titleLines={['AI画像・動画生成ツールを、', '実際の生成サンプル付きで比較']}
    lead={'プロンプト・モデル名・生成日・透かし・商用利用条件まで記録した、<b>実機検証型</b>のAIクリエイティブツールDBです。'}
    videoHref="/categories/video-generation/"
    imageHref="/categories/image-generation/"
  />

  <!-- ===== Hero下エントリーカード ===== -->
  <section class="home-entry-cards">
    <div class="hec-wrap">
      <a class="hec-card" href="/tools/">
        <span class="hec-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </span>
        <div>
          <span class="hec-title">まずはツール一覧から選ぶ</span>
          <span class="hec-desc">AI画像生成・AI動画生成ツールを、無料枠・日本語対応・透かし・商用利用条件などの軸で比較できます。</span>
          <span class="hec-cta">ツール一覧を見る →</span>
        </div>
      </a>
      <a class="hec-card" href="/conditions/free/">
        <span class="hec-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
        </span>
        <div>
          <span class="hec-title">無料で使えるツールを探す</span>
          <span class="hec-desc">無料枠のあるAI画像生成・AI動画生成ツールを、制限や透かし、日本語対応とあわせて確認できます。</span>
          <span class="hec-cta">無料枠を比較する →</span>
        </div>
      </a>
      <a class="hec-card" href="/conditions/commercial-use/">
        <span class="hec-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-4 0v2M12 12v4M10 14h4"/></svg>
        </span>
        <div>
          <span class="hec-title">商用利用条件を確認する</span>
          <span class="hec-desc">商用利用条件は、プランや用途によって異なる場合があります。公式情報をもとに整理した比較ページで確認できます。</span>
          <span class="hec-cta">商用条件を確認する →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ===== このサイトで確認できること ===== -->
  <section class="home-verify-block">
    <div class="hvb-inner">
      <div class="hvb-head">
        <span class="hvb-kicker">WHAT YOU CAN CHECK</span>
        <h2 class="hvb-title">このサイトで確認できること</h2>
        <p class="hvb-sub">公式情報だけでは分かりにくい「実際の出力」「無料枠の制限」「商用利用時の注意点」を、ツール別に記録・整理しています。</p>
      </div>
      <ul class="hvb-list" aria-label="確認できる情報の一覧">
        <li class="hvb-item">
          <span class="hvb-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          </span>
          <div>
            <span class="hvb-item-title">実際に生成した画像・動画サンプル</span>
            <span class="hvb-item-desc">公式のプロモーション素材ではなく、実際に生成した出力を掲載しています。</span>
          </div>
        </li>
        <li class="hvb-item">
          <span class="hvb-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 3l2.3 6.2L21.5 11l-6.2 2.3L13 19.5 10.7 13.3 4.5 11l6.2-2.3z"/></svg>
          </span>
          <div>
            <span class="hvb-item-title">使用プロンプト・ネガティブプロンプト・モデル名</span>
            <span class="hvb-item-desc">どの条件で生成したかを可能な範囲で記録。再現性の参考として確認できます。</span>
          </div>
        </li>
        <li class="hvb-item">
          <span class="hvb-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </span>
          <div>
            <span class="hvb-item-title">生成日・検証バージョン</span>
            <span class="hvb-item-desc">AIツールは頻繁に更新されます。情報の鮮度が分かるよう検証日を明記しています。</span>
          </div>
        </li>
        <li class="hvb-item">
          <span class="hvb-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
          </span>
          <div>
            <span class="hvb-item-title">無料枠・透かし・商用利用・日本語対応</span>
            <span class="hvb-item-desc">副業・SNS運用・仕事利用の前に確認すべき条件を、ツールごとに整理しています。</span>
          </div>
        </li>
      </ul>
      <p class="hvb-policy">掲載順位は広告・アフィリエイトの有無ではなく、比較軸・用途・確認情報に基づいて整理しています。</p>
    </div>
  </section>

  <HomeCriteriaStrip />
  <HomePurposeCards />
  <HomePillarCards />
  <HomeGoalCards />
  <HomeStartFinder />
  <HomeComparisonInteractive videoTools={cmpVideoTools} imageTools={cmpImageTools} imageAllHref="/categories/image-generation/" />
  <HomeGuidesGrid />
  <HomeEditorialPolicy />
  <HomeFaq />
  <HomeCtaBanner />

</BaseLayout>

<style>
/* ── このサイトで確認できること ───────────────────── */
.home-verify-block {
  background: #F4F4EE;
  border-top: 1px solid #E3E2D9;
  border-bottom: 1px solid #E3E2D9;
  padding: clamp(40px, 6vw, 72px) 0;
}
.hvb-inner {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 40px);
}
.hvb-head {
  margin-bottom: 36px;
}
.hvb-kicker {
  display: inline-block;
  font-family: "Space Grotesk", system-ui, sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: #6A7180;
  margin-bottom: 12px;
}
.hvb-kicker::before {
  content: "";
  display: inline-block;
  width: 22px;
  height: 2px;
  background: #4B3FE4;
  vertical-align: middle;
  margin-right: 9px;
}
.hvb-title {
  font-size: clamp(20px, 2.4vw, 28px);
  font-weight: 900;
  color: #16181D;
  margin: 0 0 12px;
  line-height: 1.2;
}
.hvb-sub {
  font-size: 15px;
  line-height: 1.85;
  color: #3A3E47;
  max-width: 660px;
  margin: 0;
}
.hvb-list {
  list-style: none;
  margin: 0 0 28px;
  padding: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.hvb-item {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  background: #fff;
  border: 1px solid #E3E2D9;
  border-radius: 12px;
  padding: 18px 20px;
}
.hvb-icon {
  width: 36px;
  height: 36px;
  border-radius: 9px;
  background: #ECEBFB;
  color: #2E25A6;
  display: grid;
  place-items: center;
  flex: none;
}
.hvb-icon svg { width: 18px; height: 18px; }
.hvb-item-title {
  display: block;
  font-size: 14px;
  font-weight: 700;
  color: #16181D;
  margin-bottom: 4px;
  line-height: 1.4;
}
.hvb-item-desc {
  display: block;
  font-size: 13px;
  line-height: 1.7;
  color: #6A7180;
}
.hvb-policy {
  font-size: 13px;
  color: #6A7180;
  line-height: 1.7;
  border-left: 3px solid #4B3FE4;
  padding-left: 14px;
  margin: 0;
}
@media (max-width: 640px) {
  .hvb-list { grid-template-columns: 1fr; }
}
</style>

<script>
// Scroll reveal — IntersectionObserver + load + rAF + 8s failsafe
window.addEventListener('load', function() {
  requestAnimationFrame(function() {
    // 8-second failsafe: force-reveal everything if observer hasn't fired
    var failsafe = setTimeout(function() {
      document.querySelectorAll('.reveal:not(.in), [data-stagger] > *:not(.in)').forEach(function(el) {
        el.classList.add('in');
      });
    }, 8000);

    // Stagger children: add .reveal to each child so IntersectionObserver can pick them up
    document.querySelectorAll('[data-stagger]').forEach(function(parent) {
      Array.from(parent.children).forEach(function(child) {
        child.classList.add('reveal');
      });
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(function(el) {
      // If already in viewport on load (above the fold), show immediately
      var rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight) {
        el.classList.add('in');
      } else {
        observer.observe(el);
      }
    });

    // Clear failsafe once all elements are revealed
    var remaining = document.querySelectorAll('.reveal:not(.in)');
    if (remaining.length === 0) clearTimeout(failsafe);
  });
});
</script>
