---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import CompareTablePreview from '../components/CompareTablePreview.astro';
import NoticeBox from '../components/NoticeBox.astro';

const FEATURED_IMAGE_SLUGS = [
  'midjourney',
  'adobe-firefly',
  'canva-ai-image-generator',
  'leonardo-ai',
  'stable-diffusion',
];

const FEATURED_VIDEO_SLUGS = [
  'runway',
  'kling-ai',
  'pika',
  'luma-ai',
  'capcut-ai',
];

const allTools = await getCollection('tools');

const imageTools = FEATURED_IMAGE_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

const videoTools = FEATURED_VIDEO_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

// 注目ツール表示用（動画→画像の順）
const tools = [...videoTools, ...imageTools].slice(0, 6);
---

<BaseLayout
  title="AI画像生成・AI動画生成ツール比較DB｜商用利用・料金・無料枠を比較"
  description="AI画像生成・AI動画生成ツールを商用利用・料金・無料枠・透かし・日本語対応で比較できるDBです。副業・SNS運用・仕事での利用前に条件を確認できます。最新情報は公式サイトをご確認ください。"
  canonicalPath="/"
>

  <!-- ============================================================ -->
  <!-- 1. HERO                                                       -->
  <!-- ============================================================ -->
  <section class="hero-bg pb-20 pt-20">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 lg:grid-cols-[1fr_320px] lg:items-start">

        <!-- Left -->
        <div>
          <!-- Badge -->
          <div class="mb-5 inline-flex items-center rounded-full border border-blue-200 bg-white px-4 py-1.5 text-xs font-semibold text-blue-700 shadow-sm">
            AIクリエイティブツール比較DB
          </div>

          <!-- H1 -->
          <h1 class="text-[1.9rem] font-bold leading-snug text-[#002B61] sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
            AI画像生成・AI動画生成ツール比較DB
          </h1>

          <!-- Description -->
          <p class="mt-5 text-base leading-relaxed text-slate-600">
            AI画像・動画生成ツールを、商用利用・無料枠・透かし・日本語対応で比較できるデータベースです。
          </p>

          <!-- 比較軸ラベル -->
          <div class="mt-4 flex flex-wrap gap-2">
            {['商用利用', '無料枠', '透かし', '日本語対応'].map(label => (
              <span class="inline-flex items-center rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">
                {label}
              </span>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/video-generators/" class="primary-btn">
              AI動画生成ツールを見る
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
              </svg>
            </a>
            <a href="/tools/" class="outline-btn">AI画像生成ツールを見る</a>
            <a href="/guides/commercial-use-copyright/" class="text-sm font-medium text-slate-500 hover:text-blue-600 self-center">商用利用ガイド →</a>
          </div>

          <!-- Flow guide -->
          <p class="mt-3 text-xs text-slate-500">
            初めての方：条件から探す → 一覧で候補を見る → 比較表で比べる → 詳細で確認 → 公式サイトで最終確認
          </p>

          <!-- Footnote -->
          <p class="mt-2 text-xs text-slate-400">
            情報は公式サイト・ヘルプ・利用規約などをもとに整理しています。確認日時点の情報です。
          </p>
        </div>

        <!-- Right: 比較できる項目 card -->
        <div class="rounded-2xl border border-blue-100 bg-white px-6 py-6 shadow-sm">
          <p class="mb-5 text-[10px] font-bold uppercase tracking-widest text-slate-400">比較できる項目</p>
          <ul class="space-y-4">
            {[
              { label: '商用利用',   desc: 'ビジネス・副業での活用可否を公式情報で確認' },
              { label: '著作権',     desc: '生成物の利用条件を利用規約で確認' },
              { label: '透かし',     desc: '出力画像・動画への透かし付与の有無' },
              { label: '無料枠',     desc: '無料で試せる範囲・クレジット数など' },
              { label: '日本語対応', desc: 'UIと日本語プロンプト対応状況' },
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-50 text-[10px] font-bold text-blue-600">✓</span>
                <div>
                  <p class="text-sm font-semibold text-slate-800">{item.label}</p>
                  <p class="text-xs leading-relaxed text-slate-500">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 2. 条件フィルター                                             -->
  <!-- ============================================================ -->
  <section class="border-y border-slate-100 bg-white py-8">
    <div class="mx-auto max-w-5xl px-6">
      <p class="mb-4 text-sm font-semibold text-slate-700">条件からAIツールを探す</p>

      <div class="flex flex-wrap gap-2">
        <a href="/video-generators/"          class="chip">AI動画生成</a>
        <a href="/tools/"                     class="chip">AI画像生成</a>
        <a href="/categories/commercial-use/" class="chip">商用利用を確認</a>
        <a href="/categories/free/"           class="chip">無料で試せる</a>
        <a href="/categories/free-video/"     class="chip">動画無料プラン</a>
        <a href="/categories/japanese/"       class="chip">日本語対応</a>
        <a href="/categories/no-watermark/"   class="chip">透かしなし</a>
      </div>

      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/video-generators/" class="primary-btn">AI動画生成ツール一覧</a>
        <a href="/tools/"            class="outline-btn">AI画像生成ツール一覧</a>
        <a href="/compare/"          class="outline-btn">比較表で見る</a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 2.5 カテゴリから探す                                          -->
  <!-- ============================================================ -->
  <section class="bg-white py-14">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-2 text-2xl font-bold text-[#002B61]">カテゴリから探す</h2>
      <p class="mb-8 text-sm text-slate-500">AI動画生成・AI画像生成を中心に、周辺領域も目的別に探せます。</p>

      <!-- 主役カテゴリ（AI動画生成 / AI画像生成） -->
      <div class="mb-4 grid gap-4 sm:grid-cols-2">

        <!-- AI動画生成 -->
        <a href="/video-generators/" class="group relative flex flex-col rounded-2xl border-2 border-blue-500 bg-gradient-to-br from-blue-50 to-indigo-50 p-6 shadow-md transition hover:border-blue-600 hover:shadow-lg">
          <div class="mb-3 flex items-center gap-2 flex-wrap">
            <span class="inline-flex items-center gap-1 rounded-full bg-blue-600 px-3 py-1 text-[10px] font-bold uppercase tracking-wide text-white shadow-sm">
              ★ 中心カテゴリ
            </span>
          </div>
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-600" aria-hidden="true">
              <polygon points="23 7 16 12 23 17 23 7"/>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
            <p class="text-base font-bold text-slate-900 group-hover:text-blue-700">AI動画生成</p>
          </div>
          <p class="mt-1 flex-1 text-sm leading-relaxed text-slate-600">テキストや画像から動画を自動生成。Runway・Kling AI・Pika など主要ツールを商用利用・無料枠・透かしで比較できます。</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Runway</span>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Kling AI</span>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Pika</span>
          </div>
          <p class="mt-4 text-right text-sm font-bold text-blue-600 group-hover:underline">ツール一覧を見る →</p>
        </a>

        <!-- AI画像生成 -->
        <a href="/tools/" class="group relative flex flex-col rounded-2xl border-2 border-blue-500 bg-gradient-to-br from-blue-50 to-indigo-50 p-6 shadow-md transition hover:border-blue-600 hover:shadow-lg">
          <div class="mb-3 flex items-center gap-2 flex-wrap">
            <span class="inline-flex items-center gap-1 rounded-full bg-blue-600 px-3 py-1 text-[10px] font-bold uppercase tracking-wide text-white shadow-sm">
              ★ 中心カテゴリ
            </span>
          </div>
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-600" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <p class="text-base font-bold text-slate-900 group-hover:text-blue-700">AI画像生成</p>
          </div>
          <p class="mt-1 flex-1 text-sm leading-relaxed text-slate-600">テキストプロンプトから画像を生成。Midjourney・Adobe Firefly など主要ツールを商用利用・無料枠・透かしで比較できます。</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Midjourney</span>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Adobe Firefly</span>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Stable Diffusion</span>
          </div>
          <p class="mt-4 text-right text-sm font-bold text-blue-600 group-hover:underline">ツール一覧を見る →</p>
        </a>

      </div>

      <!-- サポートカテゴリ（AI動画編集 / AIアバター動画） -->
      <p class="mb-3 mt-6 text-xs font-semibold uppercase tracking-widest text-slate-400">動画制作を支えるカテゴリ</p>
      <div class="mb-4 grid gap-4 sm:grid-cols-2">

        <!-- AI動画編集 -->
        <div class="flex flex-col rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-indigo-500" aria-hidden="true">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            <p class="text-sm font-bold text-slate-800">AI動画編集</p>
            <span class="ml-auto inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-[9px] font-semibold text-slate-500">準備中</span>
          </div>
          <p class="text-xs leading-relaxed text-slate-500">AIを使った動画トリミング・字幕追加・カット編集ツールの比較情報を準備中です。</p>
        </div>

        <!-- AIアバター動画 -->
        <div class="flex flex-col rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-indigo-500" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <p class="text-sm font-bold text-slate-800">AIアバター動画</p>
            <span class="ml-auto inline-flex rounded-full bg-slate-100 px-2 py-0.5 text-[9px] font-semibold text-slate-500">準備中</span>
          </div>
          <p class="text-xs leading-relaxed text-slate-500">AIアバターを使った解説動画・プレゼン動画ツールの比較情報を準備中です。</p>
        </div>

      </div>

      <!-- 制作補助カテゴリ（4つ） -->
      <p class="mb-3 mt-6 text-xs font-semibold uppercase tracking-widest text-slate-400">制作補助ツール</p>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">

        <!-- AIデザイン -->
        <div class="flex flex-col rounded-lg border border-slate-100 bg-slate-50 p-4">
          <p class="text-xs font-bold text-slate-600">AIデザイン</p>
          <p class="mt-1 text-[11px] leading-relaxed text-slate-400">バナー・LP・SNS投稿デザイン自動化ツール。比較情報準備中。</p>
          <span class="mt-3 inline-flex w-fit rounded-full bg-slate-200 px-2 py-0.5 text-[9px] font-semibold text-slate-500">準備中</span>
        </div>

        <!-- AI音声・ナレーション -->
        <div class="flex flex-col rounded-lg border border-slate-100 bg-slate-50 p-4">
          <p class="text-xs font-bold text-slate-600">AI音声・ナレーション</p>
          <p class="mt-1 text-[11px] leading-relaxed text-slate-400">テキスト読み上げ・音声クローンツール。比較情報準備中。</p>
          <span class="mt-3 inline-flex w-fit rounded-full bg-slate-200 px-2 py-0.5 text-[9px] font-semibold text-slate-500">準備中</span>
        </div>

        <!-- プロンプト活用 -->
        <div class="flex flex-col rounded-lg border border-slate-100 bg-slate-50 p-4">
          <p class="text-xs font-bold text-slate-600">プロンプト活用</p>
          <p class="mt-1 text-[11px] leading-relaxed text-slate-400">画像・動画生成を高精度化するプロンプト集・テンプレート。準備中。</p>
          <span class="mt-3 inline-flex w-fit rounded-full bg-slate-200 px-2 py-0.5 text-[9px] font-semibold text-slate-500">準備中</span>
        </div>

        <!-- 実務テンプレート -->
        <div class="flex flex-col rounded-lg border border-slate-100 bg-slate-50 p-4">
          <p class="text-xs font-bold text-slate-600">実務テンプレート</p>
          <p class="mt-1 text-[11px] leading-relaxed text-slate-400">SNS・広告・EC向け実務利用テンプレート集。準備中。</p>
          <span class="mt-3 inline-flex w-fit rounded-full bg-slate-200 px-2 py-0.5 text-[9px] font-semibold text-slate-500">準備中</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 3. 条件で探すカード                                           -->
  <!-- ============================================================ -->
  <section class="bg-slate-50 py-14">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-2 text-2xl font-bold text-[#002B61]">目的に合わせて探す</h2>
      <p class="mb-8 text-sm text-slate-500">よく使われる条件でツールを絞り込めます。</p>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">

        <!-- 無料 -->
        <a href="/categories/free/" class="group flex flex-col rounded-xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-blue-200 hover:shadow-md">
          <div class="mb-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-950" aria-hidden="true">
              <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
              <line x1="7" y1="7" x2="7.01" y2="7"/>
            </svg>
            <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-blue-600">無料</span>
          </div>
          <p class="text-sm font-bold leading-snug text-slate-900 group-hover:text-[#0066FF]">無料で使えるAI画像生成ツール</p>
          <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-500">無料プランや無料クレジットで試せるツールを確認できます。</p>
          <p class="mt-4 text-right text-xs font-semibold text-blue-600 group-hover:underline">ツールを見る →</p>
        </a>

        <!-- 商用利用 -->
        <a href="/categories/commercial-use/" class="group flex flex-col rounded-xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-blue-200 hover:shadow-md">
          <div class="mb-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-950" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
            <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-blue-600">商用利用</span>
          </div>
          <p class="text-sm font-bold leading-snug text-slate-900 group-hover:text-[#0066FF]">商用利用条件を確認できるAI画像生成ツール</p>
          <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-500">公式情報をもとに商用利用条件を確認できます。</p>
          <p class="mt-4 text-right text-xs font-semibold text-blue-600 group-hover:underline">ツールを見る →</p>
        </a>

        <!-- 日本語対応 -->
        <a href="/categories/japanese/" class="group flex flex-col rounded-xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-blue-200 hover:shadow-md">
          <div class="mb-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-950" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-blue-600">日本語対応</span>
          </div>
          <p class="text-sm font-bold leading-snug text-slate-900 group-hover:text-[#0066FF]">日本語対応AI画像生成ツール</p>
          <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-500">日本語UIや日本語プロンプトに対応したツールを探せます。</p>
          <p class="mt-4 text-right text-xs font-semibold text-blue-600 group-hover:underline">ツールを見る →</p>
        </a>

        <!-- 透かしなし -->
        <a href="/categories/no-watermark/" class="group flex flex-col rounded-xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-blue-200 hover:shadow-md">
          <div class="mb-3 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-950" aria-hidden="true">
              <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
              <line x1="2" y1="2" x2="22" y2="22"/>
            </svg>
            <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-blue-600">透かしなし</span>
          </div>
          <p class="text-sm font-bold leading-snug text-slate-900 group-hover:text-[#0066FF]">透かしなしAI画像生成ツール</p>
          <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-500">出力画像に透かしが付かないツールを条件で絞り込めます。</p>
          <p class="mt-4 text-right text-xs font-semibold text-blue-600 group-hover:underline">ツールを見る →</p>
        </a>

      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 3.5 用途別ページ導線                                          -->
  <!-- ============================================================ -->
  <section class="bg-white py-8 border-b border-slate-100">
    <div class="mx-auto max-w-5xl px-6">
      <p class="mb-3 text-sm font-semibold text-slate-700">用途から探す</p>
      <div class="flex flex-wrap gap-2">
        <a
          href="/use-cases/youtube-thumbnail/"
          class="group inline-flex items-center gap-1.5 rounded-full border border-blue-100 bg-blue-50 px-4 py-1.5 text-xs font-semibold text-blue-700 transition hover:border-blue-300 hover:bg-blue-100"
        >
