---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import CompareTablePreview from '../components/CompareTablePreview.astro';
import NoticeBox from '../components/NoticeBox.astro';

const FEATURED_SLUGS = [
  'midjourney',
  'adobe-firefly',
  'runway',
  'canva-ai-image-generator',
  'kling-ai',
  'leonardo-ai',
];

const allTools = await getCollection('tools');
const tools = FEATURED_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);
---

<BaseLayout
  title="AI画像・動画生成ツール比較【商用利用・著作権・料金】| AIクリエイティブツール比較DB"
  description="AI画像生成・動画生成ツールを商用利用・著作権・透かし・無料枠・日本語対応・料金で比較。副業・フリーランス・SNS運用者が仕事で使う前に確認できるAIツール比較DBです。"
  canonicalPath="/"
>

  <!-- ============================================================ -->
  <!-- 1. HERO                                                       -->
  <!-- ============================================================ -->
  <section class="hero-bg pb-20 pt-20">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 lg:grid-cols-[1fr_320px] lg:items-start">

        <!-- Left -->
        <div>
          <!-- Badge -->
          <div class="mb-5 inline-flex items-center rounded-full border border-blue-200 bg-white px-4 py-1.5 text-xs font-semibold text-blue-700 shadow-sm">
            AIクリエイティブツール比較DB
          </div>

          <!-- H1 -->
          <h1 class="text-[1.9rem] font-bold leading-snug text-[#002B61] sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
            AI画像・動画ツールを、<br/>仕事で使う前に比較できる
          </h1>

          <!-- Description -->
          <p class="mt-5 text-base leading-relaxed text-slate-600">
            AI画像・動画生成ツールを、商用利用・無料枠・透かし・日本語対応で比較できるデータベースです。
          </p>

          <!-- 比較軸ラベル -->
          <div class="mt-4 flex flex-wrap gap-2">
            {['商用利用', '無料枠', '透かし', '日本語対応'].map(label => (
              <span class="inline-flex items-center rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">
                {label}
              </span>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/tools/" class="primary-btn">
              AI画像生成ツール一覧を見る
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
              </svg>
            </a>
            <a href="/guides/commercial-use-copyright/" class="outline-btn">商用利用ガイドを見る</a>
          </div>

          <!-- Flow guide -->
          <p class="mt-3 text-xs text-slate-500">
            初めての方：条件から探す → 一覧で候補を見る → 比較表で比べる → 詳細で確認 → 公式サイトで最終確認
          </p>

          <!-- Footnote -->
          <p class="mt-2 text-xs text-slate-400">
            情報は公式サイト・ヘルプ・利用規約などをもとに整理しています。確認日時点の情報です。
          </p>
        </div>

        <!-- Right: 比較できる項目 card -->
        <div class="rounded-2xl border border-blue-100 bg-white px-6 py-6 shadow-sm">
          <p class="mb-5 text-[10px] font-bold uppercase tracking-widest text-slate-400">比較できる項目</p>
          <ul class="space-y-4">
            {[
              { label: '商用利用',   desc: 'ビジネス・副業での活用可否を公式情報で確認' },
              { label: '著作権',     desc: '生成物の利用条件を利用規約で確認' },
              { label: '透かし',     desc: '出力画像・動画への透かし付与の有無' },
              { label: '無料枠',     desc: '無料で試せる範囲・クレジット数など' },
              { label: '日本語対応', desc: 'UIと日本語プロンプト対応状況' },
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-50 text-[10px] font-bold text-blue-600">✓</span>
                <div>
                  <p class="text-sm font-semibold text-slate-800">{item.label}</p>
                  <p class="text-xs leading-relaxed text-slate-500">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 2. 条件フィルター                                             -->
  <!-- ============================================================ -->
  <section class="border-y border-slate-100 bg-white py-8">
    <div class="mx-auto max-w-5xl px-6">
      <p class="mb-4 text-sm font-semibold text-slate-700">条件からAIツールを探す</p>

      <div class="flex flex-wrap gap-2">
        <a href="/categories/commercial-use/" class="chip">商用利用を確認</a>
        <a href="/categories/free/"           class="chip">無料で試せる</a>
        <a href="/categories/japanese/"       class="chip">日本語対応</a>
        <a href="/categories/no-watermark/"   class="chip">透かしなし</a>
        <a href="/tools/"                     class="chip">画像生成</a>
        <a href="/tools/"                     class="chip">動画生成</a>
      </div>

      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/tools/"    class="primary-btn">すべてのツールを見る</a>
        <a href="/compare/"  class="outline-btn">比較表で見る</a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 3. 条件で探すカード                                           -->
  <!-- ============================================================ -->
  <section class="bg-slate-50 py-14">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-2 text-2xl font-bold text-[#002B61]">目的に合わせて探す</h2>
      <p class="mb-8 text-sm text-slate-500">よく使われる条件でツールを絞り込めます。</p>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            href: '/categories/free/',
            icon: '🆓',
            tag: '無料',
            title: '無料で使えるAI画像生成ツール',
            desc: '無料プランや無料クレジットで試せるツールを確認できます。',
          },
          {
            href: '/categories/commercial-use/',
            icon: '💼',
            tag: '商用利用',
            title: '商用利用条件を確認できるAI画像生成ツール',
            desc: '公式情報をもとに商用利用条件を確認できます。',
          },
          {
            href: '/categories/japanese/',
            icon: '🇯🇵',
            tag: '日本語対応',
            title: '日本語対応AI画像生成ツール',
            desc: '日本語UIや日本語プロンプトに対応したツールを探せます。',
          },
          {
            href: '/categories/no-watermark/',
            icon: '✨',
            tag: '透かしなし',
            title: '透かしなしAI画像生成ツール',
            desc: '出力画像に透かしが付かないツールを条件で絞り込めます。',
          },
        ].map(({ href, icon, tag, title, desc }) => (
          <a
            href={href}
            class="group flex flex-col rounded-xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-blue-200 hover:shadow-md"
          >
            <div class="mb-3 flex items-center gap-2">
              <span class="text-2xl" aria-hidden="true">{icon}</span>
              <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-blue-600">
                {tag}
              </span>
            </div>
            <p class="text-sm font-bold leading-snug text-slate-900 group-hover:text-[#0066FF]">{title}</p>
            <p class="mt-2 flex-1 text-xs leading-relaxed text-slate-500">{desc}</p>
            <p class="mt-4 text-right text-xs font-semibold text-blue-600 group-hover:underline">ツールを見る →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 3.5 用途別ページ導線                                          -->
  <!-- ============================================================ -->
  <section class="bg-white py-8 border-b border-slate-100">
    <div class="mx-auto max-w-5xl px-6">
      <p class="mb-3 text-sm font-semibold text-slate-700">用途から探す</p>
      <div class="flex flex-wrap gap-2">
        <a
          href="/use-cases/youtube-thumbnail/"
          class="group inline-flex items-center gap-1.5 rounded-full border border-blue-100 bg-blue-50 px-4 py-1.5 text-xs font-semibold text-blue-700 transition hover:border-blue-300 hover:bg-blue-100"
        >
          <span aria-hidden="true">▶</span>
          YouTubeサムネ向けツールを比較する
        </a>
        <a
          href="/use-cases/sns-blog-eyecatch/"
          class="group inline-flex items-center gap-1.5 rounded-full border border-blue-100 bg-blue-50 px-4 py-1.5 text-xs font-semibold text-blue-700 transition hover:border-blue-300 hover:bg-blue-100"
        >
          <span aria-hidden="true">▶</span>
          SNS・ブログ画像向けツールを比較する
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 4. 注目のツール                                               -->
  <!-- ============================================================ -->
  <section class="bg-slate-50 py-16">
    <div class="mx-auto max-w-5xl px-6">
      <div class="mb-7 flex items-baseline justify-between">
        <h2 class="flex items-center gap-3 text-2xl font-bold text-[#002B61]">
          注目のAI生成ツール
          <span class="rounded-full bg-blue-50 px-3 py-0.5 text-xs font-semibold text-blue-600">全{tools.length}件</span>
        </h2>
        <a href="/tools/" class="text-sm text-blue-600 hover:underline">すべてのツールを見る →</a>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {tools.map(tool => <ToolCard tool={tool} />)}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 5. 比較表プレビュー                                           -->
  <!-- ============================================================ -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-5xl px-6">
      <div class="mb-7 flex items-baseline justify-between">
        <h2 class="text-2xl font-bold text-[#002B61]">ツール比較表（抜粋）</h2>
        <a href="/compare/" class="text-sm text-blue-600 hover:underline">全ツールを比較表で見る →</a>
      </div>

      <CompareTablePreview tools={tools} limit={5} />

      <p class="mt-3 text-xs text-slate-400">
        ※ 商用利用の可否・著作権の取り扱いは各ツールの利用規約に基づきます。法的アドバイスではありません。最新情報は必ず公式サイトでご確認ください。
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 6. ガイドカード                                               -->
  <!-- ============================================================ -->
  <section class="bg-slate-50 py-16">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-7 text-2xl font-bold text-[#002B61]">使い方・選び方ガイド</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {[
          {
            href:  '/guides/commercial-use-copyright/',
            tag:   '商用利用',
            title: 'AI画像生成の商用利用・著作権ガイド',
            desc:  '商用利用の注意点・著作権の基本・ツール別の利用条件を整理',
          },
          {
            href:  '/guides/free-ai-image-tools/',
            tag:   '無料プラン',
            title: '無料で使えるAI画像生成ツールの選び方',
            desc:  '無料プランの比較・制限・用途別のおすすめポイントを解説',
          },
          {
            href:  '/guides/watermark-credit-guide/',
            tag:   '透かし',
            title: '透かし・クレジット表記ガイド',
            desc:  '生成画像の透かし条件とクレジット表記の考え方を整理',
          },
          {
            href:  '/guides/japanese-ai-image-tools/',
            tag:   '日本語対応',
            title: '日本語対応AI画像生成ツールの選び方',
            desc:  '日本語UIと日本語プロンプト対応状況を比較・解説',
          },
        ].map(({ href, tag, title, desc }) => (
          <a
            href={href}
            class="group flex flex-col rounded-xl border border-slate-100 bg-white p-6 shadow-sm transition hover:border-blue-100 hover:shadow-md"
          >
            <span class="mb-3 inline-flex w-fit rounded-full bg-blue-50 px-3 py-1 text-[10px] font-semibold uppercase tracking-wide text-blue-600">
              {tag}
            </span>
            <p class="font-bold leading-snug text-slate-900 group-hover:text-[#0066FF]">{title}</p>
            <p class="mt-2 text-xs leading-relaxed text-slate-500">{desc}</p>
            <p class="mt-4 text-right text-xs font-semibold text-blue-600 group-hover:underline">読む →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 7. ご利用前の注意                                             -->
  <!-- ============================================================ -->
  <section class="bg-white py-12">
    <div class="mx-auto max-w-5xl px-6">
      <NoticeBox />
      <p class="mt-3 text-xs text-slate-400">
        <a href="/guides/commercial-use-copyright/" class="font-medium text-blue-600 hover:underline">
          商用利用・著作権ガイドを読む →
        </a>
      </p>
      <p class="mt-1 text-xs text-slate-400">
        <a href="/guides/ai-image-commercial-use-checklist/" class="font-medium text-blue-600 hover:underline">
          商用利用前チェックリスト →
        </a>
      </p>
    </div>
  </section>

</BaseLayout>
