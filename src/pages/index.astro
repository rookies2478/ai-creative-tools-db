---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHeroAnimated from '../components/HomeHeroAnimated.astro';
import HomePillarCards from '../components/HomePillarCards.astro';
import HomeCriteriaStrip from '../components/HomeCriteriaStrip.astro';
import HomePurposeCards from '../components/HomePurposeCards.astro';
import HomeGoalCards from '../components/HomeGoalCards.astro';
import HomeStartFinder from '../components/HomeStartFinder.astro';
import HomeComparisonInteractive from '../components/HomeComparisonInteractive.astro';
import type { CmpTool } from '../components/HomeComparisonInteractive.astro';
import HomeGuidesGrid from '../components/HomeGuidesGrid.astro';
import HomeEditorialPolicy from '../components/HomeEditorialPolicy.astro';
import HomeFaq from '../components/HomeFaq.astro';
import HomeCtaBanner from '../components/HomeCtaBanner.astro';

const FEATURED_IMAGE_SLUGS = [
  'midjourney',
  'adobe-firefly',
  'canva-ai-image-generator',
  'leonardo-ai',
  'stable-diffusion',
];

const FEATURED_VIDEO_SLUGS = [
  'runway',
  'kling-ai',
  'pika',
  'luma-ai',
  'capcut-ai',
];

const allTools = await getCollection('tools');

const imageTools = FEATURED_IMAGE_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

const videoTools = FEATURED_VIDEO_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

// --- CmpTool マッピング ---
type Mark = 'y' | 'c' | 'n';
const TOOL_META: Record<string, { initial: string; color: string; cat: string }> = {
  'runway':                   { initial: 'R', color: '#E1543A', cat: '動画生成' },
  'kling-ai':                 { initial: 'K', color: '#3A6FF0', cat: '動画生成' },
  'pika':                     { initial: 'P', color: '#10A4C8', cat: '動画生成' },
  'luma-ai':                  { initial: 'L', color: '#15897F', cat: '動画生成' },
  'capcut-ai':                { initial: 'C', color: '#111319', cat: '動画生成' },
  'midjourney':               { initial: 'M', color: '#7A5AE0', cat: '画像生成' },
  'adobe-firefly':            { initial: 'A', color: '#D8453A', cat: '画像生成' },
  'canva-ai-image-generator': { initial: 'C', color: '#0E8E84', cat: '画像生成' },
  'leonardo-ai':              { initial: 'L', color: '#E89B12', cat: '画像生成' },
  'stable-diffusion':         { initial: 'S', color: '#1F63E8', cat: '画像生成' },
};
function mapFree(v: boolean | 'limited' | 'unknown'): Mark {
  return v === true ? 'y' : v === false ? 'n' : 'c';
}
function mapWatermark(v: 'yes' | 'no' | 'limited' | 'unknown'): Mark {
  return v === 'no' ? 'y' : v === 'yes' ? 'n' : 'c';
}
function mapJapanese(v: boolean | 'partial' | 'unknown'): Mark {
  return v === true ? 'y' : v === false ? 'n' : 'c';
}
function mapCommercial(v: 'ok' | 'paid-only' | 'limited' | 'no' | 'unknown'): Mark {
  return v === 'ok' ? 'y' : v === 'no' ? 'n' : 'c';
}
function extractPrice(s?: string): number | null {
  if (!s) return null;
  const m = s.match(/(\d+\.?\d*)/);
  return m ? parseFloat(m[1]) : null;
}
function toCmpTool(t: (typeof allTools)[number]): CmpTool {
  const d = t.data;
  const meta = TOOL_META[t.slug] ?? { initial: d.name[0], color: '#888', cat: '' };
  const noLowest = !d.lowestPaidPlan;
  const isFreeOnly = d.freePlan === true && noLowest;
  const price = isFreeOnly ? 0 : extractPrice(d.lowestPaidPlan);
  const sym = d.lowestPaidPlan?.startsWith('¥') ? '¥' : '$';
  const priceLabel = isFreeOnly
    ? '<span class="cmp-free">無料〜</span>'
    : price !== null
      ? `${sym}${price}<small>/月〜</small>`
      : '要確認';
  return {
    name: d.name, initial: meta.initial, color: meta.color, cat: meta.cat,
    free: mapFree(d.freePlan),
    watermark: mapWatermark(d.watermark),
    japanese: mapJapanese(d.japaneseUi),
    commercial: mapCommercial(d.commercialUse),
    price, priceLabel,
    checked: d.lastReviewed,
    url: `/tools/${t.slug}/`,
  };
}
const cmpVideoTools: CmpTool[] = videoTools.map(toCmpTool);
const cmpImageTools: CmpTool[] = imageTools.map(toCmpTool);
// --- ここまで ---

const jsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "AIクリエイティブナビ",
    "url": "https://aicreative-db.com/"
  },
  {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "このサイトで紹介しているAIツールは商用利用できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "商用利用の可否はツール・プラン・用途によって異なり、本サイトでは断定しません。掲載情報はあくまで参考用であり、本記事は法的助言ではありません。プランや用途によって条件が異なる場合があります。利用前に必ず各ツールの公式サイトおよび利用規約をご確認ください。"
      }
    },
    {
      "@type": "Question",
      "name": "無料で使えるAIツールだけを探せますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ツール一覧ページでは料金タグ（無料プランあり・無料クレジットなど）で絞り込めます。ただし無料枠の内容や制限はプランや用途によって条件が異なる場合があります。最新情報は公式サイトをご確認ください。"
      }
    },
    {
      "@type": "Question",
      "name": "AI画像生成ツールとAI動画生成ツールはどう選べばよいですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "本サイトはクリエイティブ制作に直接関係するAIツール（画像・動画生成）を中心に扱っています。用途（SNS投稿・商用制作など）、料金、無料枠の有無、透かしの有無などの条件で絞り込むと選びやすくなります。比較記事も参考にしてください。最終的な選択は公式サイトをご確認ください。"
      }
    },
    {
      "@type": "Question",
      "name": "日本語対応や透かしの有無はどこで確認できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "各ツールの詳細ページおよびタグ一覧から確認できます。対応状況はアップデートにより変わる場合があります。確定できない項目は要確認として表示しており、公式サイトで最終確認されることをおすすめします。"
      }
    },
    {
      "@type": "Question",
      "name": "料金や条件タグはどのくらいの頻度で更新されますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "公式情報の更新を確認次第、随時見直しを行っています。ただし更新タイミングにはラグが生じる場合があります。最新の料金・条件は必ず公式サイトをご確認ください。記事ごとに最終確認日を記載しています。"
      }
    },
    {
      "@type": "Question",
      "name": "掲載されていないAIツールを追加依頼できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "クリエイティブ制作（画像・動画生成）に直接関係するAIツールを対象に、掲載ご要望を受け付けています。ただし掲載はサイトの編集方針に基づき審査のうえ判断します。詳しくは編集方針ページをご覧ください。"
      }
    }
  ]
  }
]);
---

<BaseLayout
  title="AIクリエイティブナビ｜動画生成・画像生成を中心に目的別で探せる"
  description="AI画像生成・AI動画生成ツールを商用利用・料金・無料枠・透かし・日本語対応で比較できるDBです。副業・SNS運用・仕事での利用前に条件を確認できます。最新情報は公式サイトをご確認ください。"
  canonicalPath="/"
  jsonLd={jsonLd}
  homePage={true}
>

  <HomeHeroAnimated
    videoHref="/categories/video-generation/"
    imageHref="/categories/image-generation/"
  />
  <HomeCriteriaStrip />
  <HomePurposeCards />
  <HomePillarCards />
  <HomeGoalCards />
  <HomeStartFinder />
  <HomeComparisonInteractive videoTools={cmpVideoTools} imageTools={cmpImageTools} />
  <HomeGuidesGrid />
  <HomeEditorialPolicy />
  <HomeFaq />
  <HomeCtaBanner />

</BaseLayout>

<script>
// Scroll reveal — IntersectionObserver + load + rAF + 8s failsafe
window.addEventListener('load', function() {
  requestAnimationFrame(function() {
    // 8-second failsafe: force-reveal everything if observer hasn't fired
    var failsafe = setTimeout(function() {
      document.querySelectorAll('.reveal:not(.in), [data-stagger] > *:not(.in)').forEach(function(el) {
        el.classList.add('in');
      });
    }, 8000);

    // Stagger children: add .reveal to each child so IntersectionObserver can pick them up
    document.querySelectorAll('[data-stagger]').forEach(function(parent) {
      Array.from(parent.children).forEach(function(child) {
        child.classList.add('reveal');
      });
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('in');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(function(el) {
      // If already in viewport on load (above the fold), show immediately
      var rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight) {
        el.classList.add('in');
      } else {
        observer.observe(el);
      }
    });

    // Clear failsafe once all elements are revealed
    var remaining = document.querySelectorAll('.reveal:not(.in)');
    if (remaining.length === 0) clearTimeout(failsafe);
  });
});
</script>
