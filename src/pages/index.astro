  <script>
    function switchFeedTab(tab: string) {
      const tabs = ['pickup', 'tools', 'new'];
      tabs.forEach(t => {
        const panel = document.getElementById('feed-panel-' + t);
        const btn   = document.getElementById('feed-tab-' + t);
        if (!panel || !btn) return;
        if (t === tab) {
          panel.classList.remove('hidden');
          btn.classList.add('active');
        } else {
          panel.classList.add('hidden');
          btn.classList.remove('active');
        }
      });
    }
    (window as any).switchFeedTab = switchFeedTab;
  </script>

