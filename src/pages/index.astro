---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import CompareTablePreview from '../components/CompareTablePreview.astro';

const FEATURED_IMAGE_SLUGS = [
  'midjourney',
  'adobe-firefly',
  'canva-ai-image-generator',
  'leonardo-ai',
  'stable-diffusion',
];

const FEATURED_VIDEO_SLUGS = [
  'runway',
  'kling-ai',
  'pika',
  'luma-ai',
  'capcut-ai',
];

const allTools = await getCollection('tools');

const imageTools = FEATURED_IMAGE_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

const videoTools = FEATURED_VIDEO_SLUGS
  .map(slug => allTools.find(t => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => t !== undefined);

// 注目ツール表示用（動画→画像の順）
const tools = [...videoTools, ...imageTools].slice(0, 6);

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "このサイトで紹介しているAIツールは商用利用できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "商用利用の可否はツール・プラン・用途によって異なり、本サイトでは断定しません。掲載情報はあくまで参考用であり、本記事は法的助言ではありません。プランや用途によって条件が異なる場合があります。利用前に必ず各ツールの公式サイトおよび利用規約をご確認ください。"
      }
    },
    {
      "@type": "Question",
      "name": "無料で使えるAIツールだけを探せますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ツール一覧ページでは料金タグ（無料プランあり・無料クレジットなど）で絞り込めます。ただし無料枠の内容や制限はプランや用途によって条件が異なる場合があります。最新情報は公式サイトをご確認ください。"
      }
    },
    {
      "@type": "Question",
      "name": "AI画像生成ツールとAI動画生成ツールはどう選べばよいですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "本サイトはクリエイティブ制作に直接関係するAIツール（画像・動画生成）を中心に扱っています。用途（SNS投稿・商用制作など）、料金、無料枠の有無、透かしの有無などの条件で絞り込むと選びやすくなります。比較記事も参考にしてください。最終的な選択は公式サイトをご確認ください。"
      }
    },
    {
      "@type": "Question",
      "name": "日本語対応や透かしの有無はどこで確認できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "各ツールの詳細ページおよびタグ一覧から確認できます。対応状況はアップデートにより変わる場合があります。確定できない項目は要確認として表示しており、公式サイトで最終確認されることをおすすめします。"
      }
    },
    {
      "@type": "Question",
      "name": "料金や条件タグはどのくらいの頻度で更新されますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "公式情報の更新を確認次第、随時見直しを行っています。ただし更新タイミングにはラグが生じる場合があります。最新の料金・条件は必ず公式サイトをご確認ください。記事ごとに最終確認日を記載しています。"
      }
    },
    {
      "@type": "Question",
      "name": "掲載されていないAIツールを追加依頼できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "クリエイティブ制作（画像・動画生成）に直接関係するAIツールを対象に、掲載ご要望を受け付けています。ただし掲載はサイトの編集方針に基づき審査のうえ判断します。詳しくは編集方針ページをご覧ください。"
      }
    }
  ]
});
---

<BaseLayout
  title="AIクリエイティブナビ｜動画生成・画像生成を中心に目的別で探せる"
  description="AI画像生成・AI動画生成ツールを商用利用・料金・無料枠・透かし・日本語対応で比較できるDBです。副業・SNS運用・仕事での利用前に条件を確認できます。最新情報は公式サイトをご確認ください。"
  canonicalPath="/"
  jsonLd={faqJsonLd}
>

  <!-- ============================================================ -->
  <!-- 0. ページ内アンカーナビ（トップページ専用）                    -->
  <!-- ============================================================ -->
  <nav aria-label="ページ内ナビゲーション" class="border-b border-slate-100 bg-white">
    <div class="overflow-x-auto overflow-y-hidden">
      <div class="flex min-w-max gap-1 px-6">
        <a href="#categories"  class="inline-flex min-h-[44px] items-center whitespace-nowrap px-4 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-600">カテゴリ</a>
        <a href="#use-cases"   class="inline-flex min-h-[44px] items-center whitespace-nowrap px-4 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-600">目的から選ぶ</a>
        <a href="#comparison"  class="inline-flex min-h-[44px] items-center whitespace-nowrap px-4 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-600">主要ツール比較</a>
        <a href="#articles"    class="inline-flex min-h-[44px] items-center whitespace-nowrap px-4 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-600">記事</a>
        <a href="#pickup"      class="inline-flex min-h-[44px] items-center whitespace-nowrap px-4 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-600">ピックアップ</a>
        <a href="#faq"         class="inline-flex min-h-[44px] items-center whitespace-nowrap px-4 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-600">FAQ</a>
      </div>
    </div>
  </nav>

  <!-- ============================================================ -->
  <!-- 1. HERO                                                       -->
  <!-- ============================================================ -->
  <section class="hero-bg pb-20 pt-20">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 lg:grid-cols-[1fr_320px] lg:items-start">

        <!-- Left -->
        <div>
          <!-- Label -->
          <div class="mb-4 flex items-center gap-3 text-xs font-medium uppercase tracking-[0.28em] text-slate-500">
            <span class="h-2 w-2 rounded-full bg-blue-600"></span>
            <span>AI CREATIVE TOOL NAVI</span>
          </div>

          <!-- H1 -->
          <h1 class="text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
            AIクリエイティブナビ
          </h1>

          <!-- Description -->
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-slate-600">
            AI動画生成・AI画像生成を中心に、目的別で探せるAIクリエイティブツール比較ナビ
          </p>

          <!-- 比較軸ラベル -->
          <div class="mt-4 flex flex-wrap gap-2">
            {['商用利用', '無料枠', '透かし', '日本語対応'].map(label => (
              <span class="inline-flex items-center rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">
                {label}
              </span>
            ))}
          </div>

          <!-- CTAs -->
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/categories/video-generation/" class="primary-btn">
              AI動画生成ツールを見る
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
              </svg>
            </a>
            <a href="/tools/" class="outline-btn">AI画像生成ツールを見る</a>
            <a href="/guides/commercial-use-copyright/" class="text-sm font-medium text-slate-500 hover:text-blue-600 self-center">商用利用ガイド →</a>
          </div>

          <!-- Flow guide -->
          <p class="mt-3 text-xs text-slate-500">
            初めての方：条件から探す → 一覧で候補を見る → 比較表で比べる → 詳細で確認 → 公式サイトで最終確認
          </p>

          <!-- Footnote -->
          <p class="mt-2 text-xs text-slate-400">
            情報は公式サイト・ヘルプ・利用規約などをもとに整理しています。確認日時点の情報です。
          </p>
        </div>

        <!-- Right: 比較できる項目 card -->
        <div class="rounded-2xl border border-blue-100 bg-white px-6 py-6 shadow-sm">
          <p class="mb-5 text-[10px] font-bold uppercase tracking-widest text-slate-400">比較できる項目</p>
          <ul class="space-y-4">
            {[
              { label: '商用利用',   desc: 'ビジネス・副業での活用可否を公式情報で確認' },
              { label: '著作権',     desc: '生成物の利用条件を利用規約で確認' },
              { label: '透かし',     desc: '出力画像・動画への透かし付与の有無' },
              { label: '無料枠',     desc: '無料で試せる範囲・クレジット数など' },
              { label: '日本語対応', desc: 'UIと日本語プロンプト対応状況' },
            ].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-blue-50 text-[10px] font-bold text-blue-600">✓</span>
                <div>
                  <p class="text-sm font-semibold text-slate-800">{item.label}</p>
                  <p class="text-xs leading-relaxed text-slate-500">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 2. 条件フィルター                                             -->
  <!-- ============================================================ -->
  <section class="border-y border-slate-100 bg-white py-8">
    <div class="mx-auto max-w-5xl px-6">
      <p class="mb-4 text-sm font-semibold text-slate-700">条件からAIツールを探す</p>

      <div class="flex flex-wrap gap-2">
        <a href="/categories/video-generation/"          class="chip">AI動画生成</a>
        <a href="/categories/image-generation/"        class="chip">AI画像生成</a>
        <a href="/conditions/commercial-use/" class="chip">商用利用を確認</a>
        <a href="/conditions/free/"           class="chip">無料で試せる</a>
        <a href="/conditions/free/"     class="chip">動画無料プラン</a>
        <a href="/conditions/japanese/"       class="chip">日本語対応</a>
        <a href="/conditions/no-watermark/"   class="chip">透かしなし</a>
      </div>

      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/categories/video-generation/" class="primary-btn">AI動画生成ツール一覧</a>
        <a href="/categories/image-generation/" class="outline-btn">AI画像生成ツール一覧</a>
        <a href="/comparisons/"          class="outline-btn">比較表で見る</a>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 2.5 カテゴリから探す                                          -->
  <!-- ============================================================ -->
  <section id="categories" class="scroll-mt-24 bg-white py-14">
    <div class="mx-auto max-w-5xl px-6">
      <div class="mb-8">
        <div class="mb-4 flex items-center gap-3 text-xs font-medium uppercase tracking-[0.28em] text-slate-500">
          <span class="h-2 w-2 rounded-full bg-blue-600"></span>
          <span>CATEGORIES</span>
        </div>
        <h2 class="text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
          カテゴリから探す
        </h2>
        <p class="mt-4 max-w-3xl text-base leading-relaxed text-slate-600">
          AI動画生成・AI画像生成を中心に、動画編集・アバター・デザイン・音声まで、制作に使えるAIツールカテゴリを整理しています。
        </p>
      </div>

      <!-- 主役カテゴリ（AI動画生成 / AI画像生成） -->
      <div class="mb-4 grid gap-4 sm:grid-cols-2">

        <!-- AI動画生成 -->
        <a href="/categories/video-generation/" class="group relative flex flex-col rounded-2xl border-2 border-blue-500 bg-gradient-to-br from-blue-50 to-indigo-50 p-6 shadow-md transition hover:border-blue-600 hover:shadow-lg">
          <div class="mb-3 flex items-center gap-2 flex-wrap">
            <span class="inline-flex items-center gap-1 rounded-full bg-blue-600 px-3 py-1 text-[10px] font-bold uppercase tracking-wide text-white shadow-sm">
              ★ 中心カテゴリ
            </span>
          </div>
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-600" aria-hidden="true">
              <polygon points="23 7 16 12 23 17 23 7"/>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
            <p class="text-base font-bold text-slate-900 group-hover:text-blue-700">AI動画生成</p>
          </div>
          <p class="mt-1 text-sm leading-relaxed text-slate-600">テキストや画像から動画を自動生成。Runway・Kling AI・Pika など主要ツールを商用利用・無料枠・透かしで比較できます。</p>
          <p class="mt-2 text-xs leading-relaxed text-slate-500">Hailuo AI・PixVerse・Vidu AI・InVideo AI など10件規模のツールをカテゴリで比較できます。</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Runway</span>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Kling AI</span>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Pika</span>
          </div>
          <p class="mt-4 text-right text-sm font-bold text-blue-600 group-hover:underline">ツール一覧を見る →</p>
        </a>

        <!-- AI画像生成 -->
        <a href="/categories/image-generation/" class="group relative flex flex-col rounded-2xl border-2 border-blue-500 bg-gradient-to-br from-blue-50 to-indigo-50 p-6 shadow-md transition hover:border-blue-600 hover:shadow-lg">
          <div class="mb-3 flex items-center gap-2 flex-wrap">
            <span class="inline-flex items-center gap-1 rounded-full bg-blue-600 px-3 py-1 text-[10px] font-bold uppercase tracking-wide text-white shadow-sm">
              ★ 中心カテゴリ
            </span>
          </div>
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-600" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <p class="text-base font-bold text-slate-900 group-hover:text-blue-700">AI画像生成</p>
          </div>
          <p class="mt-1 flex-1 text-sm leading-relaxed text-slate-600">テキストプロンプトから画像を生成。Midjourney・Adobe Firefly など主要ツールを商用利用・無料枠・透かしで比較できます。</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Midjourney</span>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Adobe Firefly</span>
            <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-[10px] font-semibold text-blue-700">Stable Diffusion</span>
          </div>
          <p class="mt-4 text-right text-sm font-bold text-blue-600 group-hover:underline">ツール一覧を見る →</p>
        </a>

      </div>

      <!-- サポートカテゴリ（AI動画編集 / AIアバター動画） -->
      <p class="mb-3 mt-6 text-xs font-semibold uppercase tracking-widest text-slate-400">動画制作を支えるカテゴリ</p>
      <div class="mb-4 grid gap-4 sm:grid-cols-2">

        <!-- AI動画編集 -->
        <a href="/categories/video-editing/" class="group flex flex-col rounded-xl border border-indigo-100 bg-indigo-50/40 p-5 shadow-sm transition hover:border-indigo-300 hover:shadow-md">
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-indigo-500" aria-hidden="true">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            <p class="text-sm font-bold text-slate-800 group-hover:text-indigo-700">AI動画編集</p>
          </div>
          <p class="flex-1 text-xs leading-relaxed text-slate-600">AIを使った動画トリミング・字幕追加・カット編集ツールの比較情報。</p>
          <p class="mt-3 text-right text-xs font-semibold text-indigo-600 group-hover:underline">カテゴリを見る →</p>
        </a>

        <!-- AIアバター動画 -->
        <a href="/categories/avatar-video/" class="group flex flex-col rounded-xl border border-indigo-100 bg-indigo-50/40 p-5 shadow-sm transition hover:border-indigo-300 hover:shadow-md">
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-indigo-500" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <p class="text-sm font-bold text-slate-800 group-hover:text-indigo-700">AIアバター動画</p>
          </div>
          <p class="flex-1 text-xs leading-relaxed text-slate-600">AIアバターを使った解説動画・プレゼン動画ツールの比較情報。</p>
          <p class="mt-3 text-right text-xs font-semibold text-indigo-600 group-hover:underline">カテゴリを見る →</p>
        </a>

      </div>

      <!-- 制作補助カテゴリ（2つ） -->
      <p class="mb-3 mt-6 text-xs font-semibold uppercase tracking-widest text-slate-400">制作補助ツール</p>
      <div class="grid gap-3 sm:grid-cols-2">

        <!-- AIデザイン -->
        <div class="flex flex-col rounded-lg border border-slate-100 bg-slate-50 p-4">
          <p class="text-xs font-bold text-slate-600">AIデザイン</p>
          <p class="mt-1 text-[11px] leading-relaxed text-slate-400">バナー・LP・SNS投稿デザイン自動化ツール。比較情報準備中。</p>
          <span class="mt-3 inline-flex w-fit rounded-full bg-slate-200 px-2 py-0.5 text-[9px] font-semibold text-slate-500">準備中</span>
        </div>

        <!-- AI音声・ナレーション -->
        <div class="flex flex-col rounded-lg border border-slate-100 bg-slate-50 p-4">
          <p class="text-xs font-bold text-slate-600">AI音声・ナレーション</p>
          <p class="mt-1 text-[11px] leading-relaxed text-slate-400">テキスト読み上げ・音声クローンツール。比較情報準備中。</p>
          <span class="mt-3 inline-flex w-fit rounded-full bg-slate-200 px-2 py-0.5 text-[9px] font-semibold text-slate-500">準備中</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- 3.5 目的から選ぶ                                              -->
  <!-- ============================================================ -->
  <section id="use-cases" class="scroll-mt-24 bg-white py-14 border-b border-slate-100">
    <div class="mx-auto max-w-5xl px-6">
      <div class="mb-8">
        <div class="mb-4 flex items-center gap-3 text-xs font-medium uppercase tracking-[0.28em] text-slate-500">
          <span class="h-2 w-2 rounded-full bg-blue-600"></span>
          <span>USE CASES</span>
        </div>
        <h2 class="text-3xl font-black tracking-tight text-slate-950 sm:text-4xl">
          目的から選ぶ
        </h2>
        <p class="mt-4 max-w-3xl text-base leading-relaxed text-slate-600">
          制作したいアウトプットから、関連カテゴリの記事に案内します。未作成の用途は順次追加予定です。
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4 sm:grid-cols-2 lg:grid-cols-4">

        <!-- 1. YouTubeサムネイル（リンク） -->
        <a href="/use-cases/youtube-thumbnail/" class="group flex flex-col rounded-xl border border-slate-100 bg-white p-5 shadow-sm transition hover:border-blue-200 hover:shadow-md">
          <div class="mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-500" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
