---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AI画像生成・動画生成ツール比較DB">
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h1 class="text-3xl font-bold text-gray-900">
      AI画像生成・動画生成ツール比較DB
    </h1>
    <p class="mt-4 text-lg text-gray-600">
      AI画像生成・動画生成ツールを比較できるDB型SEOメディア。
    </p>

    <div class="mt-6 rounded-lg border border-yellow-200 bg-yellow-50 px-6 py-4">
      <p class="text-sm font-medium text-yellow-800">現在MVP構築中です。</p>
    </div>

    <nav class="mt-12">
      <h2 class="text-xl font-semibold text-gray-800">カテゴリ</h2>
      <ul class="mt-4 space-y-2 text-blue-600">
        <li><a href="/tools/" class="hover:underline">ツール一覧</a></li>
        <li><a href="/categories/free/" class="hover:underline">無料で使えるAI画像生成ツール</a></li>
        <li><a href="/categories/commercial-use/" class="hover:underline">商用利用OKのAI画像生成ツール</a></li>
        <li><a href="/categories/japanese/" class="hover:underline">日本語対応AI画像生成ツール</a></li>
        <li><a href="/categories/no-watermark/" class="hover:underline">透かしなしAI画像生成ツール</a></li>
      </ul>

      <h2 class="mt-8 text-xl font-semibold text-gray-800">ガイド</h2>
      <ul class="mt-4 space-y-2 text-blue-600">
        <li>
          <a href="/guides/commercial-use-copyright/" class="hover:underline">
            AI画像生成の商用利用・著作権ガイド
          </a>
        </li>
      </ul>
    </nav>
  </section>
</BaseLayout>
