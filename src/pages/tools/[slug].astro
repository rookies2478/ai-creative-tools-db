---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import ToolFAQ from '../../components/ToolFAQ.astro';
import FreshnessLabel from '../../components/FreshnessLabel.astro';
import { generatedImages } from '../../data/generatedImages';
import '../../styles/tool-detail.css';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  const STATIC_OVERRIDES = new Set(['adobe-firefly']);
  return tools
    .filter((entry) => !STATIC_OVERRIDES.has(entry.slug))
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

const sampleImage = generatedImages.find(img => img.pageSlug === entry.slug) ?? null;

const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://aicreative-db.com';
const toolPageUrl = `${siteUrl}/tools/${entry.slug}/`;

const isVideo = data.category === 'video' || data.category === 'both';
const isImage = data.category === 'image' || data.category === 'both';
const categoryUrl = isVideo ? `${siteUrl}/categories/video-generation/` : `${siteUrl}/categories/image-generation/`;
const categoryName = data.category === 'both'
  ? 'AI画像・動画生成ツール一覧'
  : isVideo ? 'AI動画生成ツール一覧' : 'AI画像生成ツール一覧';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'トップ', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: categoryName, item: categoryUrl },
    { '@type': 'ListItem', position: 3, name: data.name, item: toolPageUrl },
  ],
};

const softwareAppJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: data.name,
  operatingSystem: 'Web',
  applicationCategory: isVideo ? 'MultimediaApplication' : 'DesignApplication',
};
if (data.shortDescription) softwareAppJsonLd.description = data.shortDescription;
if (data.officialUrl) softwareAppJsonLd.url = data.officialUrl;

const jsonLd = JSON.stringify([breadcrumbJsonLd, softwareAppJsonLd]);

/* ---- badge helpers ---- */
type CommercialUse = 'ok' | 'paid-only' | 'limited' | 'no' | 'unknown';
type FreePlan = boolean | 'limited' | 'unknown';
type FourState = 'yes' | 'no' | 'limited' | 'unknown';
type TriState = boolean | 'partial' | 'unknown';

function cuInfo(val: CommercialUse): { badge: string; cls: string; dot: string; desc: string } {
  if (val === 'ok')        return { badge: '案内あり', cls: 'ok',   dot: 'ok',   desc: '公式情報では商用利用可能とされています。最新情報は公式サイトをご確認ください。' };
  if (val === 'paid-only') return { badge: '有料向け', cls: 'warn', dot: 'warn', desc: '有料プランで商用利用可能と案内されています。最新情報は公式サイトをご確認ください。' };
  if (val === 'limited')   return { badge: '条件あり', cls: 'warn', dot: 'warn', desc: '用途やプランによって制限がある可能性があります。公式規約をご確認ください。' };
  if (val === 'no')        return { badge: '非推奨',   cls: 'na',   dot: 'na',   desc: '商用利用はできない、または推奨されない可能性があります。最新の公式情報をご確認ください。' };
  return                          { badge: '要確認',   cls: 'warn', dot: 'warn', desc: '公式情報の確認が必要です。利用前に公式サイトをご確認ください。' };
}

function fpInfo(val: FreePlan): { text: string; cls: string } {
  if (val === true)      return { text: '無料枠あり', cls: 'ok' };
  if (val === false)     return { text: '無料枠なし', cls: 'na' };
  if (val === 'limited') return { text: '限定的',     cls: 'warn' };
  return                        { text: '要確認',      cls: 'warn' };
}

function wmInfo(val: FourState): { text: string; cls: string } {
  if (val === 'no')      return { text: '透かしなし', cls: 'ok' };
  if (val === 'yes')     return { text: '透かしあり', cls: 'na' };
  if (val === 'limited') return { text: 'プランによる', cls: 'warn' };
  return                        { text: '要確認',       cls: 'warn' };
}

function triInfo(val: TriState): { text: string; cls: string } {
  if (val === true)      return { text: '○', cls: 'ok' };
  if (val === false)     return { text: '×', cls: 'na' };
  if (val === 'partial') return { text: '△', cls: 'warn' };
  return                        { text: '要確認', cls: 'warn' };
}

function sourceTypeLabel(type: string): string {
  const m: Record<string, string> = {
    official: '公式', pricing: '料金', terms: '規約',
    help: 'ヘルプ', policy: 'ポリシー', commercial: '商用', docs: 'ドキュメント',
  };
  return m[type] ?? type;
}

function catBadgeCls(cat: string): string {
  if (cat === 'image') return 'image';
  if (cat === 'video') return 'video';
  return 'both';
}

function catLabel(cat: string): string {
  if (cat === 'image') return 'AI画像生成';
  if (cat === 'video') return 'AI動画生成';
  return 'AI画像・動画生成';
}

const cu  = cuInfo(data.commercialUse);
const fp  = fpInfo(data.freePlan);
const wm  = wmInfo(data.watermark);
const jui = triInfo(data.japaneseUi);
const jpr = triInfo(data.japanesePrompt);

const platformLabels: Record<string, string> = {
  web: 'Web', discord: 'Discord', ios: 'iOS', android: 'Android',
  desktop: 'デスクトップ', api: 'API', local: 'ローカル',
};

const featureLabels: Record<string, string> = {
  textToImage: 'テキスト→画像', imageToImage: '画像→画像',
  inpainting: '部分修正', outpainting: '画像拡張',
  upscale: '高解像度化', backgroundRemoval: '背景削除',
  stylePresets: 'スタイル選択', promptAssist: 'プロンプト補助',
  textToVideo: 'テキスト→動画', imageToVideo: '画像→動画',
  videoExtend: '動画延長', apiAvailable: 'API対応',
};

const featureOrder = [
  'textToImage','imageToImage','inpainting','outpainting',
  'upscale','backgroundRemoval','stylePresets','promptAssist',
  'textToVideo','imageToVideo','videoExtend','apiAvailable',
] as const;
type FeatureKey = typeof featureOrder[number];
const trueFeatures: string[] = data.features
  ? featureOrder.filter(k => data.features![k as FeatureKey] === true).map(k => featureLabels[k]).slice(0, 8)
  : [];
---

<BaseLayout
  title={`${data.name}の商用利用・料金・無料枠を比較｜AI生成ツールDB`}
  description={`${data.name}の商用利用条件・料金プラン・無料枠・透かし・日本語対応状況をまとめています。最新情報は公式サイトをご確認ください。`}
  canonicalPath={`/tools/${entry.slug}/`}
  ogType="article"
  jsonLd={jsonLd}
>

  <!-- ===== HERO ===== -->
  <section class="td-head">
    <div class="wrap">

      <!-- パンくず -->
      <nav class="td-breadcrumb" aria-label="パンくずリスト">
        <a href="/">トップ</a>
        <span class="sep">/</span>
        <a href="/tools/">ツール一覧</a>
        <span class="sep">/</span>
        <span class="cur">{data.name}</span>
      </nav>

      <!-- eyebrow row -->
      <div class="td-eyebrow-row">
        <span class="eyebrow">TOOL DETAIL</span>
        <span class={`td-cat-badge ${catBadgeCls(data.category)}`}>{catLabel(data.category)}</span>
        <FreshnessLabel verifiedAt={data.verifiedAt} lastReviewed={data.lastReviewed} variant="detail" />
      </div>

      <!-- H1 -->
      <h1>{data.name}<span class="hl">の<span class="phrase-nowrap">商用利用</span>・料金・無料枠まとめ</span></h1>

      <!-- lead -->
      <p class="td-lead">
        {data.shortDescription
          ? data.shortDescription
          : `${data.name}の料金・商用利用・日本語対応・透かしの有無など、実務利用前に確認すべきポイントをまとめています。`}
      </p>

      <!-- stat chips -->
      <div class="td-hero-stats">
        <div class="td-hstat">
          <span class="ck">商用利用</span>
          <span class={`cv ${cu.dot}`}>{cu.badge}</span>
        </div>
        <div class="td-hstat">
          <span class="ck">無料枠</span>
          <span class={`cv ${fp.cls}`}>{fp.text}</span>
        </div>
        <div class="td-hstat">
          <span class="ck">料金目安</span>
          <span class="cv">{data.lowestPaidPlan ?? '要確認'}</span>
        </div>
        <div class="td-hstat">
          <span class="ck">透かし</span>
          <span class={`cv ${wm.cls}`}>{wm.text}</span>
        </div>
        <div class="td-hstat">
          <span class="ck">日本語UI</span>
          <span class={`cv ${jui.cls}`}>{jui.text}</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="td-hero-cta">
        {data.officialUrl && (
          <a
            href={data.officialUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
          >
            公式サイトで確認する <span class="arr">↗</span>
          </a>
        )}
        {data.officialSourceUrl && data.officialSourceUrl !== data.officialUrl && (
          <a
            href={data.officialSourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-ghost"
          >
            公式情報ページ <span class="arr">↗</span>
          </a>
        )}
      </div>

    </div>
  </section>

  <!-- ===== BODY ===== -->
  <div class="td-body">

    <!-- 注意バナー -->
    <div class="td-notice">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/>
      </svg>
      <p>
        <b>ご注意：</b>料金・無料枠・商用利用条件・透かしの有無は変更される場合があります。最新情報は必ず公式サイトをご確認ください。本記事は法的助言ではありません。
      </p>
    </div>

    <!-- ===== 基本情報グリッド ===== -->
    <section class="td-section" aria-label="基本情報">
      <h2 class="td-section-h">基本情報</h2>
      <div class="td-info-grid">

        <!-- 商用利用（wide） -->
        <div class="td-info-card wide">
          <p class="ic-label">商用利用</p>
          <div class="ic-val">
            <span class={`td-badge ${cu.cls}`}>{cu.badge}</span>
          </div>
          <p class="ic-note">{cu.desc}</p>
          {data.commercialUseNote && <p class="ic-note">{data.commercialUseNote}</p>}
        </div>

        <!-- 無料枠 -->
        <div class="td-info-card">
          <p class="ic-label">無料枠</p>
          <div class="ic-val">
            <span class={`td-badge ${fp.cls}`}>{fp.text}</span>
          </div>
          {data.freePlanNote && <p class="ic-note">{data.freePlanNote}</p>}
        </div>

        <!-- 料金 -->
        <div class="td-info-card">
          <p class="ic-label">最安料金目安</p>
          <p class="ic-val">{data.lowestPaidPlan ?? '要確認'}</p>
          {data.paidPlanNote && <p class="ic-note">{data.paidPlanNote}</p>}
        </div>

        <!-- 透かし -->
        <div class="td-info-card">
          <p class="ic-label">透かし</p>
          <div class="ic-val">
            <span class={`td-badge ${wm.cls}`}>{wm.text}</span>
          </div>
          {data.watermarkCondition && <p class="ic-note">{data.watermarkCondition}</p>}
        </div>

        <!-- 日本語対応 -->
        <div class="td-info-card">
          <p class="ic-label">日本語対応</p>
          <div style="display:flex;flex-direction:column;gap:5px;margin-top:4px;">
            <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--ink-soft);">
              <span style="color:var(--muted);font-size:12px;">UI：</span>
              <span class={`td-badge ${jui.cls}`}>{jui.text}</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--ink-soft);">
              <span style="color:var(--muted);font-size:12px;">プロンプト：</span>
              <span class={`td-badge ${jpr.cls}`}>{jpr.text}</span>
            </div>
          </div>
        </div>

        <!-- 対応プラットフォーム -->
        {data.platforms && data.platforms.length > 0 && (
          <div class="td-info-card">
            <p class="ic-label">対応環境</p>
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;">
              {data.platforms.map((p: string) => (
                <span style="font-family:var(--f-mono);font-size:12px;background:var(--surface-2);border:1px solid var(--line);border-radius:7px;padding:3px 9px;color:var(--muted);">
                  {platformLabels[p] ?? p}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- 主な機能 -->
        {trueFeatures.length > 0 && (
          <div class="td-info-card wide">
            <p class="ic-label">主な機能</p>
            <div style="display:flex;flex-wrap:wrap;gap:7px;margin-top:6px;">
              {trueFeatures.map((label: string) => (
                <span class="td-badge info">{label}</span>
              ))}
              {data.features?.maxResolution && (
                <span class="td-badge info">最大解像度: {data.features.maxResolution}</span>
              )}
              {data.features?.maxVideoDuration && (
                <span class="td-badge info">最大動画尺: {data.features.maxVideoDuration}</span>
              )}
            </div>
          </div>
        )}

      </div>
    </section>

    <!-- ===== 向いている用途 ===== -->
    {data.bestFor && data.bestFor.length > 0 && (
      <section class="td-section" aria-label="向いている用途">
        <h2 class="td-section-h">向いている用途</h2>
        <div class="td-bestfor-tags">
          {data.bestFor.map((item: string) => (
            <span class="td-bestfor-tag">{item}</span>
          ))}
        </div>
      </section>
    )}

    <!-- ===== 強み・注意点 ===== -->
    {(data.strengths?.length > 0 || data.weaknesses?.length > 0 || data.limitations?.length > 0) && (
      <section class="td-section" aria-label="強み・注意点">
        <h2 class="td-section-h">強み・注意点</h2>
        <div class="td-points-grid">
          {data.strengths && data.strengths.length > 0 && (
            <div class="td-point-card ok">
              <div class="pc-head">
                <span class="bdg">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" width="14" height="14" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                強み
              </div>
              <ul>
                {data.strengths.map((item: string) => (
                  <li><span class="m">○</span><span>{item}</span></li>
                ))}
              </ul>
            </div>
          )}
          {data.weaknesses && data.weaknesses.length > 0 && (
            <div class="td-point-card na">
              <div class="pc-head">
                <span class="bdg">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" width="14" height="14" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </span>
                弱み
              </div>
              <ul>
                {data.weaknesses.map((item: string) => (
                  <li><span class="m">×</span><span>{item}</span></li>
                ))}
              </ul>
            </div>
          )}
          {data.limitations && data.limitations.length > 0 && (
            <div class="td-point-card warn" style="grid-column: 1 / -1;">
              <div class="pc-head">
                <span class="bdg">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" width="14" height="14" aria-hidden="true"><path d="M12 9v4m0 4h.01M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
                </span>
                制限・注意点
              </div>
              <ul>
                {data.limitations.map((item: string) => (
                  <li><span class="m">!</span><span>{item}</span></li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- ===== 比較ポイント早見表 ===== -->
    <section class="td-section" aria-label="比較ポイント早見表">
      <h2 class="td-section-h">比較ポイント早見表</h2>
      <div class="td-table-wrap">
        <table>
          <tbody>
            <tr>
              <th>ツール名</th>
              <td style="font-weight:700;color:var(--ink);">{data.name}</td>
            </tr>
            <tr>
              <th>カテゴリ</th>
              <td>{catLabel(data.category)}</td>
            </tr>
            <tr>
              <th>無料枠</th>
              <td>
                <span class={`td-badge ${fp.cls}`}>{fp.text}</span>
                {data.freePlanNote && <p style="margin-top:6px;font-size:12px;color:var(--muted);">{data.freePlanNote}</p>}
              </td>
            </tr>
            <tr>
              <th>最安料金</th>
              <td>
                {data.lowestPaidPlan ?? '要確認'}
                {data.paidPlanNote && <p style="margin-top:6px;font-size:12px;color:var(--muted);">{data.paidPlanNote}</p>}
              </td>
            </tr>
            <tr>
              <th>商用利用</th>
              <td>
                <span class={`td-badge ${cu.cls}`}>{cu.badge}</span>
                <p style="margin-top:6px;font-size:12px;color:var(--muted);">{cu.desc}</p>
                {data.commercialUseNote && <p style="margin-top:4px;font-size:12px;color:var(--muted);">{data.commercialUseNote}</p>}
              </td>
            </tr>
            <tr>
              <th>透かし</th>
              <td>
                <span class={`td-badge ${wm.cls}`}>{wm.text}</span>
                {data.watermarkCondition && <p style="margin-top:6px;font-size:12px;color:var(--muted);">{data.watermarkCondition}</p>}
              </td>
            </tr>
            <tr>
              <th>日本語UI</th>
              <td><span class={`td-badge ${jui.cls}`}>{jui.text}</span></td>
            </tr>
            <tr>
              <th>日本語プロンプト</th>
              <td><span class={`td-badge ${jpr.cls}`}>{jpr.text}</span></td>
            </tr>
            {data.platforms && data.platforms.length > 0 && (
              <tr>
                <th>対応環境</th>
                <td>
                  <div style="display:flex;flex-wrap:wrap;gap:6px;">
                    {data.platforms.map((p: string) => (
                      <span style="font-family:var(--f-mono);font-size:12px;background:var(--brand-tint);color:var(--brand-ink);border-radius:7px;padding:3px 9px;">{platformLabels[p] ?? p}</span>
                    ))}
                  </div>
                </td>
              </tr>
            )}
            <tr>
              <th>情報確認日</th>
              <td style="font-family:var(--f-mono);font-size:12.5px;">{data.lastReviewed ?? '—'}</td>
            </tr>
            {data.nextReviewDue && (
              <tr>
                <th>次回確認予定</th>
                <td style="font-family:var(--f-mono);font-size:12.5px;">{data.nextReviewDue}</td>
              </tr>
            )}
            <tr>
              <th>公式サイト</th>
              <td>
                <a href={data.officialUrl} target="_blank" rel="noopener noreferrer"
                  style="color:var(--brand-ink);font-weight:600;font-size:13px;">
                  公式サイトで確認 ↗
                </a>
              </td>
            </tr>
          </tbody>
        </table>
        <p style="padding:10px 18px 12px;font-size:11px;color:var(--faint);line-height:1.7;">
          ※ 値は確認日時点の参考値です。プランや用途により異なる場合があります。最新情報は必ず公式サイトでご確認ください。
        </p>
      </div>
    </section>

    <!-- ===== Markdown本文 ===== -->
    <section class="td-section" aria-label="詳細説明">
      <div class="td-prose">
        <Content />
      </div>
    </section>

    <!-- ===== 公式情報・鮮度 ===== -->
    <section class="td-section" aria-label="情報の鮮度・参照元">
      <h2 class="td-section-h">情報の鮮度・参照元</h2>
      <div class="td-freshness">
        <dl class="fr-row">
          <div style="display:flex;gap:6px;">
            <dt>最終確認日：</dt>
            <dd>{data.lastReviewed ?? '—'}</dd>
          </div>
          {data.nextReviewDue && (
            <div style="display:flex;gap:6px;">
              <dt>次回確認予定：</dt>
              <dd>{data.nextReviewDue}</dd>
            </div>
          )}
          {data.verifiedAt && (
            <div style="display:flex;gap:6px;">
              <dt>情報検証日：</dt>
              <dd>{data.verifiedAt}</dd>
            </div>
          )}
        </dl>

        {/* sourceRefs優先、なければsources */}
        {data.sourceRefs && data.sourceRefs.length > 0 ? (
          <div class="fr-sources">
            <p class="fr-sources-title">参照元</p>
            <div class="fr-source-list">
              {data.sourceRefs.map((ref: {type:string;url:string;label:string}) => (
                <a href={ref.url} target="_blank" rel="noopener noreferrer" class="fr-source">
                  <span class="fr-type">{sourceTypeLabel(ref.type)}</span>
                  {ref.label}
                </a>
              ))}
            </div>
          </div>
        ) : data.sources && data.sources.length > 0 ? (
          <div class="fr-sources">
            <p class="fr-sources-title">参照元</p>
            <div class="fr-source-list">
              {data.sources.map((src: {url:string;title:string}) => (
                <a href={src.url} target="_blank" rel="noopener noreferrer" class="fr-source">
                  {src.title}
                </a>
              ))}
            </div>
          </div>
        ) : null}

        <p class="fr-disclaimer">
