---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticeBox from '../../components/NoticeBox.astro';
import ToolSummaryTable from '../../components/ToolSummaryTable.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import ToolFAQ from '../../components/ToolFAQ.astro';
import ToolSummaryCards from '../../components/ToolSummaryCards.astro';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

const leadText = `${data.name}の料金・商用利用・日本語対応・透かしの有無など、実務利用前に確認すべきポイントをまとめています。`;

function commercialUseDesc(val: string): string {
  if (val === 'ok')        return '公式情報では商用利用可能とされています。最新情報は公式サイトをご確認ください。';
  if (val === 'paid-only') return '有料プランで商用利用可能と案内されています。最新情報は公式サイトをご確認ください。';
  if (val === 'limited')   return '用途やプランによって制限がある可能性があります。公式規約をご確認ください。';
  if (val === 'no')        return '商用利用はできない、または推奨されない可能性があります。最新の公式情報をご確認ください。';
  return '公式情報の確認が必要です。利用前に公式サイトをご確認ください。';
}

function commercialUseLabel(val: string): string {
  if (val === 'ok')        return '商用利用：公式情報で可能';
  if (val === 'paid-only') return '商用利用：有料プラン向け';
  if (val === 'limited')   return '商用利用：条件あり';
  if (val === 'no')        return '商用利用：不可または非推奨';
  return '商用利用：要確認';
}

function commercialUseBadgeCls(val: string): string {
  if (val === 'ok')        return 'bg-emerald-100 text-emerald-800';
  if (val === 'paid-only') return 'bg-sky-100 text-sky-800';
  if (val === 'limited')   return 'bg-amber-100 text-amber-800';
  if (val === 'no')        return 'bg-red-100 text-red-800';
  return 'bg-slate-100 text-slate-600';
}

function sourceTypeLabel(type: string) {
  const labels: Record<string, string> = {
    official: '公式サイト',
    pricing: '料金',
    terms: '利用規約',
    help: 'ヘルプ',
    policy: 'ポリシー',
    commercial: '商用利用',
    docs: 'ドキュメント',
  };
  return labels[type] ?? type;
}
---

<BaseLayout
  title={`${data.name}の商用利用・料金・無料枠を比較｜AI生成ツールDB`}
  description={`${data.name}の商用利用条件・料金プラン・無料枠・透かし・日本語対応状況をまとめています。最新情報は公式サイトをご確認ください。`}
  canonicalPath={`/tools/${entry.slug}/`}
  ogType="article"
>
  <article class="mx-auto max-w-3xl px-6 py-12">

    <!-- パンくず -->
    <nav class="mb-6 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>{data.name}</span>
    </nav>

    <!-- H1 -->
    <h1 class="mb-3 text-3xl font-bold text-slate-900">{data.name}の商用利用・料金・無料枠まとめ</h1>

    <!-- リード文 -->
    <p class="mb-6 text-sm leading-relaxed text-slate-600">{leadText}</p>

    <!-- 結論サマリーカード -->
    <ToolSummaryCards data={data} />

    <!-- NoticeBox -->
    <div class="mb-6">
      <NoticeBox />
    </div>

    <!-- 信頼性表示ボックス -->
    <div class="mb-6 rounded-lg border border-slate-200 bg-slate-50 px-5 py-4 text-xs text-slate-600">
      <dl class="flex flex-wrap gap-x-6 gap-y-1.5">
        <div class="flex items-baseline gap-1.5">
          <dt class="font-semibold text-slate-700 shrink-0">最終確認日：</dt>
          <dd>{data.lastReviewed ?? '—'}</dd>
        </div>
        {data.nextReviewDue && (
          <div class="flex items-baseline gap-1.5">
            <dt class="font-semibold text-slate-700 shrink-0">次回確認予定：</dt>
            <dd>{data.nextReviewDue}</dd>
          </div>
        )}
      </dl>

      {/* sourceRefs優先、なければsources */}
      {data.sourceRefs && data.sourceRefs.length > 0 ? (
        <div class="mt-2.5">
          <p class="mb-1 font-semibold text-slate-700">参照元：</p>
          <ul class="flex flex-wrap gap-x-3 gap-y-1">
            {data.sourceRefs.map((ref) => (
              <li>
                <a
                  href={ref.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-blue-600 hover:underline"
                >
                  <span class="rounded bg-slate-200 px-1.5 py-0.5 text-[10px] text-slate-500">{sourceTypeLabel(ref.type)}</span>
                  {ref.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ) : data.sources && data.sources.length > 0 ? (
        <div class="mt-2.5">
          <p class="mb-1 font-semibold text-slate-700">参照元：</p>
          <ul class="flex flex-wrap gap-x-3 gap-y-1">
            {data.sources.map((src) => (
              <li>
                <a
                  href={src.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-blue-600 hover:underline"
                >
                  {src.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ) : null}

      <p class="mt-3 leading-relaxed text-slate-500">
        本ページの情報は、各ツールの公式サイト・料金ページ・利用規約等をもとに整理したものです。掲載内容は確認時点の情報であり、最新情報や具体的な利用可否は必ず各公式サイトでご確認ください。本記事は法的助言ではありません。
      </p>
    </div>

    <!-- このツールの要点 -->
    <section class="mb-8 rounded-xl border border-blue-100 bg-blue-50 px-6 py-5">
      <h2 class="mb-4 text-base font-bold text-[#002B61]">このツールの要点</h2>

      <dl class="space-y-4 text-sm">
        <!-- 概要 -->
        <div>
          <dt class="mb-0.5 font-semibold text-slate-700">概要</dt>
          <dd class="leading-relaxed text-slate-600">{leadText}</dd>
        </div>

        <!-- 向いている用途 -->
        {data.bestFor && data.bestFor.length > 0 && (
          <div>
            <dt class="mb-1.5 font-semibold text-slate-700">向いている用途</dt>
            <dd class="flex flex-wrap gap-2">
              {data.bestFor.map((item: string) => (
                <span class="inline-flex rounded-full border border-blue-200 bg-white px-3 py-0.5 text-xs font-medium text-blue-700">
                  {item}
                </span>
              ))}
            </dd>
          </div>
        )}

        <!-- 強み -->
        {data.strengths && data.strengths.length > 0 && (
          <div>
            <dt class="mb-1 font-semibold text-slate-700">強み</dt>
            <dd>
              <ul class="space-y-1">
                {data.strengths.slice(0, 3).map((item: string) => (
                  <li class="flex items-start gap-1.5 text-green-900">
                    <span class="mt-0.5 shrink-0 text-green-600">○</span>{item}
                  </li>
                ))}
              </ul>
            </dd>
          </div>
        )}

        <!-- 注意点 -->
        {data.weaknesses && data.weaknesses.length > 0 && (
          <div>
            <dt class="mb-1 font-semibold text-slate-700">注意点</dt>
            <dd>
              <ul class="space-y-1">
                {data.weaknesses.slice(0, 3).map((item: string) => (
                  <li class="flex items-start gap-1.5 text-red-900">
                    <span class="mt-0.5 shrink-0 text-red-500">×</span>{item}
                  </li>
                ))}
              </ul>
            </dd>
          </div>
        )}

        <!-- 商用利用 -->
        <div>
          <dt class="mb-1 font-semibold text-slate-700">商用利用</dt>
          <dd>
            <span class={`inline-block rounded px-2 py-0.5 text-xs font-medium ${commercialUseBadgeCls(data.commercialUse)}`}>
              {commercialUseLabel(data.commercialUse)}
            </span>
            <p class="mt-1 text-sm leading-relaxed text-slate-600">{commercialUseDesc(data.commercialUse)}</p>
            {data.commercialUseNote && (
              <p class="mt-1 text-sm leading-relaxed text-slate-500">{data.commercialUseNote}</p>
            )}
          </dd>
        </div>
      </dl>

      <!-- 公式サイト確認導線 -->
      <div class="mt-5 border-t border-blue-100 pt-4">
        <p class="mb-2 text-xs text-slate-600">最新の料金・商用利用条件は公式サイトで確認してください。</p>
        <a
          href={data.officialUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-md bg-blue-600 px-4 py-2 text-xs font-semibold text-white hover:bg-blue-700 transition-colors"
        >
          公式サイトで確認する
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </section>

    <!-- ToolSummaryTable -->
    <ToolSummaryTable tool={entry} />

    <!-- 強み・弱み -->
    <section class="mb-8 grid gap-4 sm:grid-cols-2">
      <div class="rounded-lg border border-green-100 bg-green-50 p-4">
        <h2 class="mb-2 text-sm font-semibold text-green-800">強み</h2>
        <ul class="space-y-1">
          {data.strengths.map((item) => (
            <li class="flex items-start gap-1.5 text-sm text-green-900">
              <span>○</span>{item}
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-lg border border-red-100 bg-red-50 p-4">
        <h2 class="mb-2 text-sm font-semibold text-red-800">弱み</h2>
        <ul class="space-y-1">
          {data.weaknesses.map((item) => (
            <li class="flex items-start gap-1.5 text-sm text-red-900">
              <span>×</span>{item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 制限・注意点 -->
    {data.limitations && data.limitations.length > 0 && (
      <section class="mb-8 rounded-lg border border-orange-100 bg-orange-50 p-4">
        <h2 class="mb-2 text-sm font-semibold text-orange-800">制限・注意点</h2>
        <ul class="space-y-1">
          {data.limitations.map((item) => (
            <li class="flex items-start gap-1.5 text-sm text-orange-900">
              <span class="shrink-0 font-bold">!</span>{item}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Markdown本文 -->
    <div class="prose prose-slate mb-10 max-w-none text-sm leading-relaxed">
      <Content />
    </div>

    <!-- FAQ -->
    <ToolFAQ faqs={data.faqs} />

    <!-- 情報鮮度・免責 -->
    <section class="mb-8 rounded-lg border border-yellow-200 bg-yellow-50 px-5 py-4 text-sm text-yellow-800">
      {data.reviewed ? (
        <div>
          <p class="font-semibold">情報の確認日：</p>
          <ul class="mt-1 space-y-0.5 text-xs">
            {data.reviewed.pricing && <li>料金：{data.reviewed.pricing}</li>}
            {data.reviewed.terms && <li>利用規約：{data.reviewed.terms}</li>}
            {data.reviewed.features && <li>機能：{data.reviewed.features}</li>}
          </ul>
          <p class="mt-1 text-xs text-yellow-700">次回確認予定：{data.nextReviewDue}</p>
        </div>
      ) : (
        <p>
          <strong>情報の鮮度：</strong>最終確認日 {data.lastReviewed}（次回確認予定 {data.nextReviewDue}）
        </p>
      )}
      <p class="mt-1">
        料金・利用規約は予告なく変更されます。商用利用の可否は必ず公式サイトの最新規約でご確認ください。
      </p>
    </section>

    <!-- 免責文（商用利用・著作権） -->
    <div class="mb-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-xs text-slate-600">
      商用利用・著作権に関する内容は、公式情報をもとにした一般的な整理です。法的助言ではありません。実務利用前には必ず各ツールの公式規約・ライセンスをご確認ください。
    </div>

    <!-- 参照元（sourceRefsがある場合は優先表示） -->
    {data.sourceRefs && data.sourceRefs.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm font-semibold text-slate-600">参照元</h2>
        <ul class="space-y-1.5">
          {data.sourceRefs.map((ref) => (
            <li class="flex items-baseline gap-2 text-sm">
              <span class="shrink-0 rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-500">{sourceTypeLabel(ref.type)}</span>
              <a
                href={ref.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:underline"
              >
                {ref.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- 参照元（sourceRefsがない場合の既存sources） -->
    {(!data.sourceRefs || data.sourceRefs.length === 0) && data.sources.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm font-semibold text-slate-600">参照元</h2>
        <ul class="space-y-1">
          {data.sources.map((src) => (
            <li class="text-sm">
              <a
                href={src.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:underline"
              >
                {src.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- 関連ツール -->
    <RelatedTools currentSlug={entry.slug} category={data.category} />

    <!-- 次に読む -->
    <section class="mb-8">
      <h2 class="mb-4 text-base font-bold text-slate-800">次に読む</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {(data.category === 'video' || data.category === 'both') ? (
          <>
            <a href="/video-generators/" class="flex flex-col gap-1 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <span class="text-sm font-semibold text-blue-700">AI動画生成ツール一覧を見る →</span>
              <span class="text-xs leading-relaxed text-slate-600">主要なAI動画生成ツールを無料プラン・商用利用条件などで比較できます。</span>
            </a>
            <a href="/categories/free-video/" class="flex flex-col gap-1 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <span class="text-sm font-semibold text-blue-700">無料で使えるAI動画生成ツールを見る →</span>
              <span class="text-xs leading-relaxed text-slate-600">無料枠・透かし・商用利用条件をまとめて比較できます。</span>
            </a>
            <a href="/compare/runway-vs-pika/" class="flex flex-col gap-1 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <span class="text-sm font-semibold text-blue-700">RunwayとPikaを比較する →</span>
              <span class="text-xs leading-relaxed text-slate-600">主要AI動画生成ツールの料金・商用利用条件を詳しく比較しています。</span>
            </a>
          </>
        ) : (
          <>
            <a href="/tools/" class="flex flex-col gap-1 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <span class="text-sm font-semibold text-blue-700">AI画像生成ツール一覧を見る →</span>
              <span class="text-xs leading-relaxed text-slate-600">主要なAI画像・動画生成ツールを一覧で確認できます。</span>
            </a>
            <a href="/categories/free/" class="flex flex-col gap-1 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 hover:border-blue-300 hover:bg-blue-50 transition-colors">
              <span class="text-sm font-semibold text-blue-700">無料で使えるAI画像生成ツールを見る →</span>
              <span class="text-xs leading-relaxed text-slate-600">無料枠のあるAI画像生成ツールを確認できます。</span>
            </a>
          </>
        )}
        <a href="/compare/" class="flex flex-col gap-1 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 hover:border-blue-300 hover:bg-blue-50 transition-colors">
          <span class="text-sm font-semibold text-blue-700">比較表でまとめて比較する →</span>
          <span class="text-xs leading-relaxed text-slate-600">商用利用・無料枠・透かし・日本語対応を横断比較できます。</span>
        </a>
        <a href="/guides/commercial-use-copyright/" class="flex flex-col gap-1 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 hover:border-blue-300 hover:bg-blue-50 transition-colors">
          <span class="text-sm font-semibold text-blue-700">商用利用・著作権ガイドを見る →</span>
          <span class="text-xs leading-relaxed text-slate-600">商用利用や著作権まわりの確認ポイントを整理しています。</span>
        </a>
      </div>
    </section>

    <!-- その他のカテゴリリンク -->
    <section class="mb-8">
      <h2 class="mb-4 text-sm font-semibold text-slate-600">カテゴリで探す</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/tools/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100">ツール一覧</a></li>
        {(data.category === 'video' || data.category === 'both') && (
          <>
            <li><a href="/video-generators/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100">AI動画生成ツール一覧</a></li>
            <li><a href="/categories/free-video/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100">無料で使えるAI動画生成ツール</a></li>
          </>
        )}
        <li><a href="/categories/free/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100">無料で使えるツール</a></li>
        <li><a href="/categories/commercial-use/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100">商用利用を確認しやすいツール</a></li>
        <li><a href="/categories/japanese/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100">日本語対応ツール</a></li>
        <li><a href="/categories/no-watermark/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100">透かしなしツール</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-slate-300 px-4 py-1.5 hover:bg-slate-100">商用利用・著作権ガイド</a></li>
      </ul>
    </section>

    <!-- ナビ -->
    <nav class="border-t border-slate-200 pt-6">
      <div class="flex flex-wrap gap-3">
        <a href="/tools/" class="rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">← ツール一覧に戻る</a>
        <a href="/compare/" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700">比較表で見る</a>
      </div>
    </nav>

  </article>
</BaseLayout>
