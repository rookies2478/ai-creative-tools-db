<script>
(function () {
  /* FAQ accordion */
  document.querySelectorAll<HTMLElement>('.td-faq-item').forEach((item) => {
    const q = item.querySelector<HTMLButtonElement>('.td-faq-q');
    const a = item.querySelector<HTMLElement>('.td-faq-a');
    if (!q || !a) return;
    q.addEventListener('click', () => {
      const open = item.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll<HTMLElement>('.td-faq-item').forEach((other) => {
        other.setAttribute('aria-expanded', 'false');
        const oa = other.querySelector<HTMLElement>('.td-faq-a');
        if (oa) oa.style.maxHeight = '';
      });
      if (!open) {
        item.setAttribute('aria-expanded', 'true');
        a.style.maxHeight = a.scrollHeight + 'px';
      }
    });
  });
})();
</script>
