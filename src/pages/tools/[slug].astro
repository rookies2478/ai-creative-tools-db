---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticeBox from '../../components/NoticeBox.astro';
import ToolSummaryTable from '../../components/ToolSummaryTable.astro';
import RelatedTools from '../../components/RelatedTools.astro';
import ToolFAQ from '../../components/ToolFAQ.astro';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

const leadText = `${data.name}の料金・商用利用・日本語対応・透かしの有無など、実務利用前に確認すべきポイントをまとめています。`;

function sourceTypeLabel(type: string) {
  const labels: Record<string, string> = {
    official: '公式サイト',
    pricing: '料金',
    terms: '利用規約',
    help: 'ヘルプ',
    policy: 'ポリシー',
    commercial: '商用利用',
    docs: 'ドキュメント',
  };
  return labels[type] ?? type;
}
---

<BaseLayout
  title={`${data.name}の料金・無料枠・商用利用・透かし・日本語対応まとめ | AIクリエイティブツール比較DB`}
  description={`${data.name}の料金プラン・無料枠・商用利用の可否・透かしの有無・日本語対応状況をまとめています。実務利用前の確認にご活用ください。`}
  canonicalPath={`/tools/${entry.slug}/`}
  ogType="article"
>
  <article class="mx-auto max-w-3xl px-6 py-12">

    <!-- パンくず -->
    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1">/</span>
      <a href="/tools/" class="hover:underline">ツール一覧</a>
      <span class="mx-1">/</span>
      <span>{data.name}</span>
    </nav>

    <!-- H1 -->
    <h1 class="mb-3 text-3xl font-bold text-gray-900">{data.name}</h1>

    <!-- リード文 -->
    <p class="mb-6 text-sm leading-relaxed text-gray-600">{leadText}</p>

    <!-- NoticeBox -->
    <div class="mb-6">
      <NoticeBox />
    </div>

    <!-- ToolSummaryTable -->
    <ToolSummaryTable tool={entry} />

    <!-- 強み・弱み -->
    <section class="mb-8 grid gap-4 sm:grid-cols-2">
      <div class="rounded-lg border border-green-100 bg-green-50 p-4">
        <h2 class="mb-2 text-sm font-semibold text-green-800">強み</h2>
        <ul class="space-y-1">
          {data.strengths.map((item) => (
            <li class="flex items-start gap-1.5 text-sm text-green-900">
              <span>○</span>{item}
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-lg border border-red-100 bg-red-50 p-4">
        <h2 class="mb-2 text-sm font-semibold text-red-800">弱み</h2>
        <ul class="space-y-1">
          {data.weaknesses.map((item) => (
            <li class="flex items-start gap-1.5 text-sm text-red-900">
              <span>×</span>{item}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 制限・注意点 -->
    {data.limitations && data.limitations.length > 0 && (
      <section class="mb-8 rounded-lg border border-orange-100 bg-orange-50 p-4">
        <h2 class="mb-2 text-sm font-semibold text-orange-800">制限・注意点</h2>
        <ul class="space-y-1">
          {data.limitations.map((item) => (
            <li class="flex items-start gap-1.5 text-sm text-orange-900">
              <span class="shrink-0 font-bold">!</span>{item}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Markdown本文 -->
    <div class="prose prose-gray mb-10 max-w-none text-sm leading-relaxed">
      <Content />
    </div>

    <!-- FAQ -->
    <ToolFAQ faqs={data.faqs} />

    <!-- 情報鮮度・免責 -->
    <section class="mb-8 rounded-lg border border-yellow-200 bg-yellow-50 px-5 py-4 text-sm text-yellow-800">
      {data.reviewed ? (
        <div>
          <p class="font-semibold">情報の確認日：</p>
          <ul class="mt-1 space-y-0.5 text-xs">
            {data.reviewed.pricing && <li>料金：{data.reviewed.pricing}</li>}
            {data.reviewed.terms && <li>利用規約：{data.reviewed.terms}</li>}
            {data.reviewed.features && <li>機能：{data.reviewed.features}</li>}
          </ul>
          <p class="mt-1 text-xs text-yellow-700">次回確認予定：{data.nextReviewDue}</p>
        </div>
      ) : (
        <p>
          <strong>情報の鮮度：</strong>最終確認日 {data.lastReviewed}（次回確認予定 {data.nextReviewDue}）
        </p>
      )}
      <p class="mt-1">
        料金・利用規約は予告なく変更されます。商用利用の可否は必ず公式サイトの最新規約でご確認ください。
      </p>
    </section>

    <!-- 免責文（商用利用・著作権） -->
    <div class="mb-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-xs text-slate-600">
      商用利用・著作権に関する内容は、公式情報をもとにした一般的な整理です。法的助言ではありません。実務利用前には必ず各ツールの公式規約・ライセンスをご確認ください。
    </div>

    <!-- 参照元（sourceRefsがある場合は優先表示） -->
    {data.sourceRefs && data.sourceRefs.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm font-semibold text-gray-600">参照元</h2>
        <ul class="space-y-1.5">
          {data.sourceRefs.map((ref) => (
            <li class="flex items-baseline gap-2 text-sm">
              <span class="shrink-0 rounded bg-gray-100 px-1.5 py-0.5 text-xs text-gray-500">{sourceTypeLabel(ref.type)}</span>
              <a
                href={ref.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:underline"
              >
                {ref.label}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- 参照元（sourceRefsがない場合の既存sources） -->
    {(!data.sourceRefs || data.sourceRefs.length === 0) && data.sources.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-2 text-sm font-semibold text-gray-600">参照元</h2>
        <ul class="space-y-1">
          {data.sources.map((src) => (
            <li class="text-sm">
              <a
                href={src.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-600 hover:underline"
              >
                {src.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- 関連ツール -->
    <RelatedTools currentSlug={entry.slug} category={data.category} />

    <!-- 内部リンク -->
    <section class="mb-8 rounded-lg border border-blue-100 bg-blue-50 p-5">
      <h2 class="mb-3 text-sm font-semibold text-blue-800">関連ページ</h2>
      <ul class="space-y-2 text-sm">
        <li>
          <a href="/compare/" class="font-medium text-blue-700 hover:underline">
            全ツール比較表を見る →
          </a>
        </li>
        <li>
          <a href="/guides/commercial-use-copyright/" class="font-medium text-blue-700 hover:underline">
            商用利用・著作権ガイド →
          </a>
        </li>
        <li>
          <a href="/categories/free/" class="font-medium text-blue-700 hover:underline">
            無料で使えるAIツール →
          </a>
        </li>
      </ul>
    </section>

    <!-- その他のカテゴリリンク -->
    <section class="mb-8">
      <h2 class="mb-4 text-sm font-semibold text-gray-600">カテゴリで探す</h2>
      <ul class="flex flex-wrap gap-3 text-sm">
        <li><a href="/tools/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">ツール一覧</a></li>
        <li><a href="/categories/free/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">無料で使えるツール</a></li>
        <li><a href="/categories/commercial-use/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用を確認しやすいツール</a></li>
        <li><a href="/categories/japanese/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">日本語対応ツール</a></li>
        <li><a href="/categories/no-watermark/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">透かしなしツール</a></li>
        <li><a href="/guides/commercial-use-copyright/" class="rounded-full border border-gray-300 px-4 py-1.5 hover:bg-gray-100">商用利用・著作権ガイド</a></li>
      </ul>
    </section>

    <!-- ナビ -->
    <nav class="border-t border-gray-200 pt-6">
      <div class="flex flex-wrap gap-3">
        <a href="/tools/" class="rounded-lg border border-slate-200 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">← ツール一覧に戻る</a>
        <a href="/compare/" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700">比較表で見る</a>
      </div>
    </nav>

  </article>
</BaseLayout>
