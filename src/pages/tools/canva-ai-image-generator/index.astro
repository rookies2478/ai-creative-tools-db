---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'canva-ai-image-generator');
const d = entry?.data;
const toolSlug = 'canva-ai-image-generator';
const sampleImage = generatedImages.find((image) =>
  image.sampleType === 'tool-output' &&
  image.sourceToolSlug === toolSlug &&
  image.isSameToolAsPage === true &&
  image.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Canva AI画像生成', item: 'https://aicreative-db.com/tools/canva-ai-image-generator/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Canva AI画像生成',
    operatingSystem: 'Web, iOS, Android',
    applicationCategory: 'DesignApplication',
    description: 'Canvaのデザインツールに統合されたAI画像生成機能。日本語UI対応で、SNS素材やバナー制作に手軽に使える。',
    url: 'https://www.canva.com',
  },
]);
---

<BaseLayout
  title="Canva AI画像生成の商用利用・料金・無料枠まとめ｜AIクリエイティブナビ"
  description="Canva AI画像生成の商用利用条件・料金プラン・無料枠・透かし・日本語対応状況を、公式情報をもとに整理しています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/canva-ai-image-generator/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Canva AI画像生成</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      sampleImage={sampleImage}
      toolName="Canva AI画像生成"
      category="AI画像生成"
      checkedDate={d?.lastReviewed ?? '2026-05-24'}
