  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">CapCut AI</span>
    </div>
  </nav>

  <div class="tdp-wrap">
