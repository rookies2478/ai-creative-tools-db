---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'capcut-ai');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'CapCut AI', item: 'https://aicreative-db.com/tools/capcut-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'CapCut AI',
    operatingSystem: 'Web, iOS, Android, Windows, Mac',
    applicationCategory: 'VideoApplication',
    description: 'CapCut AIはByteDance（TikTokの親会社）が提供するSNS動画向けAI動画編集・生成ツール。自動字幕・テンプレート・AI音声・背景削除など多数のAI機能を搭載。日本語UI対応。商用利用時は素材・音源・テンプレート・AI機能ごとの条件確認が必要。',
    url: 'https://www.capcut.com/',
  },
]);
---

<BaseLayout
