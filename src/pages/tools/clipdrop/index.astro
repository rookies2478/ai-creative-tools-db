          [{ html: '透かし', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>要公式確認</span><br>機能・プランにより異なる可能性があります。' }],
          [{ html: '日本語UI', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>要公式確認</span>' }],
          [{ html: '対応環境', rk: true }, { html: 'Web / API' }],
          [{ html: '情報確認日', rk: true }, { html: d?.lastReviewed ?? '2026-06-06', mono: true }],
          [{ html: '公式サイト', rk: true }, { html: '<a href="https://clipdrop.co/" target="_blank" rel="noopener">公式サイトで確認 ↗</a>' }],
