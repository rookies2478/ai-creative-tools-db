            [{ html: 'Pro', rk: true }, { html: '制限緩和（詳細は公式確認）', mono: false }, { html: '公式サイトで要確認', mono: false }],
          ],
        },
        notes: [
          'Freeプランの利用回数・対象機能・制限は変更される可能性があります',
          'Proプランの具体的な料金は2026年6月時点で公式サイト上に表示されていません',
          '<b>最新料金は公式料金ページでご確認ください</b>',
        ],
      }}
      commercial={{
        lead: '公式Terms（clipdrop.co/terms-visitor）ではサービス利用条件を確認できますが、生成・編集した画像の商用利用可否や権利関係については、確認時点で断定しにくい状況です。',
        points: [
          '最新の<b>公式Terms</b>の内容と商用利用に関する条件を確認する必要があります',
