---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'clipdrop');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Clipdrop', item: 'https://aicreative-db.com/tools/clipdrop/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Clipdrop',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: '背景削除・画像拡張・アップスケール・不要物削除・文字削除・画像生成など、複数のAI画像編集機能をブラウザ上で使えるオールインワン型ツール。',
    url: 'https://clipdrop.co/',
  },
]);
---

<BaseLayout
  title="Clipdropの商用利用・料金・無料枠まとめ｜AI生成ツールDB"
  description="Clipdropの商用利用条件・料金プラン・無料枠・透かし・日本語対応を公式情報をもとに整理。背景削除・不要物削除・アップスケール等の画像編集AI機能が揃うオールインワンツール。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/clipdrop/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Clipdrop</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      toolName="Clipdrop"
      category="AI画像編集・生成"
      checkedDate={d?.lastReviewed ?? '2026-06-06'}
      headingHtml='Clipdropの<span class="hl"><span class="phrase-nowrap">商用利用</span>・料金・無料枠</span>まとめ'
      lead="背景削除・画像拡張・アップスケール・不要物削除・文字削除・画像生成など、複数のAI画像編集機能をブラウザ上で使えるオールインワン型ツールです。Freeプランで主要機能の一部を試せますが、商用利用条件は公式Termsで確認が必要です。"
      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: '要公式確認' } },
        { lb: '無料枠', badge: { s: 'cond', label: '機能ごとに回数制限あり' } },
        { lb: '料金目安', text: 'Proプランは要公式確認', mono: true },
        { lb: '透かし', badge: { s: 'cond', label: '要公式確認' } },
        { lb: '日本語UI', badge: { s: 'cond', label: '要公式確認' } },
      ]}
      primaryCta={{ label: '公式サイトで確認する', href: 'https://clipdrop.co/' }}
      secondaryCta={{ label: '料金プラン（公式）', href: 'https://clipdrop.co/pricing' }}
      basicInfo={[
        {
          title: '商用利用', badge: { s: 'cond', label: '要公式確認' }, wide: true,
          sum: '公式Terms（clipdrop.co/terms-visitor）ではサービス利用条件を確認できますが、生成・編集した画像の商用利用可否や権利関係については確認時点で断定しにくい状況です。',
          det: '商用利用を前提にする場合は、最新の公式Termsの確認が必要です。またアップロードする元画像の著作権・使用権の確認も必要です。このページは法的助言ではありません。',
        },
        {
          title: '無料枠', badge: { s: 'cond', label: '機能ごとに回数制限あり' },
          det: '公式料金ページではFreeプランが案内されており、Background Removal・Image Upscaler・Cleanup・Relightなどを20回/24時間、Text Removerを50回/24時間の枠で試せます。利用回数・対象機能・制限は変更される可能性があります。',
        },
        {
          title: '料金目安', sum: 'Proプランの料金は公式サイトで要確認', sumMono: false,
          det: 'Proプランの具体的な料金は2026年6月時点で公式サイト上に表示されていないとされています。最新の料金は公式サイトでご確認ください。',
        },
        {
          title: '透かし', badge: { s: 'cond', label: '要公式確認' } ,
          det: 'Freeプランの透かし有無は機能・プランにより異なる可能性があります。最新の条件は公式画面でご確認ください。',
        },
        {
          title: '日本語対応',
          lang: [
            { label: 'UI', badge: { s: 'cond', label: '要公式確認' } },
            { label: 'プロンプト', badge: { s: 'cond', label: '要公式確認' } },
          ],
        },
        { title: '対応環境', feats: ['Web', 'API'] },
        { title: '主な機能', wide: true, feats: ['背景削除', '不要物削除（Cleanup）', '高解像度化', '文字削除', '再ライティング（Relight）', '画像拡張（Uncrop）', 'テキスト→画像', 'API提供'] },
      ]}
      useCases={[
        '<b>EC・商品ページ向けの背景削除・不要物削除</b>による画像加工',
        '<b>SNS投稿・広告バナー素材</b>の画像編集',
        '<b>低解像度素材のアップスケール</b>',
        'APIを使った<b>画像編集処理の自動化</b>',
      ]}
      pros={[
        '背景削除・不要物削除・アップスケール・Relightなど画像編集系AI機能が多数揃っている',
        'ブラウザ上で使えるためインストール不要',
        'Freeプランで主要機能の一部を試せる（Background Removal等20回/24時間）',
        'APIが提供されており開発者による自動化・組み込みが可能',
        'Jasper傘下でサービス継続中（2024年以降）',
      ]}
      cons={[
        '商用利用・権利関係は公式Terms確認が必要であり断定できない',
        'アップロードする元画像の著作権・権利確認が必要',
        '無料枠や機能制限は変更される可能性がある',
        '日本語UI・日本語プロンプト対応は公式情報のみでは確認できない',
        'Proプランの料金が公式サイトで非表示（要問い合わせまたはログイン後確認）',
        '2024年にJasperに統合されAPIがJasper APIに移行済み',
      ]}
      limits={[
        '商用利用条件は公式Termsで個別確認が必要',
        'Freeプランは機能ごとに20〜50回/24時間の利用制限あり（変更の可能性あり）',
        'Proプランの具体的な料金が公式サイトで非表示',
        '2024年のJasper統合によりAPIがJasper APIに移行済み',
      ]}
      quickTable={{
        kind: 'spec',
        rows: [
          [{ html: 'カテゴリ', rk: true }, { html: 'AI画像編集・生成（オールインワン型）' }],
          [{ html: '無料枠', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>機能ごとに回数制限あり</span><br>Background Removal・Cleanup等20回/24時間。Text Remover50回/24時間。' }],
          [{ html: '料金', rk: true }, { html: 'Proプランは公式サイトで要確認（2026年6月時点で非表示）' }],
