---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'd-id');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'D-ID', item: 'https://aicreative-db.com/tools/d-id/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'D-ID',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'D-IDは、顔写真やAI生成顔から話すアバター動画を作成できるAI動画生成ツール。TTS、音声アップロード、音声クローン、APIに対応。Liteプランは非商用利用限定とされ、商用利用可否はプランごとに公式規約の確認が必要。',
    url: 'https://www.d-id.com/',
  },
]);
---

<BaseLayout
  title="D-IDとは？写真から話すアバター動画を作るAIツールの特徴・料金・商用利用"
  description="D-IDは、顔写真やAI生成顔から話すアバター動画を作成できるAI動画生成ツールです。料金・無料トライアル・商用利用・透かし・日本語対応・API利用時の確認ポイントを整理します。"
  canonicalPath="/tools/d-id/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">D-ID</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage japanBilling={d?.japanBilling}
      toolName="D-ID"
      category="AIアバター動画"
      checkedDate={d?.lastReviewed ?? '2026-07-05'}
      headingHtml='D-ID（Creative Reality Studio）'
      lead="D-IDは、顔写真やAI生成顔、テキスト、音声などを使って、話すアバター動画を生成できるAI動画生成ツールです。TTS、音声アップロード、音声クローン、APIにも対応しており、多言語の説明動画やサービス組み込み向けのアバター動画制作に活用できます。<b>Liteプランは非商用利用限定とされているため、商用利用前にプランの確認が必要です。</b>"
      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: 'Lite限定は非商用（要確認）' } },
        { lb: '無料枠', badge: { s: 'cond', label: 'Trialあり（透かし）' } },
        { lb: '料金目安', text: '要確認（公式Pricing参照）', mono: true },
        { lb: '透かし', badge: { s: 'cond', label: 'Trial/Liteあり・上位は要確認' } },
        { lb: '日本語UI', badge: { s: 'cond', label: '不明（要確認）' } },
        { lb: '入力素材', badge: { s: 'cond', label: '注意あり（肖像権・音声権）' } },
      ]}
      primaryCta={{ label: '公式サイトで最新の料金・機能を確認する', href: 'https://www.d-id.com/' }}
      secondaryCta={{ label: '料金プランを確認（公式）', href: 'https://www.d-id.com/pricing/studio/' }}
      basicInfo={[
        {
          title: '商用利用', badge: { s: 'cond', label: 'Lite限定は非商用（要確認）' }, wide: true,
          sum: 'Liteプランは非商用利用限定とされています。Lite以外のプランでは商用利用可能とされていますが、<b>EULA / Studio EULA / 最新の公式Pricingを必ず確認してください。</b>顔写真・音声を扱う場合は本人同意や第三者権利の確認も必要です。',
          det: 'D-IDは顔写真・音声を扱うサービスのため、商用利用時は出力条件に加えて肖像権・音声権・なりすまし禁止事項の確認が重要です。このページは法的助言ではありません。',
        },
        {
          title: '無料枠', badge: { s: 'cond', label: 'Trialあり（透かし）' },
