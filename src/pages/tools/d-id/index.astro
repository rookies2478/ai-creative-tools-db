        { title: '主な機能', wide: true, feats: ['顔写真・AI生成顔からのアバター動画生成', 'TTS・音声アップロード', '音声クローン', 'API・リアルタイム生成', '多言語対応（日本語を含むという公式記載あり）'] },
      ]}
      useCases={[
