---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'dreamstudio');
const d = entry?.data;
const toolSlug = 'dreamstudio';
const sampleImage = generatedImages.find((img) =>
  img.sampleType === 'tool-output' &&
  img.sourceToolSlug === toolSlug &&
  img.isSameToolAsPage === true &&
  img.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Brand Studio（旧DreamStudio）', item: 'https://aicreative-db.com/tools/dreamstudio/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Brand Studio（旧DreamStudio）',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: 'Stability AI公式のAI画像生成サービス（旧DreamStudio / Brand Studio）。ブラウザ上でプロンプト・ネガティブプロンプト・画像サイズを調整して画像生成できる。',
    url: 'https://stability.ai/brandstudio',
  },
]);
---

