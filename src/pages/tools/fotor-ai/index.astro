---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'fotor-ai');
const d = entry?.data;
const toolSlug = 'fotor-ai';
const sampleImage = generatedImages.find((image) =>
  image.sampleType === 'tool-output' &&
  image.sourceToolSlug === toolSlug &&
  image.isSameToolAsPage === true &&
  image.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Fotor AI', item: 'https://aicreative-db.com/tools/fotor-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Fotor AI',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: 'AI画像生成・写真編集・背景除去・デザインテンプレートをまとめて使えるオンライン画像編集・デザインツール。日本語ページあり。',
    url: 'https://www.fotor.com/jp/ai-image-generator/',
  },
]);
---

<BaseLayout
  title="Fotor AIの使い方｜無料でのAIペイント生成と商用利用の注意点"
  description="Fotor AIを無料で使う方法、AIペイント生成・AI画像生成の使い方、料金プラン、商用利用、透かし、日本語対応の確認ポイントを整理します。利用前に確認したい規約や権利の注意点もまとめます。"
  canonicalPath="/tools/fotor-ai/"
  ogType="article"
  jsonLd={jsonLd}
