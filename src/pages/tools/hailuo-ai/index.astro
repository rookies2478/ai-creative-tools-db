---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'hailuo-ai');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Hailuo AI', item: 'https://aicreative-db.com/tools/hailuo-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Hailuo AI',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'Hailuo AI（MiniMax運営）はAI動画生成ツール。テキスト・画像から動画生成・動画延長（最大3分）に対応。中国企業MiniMaxが運営。利用規約にHailuo AIへの広範なコンテンツライセンスが含まれることに注意が必要。',
    url: 'https://hailuoai.video',
  },
]);
