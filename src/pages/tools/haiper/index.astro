      specs={[
        { lb: '商用利用', badge: { s: 'paid', label: '有料メンバーのみ（公式FAQ）' } },
        { lb: '無料枠', badge: { s: 'cond', label: 'クレジット制（要確認）' } },
        { lb: '料金目安', text: '要公式確認', mono: true },
        { lb: '透かし', badge: { s: 'cond', label: '無料あり・有料なし（公式FAQ）' } },
        { lb: '日本語UI', badge: { s: 'na', label: '非対応（要確認）' } },
