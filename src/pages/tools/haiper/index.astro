    background: var(--surface, #fff);
  }
  .tdp-bc .wrap {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    color: var(--muted, #6A7180);
