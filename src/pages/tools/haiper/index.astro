---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'haiper');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Haiper', item: 'https://aicreative-db.com/tools/haiper/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Haiper',
    operatingSystem: 'Web, iOS',
    applicationCategory: 'VideoApplication',
    description: 'Haiperはテキストから動画・画像から動画・キーフレーム指定などに対応するAI動画生成ツール。Web App / iOS App / APIで利用可能。有料メンバーで透かしなし・商用利用可と公式FAQで案内されている。',
    url: 'https://haiper.ai/',
  },
]);
---

<BaseLayout
  title="Haiperの商用利用・料金・無料枠まとめ｜AI動画生成ツールDB"
  description="HaiperのAI動画生成における商用利用条件・料金プラン・無料枠・透かし・利用規約の注意点を整理。Web App / iOS App / API対応。有料メンバーで透かしなし・商用利用可と公式FAQに案内。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/haiper/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Haiper</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      toolName="Haiper"
      category="AI動画生成"
      checkedDate={d?.lastReviewed ?? '2026-05-24'}
