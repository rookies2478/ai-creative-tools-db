---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'heygen');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'HeyGen', item: 'https://aicreative-db.com/tools/heygen/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'HeyGen',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'HeyGenはAIアバター、リップシンク、動画翻訳、ボイスクローンなどを使い、研修・マーケティング・セールス・ローカライズ向けの動画を作成できるAIアバター動画ツール。無料プランと有料プランで商用利用条件が異なるため公式Termsの確認が必要。',
    url: 'https://www.heygen.com/',
  },
]);
---

<BaseLayout
  title="HeyGenとは？AIアバター動画生成の特徴・料金・商用利用の確認ポイント"
  description="HeyGenは、AIアバターや動画翻訳、ボイスクローンを使って研修・マーケティング・営業向け動画を作成できるAI動画生成ツールです。料金・無料プラン・商用利用・透かし・肖像権確認のポイントを整理します。"
  canonicalPath="/tools/heygen/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">HeyGen</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage japanBilling={d?.japanBilling}
      toolName="HeyGen"
      category="AIアバター動画"
      checkedDate={d?.lastReviewed ?? '2026-07-05'}
      headingHtml='HeyGen（ヘイジェン）'
      lead="HeyGenは、AIアバター、リップシンク、動画翻訳、ボイスクローンなどを使って、研修・マーケティング・セールス・ローカライズ向けの動画を作成できるAI動画生成ツールです。<b>無料プランと有料プランで商用利用や出力条件が異なる可能性があるため、利用前に公式Termsの確認が必要です。</b>"
      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: 'プランにより異なる（要確認）' } },
        { lb: '無料枠', badge: { s: 'cond', label: 'あり（透かし・1分制限）' } },
        { lb: '料金目安', text: '要確認（公式Pricing参照）', mono: true },
        { lb: '透かし', badge: { s: 'cond', label: '無料あり・有料は要確認' } },
        { lb: '日本語UI', badge: { s: 'cond', label: '不明（要確認）' } },
        { lb: '入力素材', badge: { s: 'cond', label: '注意あり（肖像権・音声権）' } },
      ]}
      primaryCta={{ label: '公式サイトで最新の料金・機能を確認する', href: 'https://www.heygen.com/' }}
      secondaryCta={{ label: '料金プランを確認（公式）', href: 'https://www.heygen.com/pricing' }}
      basicInfo={[
        {
          title: '商用利用', badge: { s: 'cond', label: 'プランにより異なる（要確認）' }, wide: true,
