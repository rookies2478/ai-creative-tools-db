---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'ideogram');
const d = entry?.data;
const toolSlug = 'ideogram';
const sampleImage = generatedImages.find((img) =>
  img.sampleType === 'tool-output' &&
  img.sourceToolSlug === toolSlug &&
  img.isSameToolAsPage === true &&
  img.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Ideogram', item: 'https://aicreative-db.com/tools/ideogram/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Ideogram',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: 'テキスト入り画像やタイポグラフィ表現に強いAI画像生成サービス。ロゴ風デザイン・ポスター・SNS画像の作成に活用されている。',
    url: 'https://ideogram.ai/',
  },
]);
---

<BaseLayout
  title="Ideogramの商用利用・料金・無料枠まとめ｜AI生成ツールDB"
  description="Ideogramの商用利用条件・料金プラン・無料枠・透かし・日本語対応を公式情報をもとに整理。文字入り画像・ロゴ風デザインに強いAI画像生成サービスです。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/ideogram/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Ideogram</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      sampleImage={sampleImage}
      toolName="Ideogram"
      category="AI画像生成"
      checkedDate={d?.lastReviewed ?? '2026-05-26'}
