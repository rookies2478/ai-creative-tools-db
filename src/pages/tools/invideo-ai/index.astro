---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'invideo-ai');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'InVideo AI', item: 'https://aicreative-db.com/tools/invideo-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'InVideo AI',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'InVideo AIはテキストから動画を自動生成・編集できるAIビデオ作成サービス。テンプレートと音声ナレーション生成を活用した動画制作に対応。有料プランで商用利用可とされているが、生成AIの利用条件と素材ライセンスは分けて確認が必要。',
    url: 'https://invideo.io',
  },
]);
