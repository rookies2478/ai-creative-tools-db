---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'kling-ai');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Kling AI', item: 'https://aicreative-db.com/tools/kling-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Kling AI',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'Kling AIは中国Kuaishou運営のAI動画生成ツール。テキスト・画像から最大10秒の動画を生成でき、動画延長（最大3分）にも対応。無料プランは1日66クレジット付与。',
    url: 'https://klingai.com',
  },
]);
---

<BaseLayout
