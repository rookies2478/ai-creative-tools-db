---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'leonardo-ai');
const d = entry?.data;
const toolSlug = 'leonardo-ai';
const toolOutputBase = (image: import('../../../data/generatedImages').GeneratedImage) =>
  image.sampleType === 'tool-output' &&
  image.sourceToolSlug === toolSlug &&
  image.isSameToolAsPage === true;
const benchmarkSampleImage = generatedImages.find((image) =>
  toolOutputBase(image) && image.promptVersion === 'image-tool-benchmark-v1'
);
const fallbackSampleImage = generatedImages.find((image) =>
  toolOutputBase(image) && image.promptVersion === 'home-showcase-v1'
);
const sampleImage = benchmarkSampleImage ?? fallbackSampleImage ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Leonardo AI', item: 'https://aicreative-db.com/tools/leonardo-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Leonardo AI',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: 'ゲーム・イラスト向けのカスタムモデルが豊富なAI画像生成サービス。無料枠のトークン数が比較的多い。',
    url: 'https://leonardo.ai',
  },
]);
---

<BaseLayout
  title="Leonardo AIの商用利用・料金・無料枠まとめ｜AIクリエイティブナビ"
  description="Leonardo AIの商用利用条件・料金プラン・無料枠・透かし・日本語対応状況を、公式情報をもとに整理しています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/leonardo-ai/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Leonardo AI</span>
    </div>
  </nav>

  <div class="tdp-wrap">
