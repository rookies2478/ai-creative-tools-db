---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedVideos } from '../../../data/generatedVideos';
import { buildNextReads, buildConditionTags } from '../../../data/toolRelatedLinks';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'luma-ai');
const d = entry?.data;

const lumaSampleVideo = generatedVideos.find(
  (v) => v.pageSlug === 'luma-ai' && v.sampleType === 'tool-video-output' && v.isSameToolAsPage
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Luma AI', item: 'https://aicreative-db.com/tools/luma-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Luma AI',
    operatingSystem: 'Web, API',
    applicationCategory: 'VideoApplication',
    description: 'Luma AIはテキスト・画像からAI動画を生成するツール。Ray3モデルで最大20秒の動画生成に対応。無料プランは限定クレジット・非商用のみ。Plusプラン以上で商用利用可とされる。',
    url: 'https://lumalabs.ai/',
  },
]);
---

<BaseLayout
  title="Luma AI / Dream Machineの無料枠・料金・商用利用の注意点"
  description="Luma AI / Dream Machineの動画生成機能、無料枠、料金プラン、商用利用、透かしの確認ポイントを整理します。無料枠や利用条件は変更される場合があるため、最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/luma-ai/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Luma AI</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage japanBilling={d?.japanBilling}
      toolName="Luma AI"
      category="AI動画生成"
      checkedDate={d?.lastReviewed ?? '2026-06-05'}
      headingHtml='Luma AIの<span class="hl"><span class="phrase-nowrap">使い方</span>・料金・商用利用</span>まとめ'
      lead="Luma AI（Luma Dream Machine）はテキストや画像からAI動画を生成するツールで、Ray3モデルで最大20秒（720p）の動画生成・動画延長・アップスケール・APIに対応しています。無料枠は生成数・商用利用の両面で制限があり、有料プランと条件が異なります。無料プランは限定クレジット付与で非商用のみ・透かしありとされています。機能名・仕様・条件は変更される場合があるため、最新情報は公式サイトでご確認ください。"
      specs={[
        { lb: '商用利用', badge: { s: 'paid', label: 'Plus以上（要確認）' } },
        { lb: '無料枠', badge: { s: 'cond', label: '限定クレジット（非商用・透かし）' } },
        { lb: '料金目安', text: '$30/月〜（Plusプラン）', mono: true },
        { lb: '透かし', badge: { s: 'cond', label: '無料プランあり・Plus以上なし' } },
        { lb: '日本語UI', badge: { s: 'na', label: '非対応' } },
        { lb: '入力素材', badge: { s: 'cond', label: '注意あり' } },
      ]}
      primaryCta={{ label: '公式サイトで確認する', href: 'https://lumalabs.ai/' }}
      secondaryCta={{ label: '料金プランを確認（公式）', href: 'https://lumalabs.ai/pricing' }}
      basicInfo={[
        {
          title: '商用利用', badge: { s: 'paid', label: 'Plus以上（要確認）' }, wide: true,
          sum: '無料プランでは商用利用不可とされています。Plusプラン（$30/月）以上で商用利用できるとされていますが、最新条件は公式サイトでご確認ください。',
          det: '商用利用条件はPlusプラン以上で可とされています。無料プランは非商用のみとされています。利用規約は変更される可能性があるため、商用利用前は必ず最新の公式利用規約をご確認ください。このページは法的助言ではありません。',
        },
        {
          title: '無料枠', badge: { s: 'cond', label: '限定クレジット（非商用・透かし）' },
          det: '無料プランでは限定クレジットが付与されますが、非商用のみ・透かしありとされています。クレジット数・条件は変更される可能性があります。',
        },
        {
          title: '最安料金目安', sum: '$30/月（Plusプラン）〜（公式案内）', sumMono: true,
