        { title: '対応環境', feats: ['Web', 'API'] },
        { title: '主な機能', wide: true, feats: ['テキスト→動画', '画像→動画', '動画延長', 'アップスケール', 'API', '最大20秒（Ray3 720p）'] },
      ]}
      useCases={[
        '<b>最大20秒の高品質な動画生成</b>（Ray3 720pモデル）',
        '<b>動画延長・アップスケール</b>で動画品質を向上させたい場合',
