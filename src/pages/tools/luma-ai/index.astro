        },
        {
          title: '透かし', badge: { s: 'cond', label: '無料プランあり・Plus以上なし' },
          det: '無料プランでは生成動画に透かしが付与されるとされています。Plusプラン以上では透かしなしとされていますが、最新仕様は公式サイトでご確認ください。',
        },
        {
          title: '日本語対応',
          lang: [
            { label: 'UI', badge: { s: 'na', label: '非対応' } },
            { label: 'プロンプト', badge: { s: 'ok', label: '対応' } },
          ],
