      ]}
      selectTable={{
        kind: 'cmp',
        headers: ['ツール', '向いているケース'],
        rows: [
          [{ html: 'Microsoft Designer（このページ）', rk: true, me: true }, { html: 'Microsoftアカウントを活用してデザインと画像生成を一体で行いたい場合' }],
          [{ html: '<a href="/tools/canva-ai-image-generator/">Canva AI画像生成</a>', rk: true }, { html: 'Canva内のテンプレートとデザイン制作フローの中で画像生成を使いたい場合' }],
          [{ html: '<a href="/tools/adobe-firefly/">Adobe Firefly</a>', rk: true }, { html: 'Adobe製品との連携や、商用利用時の条件を公式で確認しながら使いたい場合' }],
          [{ html: '<a href="/tools/midjourney/">Midjourney</a>', rk: true }, { html: 'アート調・雰囲気重視の高品質なビジュアル表現を重視する場合' }],
          [{ html: '<a href="/tools/dalle/">DALL·E</a>', rk: true }, { html: 'ChatGPT連携で手軽に画像生成・アイデア出しをしたい場合' }],
