      language={[
        '<b>日本語UI：</b>対応（日本語インターフェースで利用可能）',
        '<b>日本語プロンプト：</b>対応しているとされていますが、機能の詳細は公式サイトでご確認ください',
      ]}
      watermark={[
        '透かしの有無・条件は現時点での公式情報では確認できていません',
        '最新の条件は公式サイトでご確認ください',
      ]}
      watermarkMore={{ label: '透かしなしツール一覧を見る →', href: '/conditions/no-watermark/' }}
      checklist={[
