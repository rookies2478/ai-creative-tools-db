---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'microsoft-designer');
const d = entry?.data;
const toolSlug = 'microsoft-designer';
const sampleImage = generatedImages.find((img) =>
  img.sampleType === 'tool-output' &&
  img.sourceToolSlug === toolSlug &&
  img.isSameToolAsPage === true &&
  img.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Microsoft Designer', item: 'https://aicreative-db.com/tools/microsoft-designer/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Microsoft Designer',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: 'MicrosoftのAIデザイン・画像生成サービス。SNS画像、バナー、プレゼン素材などを手軽に作成できる。',
    url: 'https://designer.microsoft.com/',
  },
]);
---

<BaseLayout
  title="Microsoft Designer 商用利用はできる？料金・無料範囲を整理"
  description="Microsoft Designerの商用利用条件と料金を整理。用途やアカウント種別で条件が異なる可能性があるため、公式情報で確認すべきポイントもまとめています。"
  canonicalPath="/tools/microsoft-designer/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Microsoft Designer</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
