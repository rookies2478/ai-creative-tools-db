        rows: [
          [{ html: '用途の傾向', rk: true }, { html: 'Microsoft連携・デザイン', me: true }, { html: 'テンプレートデザイン・SNS' }, { html: 'デザイン制作・Adobe連携' }],
          [{ html: '無料枠', rk: true }, { html: 'あり（条件あり）', me: true }, { html: '限定的' }, { html: '限定的' }],
