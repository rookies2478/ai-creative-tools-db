---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'microsoft-designer');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Microsoft Designer', item: 'https://aicreative-db.com/tools/microsoft-designer/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Microsoft Designer',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: 'MicrosoftのAIデザイン・画像生成サービス。SNS画像、バナー、プレゼン素材などを手軽に作成できる。',
    url: 'https://designer.microsoft.com/',
  },
]);
---

<BaseLayout
  title="Microsoft Designerの商用利用・料金・無料枠まとめ｜AI生成ツールDB"
  description="Microsoft Designerの商用利用条件・料金プラン・無料枠・透かし・日本語対応状況を、公式情報をもとに整理しています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/microsoft-designer/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Microsoft Designer</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      toolName="Microsoft Designer"
      category="AI画像生成"
      checkedDate={d?.lastReviewed ?? '2026-05-26'}
      headingHtml='Microsoft Designerの<span class="hl"><span class="phrase-nowrap">商用利用</span>・料金・無料枠</span>まとめ'
      lead="MicrosoftのAIデザイン・画像生成サービス。Microsoftアカウントで利用でき、SNS画像・バナー・プレゼン素材の作成に向いている。料金・商用利用・日本語対応を公式情報をもとに整理しています。"
      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: '条件あり' } },
        { lb: '無料枠', badge: { s: 'ok', label: '無料枠あり' } },
        { lb: '料金目安', text: '要公式確認', mono: true },
        { lb: '透かし', badge: { s: 'na', label: '要確認' } },
        { lb: '日本語UI', badge: { s: 'ok', label: '〇 対応' } },
      ]}
      primaryCta={{ label: '公式サイトで確認する', href: 'https://designer.microsoft.com/' }}
      secondaryCta={{ label: 'よくある質問（公式）', href: 'https://support.microsoft.com/ja-JP/designer/frequently-asked-questions-about-microsoft-designer' }}
      basicInfo={[
        {
          title: '商用利用', badge: { s: 'cond', label: '条件あり' }, wide: true,
          sum: '用途・アカウント種別・最新規約により条件が異なる可能性があります。',
          det: 'Microsoft Designerの公式FAQでは、Microsoftアカウントでの個人的な利用や非商用利用に関する記載があります。商用利用の可否や条件は、用途・アカウント種別・Microsoftの最新規約により異なる可能性があるため、公式情報をご確認ください。',
        },
        {
          title: '無料枠', badge: { s: 'ok', label: '無料枠あり' },
          det: 'Microsoftアカウントがあれば無料で利用できる場合があります。利用可能な機能や制限は変更される可能性があります。',
        },
        {
          title: '最安料金目安', sum: '要公式確認', sumMono: true,
          det: '無料で利用できる機能があります。詳細なプラン・クレジット数・有料オプションは変更される可能性があるため、最新の情報は公式サイトでご確認ください。',
        },
        {
          title: '透かし', badge: { s: 'na', label: '要確認' },
          det: '透かしの有無・条件は現時点での公式情報では確認できていません。最新の条件は公式サイトでご確認ください。',
        },
        {
          title: '日本語対応',
          lang: [
            { label: 'UI', badge: { s: 'ok', label: '〇 対応' } },
            { label: 'プロンプト', badge: { s: 'ok', label: '〇 対応' } },
          ],
        },
        { title: '対応環境', feats: ['Web'] },
        { title: '主な機能', wide: true, feats: ['テキスト→画像', 'スタイル選択', 'プロンプト補助'] },
      ]}
      useCases={[
        '<b>SNS投稿画像</b>のビジュアル作成',
        '<b>広告バナー案</b>の初期案作りや複数パターン比較',
        '<b>ブログアイキャッチ・プレゼン資料</b>用ビジュアルの案出し',
        '<b>Microsoftアカウント・Microsoft系サービス</b>との連携環境で使いたい場合',
      ]}
      pros={[
        'Microsoftアカウントで手軽に開始できる',
        '画像生成だけでなくデザイン作成・画像編集にも使いやすい',
        'SNS投稿や資料用のビジュアル作成に向いている',
        'テンプレートを使ったデザイン制作が手軽',
        '日本語UI対応で英語ツールに慣れていない場合でも使いやすい',
      ]}
      cons={[
        '商用利用条件は用途やアカウント種別により確認が必要',
        '一部機能は地域・年齢・サブスクリプション条件に左右される可能性がある',
        '透かしの有無が公式情報から確認できていない',
      ]}
      limits={[
        '商用利用条件は公式規約の確認が必要',
        '一部機能は地域・年齢制限の対象になる場合がある',
        'APIによる自動化・組み込みには非対応（公式情報による）',
      ]}
      quickTable={{
        kind: 'spec',
        rows: [
          [{ html: 'カテゴリ', rk: true }, { html: 'AI画像生成' }],
          [{ html: '無料枠', rk: true }, { html: '<span class="tdp-st ok sm"><span class="d"></span>無料枠あり</span><br>Microsoftアカウントがあれば無料で利用できる場合があります' }],
          [{ html: '最安料金', rk: true }, { html: '<span class="mono">要公式確認</span>' }],
