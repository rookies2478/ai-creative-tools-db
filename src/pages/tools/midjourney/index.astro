---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'midjourney');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Midjourney', item: 'https://aicreative-db.com/tools/midjourney/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Midjourney',
    operatingSystem: 'Web, Discord',
    applicationCategory: 'DesignApplication',
    description: '高品質なアート・イラスト生成に定評のあるAI画像生成サービス。Discord・Web版で利用可能で、有料プランのみ提供。',
    url: 'https://www.midjourney.com',
  },
]);
---

<BaseLayout
  title="Midjourneyの商用利用・料金・無料枠まとめ｜AI生成ツールDB"
  description="Midjourneyの商用利用条件・料金プラン・無料枠・透かし・日本語対応状況を、公式情報をもとに整理しています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/midjourney/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Midjourney</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      toolName="Midjourney"
      category="AI画像生成"
      checkedDate={d?.lastReviewed ?? '2026-06-06'}
      headingHtml='Midjourneyの<span class="hl"><span class="phrase-nowrap">商用利用</span>・料金・無料枠</span>まとめ'
      lead="高品質なアート・イラスト生成に定評のあるAI画像生成サービス。Discord・Web版で利用可能で、有料プランのみの提供です。料金・商用利用条件・日本語対応を公式情報をもとに整理しています。"
      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: '条件あり' } },
        { lb: '無料枠', badge: { s: 'na', label: 'なし' } },
        { lb: '料金目安', text: '$10/月〜', mono: true },
        { lb: '透かし', badge: { s: 'ok', label: 'なし（有料）' } },
        { lb: '日本語UI', badge: { s: 'na', label: '× 非対応' } },
      ]}
      primaryCta={{ label: '公式サイトで確認する', href: 'https://www.midjourney.com' }}
      secondaryCta={{ label: 'プラン比較（公式）', href: 'https://docs.midjourney.com/hc/en-us/articles/27870484040333-Comparing-Midjourney-Plans' }}
      basicInfo={[
        {
          title: '商用利用', badge: { s: 'cond', label: '条件あり' }, wide: true,
          sum: '有料プランでは商用利用に関する公式案内があります。年間総収益100万ドル超の企業はPro/Megaプランへのアップグレードが必要とされています。',
          det: '公式ヘルプでは、有料プラン利用者向けの商用利用に関する案内が掲載されています。ただし年間総収益が100万ドル超の企業は利用規約上、Pro/Megaプランへのアップグレードが必要とされています。利用条件はプランや用途によって異なる可能性があるため、最新の公式規約をご確認ください。',
        },
        {
          title: '無料枠', badge: { s: 'na', label: 'なし' },
          det: '現在は無料プランが提供されていない場合があります（2024年末に廃止されたとされています）。最新の状況は公式サイトでご確認ください。',
        },
        {
          title: '最安料金目安', sum: '$10/月（Basic・月払い）／$8/月（年払い）', sumMono: true,
          det: 'Basic $10/月〜。年払いで$8/月〜。料金・プラン内容は変更される場合があります。',
        },
        {
          title: '透かし', badge: { s: 'ok', label: 'なし（有料）' },
          det: '公式情報上、有料プランでは生成画像に透かしは付与されない場合があります。最新の条件は公式サイトでご確認ください。',
        },
        {
          title: '日本語対応',
          lang: [
            { label: 'UI', badge: { s: 'na', label: '× 非対応' } },
            { label: 'プロンプト', badge: { s: 'cond', label: '△ 一部対応' } },
          ],
        },
        { title: '対応環境', feats: ['Discord', 'Web'] },
        { title: '主な機能', wide: true, feats: ['テキスト→画像', '画像→画像', '高解像度化', 'スタイル選択'] },
      ]}
      useCases={[
        '<b>高品質なアート・イラスト・写真風画像</b>の生成',
        '<b>SNS投稿画像・ブログアイキャッチ・サムネイル案</b>の素材制作',
        '<b>コンセプトビジュアル・デザイン方向性</b>の探索',
        'スタイルの幅が広く<b>複数のビジュアル案を短時間で比較</b>したい場合',
      ]}
      pros={[
        '画像品質・スタイル表現が業界トップクラスとされる',
        'Discordベースで操作可能、Web版も提供',
        'v6以降、プロンプト精度が向上しているとされる',
        '有料プラン利用時の商用利用に関する公式案内がある',
        '有料プランでは透かしなし',
      ]}
      cons={[
        '無料プランなし（2024年末に廃止済み。最新状況は公式サイトで確認）',
        '日本語UIなし（英語インターフェースのみ）',
        'ローカル実行不可、クラウドのみ',
        '大企業（年間総収益100万ドル超）は上位プランが必要とされる',
      ]}
      limits={[
        '無料プランなし',
        '年間総収益100万ドル超の企業はPro/Megaプランへのアップグレードが必要とされている',
        '日本語UIなし、日本語ドキュメントなし',
      ]}
      quickTable={{
        kind: 'spec',
        rows: [
          [{ html: 'カテゴリ', rk: true }, { html: 'AI画像生成' }],
          [{ html: '無料枠', rk: true }, { html: '<span class="tdp-st na sm"><span class="d"></span>なし</span><br>無料プランは廃止されたとされています（要公式確認）' }],
          [{ html: '最安料金', rk: true }, { html: '<span class="mono">$10/月〜</span><br>Basic $10/月〜（月払い）。年払い$8/月〜。' }],
          [{ html: '商用利用', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>条件あり</span><br>有料プランで商用利用可能と案内されています。年収100万ドル超企業はPro/Mega必須とされています。' }],
          [{ html: '透かし', rk: true }, { html: '<span class="tdp-st ok sm"><span class="d"></span>なし（有料）</span><br>有料プランでは透かしなし' }],
          [{ html: '日本語UI', rk: true }, { html: '<span class="tdp-st na sm"><span class="d"></span>× 非対応</span>' }],
          [{ html: '日本語プロンプト', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>△ 一部対応</span><br>英語より精度が低い傾向あり' }],
          [{ html: '対応環境', rk: true }, { html: 'Discord / Web' }],
          [{ html: '情報確認日', rk: true }, { html: d?.lastReviewed ?? '2026-06-06', mono: true }],
          [{ html: '公式サイト', rk: true }, { html: '<a href="https://www.midjourney.com" target="_blank" rel="noopener">公式サイトで確認 ↗</a>' }],
        ],
        note: '※ 値は確認日時点の参考値です。プランや用途により異なる場合があります。最新情報は必ず公式サイトでご確認ください。',
      }}
      about={[
        'Midjourneyは高品質な画像生成を強みとするAI画像生成サービスです。<b>有料プランのみの提供</b>で、日本語UIには非対応ですが、クリエイティブ用途での評価が高く、アートやイラスト・SNS画像・デザイン素材の作成に活用されています。',
        'テキストプロンプトから高品質なビジュアルを生成できます。スタイルの幅が広く、アート・イラスト・写真風など多様な表現が可能とされています。商用利用や透かし条件には規約上の条件があるため、実務利用前に公式情報の確認が必要です。',
      ]}
      aboutMore={{ label: 'AI画像生成ツール一覧で比較する →', href: '/categories/image-generation/' }}
      pricing={{
        table: {
          kind: 'cmp',
          headers: ['プラン', '月払い', '年払い'],
          rows: [
            [{ html: 'Basic', rk: true }, { html: '$10/月', mono: true }, { html: '$8/月', mono: true }],
            [{ html: 'Standard', rk: true }, { html: '$30/月', mono: true }, { html: '$24/月', mono: true }],
            [{ html: 'Pro', rk: true }, { html: '$60/月', mono: true }, { html: '$48/月', mono: true }],
            [{ html: 'Mega', rk: true }, { html: '$120/月', mono: true }, { html: '$96/月', mono: true }],
          ],
        },
        notes: [
          '無料プランは2024年末に廃止されたとされています。現在の提供状況は公式サイトでご確認ください',
          '料金・プラン内容は変更される場合があります',
          '<b>最新料金は公式サイトでご確認ください</b>',
        ],
      }}
      commercial={{
        lead: '公式ヘルプでは、有料プラン利用者向けの商用利用に関する案内が掲載されています。ただし以下の条件が設けられています。',
        points: [
          '<b>年間総収益が100万ドル超の企業</b>は利用規約上、Pro/Megaプランへのアップグレードが必要とされています',
          '規約・条件は変更される可能性があります',
          '米国著作権法上、AIのみで生成した画像は著作権保護を受けられない可能性があります（商用利用権とは別の問題です）',
        ],
        disclaimer: 'このページは情報提供を目的としており、法的助言ではありません。実務利用前は必ず最新の公式利用規約および商用利用ガイドをご確認ください。',
        more: { label: '商用利用・著作権の注意点ガイド →', href: '/guides/commercial-use-copyright/' },
      }}
      integrationTitle="DiscordとWeb版での利用"
      integration="MidjourneyはDiscordのコマンドベースで操作するのが基本ですが、公式WebサイトからWeb版でも利用できる場合があります。Discordアカウントが必要です。英語プロンプトでの操作が基本となります。最新の提供状況は公式サイトでご確認ください。"
      whoFor={[
        '高品質なイラストやアート調ビジュアルを作りたい人',
        'SNS投稿・ブログアイキャッチ・サムネイル案を素早く作りたい人',
        '複数のビジュアル案を短時間で比較・検討したい人',
        '画風や雰囲気を細かく調整しながら表現を探索したい人',
        '英語でのプロンプト操作に慣れている人',
      ]}
      whoNot={[
        '同じ人物・構図を毎回再現する必要がある人（再現性に限界あり）',
        '日本語UIのみで完結させたい人（英語インターフェースのみ）',
        '商用案件に利用したいが規約確認なく使い始めたい人',
        '無料で試したい人（無料プランなし）',
      ]}
      selectTable={{
        kind: 'cmp',
        headers: ['ツール', '向いているケース'],
        rows: [
          [{ html: 'Midjourney（このページ）', rk: true, me: true }, { html: '高品質なアート・イラスト・クリエイティブなビジュアル表現を重視する場合' }],
          [{ html: '<a href="/tools/adobe-firefly/">Adobe Firefly</a>', rk: true }, { html: 'Adobe製品との連携を重視する場合、日本語UIで操作したい場合' }],
          [{ html: '<a href="/tools/leonardo-ai/">Leonardo AI</a>', rk: true }, { html: 'イラスト・ゲーム素材・キャラクター素材の制作候補、無料枠から試したい場合' }],
          [{ html: '<a href="/tools/canva-ai-image-generator/">Canva AI画像生成</a>', rk: true }, { html: 'Canvaのデザインフローの中でAI画像を使いたい場合' }],
          [{ html: '<a href="/tools/dalle/">DALL·E</a>', rk: true }, { html: 'ChatGPT連携で手軽に画像生成・アイデア出しをしたい場合' }],
        ],
      }}
      versusTable={{
        kind: 'cmp',
        headers: ['比較軸', 'Midjourney', 'Adobe Firefly', 'Leonardo AI'],
        rows: [
          [{ html: '用途の傾向', rk: true }, { html: 'アート調・雰囲気重視', me: true }, { html: 'デザイン制作・Adobe連携' }, { html: 'ゲーム・イラスト特化' }],
          [{ html: '無料枠', rk: true }, { html: 'なし', me: true }, { html: '限定的' }, { html: '限定的' }],
          [{ html: '日本語UI', rk: true }, { html: '非対応', me: true }, { html: '対応' }, { html: '要確認' }],
          [{ html: '透かし（有料）', rk: true }, { html: 'なし', me: true }, { html: 'プランによる' }, { html: '要確認' }],
        ],
        note: '※ 各ツールの最新条件は公式サイトをご確認ください。',
      }}
      language={[
        '<b>日本語UI：</b>非対応（英語インターフェースのみ）',
        '<b>日本語プロンプト：</b>一部対応（英語より精度が低い傾向あり）',
        '日本語ドキュメント：非対応',
        '細かな画風・構図・スタイルの指定では英語プロンプトの方が意図を伝えやすい傾向があります',
      ]}
      watermark={[
        '公式情報上、有料プランでは生成画像に透かしは付与されない場合があります',
        '最新の条件は公式サイトでご確認ください',
      ]}
      watermarkMore={{ label: '透かしなしツール一覧を見る →', href: '/conditions/no-watermark/' }}
      checklist={[
        { html: '利用プラン（Basic / Standard / Pro / Mega）' },
        { html: '年間総収益が100万ドルを超えていないか（超える場合はPro/Mega必須）' },
        { html: '生成物の利用範囲（掲載媒体・配布範囲など）' },
        { html: '商用利用条件（プラン・用途による違い）' },
        { html: '人物・著名人・ブランドロゴ・第三者著作物の扱い' },
        { html: 'Midjourney公式利用規約・商用利用ガイドの最新情報' },
        { html: '利用時点での最新の利用条件' },
      ]}
      lastChecked={d?.lastReviewed ?? '2026-06-06'}
      nextCheck={d?.nextReviewDue ?? '2026-07-06'}
      verifiedDate={d?.verifiedAt ?? '2026-06-08'}
      sources={[
        { tag: '料金', label: 'Midjourneyプラン比較（公式）', href: 'https://docs.midjourney.com/hc/en-us/articles/27870484040333-Comparing-Midjourney-Plans' },
        { tag: '規約', label: 'Midjourney利用規約（2026年版・公式）', href: 'https://docs.midjourney.com/hc/en-us/articles/32083055291277-Terms-of-Service' },
        { tag: '商用', label: 'Midjourney商用利用ガイド（公式）', href: 'https://docs.midjourney.com/hc/en-us/articles/27870375276557-Using-Images-Videos-Commercially' },
        { tag: '公式', label: 'Midjourney公式サイト', href: 'https://www.midjourney.com' },
      ]}
      faqs={[
        { q: 'Midjourneyは無料で使えますか？', a: '現在は無料プランが提供されていない場合があります（2024年末に廃止されたとされています）。最新の状況は公式サイトでご確認ください。' },
        { q: 'Midjourneyは商用利用できますか？', a: '公式情報上、有料プランでは商用利用ができる場合があります。ただし年間総収益100万ドル超の企業はPro/Megaプランへのアップグレードが必要とされています。利用前に最新の公式利用規約をご確認ください。' },
        { q: 'Midjourneyは日本語で使えますか？', a: 'UIは英語のみです。日本語プロンプトを一部理解する場合がありますが、英語と比べて精度が低い傾向があります。' },
        { q: 'Midjourneyに透かしは入りますか？', a: '公式情報上、有料プランでは透かしが入らない場合があります。最新の条件は公式サイトでご確認ください。' },
