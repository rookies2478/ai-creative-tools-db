---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'nightcafe');
const d = entry?.data;
const toolSlug = 'nightcafe';
const sampleImage = generatedImages.find((img) =>
  img.sampleType === 'tool-output' &&
  img.sourceToolSlug === toolSlug &&
  img.isSameToolAsPage === true &&
  img.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'NightCafe', item: 'https://aicreative-db.com/tools/nightcafe/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'NightCafe',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: '複数の画像生成モデルを使ってAIアートを作成・共有できるコミュニティ型のAI画像生成ツール。',
    url: 'https://creator.nightcafe.studio/',
  },
]);
---

