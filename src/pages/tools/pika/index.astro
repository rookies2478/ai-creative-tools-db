---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedVideos } from '../../../data/generatedVideos';
import { buildNextReads, buildConditionTags } from '../../../data/toolRelatedLinks';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'pika');
const d = entry?.data;

const pikaSampleVideo = generatedVideos.find(
  (v) =>
    v.pageSlug === 'pika' &&
    v.sampleType === 'tool-video-output' &&
    v.isSameToolAsPage
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Pika', item: 'https://aicreative-db.com/tools/pika/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Pika',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'PikaはAI動画生成ツール。テキスト・画像から動画を生成でき、Pikaframes機能で最大25秒まで対応。無料プランは商用不可・透かしあり。有料プランから商用利用可とされる。',
    url: 'https://pika.art',
  },
]);
---

