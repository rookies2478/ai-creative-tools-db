---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'pixverse');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'PixVerse', item: 'https://aicreative-db.com/tools/pixverse/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'PixVerse',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'PixVerseはテキスト・画像からAI動画を生成できるサービス。V6モデル搭載で最大15秒の動画生成・extend機能（最大8秒延長）に対応。日本語UIあり・無料枠あり。商用利用には別途認可または商用ライセンスが必要と公式規約に案内されています。',
    url: 'https://pixverse.ai',
  },
]);
---

<BaseLayout
  title="PixVerseとは？料金・無料枠・商用利用の注意点｜AIクリエイティブナビ"
  description="PixVerseのAI動画生成機能、料金プラン・無料枠、商用利用条件、透かし、使い方・画像から動画（image-to-video）の確認ポイントを整理。V6モデル搭載・日本語UI対応。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/pixverse/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">PixVerse</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage japanBilling={d?.japanBilling}
      toolName="PixVerse"
      category="AI動画生成"
      checkedDate={d?.lastReviewed ?? '2026-06-05'}
