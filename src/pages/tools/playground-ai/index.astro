      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: '有料プランで案内あり' } },
        { lb: '無料枠', badge: { s: 'cond', label: '非商用のみ' } },
        { lb: '料金目安', text: '$12/月〜（Pro・年払い）', mono: true },
        { lb: '透かし', badge: { s: 'cond', label: '要公式確認' } },
        { lb: '日本語UI', badge: { s: 'cond', label: '要公式確認' } },
      ]}
      primaryCta={{ label: '公式サイトで確認する', href: 'https://playground.com/' }}
      secondaryCta={{ label: '料金プラン（公式）', href: 'https://playground.com/design/pricing' }}
