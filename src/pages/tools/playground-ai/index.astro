---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'playground-ai');
const d = entry?.data;
const toolSlug = 'playground-ai';
const sampleImage = generatedImages.find((img) =>
  img.sampleType === 'tool-output' &&
  img.sourceToolSlug === toolSlug &&
  img.isSameToolAsPage === true &&
  img.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Playground AI', item: 'https://aicreative-db.com/tools/playground-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Playground AI',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: '画像生成・画像編集・デザイン制作をまとめて行えるAIグラフィックデザインツール。無料枠から始められる。',
    url: 'https://playground.com/',
  },
]);
---

<BaseLayout
  title="Playground AIの商用利用・料金・無料枠まとめ｜AI生成ツールDB"
  description="Playground AIの商用利用条件・料金プラン・無料枠・透かし・日本語対応を公式情報をもとに整理。無料プランは非商用利用のみ。商用利用には有料プランが必要とされています。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/playground-ai/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Playground AI</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      sampleImage={sampleImage}
      toolName="Playground AI"
      category="AI画像生成・編集"
      checkedDate={d?.lastReviewed ?? '2026-06-06'}
