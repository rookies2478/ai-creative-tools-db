      lastChecked={d?.lastReviewed ?? '2026-06-05'}
      nextCheck={d?.nextReviewDue ?? '2026-07-05'}
      verifiedDate={d?.verifiedAt ?? '2026-06-08'}
      sources={[
        { tag: '料金', label: 'Runway 料金プラン（公式）', href: 'https://runwayml.com/pricing/' },
        { tag: '利用規約', label: 'Runway Terms of Use（公式）', href: 'https://runwayml.com/terms-of-use/' },
        { tag: '公式', label: 'Runway 公式サイト', href: 'https://runwayml.com' },
      ]}
      faqs={[
        { q: 'Runwayは無料で使えますか？', a: '初回サインアップ時に125クレジットが付与される無料プランがあります。ただし使い切った後は有料プランへの移行またはクレジット購入が必要です。無料プランでは透かしが付与されます。' },
        { q: 'Runwayは商用利用できますか？', a: '全プランで生成動画の商用利用制限はないとされていますが、第三者の権利侵害・禁止コンテンツの生成は禁止されています。商用利用前は必ず最新の公式利用規約をご確認ください。このページは法的助言ではありません。' },
        { q: 'Runwayは日本語で使えますか？', a: 'UIは英語のみです。日本語プロンプトは一部対応していますが、英語プロンプトの方が精度が高い傾向があります。' },
        { q: '透かしはありますか？', a: '無料プランでは生成動画に透かしが付与されるとされています。有料プランでは透かしなしとされていますが、最新仕様は公式サイトでご確認ください。' },
        { q: 'Gen-4とは何ですか？', a: 'RunwayのAI動画生成エンジンの最新世代モデルです。テキスト・画像からの動画生成品質向上・複雑なシーン対応が特徴とされています。詳細は公式サイトをご確認ください。' },
        { q: 'APIは利用できますか？', a: 'RunwayはAPI提供を行っており、動画生成機能をサービスやプロダクトに組み込むことができます。API料金・仕様は公式ドキュメントをご確認ください。' },
      ]}
      relatedTools={[
        { name: 'Kling AI', slug: 'kling-ai', initial: 'K', cat: '動画生成', badges: [{ s: 'paid', label: '商用：有料のみ' }, { s: 'cond', label: '無料：1日66cr' }, { s: 'cond', label: '日本語UI：部分' }], platforms: ['Web'], official: 'https://klingai.com' },
        { name: 'Luma AI', slug: 'luma-ai', initial: 'L', cat: '動画生成', badges: [{ s: 'paid', label: '商用：Plus以上' }, { s: 'cond', label: '無料：限定' }, { s: 'na', label: '日本語UI：非対応' }], platforms: ['Web', 'API'], official: 'https://lumalabs.ai/' },
