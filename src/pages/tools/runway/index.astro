---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedVideos } from '../../../data/generatedVideos';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'runway');
const d = entry?.data;

const runwaySampleVideo = generatedVideos.find(
  (v) => v.pageSlug === 'runway' && v.sampleType === 'tool-video-output' && v.isSameToolAsPage
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Runway', item: 'https://aicreative-db.com/tools/runway/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Runway',
    operatingSystem: 'Web, API',
    applicationCategory: 'VideoApplication',
    description: 'RunwayはAI動画生成・映像編集ツール。Gen-4モデルによるテキスト・画像→動画生成、動画延長、背景除去などを提供する。クリエイター・映像制作者向けのプロフェッショナルツール。',
    url: 'https://runwayml.com',
  },
]);
---

<BaseLayout
  title="Runwayの商用利用・料金・無料枠まとめ｜AI動画生成ツールDB"
  description="RunwayのAI動画生成における商用利用条件・料金プラン・無料枠・透かし・日本語対応を公式情報をもとに整理。Gen-4モデルの特徴と注意点もまとめ。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/runway/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Runway</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      toolName="Runway"
      category="AI動画生成"
      checkedDate={d?.lastReviewed ?? '2026-06-05'}
      headingHtml='Runwayの<span class="hl"><span class="phrase-nowrap">商用利用</span>・料金・無料枠</span>まとめ'
      lead="RunwayはGen-4モデルによるAI動画生成・映像編集ツールです。テキストや画像から動画を生成でき、動画延長・背景除去・APIも提供。映像制作者・クリエイター向けのプロフェッショナルツールとして知られています。無料プランでは125クレジット（初回のみ）が付与されます。商用利用条件は全プランで制限なしとされていますが、第三者の権利等への注意が必要です。"
      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: '条件あり（要確認）' } },
        { lb: '無料枠', badge: { s: 'cond', label: '125クレジット（初回のみ）' } },
        { lb: '料金目安', text: '$12/月〜（年払い）', mono: true },
        { lb: '透かし', badge: { s: 'cond', label: '無料プランあり・有料なし' } },
        { lb: '日本語UI', badge: { s: 'na', label: '非対応' } },
      ]}
      primaryCta={{ label: '公式サイトで確認する', href: 'https://runwayml.com' }}
      secondaryCta={{ label: '料金プランを確認（公式）', href: 'https://runwayml.com/pricing/' }}
      basicInfo={[
        {
          title: '商用利用', badge: { s: 'cond', label: '条件あり（要確認）' }, wide: true,
          sum: '全プランでOutput（生成動画）の商用利用制限はないとされていますが、第三者の権利・禁止コンテンツ等への注意が必要です。',
          det: '公式利用規約では生成コンテンツの商用利用について一定の条件が設けられています。第三者の権利侵害や禁止コンテンツの生成は禁止されています。利用規約は変更される可能性があるため、商用利用前は必ず最新の公式利用規約をご確認ください。',
        },
        {
          title: '無料枠', badge: { s: 'cond', label: '125クレジット（初回のみ）' },
          det: '無料プランでは初回サインアップ時に125クレジットが付与されます。使い切った後は追加クレジットの購入または有料プランへの移行が必要です。無料プランでは透かしが付与されます。',
        },
        {
          title: '最安料金目安', sum: '$12/月（年払い）〜（公式案内）', sumMono: true,
          det: '2026年6月時点の公式案内に基づきます。月払いでは料金が異なる場合があります。プラン内容・料金は変更される可能性があります。最新料金は公式サイトでご確認ください。',
        },
        {
          title: '透かし', badge: { s: 'cond', label: '無料プランあり・有料なし' },
          det: '無料プランでは生成動画に透かしが付与されるとされています。有料プランでは透かしなしとされていますが、最新仕様は公式サイトでご確認ください。',
        },
        {
          title: '日本語対応',
          lang: [
            { label: 'UI', badge: { s: 'na', label: '非対応' } },
            { label: 'プロンプト', badge: { s: 'cond', label: '△ 一部対応' } },
          ],
        },
        { title: '対応環境', feats: ['Web', 'API'] },
        { title: '主な機能', wide: true, feats: ['テキスト→動画', '画像→動画', '動画延長', '背景除去', 'API'] },
      ]}
      useCases={[
        '<b>短尺動画・広告素材</b>のAI生成（テキスト・画像→動画）',
        '<b>映像の動画延長</b>（VideoExtend機能を活用）',
        '<b>背景除去・映像合成</b>のプロフェッショナル用途',
        '<b>API連携</b>によるプロダクト・サービスへの動画生成組み込み',
      ]}
      pros={[
        'Gen-4モデルによる高品質な動画生成',
        '動画延長・背景除去など映像編集機能も充実',
        'API提供でプロダクトへの組み込みも可能',
        '映像クリエイター向けの機能セットが豊富',
      ]}
      cons={[
        '無料枠は125クレジット（初回のみ）と限定的',
        '日本語UIに非対応',
        '料金はAI動画生成ツールの中でやや高め',
        '日本語プロンプトは部分対応にとどまる',
      ]}
      limits={[
        '無料プランでは透かしが付与される',
        '商用利用条件は利用規約の確認が必要',
        '第三者の権利侵害・禁止コンテンツの生成は禁止',
        'クレジット制のため生成量に応じてコストが増加する',
      ]}
      quickTable={{
        kind: 'spec',
        rows: [
          [{ html: 'カテゴリ', rk: true }, { html: 'AI動画生成' }],
          [{ html: '無料枠', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>125クレジット（初回のみ）</span><br>使い切り後は有料プランまたはクレジット購入が必要。透かしあり。' }],
          [{ html: '最安料金', rk: true }, { html: '<span class="mono">$12/月〜（年払い）</span><br>月払いでは料金が異なる場合あり。最新料金は公式サイトで確認。' }],
          [{ html: '商用利用', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>条件あり（要確認）</span><br>全プランで制限なしとされるが第三者権利等への注意が必要。最新利用規約を確認してください。' }],
          [{ html: '透かし', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>無料プランあり・有料なし</span><br>有料プランでは透かしなしとされています。' }],
          [{ html: '日本語UI', rk: true }, { html: '<span class="tdp-st na sm"><span class="d"></span>非対応</span>' }],
          [{ html: '日本語プロンプト', rk: true }, { html: '<span class="tdp-st cond sm"><span class="d"></span>△ 一部対応</span><br>英語プロンプトの方が精度が高い傾向あり' }],
          [{ html: '対応環境', rk: true }, { html: 'Web / API' }],
          [{ html: '情報確認日', rk: true }, { html: d?.lastReviewed ?? '2026-06-05', mono: true }],
          [{ html: '公式サイト', rk: true }, { html: '<a href="https://runwayml.com" target="_blank" rel="noopener">公式サイトで確認 ↗</a>' }],
        ],
        note: '※ 料金・クレジット数・商用利用条件は変更される可能性があります。最新情報は必ず公式サイトでご確認ください。',
      }}
      about={[
        'RunwayはAI動画生成・映像編集ツールとして映像クリエイターやコンテンツ制作者から注目を集めています。Gen-4（旧Gen-2から進化）モデルによるテキスト→動画・画像→動画生成を中心に、動画延長・背景除去・インペインティングなど映像編集機能も充実しています。',
        'APIも提供されており、プロダクトやサービスへの組み込みも可能です。無料プランは125クレジット（初回のみ）で、有料プランは$12/月〜（年払い）から利用できます（2026年6月時点）。<b>商用利用条件・利用規約は変更される可能性があるため、最新情報は公式サイトでご確認ください。</b>',
      ]}
      aboutMore={{ label: 'AI動画生成ツール一覧で比較する →', href: '/categories/video-generation/' }}
      pricing={{
        table: {
          kind: 'cmp',
          headers: ['プラン', '料金', 'クレジット目安'],
          rows: [
            [{ html: '無料', rk: true }, { html: '無料' }, { html: '125クレジット（初回のみ）' }],
            [{ html: 'Standard', rk: true }, { html: '$12/月〜（年払い）', mono: true }, { html: '要公式確認' }],
            [{ html: 'Pro以上', rk: true }, { html: '要公式確認', mono: true }, { html: '要公式確認' }],
          ],
        },
        notes: [
          '料金・クレジット数は2026年6月時点の公式案内に基づきます',
          '月払いでは料金が異なる場合があります',
          '<b>最新料金は公式サイトでご確認ください</b>',
        ],
      }}
      usagePolicy={d?.usagePolicy as any}
      watermarkRaw={d?.watermark}
      watermarkConditionRaw={d?.watermarkCondition}
      commercial={{
        lead: '全プランでOutput（生成動画）の商用利用制限はないとされていますが、利用規約への準拠・第三者の権利侵害回避が必要です。商用利用前は必ず最新の公式利用規約をご確認ください。',
        points: [
          '全プランで生成動画の商用利用制限はないとされています（2026年6月時点）',
          '第三者の著作権・肖像権等の権利侵害は禁止されています',
          '禁止コンテンツの生成・利用は規約違反となります',
          '利用規約は変更される可能性があります',
        ],
        disclaimer: 'このページは情報提供を目的としており、法的助言ではありません。商用利用前は必ず最新のRunway公式利用規約をご確認ください。',
        more: { label: '商用利用・著作権の注意点ガイド →', href: '/guides/commercial-use-copyright/' },
      }}
      integrationTitle="Runway Gen-4について"
      integration="RunwayのGen-4モデルは2025〜2026年にかけてリリースされた最新世代のAI動画生成モデルです。テキスト・画像からの動画生成品質が向上し、よりリアルな動きや複雑なシーン生成に対応しているとされています。動画の長さ・解像度・クレジット消費量はプランや設定によって異なるため、最新仕様は公式サイトでご確認ください。"
      whoFor={[
        '映像クリエイター・動画制作者でAI生成動画を活用したい人',
        '短尺広告・プロモーション動画の素材をAI生成したい人',
        'APIで動画生成をサービスに組み込みたい開発者',
        '動画延長・背景除去などプロ向け機能を求める人',
      ]}
      whoNot={[
        '無料で大量に動画生成したい人（無料枠は初回125クレジットのみ）',
        '日本語UIで操作したい人',
        'コスト重視で最安ツールを探している人',
        '長尺・高解像度動画を大量生成したい人',
      ]}
      selectTable={{
        kind: 'cmp',
        headers: ['ツール', '向いているケース'],
        rows: [
          [{ html: 'Runway（このページ）', rk: true, me: true }, { html: '映像編集機能・APIも活用したプロ向けAI動画生成' }],
          [{ html: '<a href="/tools/kling-ai/">Kling AI</a>', rk: true }, { html: 'コスト重視・日本語プロンプトで動画生成したい場合' }],
          [{ html: '<a href="/tools/luma-ai/">Luma AI</a>', rk: true }, { html: '長尺動画生成・Plusプランで商用利用を想定する場合' }],
          [{ html: '<a href="/tools/pika/">Pika</a>', rk: true }, { html: '手軽に動画生成を試したい・低コストで始めたい場合' }],
          [{ html: '<a href="/tools/hailuo-ai/">Hailuo AI</a>', rk: true }, { html: '長尺動画延長（最大3分）を試したい場合（利用規約要確認）' }],
        ],
      }}
      versusTable={{
        kind: 'cmp',
        headers: ['比較軸', 'Runway', 'Kling AI', 'Luma AI', 'Pika', 'Hailuo AI'],
        rows: [
          [{ html: '最大動画長', rk: true }, { html: '要公式確認', me: true }, { html: '10秒/クリップ' }, { html: '最大20秒' }, { html: '最大25秒' }, { html: '最大10秒' }],
          [{ html: '商用利用', rk: true }, { html: '全プラン・条件あり', me: true }, { html: '有料プランのみ' }, { html: 'Plus以上' }, { html: '有料プランで可' }, { html: 'Standard以上' }],
          [{ html: '透かし（無料）', rk: true }, { html: 'あり', me: true }, { html: 'あり' }, { html: 'あり' }, { html: 'あり' }, { html: 'あり' }],
          [{ html: '日本語UI', rk: true }, { html: '非対応', me: true }, { html: '部分対応' }, { html: '非対応' }, { html: '部分対応' }, { html: '非対応' }],
          [{ html: '無料枠', rk: true }, { html: '125cr（初回）', me: true }, { html: '1日66cr' }, { html: '限定クレジット' }, { html: '月80cr' }, { html: '生成回数制限' }],
        ],
        note: '※ 各ツールの最新条件は公式サイトをご確認ください。',
      }}
      language={[
        '<b>日本語UI：</b>非対応。インターフェースは英語のみです',
        '<b>日本語プロンプト：</b>一部対応。英語プロンプトの方が精度が高い傾向があります',
        '日本語ドキュメント：公式ドキュメントは英語中心',
      ]}
      watermark={[
        '無料プランでは生成動画に透かしが付与されるとされています',
        '有料プランでは透かしなしとされていますが、最新仕様は公式サイトでご確認ください',
        '透かしの有無はプラン・設定によって異なる場合があります',
      ]}
      watermarkMore={{ label: '透かしなしツール一覧を見る →', href: '/conditions/no-watermark/' }}
      checklist={[
        { html: '利用プランが有料プランかどうか（無料プランでは透かしあり・商用条件に注意）' },
        { html: '第三者の著作権・肖像権を侵害するコンテンツでないか' },
        { html: '最新のRunway利用規約（Terms of Use）を確認したか' },
        { html: '生成動画に使用する入力画像・映像の権利関係' },
        { html: 'クレジット消費量とコストの見積もり' },
        { html: '公式サイトで最新の商用利用条件を確認したか' },
