</BaseLayout>

<style>
  .tdp-bc {
    padding: 12px 0;
    border-bottom: 1px solid var(--line, #E3E2D9);
    background: var(--surface, #fff);
  }
  .tdp-bc .wrap {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    color: var(--muted, #6A7180);
  }
  .tdp-bc a { color: var(--muted, #6A7180); text-decoration: none; }
  .tdp-bc a:hover { text-decoration: underline; }
  .tdp-bc .sep { color: var(--faint, #98A0AD); }
  .tdp-bc .cur { color: var(--ink-soft, #3A3E47); font-weight: 600; }
  .tdp-wrap { max-width: 1080px; margin: 0 auto; padding: 0 28px; }
  @media (max-width: 720px) { .tdp-wrap { padding: 0 18px; } }
</style>
