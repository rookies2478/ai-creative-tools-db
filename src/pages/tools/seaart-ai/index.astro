---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'seaart-ai');
const d = entry?.data;
const toolSlug = 'seaart-ai';
const sampleImage = generatedImages.find((img) =>
  img.sampleType === 'tool-output' &&
  img.sourceToolSlug === toolSlug &&
  img.isSameToolAsPage === true &&
  img.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'SeaArt AI', item: 'https://aicreative-db.com/tools/seaart-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'SeaArt AI',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: '画像生成・画像編集・キャラクター作成・動画生成などを含むクリエイティブAIプラットフォーム。日本語UI対応でアニメ風・イラスト系の制作と相性がよい。',
    url: 'https://www.seaart.ai/ja',
  },
]);
---

<BaseLayout
  title="SeaArt AIの商用利用・料金・無料枠まとめ｜AI生成ツールDB"
  description="SeaArt AIの商用利用条件・料金プラン・無料枠・透かし・日本語対応状況を、公式情報をもとに整理しています。アニメ・イラスト系制作に向いた多機能AIプラットフォームの特徴を解説。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/seaart-ai/"
  ogType="article"
  jsonLd={jsonLd}
