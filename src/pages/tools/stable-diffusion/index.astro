---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';
import { buildNextReads, buildConditionTags } from '../../../data/toolRelatedLinks';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'stable-diffusion');
const d = entry?.data;
const toolSlug = 'stable-diffusion';
const toolOutputBase = (image: import('../../../data/generatedImages').GeneratedImage) =>
  image.sampleType === 'tool-output' &&
  image.sourceToolSlug === toolSlug &&
  image.isSameToolAsPage === true;
const sampleImage = generatedImages.find((image) =>
  toolOutputBase(image) && image.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Stable Diffusion', item: 'https://aicreative-db.com/tools/stable-diffusion/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Stable Diffusion',
    operatingSystem: 'Windows, Mac, Linux, API',
    applicationCategory: 'DesignApplication',
    description: 'Stability AIが公開したオープンソースのAI画像生成モデル。ローカル環境で無料実行でき、高度なカスタマイズが可能。',
    url: 'https://stability.ai',
  },
]);
