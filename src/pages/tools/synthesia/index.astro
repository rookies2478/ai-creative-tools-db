---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'synthesia');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Synthesia', item: 'https://aicreative-db.com/tools/synthesia/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Synthesia',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'Synthesiaは240以上のAIアバターと1000以上のAI音声、160以上の言語対応でテキストから動画を生成できるビジネス向けAI動画生成ツール。研修・マーケティング・社内コミュニケーション向けの動画制作に対応。生成動画の権利は組織に帰属するとされ、商用利用条件は公式Termsの確認が必要。',
    url: 'https://www.synthesia.io/',
  },
]);
---

<BaseLayout
  title="Synthesiaとは？AIアバター動画生成ツールの特徴・料金・商用利用を解説"
  description="Synthesiaは、AIアバターやAI音声、翻訳、自動字幕を使って研修・マーケティング・社内向け動画を作成できるAI動画生成ツールです。料金・無料プラン・商用利用・透かし・法人向けセキュリティの確認ポイントを整理します。"
  canonicalPath="/tools/synthesia/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Synthesia</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      toolName="Synthesia"
      category="AIアバター動画"
      checkedDate={d?.lastReviewed ?? '2026-07-05'}
      headingHtml='Synthesia（シンセシア）'
      lead="Synthesiaは、テキストからAIアバターが話す動画を生成できる、ビジネス向けのAI動画生成プラットフォームです。AIアバター、AI音声、翻訳、自動字幕、ブランド管理機能などを使い、研修・マーケティング・社内コミュニケーション向けの動画制作に活用できます。<b>生成動画の権利は個人ではなく組織（契約主体）に帰属するとされており、商用利用の可否や条件は利用前に公式規約の確認が必要です。</b>"
      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: 'プランにより異なる（要確認）' } },
        { lb: '無料枠', badge: { s: 'cond', label: 'あり（透かし・分数制限）' } },
        { lb: '料金目安', text: '要確認（公式Pricing参照）', mono: true },
        { lb: '透かし', badge: { s: 'cond', label: 'Basicあり・有料は要確認' } },
        { lb: '日本語UI', badge: { s: 'cond', label: '不明（要確認）' } },
        { lb: '入力素材', badge: { s: 'cond', label: '注意あり（肖像権・音声権）' } },
      ]}
      primaryCta={{ label: '公式サイトで最新の料金・機能を確認する', href: 'https://www.synthesia.io/' }}
      secondaryCta={{ label: '料金プランを確認（公式）', href: 'https://www.synthesia.io/pricing' }}
      basicInfo={[
        {
          title: '商用利用', badge: { s: 'cond', label: 'プランにより異なる（要確認）' }, wide: true,
          sum: '生成動画の権利は個人ではなく組織（契約主体）に帰属するとされています。商用利用の条件はプラン・契約内容によって異なるため、<b>Customer Terms / User Terms / Acceptable Use Policyなど最新の公式規約を必ず確認してください。</b>人物アバター・音声を扱う場合は本人同意や第三者権利の確認も必要です。',
          det: 'Synthesiaはアバター・音声を扱うサービスのため、商用利用時は出力条件に加えて肖像権・音声権・なりすまし禁止事項の確認が重要です。このページは法的助言ではありません。',
        },
        {
          title: '無料枠', badge: { s: 'cond', label: 'あり（透かし・分数制限）' },
          det: 'Basic（無料）プランがあり、クレジットカード不要で試用できるとされています。ただし月10分までの制限やロゴ（透かし）があります。詳細は公式サイトでご確認ください。',
        },
        {
          title: '最安料金目安', sum: '要確認（公式Pricing参照）', sumMono: true,
          det: 'Basic / Starter / Creator / Enterpriseなどのプランがあるとされていますが、料金は変更される場合があります。最新のプラン内容は必ず公式サイトでご確認ください。',
        },
        {
          title: '透かし', badge: { s: 'cond', label: 'Basicあり・有料は要確認' },
          det: 'Basic（無料）プランではロゴ（透かし）が付与されます。Starter以上のプランではロゴ削除機能があるとされていますが、最新仕様は公式サイトでご確認ください。',
        },
        {
          title: '日本語対応',
          lang: [
            { label: 'UI', badge: { s: 'cond', label: '不明（要確認）' } },
            { label: 'プロンプト', badge: { s: 'cond', label: '不明（要確認）' } },
          ],
        },
        { title: '対応環境', feats: ['Web'] },
        { title: '主な機能', wide: true, feats: ['AIアバター・AI音声（テキストから動画）', 'ワンクリック翻訳・自動字幕', 'ブランドキット・チーム管理', '研修・マーケティング・社内コミュニケーション向け'] },
      ]}
      useCases={[
        '<b>研修・eラーニング向けのアバター解説動画</b>を作りたい場合',
        '<b>翻訳・自動字幕を使った多言語マーケティング動画</b>の展開',
        '<b>社内コミュニケーション動画</b>や製品説明動画の制作',
      ]}
      pros={[
        '240以上のAIアバターと1000以上のAI音声、160以上の言語に対応',
        'テキストから動画生成・ワンクリック翻訳・自動字幕に対応',
        'ブランドキットやチーム管理など法人向けの運用機能がある',
        '研修・eラーニング・社内コミュニケーション動画に向いている',
        'Enterprise向けにセキュリティ・認証・管理機能の確認先がある',
      ]}
      cons={[
        'Basic無料枠は分数・透かしなどの制限がある',
        '日本語UIの対応状況は公式情報で明確に確認できない',
        '生成動画の権利は組織（契約主体）に帰属するとされ、個人利用の位置づけが分かりにくい',
