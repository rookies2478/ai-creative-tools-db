      specs={[
        { lb: '商用利用', badge: { s: 'cond', label: '条件あり（モデル依存）' } },
        { lb: '無料枠', badge: { s: 'ok', label: '無料利用枠あり' } },
        { lb: '料金目安', text: '無料〜Proプラン（公式確認）', mono: true },
