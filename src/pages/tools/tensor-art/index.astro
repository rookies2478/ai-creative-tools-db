---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';
import { generatedImages } from '../../../data/generatedImages';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'tensor-art');
const d = entry?.data;
const toolSlug = 'tensor-art';
const sampleImage = generatedImages.find((img) =>
  img.sampleType === 'tool-output' &&
  img.sourceToolSlug === toolSlug &&
  img.isSameToolAsPage === true &&
  img.promptVersion === 'image-tool-benchmark-v1'
) ?? null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Tensor.Art', item: 'https://aicreative-db.com/tools/tensor-art/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Tensor.Art',
    operatingSystem: 'Web',
    applicationCategory: 'DesignApplication',
    description: 'Stable Diffusion系モデル・LoRA・Checkpoint・Workflowを活用してブラウザ上で画像生成できるコミュニティ型AI画像生成プラットフォーム。',
    url: 'https://tensor.art/',
  },
]);
---

<BaseLayout
  title="Tensor.Artの商用利用・料金・無料枠まとめ｜AI生成ツールDB"
  description="Tensor.ArtのSD系モデル・LoRA活用・商用利用条件・料金プラン・無料枠を公式情報をもとに整理。モデルごとのライセンス確認の重要性も解説。最新情報は公式サイトをご確認ください。"
  canonicalPath="/tools/tensor-art/"
  ogType="article"
  jsonLd={jsonLd}
>

  <nav class="tdp-bc" aria-label="パンくずリスト">
    <div class="wrap">
      <a href="/">トップ</a>
      <span class="sep">/</span>
      <a href="/tools/">ツール一覧</a>
      <span class="sep">/</span>
      <span class="cur">Tensor.Art</span>
    </div>
  </nav>

  <div class="tdp-wrap">
    <ToolDetailPage
      sampleImage={sampleImage}
      toolName="Tensor.Art"
      category="AI画像生成（コミュニティ型）"
      checkedDate={d?.lastReviewed ?? '2026-05-14'}
      headingHtml='Tensor.Artの<span class="hl"><span class="phrase-nowrap">商用利用</span>・料金・無料枠</span>まとめ'
