---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolDetailPage from '../../../components/ToolDetailPage.astro';

const tools = await getCollection('tools');
const entry = tools.find((t) => t.slug === 'vidu-ai');
const d = entry?.data;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'トップ', item: 'https://aicreative-db.com/' },
      { '@type': 'ListItem', position: 2, name: 'ツール一覧', item: 'https://aicreative-db.com/tools/' },
      { '@type': 'ListItem', position: 3, name: 'Vidu AI', item: 'https://aicreative-db.com/tools/vidu-ai/' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Vidu AI',
    operatingSystem: 'Web',
    applicationCategory: 'VideoApplication',
    description: 'Vidu AIは中国Shengshu Technologyが開発したAI動画生成サービス。テキスト・画像・最大7枚の参照画像から動画を生成。アニメ動画生成・音効生成に対応。有料プランで商用利用が公式利用規約で明記されているが、ユーザー投稿コンテンツへの広範なライセンス（取消不能）にも注意が必要。',
    url: 'https://www.vidu.com',
  },
]);
