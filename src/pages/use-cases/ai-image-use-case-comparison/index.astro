<script>
  document.querySelectorAll<HTMLElement>('[data-cp]').forEach((root) => {
    const items = Array.from(root.querySelectorAll<HTMLElement>('.faq-item'));
    items.forEach((item) => {
      const q = item.querySelector<HTMLElement>('.faq-q')!;
      const a = item.querySelector<HTMLElement>('.faq-a')!;
      q.addEventListener('click', () => {
        const open = item.getAttribute('aria-expanded') === 'true';
        items.forEach((o) => { o.setAttribute('aria-expanded', 'false'); const oa = o.querySelector<HTMLElement>('.faq-a')!; if (oa) oa.style.maxHeight = ''; });
        if (!open) { item.setAttribute('aria-expanded', 'true'); a.style.maxHeight = a.scrollHeight + 'px'; }
      });
    });
  });
</script>
