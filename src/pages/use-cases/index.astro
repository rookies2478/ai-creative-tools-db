---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import UseCasesIndex from '../../components/UseCasesIndex.astro';

const allTools = await getCollection('tools');
function countByTag(tag: string): number {
  return allTools.filter((t) => (t.data.useCases ?? []).includes(tag as never)).length;
}
const toolCounts: Record<string, number> = {
  '/use-cases/youtube-thumbnail/': countByTag('youtube'),
  '/use-cases/sns-post-image/':    countByTag('sns'),
  '/use-cases/ad-banner/':         countByTag('ad_creative'),
  '/use-cases/blog-eyecatch/':     countByTag('blog'),
  '/use-cases/ec-product-image/':  countByTag('product_image'),
  '/use-cases/anime-illustration/': countByTag('illustration'),
  '/use-cases/sns-blog-eyecatch/': allTools.filter((t) => {
    const uc = (t.data.useCases ?? []) as string[];
    return uc.includes('sns') || uc.includes('blog');
  }).length,
};
---

<BaseLayout
  title="目的別にAIツールを探す｜AIクリエイティブナビ"
  description="YouTubeサムネイル、SNS投稿、広告バナー、EC商品画像、ブログアイキャッチなど、制作目的別にAI画像生成・AI動画生成ツールを探せる用途別記事一覧です。"
  canonicalPath="/use-cases/"
>
  <div class="mx-auto max-w-5xl px-6">

    <nav aria-label="パンくずリスト" class="pt-6 mb-4 text-sm text-slate-500">
      <a href="/" class="hover:underline">トップ</a>
      <span class="mx-1" aria-hidden="true">/</span>
      <span aria-current="page">用途別記事一覧</span>
    </nav>

    <UseCasesIndex
      headingHtml='目的別に<span class="hl">AIツール</span>を探す'
      toolCounts={toolCounts}
    />

  </div>
</BaseLayout>
