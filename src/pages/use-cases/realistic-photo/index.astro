  .cp-x .mk { display: inline-flex; width: 24px; height: 24px; border-radius: 50%; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; }
  .cp-x .mk.yes { background: var(--ok-tint); color: var(--ok); }
  .cp-x .mk.cond { background: var(--warn-tint); color: var(--warn); }
  .cp-x .mk.no { background: var(--na-tint); color: var(--na); }
  .cp-x .cp-detail { font-weight: 700; font-size: 12.5px; color: var(--brand-ink); white-space: nowrap; }
