  .cp-x .nc-f p { font-size: 13px; color: var(--ink-soft); line-height: 1.78; }

  .cp-x .warn-card { background: #FFFBEB; border: 1px solid #FDE68A; border-radius: var(--radius-lg); padding: 28px 30px; }
  .cp-x .warn-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px; }
  .cp-x .warn-list li { display: flex; gap: 10px; font-size: 14px; color: #92400E; line-height: 1.7; }
  .cp-x .warn-list li b { font-weight: 700; }
  .cp-x .wi { color: #D97706; flex: none; margin-top: 2px; }
